<ui:FluentWindow x:Class="BombaProMaxWPF.Views.LoginWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:loc="clr-namespace:BombaProMaxWPF.Localization"
                 xmlns:vm="clr-namespace:BombaProMaxWPF.ViewModels"
                 mc:Ignorable="d"
                 Title="{Binding [AppName], Source={x:Static loc:LanguageManager.Instance}}"
                 Height="760" Width="560"
                 MinHeight="640" MinWidth="480"
                 ResizeMode="CanResize"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="None"
                 Background="{DynamicResource NeuBackgroundBrush}"
                 Foreground="{DynamicResource NeuTextPrimaryBrush}">

    <Grid Background="{DynamicResource NeuBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <ui:TitleBar Grid.Row="0"
                     Title="{Binding [AppName], Source={x:Static loc:LanguageManager.Instance}}"
                     Background="{DynamicResource NeuBackgroundBrush}"
                     Foreground="{DynamicResource NeuTextPrimaryBrush}"
                     ShowMaximize="True"
                     ShowMinimize="True"
                     ShowClose="True" />

        <!-- Top toolbar: theme + language (neumorphic raised pill) -->
        <ContentControl Grid.Row="1"
                        Style="{DynamicResource NeuToolbarStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="16,8,16,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border x:Name="LanguagePickerHost"
                        Background="{DynamicResource NeuInputFillBrush}"
                        BorderBrush="{DynamicResource NeuTextSecondaryBrush}"
                        BorderThickness="0"
                        CornerRadius="20"
                        Padding="0,0"
                        Cursor="Hand"
                        MouseLeftButtonUp="LanguagePickerHost_MouseLeftButtonUp">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{DynamicResource NeuTextSecondaryBrush}" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource NeuAccentBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Globe24"
                                       FontSize="18"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource NeuTextPrimaryBrush}"
                                       Margin="4,0,8,0" />
                        <TextBlock Text="{Binding [LanguageLabel], Source={x:Static loc:LanguageManager.Instance}}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Foreground="{DynamicResource NeuTextSecondaryBrush}" />
                        <ComboBox x:Name="LanguageComboBox"
                                  Style="{DynamicResource NeuComboBoxStyle}"
                                  Width="140"
                                  SelectedIndex="0"
                                  SelectionChanged="LanguageComboBox_SelectionChanged">
                            <ComboBoxItem Content="Français" Tag="fr" />
                            <ComboBoxItem Content="العربية" Tag="ar" />
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border Width="1" Margin="16,6"
                        Background="{DynamicResource NeuTextSecondaryBrush}"
                        Opacity="0.3" />

                <ui:SymbolIcon x:Name="ThemeIcon"
                               Symbol="WeatherSunny24"
                               FontSize="18"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource NeuTextPrimaryBrush}"
                               Margin="0,0,8,0" />
                <TextBlock Text="{Binding [ThemeLabel], Source={x:Static loc:LanguageManager.Instance}}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="{DynamicResource NeuTextSecondaryBrush}" />
                <ToggleButton x:Name="ThemeToggle"
                              Style="{DynamicResource NeuToggleSwitchStyle}"
                              Checked="ThemeToggle_Checked"
                              Unchecked="ThemeToggle_Unchecked"
                              VerticalAlignment="Center"
                              Margin="0,0,4,0" />
            </StackPanel>
        </ContentControl>

        <!-- Login card -->
        <Grid Grid.Row="2" Background="{DynamicResource NeuBackgroundBrush}">
            <ContentControl Style="{StaticResource NeuCardStyle}"
                            Width="440"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="32">
                <StackPanel HorizontalAlignment="Stretch">

                    <!-- Logo badge -->
                    <Border Style="{StaticResource NeuLogoBadgeStyle}"
                            Width="200" Height="150"
                            CornerRadius="75"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                        <Image Source="/Logos/BPM.png"
                               Width="230" Height="155"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Text="{Binding [AppName], Source={x:Static loc:LanguageManager.Instance}}"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Foreground="{DynamicResource NeuTextPrimaryBrush}" />

                    <TextBlock Text="{Binding [SignInTitle], Source={x:Static loc:LanguageManager.Instance}}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,4,0,28"
                               Foreground="{DynamicResource NeuTextSecondaryBrush}" />

                    <!-- Email -->
                    <TextBlock Text="{Binding [EmailLabel], Source={x:Static loc:LanguageManager.Instance}}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="2,0,0,8"
                               Foreground="{DynamicResource NeuTextSecondaryBrush}" />
                    <TextBox Style="{StaticResource NeuTextBoxStyle}"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,18" />

                    <!-- Password -->
                    <TextBlock Text="{Binding [PasswordLabel], Source={x:Static loc:LanguageManager.Instance}}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="2,0,0,8"
                               Foreground="{DynamicResource NeuTextSecondaryBrush}" />
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource NeuPasswordBoxStyle}"
                                 PasswordChanged="PasswordBox_PasswordChanged"
                                 Margin="0,0,0,10" />

                    <!-- Forgot link -->
                    <Button Content="{Binding [ForgotPassword], Source={x:Static loc:LanguageManager.Instance}}"
                            Style="{StaticResource NeuLinkButtonStyle}"
                            Command="{Binding ForgotPasswordCommand}"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,16" />

                    <!-- Error banner -->
                    <Border Background="#33D32F2F"
                            CornerRadius="8"
                            Padding="12,8"
                            Margin="0,0,0,12"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#FFE57373"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </Border>

                    <!-- Sign in button -->
                    <Button Content="{Binding [SignInButton], Source={x:Static loc:LanguageManager.Instance}}"
                            Style="{StaticResource NeuButtonStyle}"
                            Command="{Binding SignInCommand}"
                            HorizontalAlignment="Stretch"
                            FontSize="15"
                            Padding="0,14"
                            Margin="0,4,0,0" />

                    <!-- Busy indicator -->
                    <TextBlock Text="{Binding [Connecting], Source={x:Static loc:LanguageManager.Instance}}"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"
                               Foreground="{DynamicResource NeuTextSecondaryBrush}"
                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
            </ContentControl>
        </Grid>
    </Grid>
</ui:FluentWindow>
