<UserControl x:Class="BombaProMaxWPF.Views.DashboardPages.Controls.PumpStatusTile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fc="clr-namespace:BombaProMaxWPF.Models.Forecourt"
             xmlns:loc="clr-namespace:BombaProMaxWPF.Localization"
             x:Name="TileRoot"
             Width="96" Height="104">
    <Border CornerRadius="14"
            Background="{DynamicResource NeuInputFillBrush}"
            BorderBrush="{DynamicResource NeuAccentBrush}"
            BorderThickness="1"
            Opacity="1"
            Padding="10,12">
        <Border.Resources>
            <Style TargetType="TextBlock" x:Key="BadgeText">
                <Setter Property="FontSize" Value="9" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>
        </Border.Resources>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       HorizontalAlignment="Center"
                       FontSize="9" FontWeight="SemiBold"
                       Foreground="{DynamicResource NeuTextSecondaryBrush}"
                       Text="{Binding ElementName=TileRoot, Path=PumpName}" />

            <Ellipse Grid.Row="1"
                     Width="10" Height="10"
                     HorizontalAlignment="Center" VerticalAlignment="Center">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="{DynamicResource NeuTextSecondaryBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=TileRoot, Path=Status}"
                                         Value="{x:Static fc:PumpStatus.InUse}">
                                <Setter Property="Fill" Value="{DynamicResource NeuAccentBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ElementName=TileRoot, Path=Status}"
                                         Value="{x:Static fc:PumpStatus.Check}">
                                <Setter Property="Fill" Value="{DynamicResource NeuWarnBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>

            <TextBlock Grid.Row="2">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource BadgeText}">
                        <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
                        <Setter Property="Text" Value="{Binding [DashIdle], Source={x:Static loc:LanguageManager.Instance}}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=TileRoot, Path=Status}"
                                         Value="{x:Static fc:PumpStatus.InUse}">
                                <Setter Property="Foreground" Value="{DynamicResource NeuAccentBrush}" />
                                <Setter Property="Text" Value="{Binding [DashInUse], Source={x:Static loc:LanguageManager.Instance}}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ElementName=TileRoot, Path=Status}"
                                         Value="{x:Static fc:PumpStatus.Check}">
                                <Setter Property="Foreground" Value="{DynamicResource NeuWarnBrush}" />
                                <Setter Property="Text" Value="{Binding [DashCheck], Source={x:Static loc:LanguageManager.Instance}}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Border>
</UserControl>
