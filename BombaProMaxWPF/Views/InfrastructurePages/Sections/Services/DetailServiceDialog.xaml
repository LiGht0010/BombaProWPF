<ui:FluentWindow x:Class="BombaProMaxWPF.Views.InfrastructurePages.Sections.Services.DetailServiceDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:loc="clr-namespace:BombaProMaxWPF.Localization"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 mc:Ignorable="d"
                 Title="{Binding [DetailSrvTitle], Source={x:Static loc:LanguageManager.Instance}}"
                 Width="520" Height="440"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 WindowBackdropType="None"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource NeuBackgroundBrush}">

    <ui:FluentWindow.Resources>

        <Style x:Key="DlgCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource NeuBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource NeuInputFillBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20,18" />
        </Style>

        <Style x:Key="DlgCardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DlgIconCircleStyle" TargetType="Border">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style x:Key="DetailLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <Style x:Key="DetailValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="DetailAccentValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource NeuJaugAccentBrush}" />
        </Style>

        <Style x:Key="DlgCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource NeuJaugAccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuJaugAccentHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </ui:FluentWindow.Resources>

    <!-- Outer shell card -->
    <Border CornerRadius="14"
            Background="{DynamicResource NeuBackgroundBrush}"
            BorderBrush="{DynamicResource NeuInputFillBrush}"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="24" ShadowDepth="0" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="22,18,18,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Style="{StaticResource DlgCloseButtonStyle}" Click="OnCloseClick">
                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="14" />
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                    <ui:SymbolIcon Symbol="Wrench24"
                                   FontSize="18"
                                   Foreground="{DynamicResource NeuJaugAccentBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Numero}"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="{DynamicResource NeuJaugAccentBrush}" />
                        <TextBlock Text="{Binding [DetailSrvTitle], Source={x:Static loc:LanguageManager.Instance}}"
                                   FontSize="11"
                                   Foreground="{DynamicResource NeuTextSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Scrollable content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,0,18,0">
                <StackPanel>

                    <!-- Card 1: Informations générales -->
                    <Border Style="{StaticResource DlgCardBorderStyle}" Margin="0,8,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Style="{StaticResource DlgIconCircleStyle}">
                                    <ui:SymbolIcon Symbol="Info24" FontSize="14"
                                                   Foreground="{DynamicResource NeuJaugAccentBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{Binding [DetailSrvInfoSection], Source={x:Static loc:LanguageManager.Instance}}"
                                           Style="{StaticResource DlgCardTitleStyle}" />
                            </StackPanel>

                            <!-- Numéro + Catégorie -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding [DetailSrvLabelNumero], Source={x:Static loc:LanguageManager.Instance}}"
                                               Style="{StaticResource DetailLabelStyle}" />
                                    <TextBlock Text="{Binding Numero, TargetNullValue='—'}"
                                               Style="{StaticResource DetailAccentValueStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding [DetailSrvLabelCategorie], Source={x:Static loc:LanguageManager.Instance}}"
                                               Style="{StaticResource DetailLabelStyle}" />
                                    <TextBlock Text="{Binding ServiceCategorieNom, TargetNullValue='—'}"
                                               Style="{StaticResource DetailValueStyle}" />
                                </StackPanel>
                            </Grid>

                            <!-- Description -->
                            <StackPanel>
                                <TextBlock Text="{Binding [DetailSrvLabelDescription], Source={x:Static loc:LanguageManager.Instance}}"
                                           Style="{StaticResource DetailLabelStyle}" />
                                <TextBlock Text="{Binding Description, TargetNullValue='—'}"
                                           Style="{StaticResource DetailValueStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Card 2: Tarification -->
                    <Border Style="{StaticResource DlgCardBorderStyle}" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Style="{StaticResource DlgIconCircleStyle}">
                                    <ui:SymbolIcon Symbol="Money24" FontSize="14"
                                                   Foreground="{DynamicResource NeuJaugAccentBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{Binding [DetailSrvPrixSection], Source={x:Static loc:LanguageManager.Instance}}"
                                           Style="{StaticResource DlgCardTitleStyle}" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="{Binding [DetailSrvLabelPrix], Source={x:Static loc:LanguageManager.Instance}}"
                                           Style="{StaticResource DetailLabelStyle}" />
                                <TextBlock Text="{Binding Prix, StringFormat='{}{0:N2} DH', TargetNullValue='—'}"
                                           Style="{StaticResource DetailAccentValueStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource NeuInputFillBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            Style="{StaticResource DlgSecondaryButtonStyle}"
                            Margin="0,0,10,0"
                            Content="{Binding [DetailSrvCloseButton], Source={x:Static loc:LanguageManager.Instance}}"
                            Click="OnCloseClick" />

                    <Button Grid.Column="2"
                            Style="{StaticResource DlgPrimaryButtonStyle}"
                            Click="OnEditClick">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Edit24" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding [DetailSrvEditButton], Source={x:Static loc:LanguageManager.Instance}, StringFormat='  {0}'}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Border>
</ui:FluentWindow>
