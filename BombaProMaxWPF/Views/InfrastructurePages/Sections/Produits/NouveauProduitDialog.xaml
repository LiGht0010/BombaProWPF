<ui:FluentWindow x:Class="BombaProMaxWPF.Views.InfrastructurePages.Sections.Produits.NouveauProduitDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:loc="clr-namespace:BombaProMaxWPF.Localization"
                 xmlns:vm="clr-namespace:BombaProMaxWPF.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=vm:NouveauProduitViewModel}"
                 Title="{Binding [NouveauProdTitle], Source={x:Static loc:LanguageManager.Instance}}"
                 Width="680" Height="780"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 WindowBackdropType="None"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource NeuBackgroundBrush}">

    <ui:FluentWindow.Resources>

        <Style x:Key="DlgCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource NeuBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource NeuInputFillBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20,18" />
        </Style>

        <Style x:Key="DlgCardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DlgFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="DlgInputBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource NeuInputFillBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinHeight" Value="36" />
        </Style>

        <Style x:Key="DlgInputTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="DlgIconCircleStyle" TargetType="Border">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style x:Key="DlgPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource NeuJaugAccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuJaugAccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Computed value display box (read-only, accent-tinted) -->
        <Style x:Key="DlgComputedBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource NeuJaugAccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>

    </ui:FluentWindow.Resources>

    <!-- Outer shell card -->
    <Border CornerRadius="14"
            Background="{DynamicResource NeuBackgroundBrush}"
            BorderBrush="{DynamicResource NeuInputFillBrush}"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="24" ShadowDepth="0" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- â”€â”€â”€ Header â”€â”€â”€ -->
            <Grid Grid.Row="0" Margin="22,18,18,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource DlgCloseButtonStyle}"
                        Click="OnCancelClick">
                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="14" />
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                    <ui:SymbolIcon Symbol="Box24"
                                   FontSize="18"
                                   Foreground="{DynamicResource NeuJaugAccentBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                    <TextBlock Text="{Binding [NouveauProdTitle], Source={x:Static loc:LanguageManager.Instance}}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource NeuJaugAccentBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- â”€â”€â”€ Scrollable content â”€â”€â”€ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,0,18,0">
                <StackPanel>

                    <!-- Error banner -->
                    <Border Background="#FFEED3D3"
                            CornerRadius="8"
                            Padding="14,10"
                            Margin="0,8,0,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" Value="Visible">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#FF8B0000"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- â”€â”€ Card 1: Informations gÃ©nÃ©rales â”€â”€ -->
                    <Border Style="{StaticResource DlgCardBorderStyle}" Margin="0,8,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Style="{StaticResource DlgIconCircleStyle}">
                                    <ui:SymbolIcon Symbol="Info24"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource NeuJaugAccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{Binding [NouveauProdInfoSection], Source={x:Static loc:LanguageManager.Instance}}"
                                           Style="{StaticResource DlgCardTitleStyle}" />
                            </StackPanel>

                            <!-- NumÃ©ro + CatÃ©gorie -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding [NouveauProdLabelNumero], Source={x:Static loc:LanguageManager.Instance}}"
                                               Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgInputBorderStyle}">
                                        <TextBox Text="{Binding Numero, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DlgInputTextBoxStyle}" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding [NouveauProdLabelCategorie], Source={x:Static loc:LanguageManager.Instance}}"
                                               Style="{StaticResource DlgFieldLabelStyle}" />
                                    <ComboBox Style="{DynamicResource NeuComboBoxStyle}"
                                              ItemsSource="{Binding Categories}"
                                              SelectedItem="{Binding SelectedCategorie, Mode=TwoWay}"
                                              DisplayMemberPath="Nom" />
                                </StackPanel>
                            </Grid>

                            <!-- Description -->
                            <TextBlock Text="{Binding [NouveauProdLabelDescription], Source={x:Static loc:LanguageManager.Instance}}"
                                       Style="{StaticResource DlgFieldLabelStyle}" />
                            <Border Style="{StaticResource DlgInputBorderStyle}">
                                <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource DlgInputTextBoxStyle}" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- â”€â”€ Card 2: Tarification (auto-calc) â”€â”€ -->
                    <Border Style="{StaticResource DlgCardBorderStyle}" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Style="{StaticResource DlgIconCircleStyle}">
                                    <ui:SymbolIcon Symbol="Money24"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource NeuJaugAccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{Binding [NouveauProdPricingSection], Source={x:Static loc:LanguageManager.Instance}}"
                                           Style="{StaticResource DlgCardTitleStyle}" />
                            </StackPanel>

                            <!-- Row 1: Prix d'achat + Prix HT (inputs) -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding [NouveauProdLabelPrixAchat], Source={x:Static loc:LanguageManager.Instance}}"
                                               Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgInputBorderStyle}">
                                        <TextBox Text="{Binding PrixAchatText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DlgInputTextBoxStyle}" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding [NouveauProdLabelPrixHT], Source={x:Static loc:LanguageManager.Instance}}"
                                               Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgInputBorderStyle}">
                                        <TextBox Text="{Binding PrixHtText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DlgInputTextBoxStyle}" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                            <!-- Row 2: TVA + Prix TTC (both editable) -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding [NouveauProdLabelTVA], Source={x:Static loc:LanguageManager.Instance}}"
                                               Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgInputBorderStyle}">
                                        <TextBox Text="{Binding TvaText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DlgInputTextBoxStyle}" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding [NouveauProdLabelPrixTTC], Source={x:Static loc:LanguageManager.Instance}}"
                                               Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgInputBorderStyle}">
                                        <TextBox Text="{Binding PrixTtcText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DlgInputTextBoxStyle}" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                            <!-- Row 3: Marge DH (computed, read-only) -->
                            <Grid Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="{Binding [NouveauProdLabelMarge], Source={x:Static loc:LanguageManager.Instance}}"
                                               Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgComputedBorderStyle}">
                                        <TextBlock Text="{Binding Marge, StringFormat='{}{0:F2} DH', TargetNullValue='&#x2014; DH'}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource NeuJaugAccentBrush}"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                            <!-- Row 4: Marge % summary pill -->
                            <Border Background="{DynamicResource NeuInputFillBrush}"
                                    CornerRadius="8"
                                    Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ui:SymbolIcon Symbol="ArrowTrending24"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource NeuJaugAccentBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0" />
                                        <TextBlock Text="Marge %"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource NeuTextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding MargePct, StringFormat='{}{0:F1} %', TargetNullValue='&#x2014; %'}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource NeuJaugAccentBrush}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                        </StackPanel>
                    </Border>

                    <!-- â”€â”€ Card 3: Stock â”€â”€ -->
                    <Border Style="{StaticResource DlgCardBorderStyle}" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Style="{StaticResource DlgIconCircleStyle}">
                                    <ui:SymbolIcon Symbol="Stack24"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource NeuJaugAccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{Binding [NouveauProdStockSection], Source={x:Static loc:LanguageManager.Instance}}"
                                           Style="{StaticResource DlgCardTitleStyle}" />
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Stock initial -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding [NouveauProdLabelStock], Source={x:Static loc:LanguageManager.Instance}}"
                                               Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgInputBorderStyle}">
                                        <TextBox Text="{Binding StockText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DlgInputTextBoxStyle}" />
                                    </Border>
                                </StackPanel>

                                <!-- Stock minimum -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding [NouveauProdLabelStockMin], Source={x:Static loc:LanguageManager.Instance}}"
                                               Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgInputBorderStyle}">
                                        <TextBox Text="{Binding StockMinText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DlgInputTextBoxStyle}" />
                                    </Border>
                                </StackPanel>

                                <!-- DÃ©lai livraison -->
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="{Binding [NouveauProdLabelDelai], Source={x:Static loc:LanguageManager.Instance}}"
                                               Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgInputBorderStyle}">
                                        <TextBox Text="{Binding DelaiText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DlgInputTextBoxStyle}" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- â”€â”€â”€ Footer â”€â”€â”€ -->
            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource NeuInputFillBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Error toast (left area) -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource NeuDangerBrush}"
                            Opacity="0.95"
                            CornerRadius="6"
                            Padding="12,6"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="White" />
                    </Border>

                    <Button Grid.Column="1"
                            Style="{StaticResource DlgSecondaryButtonStyle}"
                            Margin="0,0,10,0"
                            Content="{Binding [NouveauProdCancel], Source={x:Static loc:LanguageManager.Instance}}"
                            Click="OnCancelClick" />

                    <Button Grid.Column="2"
                            Style="{StaticResource DlgPrimaryButtonStyle}"
                            IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}"
                            Command="{Binding SaveCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Save24" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding [NouveauProdSave], Source={x:Static loc:LanguageManager.Instance}, StringFormat='  {0}'}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Border>
</ui:FluentWindow>
