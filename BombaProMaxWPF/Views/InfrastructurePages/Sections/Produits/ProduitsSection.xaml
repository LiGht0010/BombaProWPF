<UserControl x:Class="BombaProMaxWPF.Views.InfrastructurePages.Sections.Produits.ProduitsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:BombaProMaxWPF.Localization"
             xmlns:vm="clr-namespace:BombaProMaxWPF.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ProduitsSectionViewModel}"
             Background="Transparent">

    <UserControl.Resources>

        <Style x:Key="ProdIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProdColHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ProdCellTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <DataTemplate x:Key="ProduitRowTemplate" DataType="{x:Type vm:ProduitCardItem}">
            <Border Padding="0,12,0,12"
                    BorderBrush="{DynamicResource NeuInputFillBrush}"
                    BorderThickness="0,0,0,1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="130" />
                    </Grid.ColumnDefinitions>

                    <!-- Numéro badge -->
                    <Border Grid.Column="0" Background="{DynamicResource NeuInputFillBrush}"
                            CornerRadius="6" Padding="8,3" HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding Numero}"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource NeuAccentBrush}" />
                    </Border>

                    <!-- Description -->
                    <TextBlock Grid.Column="1" Text="{Binding Description}"
                               Style="{StaticResource ProdCellTextStyle}"
                               Margin="16,0,8,0" />

                    <!-- Catégorie -->
                    <TextBlock Grid.Column="2" Text="{Binding Categorie}"
                               Style="{StaticResource ProdCellTextStyle}" />

                    <!-- Prix Achat -->
                    <TextBlock Grid.Column="3" Text="{Binding PrixAchatDisplay}"
                               Style="{StaticResource ProdCellTextStyle}" />

                    <!-- Prix TTC -->
                    <TextBlock Grid.Column="4" Text="{Binding PrixTtcDisplay}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource NeuAccentBrush}"
                               Style="{StaticResource ProdCellTextStyle}" />

                    <!-- Marge -->
                    <TextBlock Grid.Column="5" Text="{Binding MargeDisplay}"
                               Style="{StaticResource ProdCellTextStyle}" />

                    <!-- Stock badge -->
                    <Border Grid.Column="6"
                            HorizontalAlignment="Left" VerticalAlignment="Center"
                            CornerRadius="10" Padding="10,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#1F3FD46A" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StockState}" Value="Bas">
                                        <Setter Property="Background" Value="#1FE0B341" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StockState}" Value="Rupture">
                                        <Setter Property="Background" Value="#1FE05555" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#3FD46A" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StockState}" Value="Bas">
                                                <Setter Property="Fill" Value="#E0B341" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StockState}" Value="Rupture">
                                                <Setter Property="Fill" Value="#E05555" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock FontSize="10" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding [ProdBadgeStockOk], Source={x:Static loc:LanguageManager.Instance}}" />
                                        <Setter Property="Foreground" Value="#3FD46A" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StockState}" Value="Bas">
                                                <Setter Property="Text" Value="{Binding [ProdBadgeStockBas], Source={x:Static loc:LanguageManager.Instance}}" />
                                                <Setter Property="Foreground" Value="#E0B341" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StockState}" Value="Rupture">
                                                <Setter Property="Text" Value="{Binding [ProdBadgeRupture], Source={x:Static loc:LanguageManager.Instance}}" />
                                                <Setter Property="Foreground" Value="#E05555" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Actions -->
                    <StackPanel Grid.Column="7" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Style="{StaticResource ProdIconButtonStyle}"
                                ToolTip="{Binding [DetailProdTooltip], Source={x:Static loc:LanguageManager.Instance}}"
                                Command="{Binding DataContext.DetailProduitCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}">
                            <ui:SymbolIcon Symbol="Info24" FontSize="14" />
                        </Button>
                        <Button Style="{StaticResource ProdIconButtonStyle}"
                                Margin="4,0,0,0"
                                ToolTip="{Binding [ProdEditTooltip], Source={x:Static loc:LanguageManager.Instance}}"
                                Command="{Binding DataContext.EditProduitCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}">
                            <ui:SymbolIcon Symbol="Edit24" FontSize="14" />
                        </Button>
                        <Button Style="{StaticResource ProdIconButtonStyle}"
                                Margin="4,0,0,0"
                                ToolTip="{Binding [ProdDeleteTooltip], Source={x:Static loc:LanguageManager.Instance}}"
                                Command="{Binding DataContext.DeleteProduitCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Foreground="{DynamicResource NeuDangerBrush}">
                            <ui:SymbolIcon Symbol="Delete24" FontSize="14" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ─── Header: breadcrumb + Add button ─── -->
        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding [ProdBreadcrumbInfra], Source={x:Static loc:LanguageManager.Instance}}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource NeuAccentBrush}" />
                    <TextBlock Text=" › " FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource NeuTextSecondaryBrush}" />
                    <TextBlock Text="{Binding [ProdBreadcrumbProduits], Source={x:Static loc:LanguageManager.Instance}}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource NeuAccentBrush}" />
                </StackPanel>
                <TextBlock Text="{Binding [ProdPageSubtitle], Source={x:Static loc:LanguageManager.Instance}}"
                           FontSize="13" Margin="0,4,0,0"
                           Foreground="{DynamicResource NeuTextSecondaryBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Style="{StaticResource NeuButtonStyle}"
                                    Padding="16,10"
                                    FontWeight="SemiBold"
                                    Margin="0,0,10,0"
                                    Command="{Binding ManageCategoriesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Tag24" FontSize="16" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding [ProdManageCategoriesButton], Source={x:Static loc:LanguageManager.Instance}}"
                                               Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NeuButtonStyle}"
                                    Background="{DynamicResource NeuAccentBrush}"
                                    Foreground="White"
                                    Padding="16,10"
                                    FontWeight="SemiBold"
                                    Command="{Binding AddProduitCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="AddCircle24" FontSize="16" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding [ProdAddButton], Source={x:Static loc:LanguageManager.Instance}}"
                                               Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
        </Grid>

        <!-- ─── Products table card ─── -->
        <ContentControl Grid.Row="1"
                        Style="{StaticResource NeuDashCardStyle}"
                        Margin="8,0,8,18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Card header -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding [ProdTableTitle], Source={x:Static loc:LanguageManager.Instance}}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource NeuTextPrimaryBrush}" />
                        <TextBlock Text="{Binding [ProdTableSubtitle], Source={x:Static loc:LanguageManager.Instance}}"
                                   FontSize="11" Margin="0,2,0,0"
                                   Foreground="{DynamicResource NeuTextSecondaryBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Count badge -->
                        <Border Background="{DynamicResource NeuInputFillBrush}"
                                CornerRadius="10" Padding="12,5" Margin="0,0,12,0">
                            <TextBlock FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource NeuAccentBrush}">
                                <Run Text="{Binding Produits.Count, Mode=OneWay}" />
                                <Run Text=" " />
                                <Run Text="{Binding [ProdCountBadge], Source={x:Static loc:LanguageManager.Instance}, Mode=OneWay}" />
                            </TextBlock>
                        </Border>
                        <!-- Refresh -->
                        <Button Style="{StaticResource NeuButtonStyle}"
                                Padding="10,8"
                                Command="{Binding RefreshCommand}">
                            <ui:SymbolIcon Symbol="ArrowSync24" FontSize="15" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Column headers -->
                <Grid Grid.Row="1" Margin="0,16,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="130" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding [ProdColNumero], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource ProdColHeaderStyle}" />
                    <TextBlock Grid.Column="1" Text="{Binding [ProdColDescription], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource ProdColHeaderStyle}" />
                    <TextBlock Grid.Column="2" Text="{Binding [ProdColCategorie], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource ProdColHeaderStyle}" />
                    <TextBlock Grid.Column="3" Text="{Binding [ProdColPrixAchat], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource ProdColHeaderStyle}" />
                    <TextBlock Grid.Column="4" Text="{Binding [ProdColPrixTTC], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource ProdColHeaderStyle}" />
                    <TextBlock Grid.Column="5" Text="{Binding [ProdColMarge], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource ProdColHeaderStyle}" />
                    <TextBlock Grid.Column="6" Text="{Binding [ProdColStock], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource ProdColHeaderStyle}" />
                    <TextBlock Grid.Column="7" Text="{Binding [ProdColActions], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource ProdColHeaderStyle}" HorizontalAlignment="Center" />
                </Grid>

                <!-- Rows -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <ItemsControl ItemsSource="{Binding Produits}"
                                      ItemTemplate="{StaticResource ProduitRowTemplate}"
                                      AlternationCount="2" />

                        <!-- Loading overlay -->
                        <Border Background="#33000000" CornerRadius="8"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ui:ProgressRing IsIndeterminate="True"
                                             Width="40" Height="40"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Foreground="{DynamicResource NeuAccentBrush}" />
                        </Border>

                        <!-- Empty state -->
                        <TextBlock Text="{Binding [ProdEmpty], Source={x:Static loc:LanguageManager.Instance}}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{DynamicResource NeuTextSecondaryBrush}"
                                   Margin="0,32,0,32">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsLoading}" Value="False" />
                                                <Condition Binding="{Binding Produits.Count}" Value="0" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </ContentControl>

        <!-- ─── Status bar ─── -->
        <Border Grid.Row="2" Margin="8,0,8,0">
            <StackPanel Orientation="Horizontal">
                <!-- Error -->
                <Border Background="#1FE05555" CornerRadius="8" Padding="12,6"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ErrorCircle24" FontSize="14"
                                       Foreground="#E05555" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="12" Foreground="#E05555"
                                   VerticalAlignment="Center" Margin="6,0,0,0" />
                    </StackPanel>
                </Border>
                <!-- Success -->
                <Border Background="#1F3FD46A" CornerRadius="8" Padding="12,6"
                        Visibility="{Binding SuccessMessage, Converter={StaticResource NullToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="14"
                                       Foreground="#3FD46A" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding SuccessMessage}"
                                   FontSize="12" Foreground="#3FD46A"
                                   VerticalAlignment="Center" Margin="6,0,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>

