<ui:FluentWindow x:Class="BombaProMaxWPF.Views.InfrastructurePages.Sections.Produits.GererCategoriesDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:loc="clr-namespace:BombaProMaxWPF.Localization"
                 xmlns:vm="clr-namespace:BombaProMaxWPF.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=vm:GererCategoriesViewModel}"
                 Title="{Binding [CatDlgTitle], Source={x:Static loc:LanguageManager.Instance}}"
                 Width="560" SizeToContent="Height"
                 MaxHeight="720"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 WindowBackdropType="None"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource NeuBackgroundBrush}">

    <ui:FluentWindow.Resources>

        <Style x:Key="DlgCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource NeuJaugAccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuJaugAccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Category row DataTemplate ── -->
        <DataTemplate x:Key="CategorieRowTemplate" DataType="{x:Type vm:CategorieRowItem}">
            <Border Margin="0,0,0,6"
                    Background="{DynamicResource NeuInputFillBrush}"
                    CornerRadius="10"
                    Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- READ mode: dot + label -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Border Width="8" Height="8" CornerRadius="4"
                                Background="{DynamicResource NeuJaugAccentBrush}"
                                Margin="0,0,10,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Nom}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource NeuTextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- EDIT mode: inline TextBox -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource NeuBackgroundBrush}"
                            BorderBrush="{DynamicResource NeuJaugAccentBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBox x:Name="EditBox"
                                 Text="{Binding EditText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource NeuTextPrimaryBrush}"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 VerticalContentAlignment="Center"
                                 KeyDown="EditBox_KeyDown"
                                 Tag="{Binding}" />
                    </Border>

                    <!-- READ actions: Edit + Delete -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Button Style="{StaticResource DlgIconButtonStyle}"
                                ToolTip="{Binding [CatDlgEditTooltip], Source={x:Static loc:LanguageManager.Instance}}"
                                Command="{Binding DataContext.BeginEditCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                CommandParameter="{Binding}">
                            <ui:SymbolIcon Symbol="Edit24" FontSize="15"
                                           Foreground="{DynamicResource NeuTextSecondaryBrush}" />
                        </Button>
                        <Button Style="{StaticResource DlgIconButtonStyle}"
                                Margin="4,0,0,0"
                                ToolTip="{Binding [CatDlgDeleteTooltip], Source={x:Static loc:LanguageManager.Instance}}"
                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                CommandParameter="{Binding}">
                            <ui:SymbolIcon Symbol="Delete24" FontSize="15"
                                           Foreground="{DynamicResource NeuDangerBrush}" />
                        </Button>
                    </StackPanel>

                    <!-- EDIT actions: Save ✓ + Cancel ✗ -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Button Style="{StaticResource DlgIconButtonStyle}"
                                ToolTip="{Binding [CatDlgSaveTooltip], Source={x:Static loc:LanguageManager.Instance}}"
                                Command="{Binding DataContext.CommitEditCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                CommandParameter="{Binding}">
                            <ui:SymbolIcon Symbol="Checkmark24" FontSize="15"
                                           Foreground="{DynamicResource NeuJaugAccentBrush}" />
                        </Button>
                        <Button Style="{StaticResource DlgIconButtonStyle}"
                                Margin="4,0,0,0"
                                ToolTip="{Binding [CatDlgCancelTooltip], Source={x:Static loc:LanguageManager.Instance}}"
                                Command="{Binding DataContext.CancelEditCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                CommandParameter="{Binding}">
                            <ui:SymbolIcon Symbol="Dismiss24" FontSize="15"
                                           Foreground="{DynamicResource NeuTextSecondaryBrush}" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

    </ui:FluentWindow.Resources>

    <!-- Outer shell card -->
    <Border CornerRadius="14"
            Background="{DynamicResource NeuBackgroundBrush}"
            BorderBrush="{DynamicResource NeuInputFillBrush}"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="24" ShadowDepth="0" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ─── Header ─── -->
            <Grid Grid.Row="0" Margin="22,18,18,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource DlgCloseButtonStyle}"
                        Click="OnCloseClick">
                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"
                                   Foreground="{DynamicResource NeuTextSecondaryBrush}" />
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                    <ui:SymbolIcon Symbol="Tag24"
                                   FontSize="18"
                                   Foreground="{DynamicResource NeuJaugAccentBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                    <TextBlock Text="{Binding [CatDlgTitle], Source={x:Static loc:LanguageManager.Instance}}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource NeuJaugAccentBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- ─── Scrollable content ─── -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,0,18,0">
                <StackPanel>

                    <!-- ── Card 1: Nouvelle catégorie ── -->
                    <Border Background="{DynamicResource NeuBackgroundBrush}"
                            BorderBrush="{DynamicResource NeuInputFillBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="20,18"
                            Margin="0,8,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="28" Height="28" CornerRadius="14"
                                        Background="{DynamicResource NeuInputFillBrush}"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0">
                                    <ui:SymbolIcon Symbol="AddCircle24" FontSize="14"
                                                   Foreground="{DynamicResource NeuJaugAccentBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{Binding [CatDlgNewLabel], Source={x:Static loc:LanguageManager.Instance}}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource NeuTextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="{DynamicResource NeuInputFillBrush}"
                                        BorderBrush="{DynamicResource NeuInputFillBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,6"
                                        MinHeight="36">
                                    <TextBox Text="{Binding NewNom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="{DynamicResource NeuTextPrimaryBrush}"
                                             FontSize="13"
                                             VerticalContentAlignment="Center"
                                             ToolTip="{Binding [CatDlgPlaceholder], Source={x:Static loc:LanguageManager.Instance}}"
                                             KeyDown="NewNomBox_KeyDown" />
                                </Border>

                                <Button Grid.Column="2"
                                        Style="{StaticResource DlgPrimaryButtonStyle}"
                                        Content="{Binding [CatDlgAjouter], Source={x:Static loc:LanguageManager.Instance}}"
                                        Command="{Binding AddCommand}" />
                            </Grid>

                            <!-- Error banner -->
                            <Border Background="#1FE05252"
                                    BorderBrush="#E05252"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,8"
                                    Margin="0,10,0,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" Value="Visible">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ErrorCircle24" FontSize="13"
                                                   Foreground="#E05252"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0" />
                                    <TextBlock Text="{Binding ErrorMessage}"
                                               FontSize="12"
                                               Foreground="#E05252"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── Card 2: Catégories existantes ── -->
                    <Border Background="{DynamicResource NeuBackgroundBrush}"
                            BorderBrush="{DynamicResource NeuInputFillBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="20,18"
                            Margin="0,0,0,8">
                        <StackPanel>
                            <!-- Card header + count badge -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Border Width="28" Height="28" CornerRadius="14"
                                            Background="{DynamicResource NeuInputFillBrush}"
                                            VerticalAlignment="Center"
                                            Margin="0,0,10,0">
                                        <ui:SymbolIcon Symbol="Tag24" FontSize="14"
                                                       Foreground="{DynamicResource NeuJaugAccentBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="{Binding [CatDlgExistingLabel], Source={x:Static loc:LanguageManager.Instance}}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource NeuTextPrimaryBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Background="{DynamicResource NeuInputFillBrush}"
                                        CornerRadius="10"
                                        Padding="10,4"
                                        VerticalAlignment="Center">
                                    <TextBlock FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource NeuJaugAccentBrush}"
                                               Text="{Binding Rows.Count}" />
                                </Border>
                            </Grid>

                            <!-- Loading spinner -->
                            <ui:ProgressRing IsIndeterminate="True"
                                             Width="32" Height="32"
                                             HorizontalAlignment="Center"
                                             Foreground="{DynamicResource NeuJaugAccentBrush}"
                                             Margin="0,8">
                                <ui:ProgressRing.Style>
                                    <Style TargetType="ui:ProgressRing">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:ProgressRing.Style>
                            </ui:ProgressRing>

                            <!-- Empty state -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,16">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsLoading}" Value="False" />
                                                    <Condition Binding="{Binding HasRows}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ui:SymbolIcon Symbol="Tag24" FontSize="28"
                                               Foreground="{DynamicResource NeuTextSecondaryBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8" />
                                <TextBlock Text="{Binding [CatDlgEmpty], Source={x:Static loc:LanguageManager.Instance}}"
                                           FontSize="13"
                                           FontStyle="Italic"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource NeuTextSecondaryBrush}" />
                            </StackPanel>

                            <!-- Rows list -->
                            <ScrollViewer MaxHeight="300"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Rows}"
                                              ItemTemplate="{StaticResource CategorieRowTemplate}" />
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ─── Footer ─── -->
            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource NeuInputFillBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               FontSize="11"
                               Foreground="{DynamicResource NeuTextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Text="Appuyez sur Entrée pour ajouter rapidement" />

                    <Button Grid.Column="1"
                            Style="{StaticResource DlgSecondaryButtonStyle}"
                            Content="{Binding [CatDlgFermer], Source={x:Static loc:LanguageManager.Instance}}"
                            Click="OnCloseClick" />
                </Grid>
            </Border>

        </Grid>
    </Border>
</ui:FluentWindow>
