<UserControl x:Class="BombaProMaxWPF.Views.InfrastructurePages.Sections.Pompes.PompesSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:BombaProMaxWPF.Localization"
             Background="Transparent">

    <ContentControl Style="{StaticResource NeuDashCardStyle}">
        <StackPanel>
            <TextBlock Text="{Binding [InfraPompes], Source={x:Static loc:LanguageManager.Instance}}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource NeuTextPrimaryBrush}" />
            <TextBlock Text="{Binding [InfraComingSoon], Source={x:Static loc:LanguageManager.Instance}}"
                       FontSize="13"
                       Margin="0,8,0,0"
                       Foreground="{DynamicResource NeuTextSecondaryBrush}"
                       TextWrapping="Wrap" />
        </StackPanel>
    </ContentControl>
</UserControl>
