<ui:FluentWindow x:Class="BombaProMaxWPF.Views.InfrastructurePages.Sections.Reservoirs.ReservoirDetailsDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:loc="clr-namespace:BombaProMaxWPF.Localization"
                 xmlns:vm="clr-namespace:BombaProMaxWPF.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=vm:ReservoirDetailsViewModel}"
                 Title="{Binding [DetailsResTitle], Source={x:Static loc:LanguageManager.Instance}}"
                 Width="640" Height="720"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 WindowBackdropType="None"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource NeuBackgroundBrush}">

    <ui:FluentWindow.Resources>

        <Style x:Key="DlgCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource NeuBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource NeuInputFillBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20,18" />
        </Style>

        <Style x:Key="DlgCardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DlgFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="DlgReadValueBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MinHeight" Value="36" />
        </Style>

        <Style x:Key="DlgReadValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DlgIconCircleStyle" TargetType="Border">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style x:Key="DlgSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgColHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DlgCellTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />

    </ui:FluentWindow.Resources>

    <!-- Outer drop-shadow wrapper -->
    <Border CornerRadius="14" Background="{DynamicResource NeuBackgroundBrush}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.18" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- title bar -->
                <RowDefinition Height="*" />     <!-- scrollable content -->
                <RowDefinition Height="Auto" />  <!-- footer -->
            </Grid.RowDefinitions>

            <!-- ── TITLE BAR ─────────────────────────────────────────── -->
            <Border Grid.Row="0" Padding="20,16,16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Style="{StaticResource DlgIconCircleStyle}">
                            <ui:SymbolIcon Symbol="Info24" FontSize="14"
                                           Foreground="{DynamicResource NeuJaugAccentBrush}" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding [DetailsResTitle], Source={x:Static loc:LanguageManager.Instance}}"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource NeuTextPrimaryBrush}" />
                            <TextBlock Text="{Binding NumeroDisplay}"
                                       FontSize="11"
                                       Foreground="{DynamicResource NeuTextSecondaryBrush}"
                                       Margin="0,1,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource DlgSecondaryButtonStyle}"
                            Width="32" Height="32" Padding="0"
                            Click="OnCloseClick"
                            VerticalAlignment="Top">
                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="14" />
                    </Button>
                </Grid>
            </Border>

            <!-- ── CONTENT ───────────────────────────────────────────── -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="20,0,20,8">
                <StackPanel>

                    <!-- Loading spinner -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,40,0,0"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                        <ui:ProgressRing IsIndeterminate="True" Width="40" Height="40"
                                         Foreground="{DynamicResource NeuJaugAccentBrush}" />
                        <TextBlock Text="{Binding [DetailsResLoading], Source={x:Static loc:LanguageManager.Instance}}" Margin="0,10,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource NeuTextSecondaryBrush}"
                                   FontSize="12" />
                    </StackPanel>

                    <!-- ── CARD 1: Informations générales ───────────── -->
                    <Border Style="{StaticResource DlgCardBorderStyle}" Margin="0,0,0,12">
                        <!-- Card title -->
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Style="{StaticResource DlgIconCircleStyle}">
                                    <ui:SymbolIcon Symbol="Database24" FontSize="13"
                                                   Foreground="{DynamicResource NeuJaugAccentBrush}" />
                                </Border>
                                <TextBlock Text="{Binding [DetailsResInfoSection], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgCardTitleStyle}" />
                            </StackPanel>

                            <!-- Row 1: Numéro + Produit -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding [DetailsResLabelNumero], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgReadValueBorderStyle}">
                                        <TextBlock Text="{Binding NumeroDisplay}" Style="{StaticResource DlgReadValueTextStyle}" />
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding [DetailsResLabelProduit], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgReadValueBorderStyle}">
                                        <TextBlock Text="{Binding ProduitDisplay}" Style="{StaticResource DlgReadValueTextStyle}" />
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Row 2: Capacité + Niveau actuel -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding [DetailsResLabelCapacite], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgReadValueBorderStyle}">
                                        <TextBlock Text="{Binding CapaciteDisplay}" Style="{StaticResource DlgReadValueTextStyle}" />
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding [DetailsResLabelNiveau], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgReadValueBorderStyle}">
                                        <TextBlock Text="{Binding NiveauDisplay}" Style="{StaticResource DlgReadValueTextStyle}" />
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Row 3: Fabricant + N° de série -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding [DetailsResLabelFabricant], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgReadValueBorderStyle}">
                                        <TextBlock Text="{Binding FabricantDisplay}" Style="{StaticResource DlgReadValueTextStyle}" />
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding [DetailsResLabelNumSerie], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgReadValueBorderStyle}">
                                        <TextBlock Text="{Binding NumeroSerieDisplay}" Style="{StaticResource DlgReadValueTextStyle}" />
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Row 4: Diamètre + Date de création -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding [DetailsResLabelDiametre], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgReadValueBorderStyle}">
                                        <TextBlock Text="{Binding DiametreDisplay}" Style="{StaticResource DlgReadValueTextStyle}" />
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding [DetailsResLabelDateCreation], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgReadValueBorderStyle}">
                                        <TextBlock Text="{Binding DateCreationDisplay}" Style="{StaticResource DlgReadValueTextStyle}" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── CARD 2: Table de calibration ─────────────── -->
                    <Border Style="{StaticResource DlgCardBorderStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <!-- Card title -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Style="{StaticResource DlgIconCircleStyle}">
                                    <ui:SymbolIcon Symbol="DocumentTable24" FontSize="13"
                                                   Foreground="{DynamicResource NeuJaugAccentBrush}" />
                                </Border>
                                <TextBlock Text="{Binding [DetailsResCalibSection], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgCardTitleStyle}" />
                                <!-- Count badge -->
                                <Border Background="{DynamicResource NeuInputFillBrush}"
                                        CornerRadius="10" Padding="8,2"
                                        VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource NeuJaugAccentBrush}">
                                        <Run Text="{Binding CalibrationRows.Count, Mode=OneWay}" />
                                        <Run Text="{Binding [DetailsResCalibLines], Source={x:Static loc:LanguageManager.Instance}, Mode=OneWay}" />
                                    </TextBlock>
                                </Border>
                            </StackPanel>

                            <!-- Empty state -->
                            <TextBlock Text="{Binding [DetailsResEmptyCalib], Source={x:Static loc:LanguageManager.Instance}}"
                                       FontSize="12" FontStyle="Italic"
                                       Padding="0,4"
                                       Foreground="{DynamicResource NeuTextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       Visibility="{Binding HasCalibration, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                            <!-- Voir toutes button -->
                            <Button x:Name="ShowCalibrationTableButton"
                                    HorizontalAlignment="Stretch"
                                    Background="{DynamicResource NeuInputFillBrush}"
                                    BorderThickness="0"
                                    Padding="12,10"
                                    Cursor="Hand"
                                    Visibility="{Binding HasCalibration, Converter={StaticResource BoolToVis}}"
                                    Click="OnShowCalibrationTableClick">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ui:SymbolIcon Symbol="DocumentTable24" FontSize="14"
                                                                   Foreground="{DynamicResource NeuJaugAccentBrush}"
                                                                   Margin="0,0,8,0" />
                                                    <TextBlock FontSize="13" FontWeight="Medium"
                                                               Foreground="{DynamicResource NeuTextPrimaryBrush}"
                                                               VerticalAlignment="Center">
                                                        <Run Text="{Binding [DetailsResVoirCalib], Source={x:Static loc:LanguageManager.Instance}, Mode=OneWay}" />
                                                    </TextBlock>
                                                </StackPanel>
                                                <ui:SymbolIcon Grid.Column="1" Symbol="ChevronRight24" FontSize="13"
                                                               Foreground="{DynamicResource NeuTextSecondaryBrush}" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuJaugAccentBrush}" />
                                                <Setter TargetName="bd" Property="Opacity" Value="0.9" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- ── CARD 3: Jaugeages récents ─────────────────── -->
                    <Border Style="{StaticResource DlgCardBorderStyle}" Margin="0,0,0,4">
                        <StackPanel>
                            <!-- Card title -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Style="{StaticResource DlgIconCircleStyle}">
                                    <ui:SymbolIcon Symbol="ArrowDownload28" FontSize="13"
                                                   Foreground="{DynamicResource NeuJaugAccentBrush}" />
                                </Border>
                                <TextBlock Text="{Binding [DetailsResJaugeagesSection], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgCardTitleStyle}" />
                            </StackPanel>

                            <!-- Empty state -->
                            <Border Padding="0,12"
                                    Visibility="{Binding HasRecentJaugeages, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding [DetailsResEmptyJaugeages], Source={x:Static loc:LanguageManager.Instance}}"
                                           FontSize="12" FontStyle="Italic"
                                           Foreground="{DynamicResource NeuTextSecondaryBrush}"
                                           HorizontalAlignment="Center" />
                            </Border>

                            <!-- Column headers -->
                            <Grid Margin="0,0,0,6"
                                  Visibility="{Binding HasRecentJaugeages, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding [DetailsResColNumero], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgColHeaderStyle}" />
                                <TextBlock Grid.Column="1" Text="{Binding [DetailsResColDate], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgColHeaderStyle}" />
                                <TextBlock Grid.Column="2" Text="{Binding [DetailsResColVolume], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgColHeaderStyle}" />
                            </Grid>

                            <!-- Rows -->
                            <ItemsControl ItemsSource="{Binding RecentJaugeages}"
                                          Visibility="{Binding HasRecentJaugeages, Converter={StaticResource BoolToVis}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,8,0,8"
                                                BorderBrush="{DynamicResource NeuInputFillBrush}"
                                                BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Numero}"
                                                           Style="{StaticResource DlgCellTextStyle}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DateTimeDisplay}"
                                                           Style="{StaticResource DlgCellTextStyle}" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding VolumeDisplay}"
                                                           Style="{StaticResource DlgCellTextStyle}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ── FOOTER ────────────────────────────────────────────── -->
            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource NeuInputFillBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="20,14">
                <Grid>
                    <Button Style="{StaticResource DlgSecondaryButtonStyle}"
                            HorizontalAlignment="Right"
                            Click="OnCloseClick">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Dismiss24" FontSize="13" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding [DetailsResClose], Source={x:Static loc:LanguageManager.Instance}}" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Border>
</ui:FluentWindow>
