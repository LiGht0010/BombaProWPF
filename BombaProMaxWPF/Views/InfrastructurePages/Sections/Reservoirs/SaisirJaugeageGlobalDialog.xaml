<ui:FluentWindow x:Class="BombaProMaxWPF.Views.InfrastructurePages.Sections.Reservoirs.SaisirJaugeageGlobalDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:loc="clr-namespace:BombaProMaxWPF.Localization"
                 xmlns:vm="clr-namespace:BombaProMaxWPF.ViewModels"
                 Title="{Binding [JaugDlgTitle], Source={x:Static loc:LanguageManager.Instance}}"
                 Width="900" Height="780"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 WindowBackdropType="None"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource NeuBackgroundBrush}"
                 d:DataContext="{d:DesignInstance Type=vm:SaisirJaugeageGlobalViewModel}"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 mc:Ignorable="d">

    <ui:FluentWindow.Resources>

        <!-- ─── Card surface (matches NeuDashCardStyle aesthetic, dialog-local) ─── -->
        <Style x:Key="DlgCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource NeuBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource NeuInputFillBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20,18" />
        </Style>

        <Style x:Key="DlgCardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DlgFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="DlgInputBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource NeuInputFillBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinHeight" Value="36" />
        </Style>

        <Style x:Key="DlgInputTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="DlgIconCircleStyle" TargetType="Border">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style x:Key="DlgPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource NeuJaugAccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuJaugAccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DlgColHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DlgCellTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Row template for the "ÉLÉMENTS AJOUTÉS" table -->
        <DataTemplate x:Key="JaugeageItemRowTemplate" DataType="{x:Type vm:JaugeageItemVm}">
            <Border Padding="14,12"
                    BorderBrush="{DynamicResource NeuInputFillBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="0.9*" />
                        <ColumnDefinition Width="0.9*" />
                        <ColumnDefinition Width="1.4*" />
                        <ColumnDefinition Width="60" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding DisplayName}"
                               FontWeight="SemiBold"
                               Style="{StaticResource DlgCellTextStyle}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ProduitNom}"
                               Style="{StaticResource DlgCellTextStyle}" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding HauteurCm, StringFormat=N1}"
                               Style="{StaticResource DlgCellTextStyle}" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding VolumeCalcule, StringFormat=N2}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource NeuJaugAccentBrush}"
                               Style="{StaticResource DlgCellTextStyle}" />
                    <TextBlock Grid.Column="4"
                               Text="{Binding Notes, TargetNullValue='—'}"
                               FontStyle="Italic"
                               Style="{StaticResource DlgCellTextStyle}" />
                    <Button Grid.Column="5"
                            HorizontalAlignment="Right"
                            Width="32" Height="32"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                            CommandParameter="{Binding}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" CornerRadius="16">
                                    <ui:SymbolIcon Symbol="Delete24"
                                                   FontSize="16"
                                                   Foreground="{DynamicResource NeuDangerBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <!-- Outer shell card -->
    <Border CornerRadius="14"
            Background="{DynamicResource NeuBackgroundBrush}"
            BorderBrush="{DynamicResource NeuInputFillBrush}"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="24" ShadowDepth="0" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ─── Header ─── -->
            <Grid Grid.Row="0" Margin="22,18,18,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource DlgCloseButtonStyle}"
                        Click="OnCancelClick"
                        ToolTip="{Binding [JaugDlgCancel], Source={x:Static loc:LanguageManager.Instance}}">
                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="14" />
                </Button>

                <TextBlock Grid.Column="1"
                           Text="{Binding [JaugDlgTitle], Source={x:Static loc:LanguageManager.Instance}}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource NeuJaugAccentBrush}"
                           VerticalAlignment="Center"
                           Margin="6,0,0,0" />

                <Border Grid.Column="2"
                        Width="32" Height="32"
                        CornerRadius="16"
                        Background="Transparent"
                        BorderBrush="{DynamicResource NeuInputFillBrush}"
                        BorderThickness="1">
                    <ui:SymbolIcon Symbol="Question24"
                                   FontSize="14"
                                   Foreground="{DynamicResource NeuJaugAccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                </Border>
            </Grid>

            <!-- ─── Top: two info cards side by side ─── -->
            <Grid Grid.Row="1" Margin="18,8,18,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- LEFT: Informations Générales -->
                <Border Grid.Column="0" Style="{StaticResource DlgCardBorderStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Style="{StaticResource DlgIconCircleStyle}">
                                <ui:SymbolIcon Symbol="Info24"
                                               FontSize="14"
                                               Foreground="{DynamicResource NeuJaugAccentBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="{Binding [JaugDlgGeneralInfo], Source={x:Static loc:LanguageManager.Instance}}"
                                       Style="{StaticResource DlgCardTitleStyle}" />
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding [JaugDlgDateLabel], Source={x:Static loc:LanguageManager.Instance}}"
                                           Style="{StaticResource DlgFieldLabelStyle}" />
                                <DatePicker SelectedDate="{Binding DateJaugeage, Mode=TwoWay}"
                                            Style="{DynamicResource NeuDatePickerStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding [JaugDlgNumeroLabel], Source={x:Static loc:LanguageManager.Instance}}"
                                           Style="{StaticResource DlgFieldLabelStyle}" />
                                <Border Style="{StaticResource DlgInputBorderStyle}">
                                    <TextBox Text="{Binding NumeroJaugeage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="True"
                                             Style="{StaticResource DlgInputTextBoxStyle}"
                                             Foreground="{DynamicResource NeuTextSecondaryBrush}" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{Binding [JaugDlgTemoinLabel], Source={x:Static loc:LanguageManager.Instance}}"
                                   Style="{StaticResource DlgFieldLabelStyle}"
                                   Margin="0,14,0,6" />
                        <ComboBox ItemsSource="{Binding Employes}"
                                  SelectedItem="{Binding SelectedTemoin, Mode=TwoWay}"
                                  Style="{DynamicResource NeuComboBoxStyle}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <Run Text="{Binding Nom}" />
                                        <Run Text=" " /><Run Text="{Binding Prenom}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="{Binding [JaugDlgObservationsLabel], Source={x:Static loc:LanguageManager.Instance}}"
                                   Style="{StaticResource DlgFieldLabelStyle}"
                                   Margin="0,14,0,6" />
                        <Border Style="{StaticResource DlgInputBorderStyle}" MinHeight="80">
                            <TextBox Text="{Binding Observations, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalContentAlignment="Top"
                                     ToolTip="{Binding [JaugDlgObservationsPlaceholder], Source={x:Static loc:LanguageManager.Instance}}"
                                     Style="{StaticResource DlgInputTextBoxStyle}" />
                        </Border>
                    </StackPanel>
                </Border>

                <!-- RIGHT: Détails du Réservoir -->
                <Border Grid.Column="2" Style="{StaticResource DlgCardBorderStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Style="{StaticResource DlgIconCircleStyle}">
                                <ui:SymbolIcon Symbol="Database24"
                                               FontSize="14"
                                               Foreground="{DynamicResource NeuJaugAccentBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="{Binding [JaugDlgDetailsCard], Source={x:Static loc:LanguageManager.Instance}}"
                                       Style="{StaticResource DlgCardTitleStyle}" />
                        </StackPanel>

                        <TextBlock Text="{Binding [JaugDlgSelectReservoir], Source={x:Static loc:LanguageManager.Instance}}"
                                   Style="{StaticResource DlgFieldLabelStyle}" />
                        <ComboBox ItemsSource="{Binding Reservoirs}"
                                  SelectedItem="{Binding Draft.SelectedReservoir, Mode=TwoWay}"
                                  Style="{DynamicResource NeuComboBoxStyle}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <Run Text="{Binding Numero}" FontWeight="SemiBold" />
                                        <Run Text=" - " />
                                        <Run Text="{Binding ProduitNom}" />
                                        <Run Text=" (" />
                                        <Run Text="{Binding Capacite, StringFormat=N0}" />
                                        <Run Text="L)" />
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding [JaugDlgHauteurCm], Source={x:Static loc:LanguageManager.Instance}}"
                                           Style="{StaticResource DlgFieldLabelStyle}" />
                                <Border Style="{StaticResource DlgInputBorderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding Draft.HauteurCm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N1, TargetNullValue=''}"
                                                 Style="{StaticResource DlgInputTextBoxStyle}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="CM"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource NeuTextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding [JaugDlgVolumeLitres], Source={x:Static loc:LanguageManager.Instance}}"
                                           Style="{StaticResource DlgFieldLabelStyle}" />
                                <Border Style="{StaticResource DlgInputBorderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Draft.VolumeCalcule, StringFormat=N2, TargetNullValue=''}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource NeuTextPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="LTR"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource NeuTextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{Binding [JaugDlgNotesSpecLabel], Source={x:Static loc:LanguageManager.Instance}}"
                                   Style="{StaticResource DlgFieldLabelStyle}"
                                   Margin="0,14,0,6" />
                        <Border Style="{StaticResource DlgInputBorderStyle}">
                            <TextBox Text="{Binding Draft.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding [JaugDlgNotesSpecPlaceholder], Source={x:Static loc:LanguageManager.Instance}}"
                                     Style="{StaticResource DlgInputTextBoxStyle}" />
                        </Border>

                        <Button Style="{StaticResource DlgPrimaryButtonStyle}"
                                Margin="0,16,0,0"
                                Command="{Binding AddToJaugeageCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="AddCircle24" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding [JaugDlgAddToJaugeage], Source={x:Static loc:LanguageManager.Instance}}"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ─── Bottom: ÉLÉMENTS AJOUTÉS table ─── -->
            <Border Grid.Row="2" Style="{StaticResource DlgCardBorderStyle}" Margin="18,8,18,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Notebook24"
                                           FontSize="16"
                                           Foreground="{DynamicResource NeuTextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                            <TextBlock Text="{Binding [JaugDlgItemsAdded], Source={x:Static loc:LanguageManager.Instance}}"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource NeuTextPrimaryBrush}"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource DlgBadgeStyle}">
                            <TextBlock FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource NeuJaugAccentBrush}">
                                <Run Text="{Binding MeasuredCount, Mode=OneWay}" />
                                <Run Text=" " />
                                <Run Text="{Binding [JaugDlgItemsAdded], Source={x:Static loc:LanguageManager.Instance}, Mode=OneWay}" />
                            </TextBlock>
                        </Border>
                    </Grid>

                    <!-- Column headers -->
                    <Grid Grid.Row="1" Margin="14,14,14,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="0.9*" />
                            <ColumnDefinition Width="0.9*" />
                            <ColumnDefinition Width="1.4*" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding [JaugDlgColReservoir], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgColHeaderStyle}" />
                        <TextBlock Grid.Column="1" Text="{Binding [JaugDlgColProduit], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgColHeaderStyle}" />
                        <TextBlock Grid.Column="2" Text="{Binding [JaugDlgHauteurCm], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgColHeaderStyle}" />
                        <TextBlock Grid.Column="3" Text="{Binding [JaugDlgVolumeLitres], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgColHeaderStyle}" />
                        <TextBlock Grid.Column="4" Text="{Binding [JaugDlgColNotes], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgColHeaderStyle}" />
                        <TextBlock Grid.Column="5" Text="{Binding [JaugDlgColAction], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource DlgColHeaderStyle}" HorizontalAlignment="Right" />
                    </Grid>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <ItemsControl ItemsSource="{Binding Rows}"
                                          ItemTemplate="{StaticResource JaugeageItemRowTemplate}" />
                            <TextBlock Text="{Binding [JaugDlgEmptyState], Source={x:Static loc:LanguageManager.Instance}}"
                                       FontSize="12"
                                       Foreground="{DynamicResource NeuTextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,28,0,28"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Rows.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ─── Footer ─── -->
            <Border Grid.Row="3"
                    BorderBrush="{DynamicResource NeuInputFillBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding [JaugDlgFooterBrand], Source={x:Static loc:LanguageManager.Instance}}"
                               FontSize="11"
                               Foreground="{DynamicResource NeuTextSecondaryBrush}"
                               VerticalAlignment="Center" />

                    <Button Grid.Column="1"
                            Style="{StaticResource DlgSecondaryButtonStyle}"
                            Margin="0,0,10,0"
                            Content="{Binding [JaugDlgCancel], Source={x:Static loc:LanguageManager.Instance}}"
                            Click="OnCancelClick" />

                    <Button Grid.Column="2"
                            Style="{StaticResource DlgPrimaryButtonStyle}"
                            Click="OnSaveClick"
                            Command="{Binding SaveCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Save24" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding [JaugDlgSaveShort], Source={x:Static loc:LanguageManager.Instance}}"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- error toast -->
            <Border Grid.Row="3"
                    Margin="22,0,22,78"
                    VerticalAlignment="Top"
                    Background="{DynamicResource NeuDangerBrush}"
                    Opacity="0.95"
                    CornerRadius="6"
                    Padding="12,6"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="12"
                           Foreground="White" />
            </Border>
        </Grid>
    </Border>
</ui:FluentWindow>
