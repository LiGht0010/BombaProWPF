<ui:FluentWindow x:Class="BombaProMaxWPF.Views.InfrastructurePages.Sections.Reservoirs.NouveauReservoirDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:BombaProMaxWPF.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=vm:NouveauReservoirViewModel}"
                 Title="Nouveau Réservoir"
                 Width="700" Height="780"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 WindowBackdropType="None"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource NeuBackgroundBrush}">

    <ui:FluentWindow.Resources>

        <Style x:Key="DlgCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource NeuBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource NeuInputFillBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20,18" />
        </Style>

        <Style x:Key="DlgCardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DlgFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="DlgInputBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource NeuInputFillBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinHeight" Value="36" />
        </Style>

        <Style x:Key="DlgInputTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="DlgIconCircleStyle" TargetType="Border">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style x:Key="DlgPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource NeuJaugAccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuJaugAccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgColHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DlgCellTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

    </ui:FluentWindow.Resources>

    <!-- Outer shell card -->
    <Border CornerRadius="14"
            Background="{DynamicResource NeuBackgroundBrush}"
            BorderBrush="{DynamicResource NeuInputFillBrush}"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="24" ShadowDepth="0" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ─── Header ─── -->
            <Grid Grid.Row="0" Margin="22,18,18,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource DlgCloseButtonStyle}"
                        Click="OnCancelClick">
                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="14" />
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                    <ui:SymbolIcon Symbol="Database24"
                                   FontSize="18"
                                   Foreground="{DynamicResource NeuJaugAccentBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                    <TextBlock Text="Nouveau Réservoir"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource NeuJaugAccentBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Border Grid.Column="2"
                        Width="32" Height="32"
                        CornerRadius="16"
                        Background="Transparent"
                        BorderBrush="{DynamicResource NeuInputFillBrush}"
                        BorderThickness="1"
                        Margin="0,0,6,0">
                    <ui:SymbolIcon Symbol="Question24"
                                   FontSize="14"
                                   Foreground="{DynamicResource NeuJaugAccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                </Border>
            </Grid>

            <!-- ─── Scrollable content ─── -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,0,18,0">
                <StackPanel>

                    <!-- ── Card 1: Informations Générales ── -->
                    <Border Style="{StaticResource DlgCardBorderStyle}" Margin="0,8,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Style="{StaticResource DlgIconCircleStyle}">
                                    <ui:SymbolIcon Symbol="Info24"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource NeuJaugAccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Informations Générales" Style="{StaticResource DlgCardTitleStyle}" />
                            </StackPanel>

                            <!-- Row 1: Numéro + Type de Produit -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="NUMÉRO DU RÉSERVOIR *" Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgInputBorderStyle}">
                                        <TextBox Text="{Binding Numero, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DlgInputTextBoxStyle}"
                                                 ToolTip="ex: Tank A-01" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="TYPE DE PRODUIT" Style="{StaticResource DlgFieldLabelStyle}" />
                                    <ComboBox ItemsSource="{Binding Produits}"
                                              SelectedItem="{Binding SelectedProduit, Mode=TwoWay}"
                                              Style="{DynamicResource NeuComboBoxStyle}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <TextBlock.Text>
                                                        <PriorityBinding>
                                                            <Binding Path="CategorieNom" />
                                                            <Binding Path="NumeroProduit" />
                                                        </PriorityBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- Row 2: Capacité + Fabricant -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="CAPACITÉ (L) *" Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgInputBorderStyle}">
                                        <TextBox Text="{Binding Capacite, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DlgInputTextBoxStyle}"
                                                 ToolTip="ex: 10000" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="FABRICANT" Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgInputBorderStyle}">
                                        <TextBox Text="{Binding Fabricant, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DlgInputTextBoxStyle}"
                                                 ToolTip="ex: TerraSteel Corp" />
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Row 3: Numéro de Série + Diamètre -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="NUMÉRO DE SÉRIE" Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgInputBorderStyle}">
                                        <TextBox Text="{Binding NumeroSerie, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DlgInputTextBoxStyle}"
                                                 ToolTip="ex: SN-8829-X" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="DIAMÈTRE (CM)" Style="{StaticResource DlgFieldLabelStyle}" />
                                    <Border Style="{StaticResource DlgInputBorderStyle}">
                                        <TextBox Text="{Binding DiametreCm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                                 Style="{StaticResource DlgInputTextBoxStyle}"
                                                 ToolTip="ex: 250" />
                                    </Border>
                                </StackPanel>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- ── Card 2: Table de Calibration ── -->
                    <Border Style="{StaticResource DlgCardBorderStyle}" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Style="{StaticResource DlgIconCircleStyle}">
                                    <ui:SymbolIcon Symbol="DocumentTable24"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource NeuJaugAccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Table de Calibration" Style="{StaticResource DlgCardTitleStyle}" />
                            </StackPanel>

                            <!-- Segmented pill tab bar -->
                            <Border Background="{DynamicResource NeuInputFillBrush}"
                                    CornerRadius="22"
                                    Padding="4"
                                    Margin="0,0,0,16">
                                <UniformGrid Rows="1" Columns="2">
                                    <RadioButton Content="Saisie Manuelle"
                                                 Style="{StaticResource NeuSegmentedPillStyle}"
                                                 IsChecked="{Binding IsManualTab, Mode=TwoWay}"
                                                 GroupName="CalibTabGroup" />
                                    <RadioButton Content="Importation CSV"
                                                 Style="{StaticResource NeuSegmentedPillStyle}"
                                                 IsChecked="{Binding IsCsvTab, Mode=TwoWay}"
                                                 GroupName="CalibTabGroup" />
                                </UniformGrid>
                            </Border>

                            <!-- ── Manual panel ── -->
                            <StackPanel Visibility="{Binding IsManualTab, Converter={StaticResource BoolToVisibilityConverter}}">

                                <!-- Column headers -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="40" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="HAUTEUR (CM)" Style="{StaticResource DlgColHeaderStyle}" />
                                    <TextBlock Grid.Column="2" Text="VOLUME (L)" Style="{StaticResource DlgColHeaderStyle}" />
                                </Grid>

                                <!-- Calibration rows -->
                                <ItemsControl ItemsSource="{Binding CalibrationLines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="0,4"
                                                    BorderBrush="{DynamicResource NeuInputFillBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="16" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="40" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Style="{StaticResource DlgInputBorderStyle}">
                                                        <TextBlock Text="{Binding HauteurCm}" Style="{StaticResource DlgCellTextStyle}" />
                                                    </Border>
                                                    <Border Grid.Column="2" Style="{StaticResource DlgInputBorderStyle}">
                                                        <TextBlock Text="{Binding VolumeLitres}" Style="{StaticResource DlgCellTextStyle}" />
                                                    </Border>
                                                    <Button Grid.Column="3"
                                                            HorizontalAlignment="Center"
                                                            Width="32" Height="32"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="bd" Background="Transparent" CornerRadius="16">
                                                                    <ui:SymbolIcon Symbol="Delete24"
                                                                                   FontSize="15"
                                                                                   Foreground="{DynamicResource NeuDangerBrush}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center" />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Add row inputs -->
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="40" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource DlgInputBorderStyle}">
                                        <TextBox Text="{Binding NewHauteur, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DlgInputTextBoxStyle}"
                                                 ToolTip="Hauteur (cm)" />
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource DlgInputBorderStyle}">
                                        <TextBox Text="{Binding NewVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DlgInputTextBoxStyle}"
                                                 ToolTip="Volume (L)" />
                                    </Border>
                                </Grid>

                                <!-- Add line link-button -->
                                <Button HorizontalAlignment="Left"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Margin="0,10,0,0"
                                        Command="{Binding AddLineCommand}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="AddCircle24"
                                                               FontSize="16"
                                                               Foreground="{DynamicResource NeuJaugAccentBrush}"
                                                               VerticalAlignment="Center" />
                                                <TextBlock Text="  Ajouter une ligne"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource NeuJaugAccentBrush}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                            </StackPanel>

                            <!-- ── CSV import panel ── -->
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsManualTab}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <!-- Dashed drop zone -->
                                <Border CornerRadius="12"
                                        BorderThickness="2"
                                        Padding="20,32"
                                        Margin="0,0,0,14">
                                    <Border.BorderBrush>
                                        <DrawingBrush Viewport="0,0,12,12" ViewportUnits="Absolute" TileMode="Tile">
                                            <DrawingBrush.Drawing>
                                                <GeometryDrawing>
                                                    <GeometryDrawing.Pen>
                                                        <Pen Brush="{DynamicResource NeuTextSecondaryBrush}" Thickness="1.5" DashStyle="{x:Static DashStyles.Dash}" />
                                                    </GeometryDrawing.Pen>
                                                    <GeometryDrawing.Geometry>
                                                        <RectangleGeometry Rect="0,0,12,12" />
                                                    </GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                            </DrawingBrush.Drawing>
                                        </DrawingBrush>
                                    </Border.BorderBrush>
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="52" Height="52"
                                                CornerRadius="26"
                                                Background="{DynamicResource NeuInputFillBrush}"
                                                HorizontalAlignment="Center"
                                                Margin="0,0,0,14">
                                            <ui:SymbolIcon Symbol="ArrowUpload24"
                                                           FontSize="24"
                                                           Foreground="{DynamicResource NeuJaugAccentBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="Glissez votre fichier ici"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource NeuTextPrimaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Text="Format supporté : .CSV (max 5Mo)"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource NeuJaugAccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,16" />
                                        <Button Style="{StaticResource DlgPrimaryButtonStyle}"
                                                HorizontalAlignment="Center"
                                                Command="{Binding ImportCsvCommand}">
                                            <TextBlock Text="Choisir un fichier" />
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <!-- Download template link -->
                                <Button HorizontalAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="ArrowDownload28"
                                                               FontSize="14"
                                                               Foreground="{DynamicResource NeuJaugAccentBrush}"
                                                               VerticalAlignment="Center" />
                                                <TextBlock Text="  Télécharger le modèle de calibration"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource NeuJaugAccentBrush}"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.TextDecorations>
                                                        <TextDecoration Location="Underline" />
                                                    </TextBlock.TextDecorations>
                                                </TextBlock>
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                            </StackPanel>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ─── Footer ─── -->
            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource NeuInputFillBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- error toast (left area) -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource NeuDangerBrush}"
                            Opacity="0.95"
                            CornerRadius="6"
                            Padding="12,6"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="White" />
                    </Border>

                    <Button Grid.Column="1"
                            Style="{StaticResource DlgSecondaryButtonStyle}"
                            Margin="0,0,10,0"
                            Content="Annuler"
                            Click="OnCancelClick" />

                    <Button Grid.Column="2"
                            Style="{StaticResource DlgPrimaryButtonStyle}"
                            Click="OnSaveClick"
                            Command="{Binding SaveCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Save24" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock Text="  Enregistrer le Réservoir" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Border>
</ui:FluentWindow>
