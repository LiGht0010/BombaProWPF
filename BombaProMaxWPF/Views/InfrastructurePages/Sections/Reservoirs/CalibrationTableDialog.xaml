<ui:FluentWindow x:Class="BombaProMaxWPF.Views.InfrastructurePages.Sections.Reservoirs.CalibrationTableDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:loc="clr-namespace:BombaProMaxWPF.Localization"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 mc:Ignorable="d"
                 Title="{Binding [CalibTableTitle], Source={x:Static loc:LanguageManager.Instance}}"
                 Width="480" Height="600"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 WindowBackdropType="None"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource NeuBackgroundBrush}">

    <ui:FluentWindow.Resources>

        <Style x:Key="CalColHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="CalCellTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </ui:FluentWindow.Resources>

    <Border CornerRadius="14" Background="{DynamicResource NeuBackgroundBrush}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.18" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- header -->
                <RowDefinition Height="Auto" />  <!-- col headers -->
                <RowDefinition Height="*" />     <!-- rows -->
                <RowDefinition Height="Auto" />  <!-- footer -->
            </Grid.RowDefinitions>

            <!-- ── HEADER ── -->
            <Border Grid.Row="0" Padding="20,16,16,14"
                    BorderBrush="{DynamicResource NeuInputFillBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Width="28" Height="28" CornerRadius="14"
                                Background="{DynamicResource NeuInputFillBrush}"
                                VerticalAlignment="Center" Margin="0,0,10,0">
                            <ui:SymbolIcon Symbol="DocumentTable24" FontSize="13"
                                           Foreground="{DynamicResource NeuJaugAccentBrush}" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding [CalibTableTitle], Source={x:Static loc:LanguageManager.Instance}}"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource NeuTextPrimaryBrush}" />
                            <TextBlock FontSize="11"
                                       Foreground="{DynamicResource NeuTextSecondaryBrush}"
                                       Margin="0,1,0,0">
                                <Run Text="{Binding [CalibTableReservoir], Source={x:Static loc:LanguageManager.Instance}, Mode=OneWay}" />
                                <Run Text="{Binding ReservoirNumero, Mode=OneWay}" FontWeight="SemiBold"
                                     Foreground="{DynamicResource NeuJaugAccentBrush}" />
                                <Run Text="—" />
                                <Run Text="{Binding Rows.Count, Mode=OneWay}" />
                                <Run Text="{Binding [CalibTableLines], Source={x:Static loc:LanguageManager.Instance}, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource CloseButtonStyle}"
                            Width="32" Height="32" Padding="0"
                            Click="OnCloseClick"
                            VerticalAlignment="Top">
                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="14" />
                    </Button>
                </Grid>
            </Border>

            <!-- ── COLUMN HEADERS ── -->
            <Grid Grid.Row="1" Margin="20,12,20,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />  <!-- # -->
                    <ColumnDefinition Width="*" />   <!-- hauteur -->
                    <ColumnDefinition Width="*" />   <!-- volume -->
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [CalibTableColHash], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource CalColHeaderStyle}" />
                <TextBlock Grid.Column="1" Text="{Binding [CalibTableColHauteur], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource CalColHeaderStyle}" />
                <TextBlock Grid.Column="2" Text="{Binding [CalibTableColVolume], Source={x:Static loc:LanguageManager.Instance}}" Style="{StaticResource CalColHeaderStyle}" />
            </Grid>

            <!-- ── ROWS ── -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          Padding="20,0,20,0">
                <ItemsControl ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="0,10,0,10"
                                    BorderBrush="{DynamicResource NeuInputFillBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Row index via AlternationIndex is unavailable without AlternationCount;
                                         use ID as a row indicator instead -->
                                    <Border Grid.Column="0"
                                            Background="{DynamicResource NeuInputFillBrush}"
                                            CornerRadius="6" Width="28" Height="22"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding ID}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource NeuTextSecondaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding HauteurCm, StringFormat={}{0:N1}}"
                                               Style="{StaticResource CalCellTextStyle}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding VolumeLitres, StringFormat={}{0:N1}}"
                                               Style="{StaticResource CalCellTextStyle}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ── FOOTER ── -->
            <Border Grid.Row="3"
                    BorderBrush="{DynamicResource NeuInputFillBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="20,12">
                <Button Style="{StaticResource CloseButtonStyle}"
                        HorizontalAlignment="Right"
                        Click="OnCloseClick">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="13" Margin="0,0,6,0" />
                        <TextBlock Text="{Binding [CalibTableClose], Source={x:Static loc:LanguageManager.Instance}}" />
                    </StackPanel>
                </Button>
            </Border>

        </Grid>
    </Border>
</ui:FluentWindow>
