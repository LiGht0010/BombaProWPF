<UserControl x:Class="BombaProMaxWPF.Views.InfrastructurePages.InfrastructureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:BombaProMaxWPF.Localization"
             Background="Transparent"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  PanningMode="VerticalOnly">
        <StackPanel Margin="32,28,32,32">

            <!-- Header -->
            <StackPanel Margin="0,0,0,18">
                <TextBlock Text="{Binding [InfraTitle], Source={x:Static loc:LanguageManager.Instance}}"
                           FontSize="26"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource NeuTextPrimaryBrush}" />
                <TextBlock Text="{Binding [InfraSubtitle], Source={x:Static loc:LanguageManager.Instance}}"
                           FontSize="13"
                           Margin="0,4,0,0"
                           Foreground="{DynamicResource NeuTextSecondaryBrush}" />
            </StackPanel>

            <!-- Segmented pill bar -->
            <Border Style="{StaticResource NeuSegmentedPillBarStyle}"
                    Margin="0,0,0,22">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="PillProduits"
                                 GroupName="InfraTabs"
                                 Style="{StaticResource NeuSegmentedPillStyle}"
                                 Content="{Binding [InfraProduits], Source={x:Static loc:LanguageManager.Instance}}"
                                 Tag="produits"
                                 Checked="Pill_Checked"
                                 IsChecked="True" />
                    <RadioButton x:Name="PillReservoirs"
                                 GroupName="InfraTabs"
                                 Style="{StaticResource NeuSegmentedPillStyle}"
                                 Content="{Binding [InfraReservoirs], Source={x:Static loc:LanguageManager.Instance}}"
                                 Tag="reservoirs"
                                 Checked="Pill_Checked" />
                    <RadioButton x:Name="PillPompes"
                                 GroupName="InfraTabs"
                                 Style="{StaticResource NeuSegmentedPillStyle}"
                                 Content="{Binding [InfraPompes], Source={x:Static loc:LanguageManager.Instance}}"
                                 Tag="pompes"
                                 Checked="Pill_Checked" />
                    <RadioButton x:Name="PillServices"
                                 GroupName="InfraTabs"
                                 Style="{StaticResource NeuSegmentedPillStyle}"
                                 Content="{Binding [InfraServices], Source={x:Static loc:LanguageManager.Instance}}"
                                 Tag="services"
                                 Checked="Pill_Checked" />
                </StackPanel>
            </Border>

            <!-- Section host: swapped on pill click; UCs cached in code-behind -->
            <ContentControl x:Name="SectionHost" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
