<UserControl x:Class="BombaProMaxWPF.Views.InfrastructurePages.InfrastructureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:BombaProMaxWPF.Localization"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="Transparent"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  PanningMode="VerticalOnly">
        <ScrollViewer.Resources>
            <!-- Accent scrollbar thumb -->
            <Style TargetType="Thumb">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="{DynamicResource NeuAccentBrush}"
                                    CornerRadius="3"
                                    Margin="2,0" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ScrollViewer.Resources>

        <StackPanel Margin="32,28,32,32">

            <!-- Header — always visible -->
            <Grid Margin="0,0,0,24">
                <!-- Centred title block -->
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding [InfraTitle], Source={x:Static loc:LanguageManager.Instance}}"
                               FontSize="26"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Foreground="{DynamicResource NeuTextPrimaryBrush}" />
                    <TextBlock Text="{Binding [InfraSubtitle], Source={x:Static loc:LanguageManager.Instance}}"
                               FontSize="13"
                               Margin="0,4,0,0"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Foreground="{DynamicResource NeuTextSecondaryBrush}" />
                </StackPanel>

                <!-- Back button — top-right, only visible in section state -->
                <Button x:Name="BackButton"
                        Click="Back_Click"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        Visibility="Collapsed"
                        ToolTip="{Binding [InfraBackTooltip], Source={x:Static loc:LanguageManager.Instance}}"
                        Style="{StaticResource NeuButtonStyle}"
                        Background="{DynamicResource NeuAccentBrush}"
                        Foreground="White"
                        Padding="16,10">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowLeft24"
                                       FontSize="16"
                                       VerticalAlignment="Center" />
                        <TextBlock Text="{Binding [InfraBackButton], Source={x:Static loc:LanguageManager.Instance}}"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════
                 STATE 1 — Landing hub: 1×4 row of section cards
                 ═══════════════════════════════════════════════════════════ -->
            <UniformGrid x:Name="LandingPanel"
                         Columns="4"
                         Visibility="Visible">

                <!-- Produits -->
                <Button Tag="produits"
                        Click="Card_Click"
                        Margin="0,0,10,0"
                        Cursor="Hand"
                        ToolTip="{Binding [InfraCardDescProduits], Source={x:Static loc:LanguageManager.Instance}}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="24" Effect="{DynamicResource NeuShadowCardDark}">
                                            <Border x:Name="CardInner" CornerRadius="24"
                                                    Background="{DynamicResource NeuBackgroundBrush}"
                                                    BorderBrush="{DynamicResource NeuAccentBrush}"
                                                    BorderThickness="1.5"
                                                    Effect="{DynamicResource NeuShadowCardLight}">
                                                <StackPanel Margin="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <ui:SymbolIcon x:Name="CardIcon"
                                                                   Symbol="Beaker24"
                                                                   FontSize="48"
                                                                   HorizontalAlignment="Center"
                                                                   Foreground="{DynamicResource NeuAccentBrush}"
                                                                   Margin="0,0,0,12" />
                                                    <TextBlock x:Name="CardTitle"
                                                               Text="{Binding [InfraProduits], Source={x:Static loc:LanguageManager.Instance}}"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               TextAlignment="Center"
                                                               Foreground="{DynamicResource NeuTextPrimaryBrush}" />
                                                    <TextBlock x:Name="CardDesc"
                                                               Text="{Binding [InfraCardDescProduits], Source={x:Static loc:LanguageManager.Instance}}"
                                                               FontSize="14"
                                                               Margin="0,5,0,0"
                                                               TextWrapping="Wrap"
                                                               HorizontalAlignment="Center"
                                                               TextAlignment="Center"
                                                               Foreground="{DynamicResource NeuTextSecondaryBrush}" />
                                                </StackPanel>
                                            </Border>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardInner" Property="Background" Value="{DynamicResource NeuAccentBrush}" />
                                                <Setter TargetName="CardIcon"  Property="Foreground" Value="White" />
                                                <Setter TargetName="CardTitle" Property="Foreground" Value="White" />
                                                <Setter TargetName="CardDesc"  Property="Foreground" Value="White" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Réservoirs -->
                <Button Tag="reservoirs"
                        Click="Card_Click"
                        Margin="10,0,10,0"
                        Cursor="Hand"
                        ToolTip="{Binding [InfraCardDescReservoirs], Source={x:Static loc:LanguageManager.Instance}}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="24" Effect="{DynamicResource NeuShadowCardDark}">
                                            <Border x:Name="CardInner" CornerRadius="24"
                                                    Background="{DynamicResource NeuBackgroundBrush}"
                                                    BorderBrush="{DynamicResource NeuAccentBrush}"
                                                    BorderThickness="1.5"
                                                    Effect="{DynamicResource NeuShadowCardLight}">
                                                <StackPanel Margin="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <ui:SymbolIcon x:Name="CardIcon"
                                                                   Symbol="Drop24"
                                                                   FontSize="48"
                                                                   HorizontalAlignment="Center"
                                                                   Foreground="{DynamicResource NeuAccentBrush}"
                                                                   Margin="0,0,0,12" />
                                                    <TextBlock x:Name="CardTitle"
                                                               Text="{Binding [InfraReservoirs], Source={x:Static loc:LanguageManager.Instance}}"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               TextAlignment="Center"
                                                               Foreground="{DynamicResource NeuTextPrimaryBrush}" />
                                                    <TextBlock x:Name="CardDesc"
                                                               Text="{Binding [InfraCardDescReservoirs], Source={x:Static loc:LanguageManager.Instance}}"
                                                               FontSize="14"
                                                               Margin="0,5,0,0"
                                                               TextWrapping="Wrap"
                                                               HorizontalAlignment="Center"
                                                               TextAlignment="Center"
                                                               Foreground="{DynamicResource NeuTextSecondaryBrush}" />
                                                </StackPanel>
                                            </Border>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardInner" Property="Background" Value="{DynamicResource NeuAccentBrush}" />
                                                <Setter TargetName="CardIcon"  Property="Foreground" Value="White" />
                                                <Setter TargetName="CardTitle" Property="Foreground" Value="White" />
                                                <Setter TargetName="CardDesc"  Property="Foreground" Value="White" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Pompes -->
                <Button Tag="pompes"
                        Click="Card_Click"
                        Margin="10,0,10,0"
                        Cursor="Hand"
                        ToolTip="{Binding [InfraCardDescPompes], Source={x:Static loc:LanguageManager.Instance}}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="24" Effect="{DynamicResource NeuShadowCardDark}">
                                            <Border x:Name="CardInner" CornerRadius="24"
                                                    Background="{DynamicResource NeuBackgroundBrush}"
                                                    BorderBrush="{DynamicResource NeuAccentBrush}"
                                                    BorderThickness="1.5"
                                                    Effect="{DynamicResource NeuShadowCardLight}">
                                                <StackPanel Margin="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Viewbox Width="48" Height="48"
                                                             HorizontalAlignment="Center"
                                                             Margin="0,0,0,12">
                                                        <Path x:Name="CardIcon"
                                                              Data="M6 2C4.9 2 4 2.9 4 4v14c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2H6zm0 2h8v4H6V4zm0 6h8v8H6v-8zm10 0l2-2v2h1c.6 0 1 .4 1 1v5c0 .6-.4 1-1 1h-1v2h-2v-9z"
                                                              Stretch="Uniform"
                                                              Fill="{DynamicResource NeuAccentBrush}" />
                                                    </Viewbox>
                                                    <TextBlock x:Name="CardTitle"
                                                               Text="{Binding [InfraPompes], Source={x:Static loc:LanguageManager.Instance}}"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               TextAlignment="Center"
                                                               Foreground="{DynamicResource NeuTextPrimaryBrush}" />
                                                    <TextBlock x:Name="CardDesc"
                                                               Text="{Binding [InfraCardDescPompes], Source={x:Static loc:LanguageManager.Instance}}"
                                                               FontSize="14"
                                                               Margin="0,5,0,0"
                                                               TextWrapping="Wrap"
                                                               HorizontalAlignment="Center"
                                                               TextAlignment="Center"
                                                               Foreground="{DynamicResource NeuTextSecondaryBrush}" />
                                                </StackPanel>
                                            </Border>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardInner" Property="Background" Value="{DynamicResource NeuAccentBrush}" />
                                                <Setter TargetName="CardIcon"  Property="Fill"       Value="White" />
                                                <Setter TargetName="CardTitle" Property="Foreground" Value="White" />
                                                <Setter TargetName="CardDesc"  Property="Foreground" Value="White" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Services -->
                <Button Tag="services"
                        Click="Card_Click"
                        Margin="10,0,0,0"
                        Cursor="Hand"
                        ToolTip="{Binding [InfraCardDescServices], Source={x:Static loc:LanguageManager.Instance}}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="24" Effect="{DynamicResource NeuShadowCardDark}">
                                            <Border x:Name="CardInner" CornerRadius="24"
                                                    Background="{DynamicResource NeuBackgroundBrush}"
                                                    BorderBrush="{DynamicResource NeuAccentBrush}"
                                                    BorderThickness="1.5"
                                                    Effect="{DynamicResource NeuShadowCardLight}">
                                                <StackPanel Margin="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <ui:SymbolIcon x:Name="CardIcon"
                                                                   Symbol="Wrench24"
                                                                   FontSize="48"
                                                                   HorizontalAlignment="Center"
                                                                   Foreground="{DynamicResource NeuAccentBrush}"
                                                                   Margin="0,0,0,12" />
                                                    <TextBlock x:Name="CardTitle"
                                                               Text="{Binding [InfraServices], Source={x:Static loc:LanguageManager.Instance}}"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               TextAlignment="Center"
                                                               Foreground="{DynamicResource NeuTextPrimaryBrush}" />
                                                    <TextBlock x:Name="CardDesc"
                                                               Text="{Binding [InfraCardDescServices], Source={x:Static loc:LanguageManager.Instance}}"
                                                               FontSize="14"
                                                               Margin="0,5,0,0"
                                                               TextWrapping="Wrap"
                                                               HorizontalAlignment="Center"
                                                               TextAlignment="Center"
                                                               Foreground="{DynamicResource NeuTextSecondaryBrush}" />
                                                </StackPanel>
                                            </Border>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardInner" Property="Background" Value="{DynamicResource NeuAccentBrush}" />
                                                <Setter TargetName="CardIcon"  Property="Foreground" Value="White" />
                                                <Setter TargetName="CardTitle" Property="Foreground" Value="White" />
                                                <Setter TargetName="CardDesc"  Property="Foreground" Value="White" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

            </UniformGrid>

            <!-- ═══════════════════════════════════════════════════════════
                 STATE 2 — Section view: section host
                 (Back button lives in the header Grid above)
                 ═══════════════════════════════════════════════════════════ -->
            <StackPanel x:Name="SectionPanel"
                        Visibility="Collapsed">

                <!-- Section content -->
                <ContentControl x:Name="SectionHost" />

            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
