<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- =========================================================
         Neumorphic palette â€” LIGHT theme
         ========================================================= -->
    <Color  x:Key="NeuBackgroundColor">#E6ECF3</Color>
    <Color  x:Key="NeuLightShadowColor">#FFFFFF</Color>
    <Color  x:Key="NeuDarkShadowColor">#B8C4D6</Color>
    <Color  x:Key="NeuAccentColor">#4A8FBF</Color>
    <Color  x:Key="NeuAccentHoverColor">#5AA0D0</Color>
    <Color  x:Key="NeuTextPrimaryColor">#2D3748</Color>
    <Color  x:Key="NeuTextSecondaryColor">#6B7A8F</Color>

    <SolidColorBrush x:Key="NeuBackgroundBrush"     Color="{DynamicResource NeuBackgroundColor}" />
    <SolidColorBrush x:Key="NeuAccentBrush"         Color="{DynamicResource NeuAccentColor}" />
    <SolidColorBrush x:Key="NeuAccentHoverBrush"    Color="{DynamicResource NeuAccentHoverColor}" />
    <SolidColorBrush x:Key="NeuTextPrimaryBrush"    Color="{DynamicResource NeuTextPrimaryColor}" />
    <SolidColorBrush x:Key="NeuTextSecondaryBrush"  Color="{DynamicResource NeuTextSecondaryColor}" />

    <!-- =========================================================
         Raised card template â€” two stacked borders produce the
         classic twin-shadow neumorphic look.
         Usage: wrap your content in a ContentControl with Style=NeuCardStyle
         ========================================================= -->
    <Style x:Key="NeuCardStyle" TargetType="ContentControl">
        <Setter Property="Background" Value="{DynamicResource NeuBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
        <Setter Property="Padding" Value="40" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid>
                        <!-- Dark shadow (bottom-right) -->
                        <Border Background="{TemplateBinding Background}" CornerRadius="24">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource NeuDarkShadowColor}"
                                                  BlurRadius="30"
                                                  ShadowDepth="10"
                                                  Direction="315"
                                                  Opacity="0.55" />
                            </Border.Effect>
                        </Border>

                        <!-- Light highlight (top-left) + content -->
                        <Border Background="{TemplateBinding Background}" CornerRadius="24">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource NeuLightShadowColor}"
                                                  BlurRadius="30"
                                                  ShadowDepth="10"
                                                  Direction="135"
                                                  Opacity="0.95" />
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Neumorphic button with pressed/raised states
         ========================================================= -->
    <Style x:Key="NeuButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource NeuBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource NeuAccentBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="28,12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="RootGrid">
                        <Border x:Name="OuterShadow"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource NeuDarkShadowColor}"
                                                  BlurRadius="18"
                                                  ShadowDepth="6"
                                                  Direction="315"
                                                  Opacity="0.6" />
                            </Border.Effect>
                        </Border>

                        <Border x:Name="InnerShadow"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource NeuLightShadowColor}"
                                                  BlurRadius="18"
                                                  ShadowDepth="6"
                                                  Direction="135"
                                                  Opacity="1" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RootGrid" Property="Opacity" Value="0.92" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="OuterShadow" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{DynamicResource NeuDarkShadowColor}"
                                                      BlurRadius="6" ShadowDepth="2"
                                                      Direction="315" Opacity="0.6" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="InnerShadow" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{DynamicResource NeuLightShadowColor}"
                                                      BlurRadius="6" ShadowDepth="2"
                                                      Direction="135" Opacity="1" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Circular logo badge (neumorphic "pill") -->
    <Style x:Key="NeuLogoBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource NeuBackgroundBrush}" />
        <Setter Property="CornerRadius" Value="60" />
        <Setter Property="Width" Value="120" />
        <Setter Property="Height" Value="120" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="{DynamicResource NeuDarkShadowColor}"
                                  BlurRadius="24"
                                  ShadowDepth="8"
                                  Direction="315"
                                  Opacity="0.55" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Inset (sunken) input field â€” TextBox
         The field looks pressed-into the surface using inverted
         shadow directions on a slightly darker fill.
         ========================================================= -->
    <Color x:Key="NeuInputFillColor">#D6DEE8</Color>
    <SolidColorBrush x:Key="NeuInputFillBrush" Color="{DynamicResource NeuInputFillColor}" />

    <Style x:Key="NeuTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource NeuAccentBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource NeuAccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="22,12" />
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <!-- Outer ring: dark on top â†’ light on bottom = inset edge -->
                    <Border CornerRadius="24" BorderThickness="1.5">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0.2,0" EndPoint="0.8,1">
                                <GradientStop Color="{DynamicResource NeuDarkShadowColor}" Offset="0" />
                                <GradientStop Color="{DynamicResource NeuLightShadowColor}" Offset="1" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <!-- Inner fill (slightly darker than card) -->
                        <Border Background="{TemplateBinding Background}" CornerRadius="22">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden" />
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Inset PasswordBox â€” same look as TextBox
         ========================================================= -->
    <Style x:Key="NeuPasswordBoxStyle" TargetType="PasswordBox">
        <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource NeuAccentBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource NeuAccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="22,12" />
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="PasswordChar" Value="&#x25CF;" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border CornerRadius="24" BorderThickness="1.5">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0.2,0" EndPoint="0.8,1">
                                <GradientStop Color="{DynamicResource NeuDarkShadowColor}" Offset="0" />
                                <GradientStop Color="{DynamicResource NeuLightShadowColor}" Offset="1" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border Background="{TemplateBinding Background}" CornerRadius="22">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden" />
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Flat link-style button (e.g. "Forgot password?", "Sign up")
         ========================================================= -->
    <Style x:Key="NeuLinkButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource NeuAccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource NeuAccentHoverBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- =========================================================
         Raised neumorphic pill â€” used as a host for the top toolbar
         (theme toggle + language picker). Twin-shadow look matches
         NeuCardStyle but with a smaller radius and padding.
         ========================================================= -->
    <Style x:Key="NeuToolbarStyle" TargetType="ContentControl">
        <Setter Property="Background" Value="{DynamicResource NeuBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid>
                        <Border Background="{TemplateBinding Background}" CornerRadius="22">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource NeuDarkShadowColor}"
                                                  BlurRadius="20"
                                                  ShadowDepth="6"
                                                  Direction="315"
                                                  Opacity="0.55" />
                            </Border.Effect>
                        </Border>
                        <Border Background="{TemplateBinding Background}" CornerRadius="22">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource NeuLightShadowColor}"
                                                  BlurRadius="20"
                                                  ShadowDepth="6"
                                                  Direction="135"
                                                  Opacity="0.95" />
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Inset neumorphic ComboBox â€” matches NeuTextBoxStyle look.
         Includes a styled ComboBoxItem for hover/selected states.
         ========================================================= -->
    <Style x:Key="NeuComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10"
                            Margin="4,2"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource NeuAccentBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NeuComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource NeuComboBoxItemStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="DropDownToggle"
                                      Focusable="False"
                                      ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="OuterRing" CornerRadius="20" BorderThickness="1.2">
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0.2,0" EndPoint="0.8,1">
                                                <GradientStop Color="{DynamicResource NeuDarkShadowColor}" Offset="0" />
                                                <GradientStop Color="{DynamicResource NeuLightShadowColor}" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <Border x:Name="InnerFill"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="19">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="Chevron"
                                                      Grid.Column="1"
                                                      Margin="0,0,14,0"
                                                      Width="10" Height="6"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 5 5 L 10 0 Z"
                                                      Fill="{DynamicResource NeuTextSecondaryBrush}" />
                                            </Grid>
                                        </Border>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Chevron" Property="Fill" Value="{DynamicResource NeuAccentBrush}" />
                                            <Setter TargetName="OuterRing" Property="Opacity" Value="0.92" />
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Chevron" Property="Fill" Value="{DynamicResource NeuAccentBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <ContentPresenter Margin="14,0,32,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                          IsHitTestVisible="False" />

                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border Background="{DynamicResource NeuBackgroundBrush}"
                                    CornerRadius="14"
                                    Margin="6"
                                    MinWidth="{TemplateBinding ActualWidth}">
                                <Border.Effect>
                                    <DropShadowEffect Color="{DynamicResource NeuDarkShadowColor}"
                                                      BlurRadius="20"
                                                      ShadowDepth="6"
                                                      Direction="315"
                                                      Opacity="0.55" />
                                </Border.Effect>
                                <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                              Margin="4">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Neumorphic toggle switch (use on a plain ToggleButton).
         Track = inset pill, Knob = raised circle that slides.
         ========================================================= -->
    <Style x:Key="NeuToggleSwitchStyle" TargetType="ToggleButton">
        <Setter Property="Width" Value="56" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource NeuAccentBrush}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="OuterRing" CornerRadius="15" BorderThickness="1.2">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0.2,0" EndPoint="0.8,1">
                                <GradientStop Color="{DynamicResource NeuDarkShadowColor}" Offset="0" />
                                <GradientStop Color="{DynamicResource NeuLightShadowColor}" Offset="1" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border x:Name="Track"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <Grid>
                                <Border x:Name="Knob"
                                        Width="22" Height="22"
                                        CornerRadius="11"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Margin="3,0,0,0"
                                        Background="{DynamicResource NeuBackgroundBrush}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="{DynamicResource NeuDarkShadowColor}"
                                                          BlurRadius="8"
                                                          ShadowDepth="2"
                                                          Direction="315"
                                                          Opacity="0.6" />
                                    </Border.Effect>
                                </Border>
                            </Grid>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource NeuAccentBrush}" />
                            <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="Knob" Property="Margin" Value="0,0,3,0" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="OuterRing" Property="Opacity" Value="0.92" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Vertical sidebar host (raised neumorphic panel)
         ========================================================= -->
    <Style x:Key="NeuSidebarStyle" TargetType="ContentControl">
        <Setter Property="Background" Value="{DynamicResource NeuBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid>
                        <Border Background="{TemplateBinding Background}" CornerRadius="24">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource NeuDarkShadowColor}"
                                                  BlurRadius="28"
                                                  ShadowDepth="10"
                                                  Direction="315"
                                                  Opacity="0.55" />
                            </Border.Effect>
                        </Border>
                        <Border Background="{TemplateBinding Background}" CornerRadius="24">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource NeuLightShadowColor}"
                                                  BlurRadius="28"
                                                  ShadowDepth="10"
                                                  Direction="135"
                                                  Opacity="0.95" />
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Sidebar nav item (RadioButton). Default raised, IsChecked = inset
         with a vertical accent indicator on the left edge.
         ========================================================= -->
    <Style x:Key="NeuNavItemStyle" TargetType="RadioButton">
        <Setter Property="Background" Value="{DynamicResource NeuBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Margin" Value="0,4" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <Border x:Name="Indicator"
                                Width="3"
                                CornerRadius="2"
                                Margin="2,8"
                                HorizontalAlignment="Left"
                                Background="Transparent" />
                        <Border x:Name="HoverFill"
                                CornerRadius="14"
                                Margin="6,0,6,0"
                                Background="Transparent" />
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HoverFill" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource NeuAccentBrush}" />
                            <Setter TargetName="HoverFill" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource NeuAccentBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Small flat icon button used for the sidebar pane toggle.
         ========================================================= -->
    <Style x:Key="NeuPaneToggleStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource NeuAccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Footer user pill (inset Border with rounded look)
         ========================================================= -->
    <Style x:Key="NeuUserPillStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0.2,0" EndPoint="0.8,1">
                    <GradientStop Color="{DynamicResource NeuDarkShadowColor}" Offset="0" />
                    <GradientStop Color="{DynamicResource NeuLightShadowColor}" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Sticky CTA: accent-filled raised button (DÃ©marrer la journÃ©e).
         ========================================================= -->
    <Style x:Key="NeuStartDayButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource NeuAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root">
                        <Border x:Name="Shadow"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource NeuDarkShadowColor}"
                                                  BlurRadius="14"
                                                  ShadowDepth="4"
                                                  Direction="315"
                                                  Opacity="0.55" />
                            </Border.Effect>
                        </Border>
                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource NeuAccentHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.92" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
