<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- =========================================================
         Neumorphic palette — DARK theme
         Same keys as Light so swapping is seamless.
         ========================================================= -->
    <Color  x:Key="NeuBackgroundColor">#0b1223</Color>
    <Color  x:Key="NeuLightShadowColor">#121d38</Color>
    <Color  x:Key="NeuDarkShadowColor">#04070e</Color>
    <Color  x:Key="NeuAccentColor">#6BA5D3</Color>
    <Color  x:Key="NeuAccentHoverColor">#85B8E0</Color>
    <Color  x:Key="NeuTextPrimaryColor">#E8ECF3</Color>
    <Color  x:Key="NeuTextSecondaryColor">#9AA5BA</Color>

    <SolidColorBrush x:Key="NeuBackgroundBrush"     Color="{StaticResource NeuBackgroundColor}" />
    <SolidColorBrush x:Key="NeuAccentBrush"         Color="{StaticResource NeuAccentColor}" />
    <SolidColorBrush x:Key="NeuAccentHoverBrush"    Color="{StaticResource NeuAccentHoverColor}" />
    <SolidColorBrush x:Key="NeuTextPrimaryBrush"    Color="{StaticResource NeuTextPrimaryColor}" />
    <SolidColorBrush x:Key="NeuTextSecondaryBrush"  Color="{StaticResource NeuTextSecondaryColor}" />

    <!-- ========================================================= -->
    <Style x:Key="NeuCardStyle" TargetType="ContentControl">
        <Setter Property="Background" Value="{DynamicResource NeuBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
        <Setter Property="Padding" Value="40" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">

                    <!-- Outer: carries the DARK shadow (bottom-right) -->
                    <Border CornerRadius="24">
                        <Border.Effect>
                            <DropShadowEffect Color="#191e4f"
                                          BlurRadius="60"
                                          ShadowDepth="50"
                                          Direction="135"
                                          Opacity="0.4" />
                        </Border.Effect>

                        <!-- Inner: carries the bg + LIGHT shadow (top-left) -->
                        <Border CornerRadius="24"
                                Background="{TemplateBinding Background}">
                            <Border.Effect>
                                <DropShadowEffect Color="#425c7d"
                                              BlurRadius="60"
                                              ShadowDepth="50"
                                              Direction="315"
                                              Opacity="0.5" />
                            </Border.Effect>

                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </Border>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Dashboard / infrastructure section card (raised, smaller padding)
         ========================================================= -->
    <Style x:Key="NeuDashCardStyle" TargetType="ContentControl">
        <Setter Property="Background" Value="{DynamicResource NeuBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border CornerRadius="16">
                        <Border.Effect>
                            <DropShadowEffect Color="#191e4f"
                                              BlurRadius="60"
                                              ShadowDepth="50"
                                              Direction="135"
                                              Opacity="0.4" />
                        </Border.Effect>
                        <Border CornerRadius="16"
                                Background="{TemplateBinding Background}">
                            <Border.Effect>
                                <DropShadowEffect Color="#425c7d"
                                                  BlurRadius="60"
                                                  ShadowDepth="50"
                                                  Direction="315"
                                                  Opacity="0.5" />
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NeuButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource NeuBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource NeuAccentBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="28,12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="RootGrid">
                        <Border x:Name="OuterShadow"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <Border.Effect>
                                <DropShadowEffect Color="#425c7d"
                                                      BlurRadius="60"
                                                      ShadowDepth="50"
                                                      Direction="315"
                                                      Opacity="0.5" />
                            </Border.Effect>
                        </Border>
                        <Border x:Name="InnerShadow"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <Border.Effect>
                                <DropShadowEffect Color="#191e4f"
                                                      BlurRadius="60"
                                                      ShadowDepth="50"
                                                      Direction="135"
                                                      Opacity="0.4" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RootGrid" Property="Opacity" Value="0.92" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="OuterShadow" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#425c7d"
                                                      BlurRadius="40" ShadowDepth="25"
                                                      Direction="315" Opacity="0.5" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="InnerShadow" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#191e4f"
                                                      BlurRadius="40" ShadowDepth="25"
                                                      Direction="135" Opacity="0.4" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NeuLogoBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource NeuBackgroundBrush}" />
        <Setter Property="CornerRadius" Value="60" />
        <Setter Property="Width" Value="120" />
        <Setter Property="Height" Value="120" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#425c7d"
                                  BlurRadius="60"
                                  ShadowDepth="50"
                                  Direction="315"
                                  Opacity="0.5" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Inset (sunken) input field — TextBox
         ========================================================= -->
    <Color x:Key="NeuInputFillColor">#121d38</Color>
    <SolidColorBrush x:Key="NeuInputFillBrush" Color="{StaticResource NeuInputFillColor}" />

    <Style x:Key="NeuTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource NeuAccentBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource NeuAccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="22,12" />
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border CornerRadius="24" BorderThickness="1.5">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0.2,0" EndPoint="0.8,1">
                                <GradientStop Color="{StaticResource NeuDarkShadowColor}" Offset="0" />
                                <GradientStop Color="{StaticResource NeuLightShadowColor}" Offset="1" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border Background="{TemplateBinding Background}" CornerRadius="22">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden" />
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NeuPasswordBoxStyle" TargetType="PasswordBox">
        <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource NeuAccentBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource NeuAccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="22,12" />
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="PasswordChar" Value="●" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border CornerRadius="24" BorderThickness="1.5">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0.2,0" EndPoint="0.8,1">
                                <GradientStop Color="{StaticResource NeuDarkShadowColor}" Offset="0" />
                                <GradientStop Color="{StaticResource NeuLightShadowColor}" Offset="1" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border Background="{TemplateBinding Background}" CornerRadius="22">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden" />
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NeuLinkButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource NeuAccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource NeuAccentHoverBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- =========================================================
         Raised neumorphic pill — used as a host for the top toolbar
         (theme toggle + language picker).
         ========================================================= -->
    <Style x:Key="NeuToolbarStyle" TargetType="ContentControl">
        <Setter Property="Background" Value="{DynamicResource NeuBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid>
                        <Border Background="{TemplateBinding Background}" CornerRadius="22">
                            <Border.Effect>
                                <DropShadowEffect Color="#425c7d"
                                                  BlurRadius="60"
                                                  ShadowDepth="50"
                                                  Direction="315"
                                                  Opacity="0.5" />
                            </Border.Effect>
                        </Border>
                        <Border Background="{TemplateBinding Background}" CornerRadius="22">
                            <Border.Effect>
                                <DropShadowEffect Color="#191e4f"
                                                  BlurRadius="60"
                                                  ShadowDepth="50"
                                                  Direction="135"
                                                  Opacity="0.4" />
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Inset neumorphic ComboBox — matches NeuTextBoxStyle look.
         ========================================================= -->
    <Style x:Key="NeuComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10"
                            Margin="4,2"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource NeuAccentBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NeuComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="MinWidth" Value="180" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource NeuComboBoxItemStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <!-- Full-width clickable surface: the ToggleButton hosts both
                             the selection display and the chevron in a two-column grid
                             so they never overlap. -->
                        <ToggleButton x:Name="DropDownToggle"
                                      Focusable="False"
                                      ClickMode="Press"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="OuterRing"
                                            CornerRadius="20"
                                            BorderThickness="0"
                                            Background="{DynamicResource NeuInputFillBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter x:Name="SelectionDisplay"
                                                              Grid.Column="0"
                                                              Margin="14,0,8,0"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Left"
                                                              Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}, Mode=OneWay}"
                                                              ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}, Mode=OneWay}"
                                                              ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}, Mode=OneWay}"
                                                              TextElement.Foreground="{DynamicResource NeuTextPrimaryBrush}"
                                                              TextElement.FontSize="13"
                                                              IsHitTestVisible="False" />
                                            <Path x:Name="Chevron"
                                                  Grid.Column="1"
                                                  Margin="0,0,16,0"
                                                  Width="12" Height="7"
                                                  VerticalAlignment="Center"
                                                  Stretch="Fill"
                                                  Data="M 0 0 L 5 5 L 10 0 Z"
                                                  Fill="{DynamicResource NeuTextSecondaryBrush}" />
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Chevron" Property="Fill" Value="{DynamicResource NeuAccentBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Chevron" Property="Fill" Value="{DynamicResource NeuAccentBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border Background="{DynamicResource NeuBackgroundBrush}"
                                    CornerRadius="14"
                                    Margin="6"
                                    MinWidth="{TemplateBinding ActualWidth}">
                                <Border.Effect>
                                    <DropShadowEffect Color="#425c7d"
                                                      BlurRadius="60"
                                                      ShadowDepth="50"
                                                      Direction="315"
                                                      Opacity="0.5" />
                                </Border.Effect>
                                <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                              Margin="4">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Neumorphic toggle switch (use on a plain ToggleButton).
         ========================================================= -->
    <Style x:Key="NeuToggleSwitchStyle" TargetType="ToggleButton">
        <Setter Property="Width" Value="56" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource NeuAccentBrush}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="OuterRing" CornerRadius="15" BorderThickness="1.2">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0.2,0" EndPoint="0.8,1">
                                <GradientStop Color="{StaticResource NeuDarkShadowColor}" Offset="0" />
                                <GradientStop Color="{StaticResource NeuLightShadowColor}" Offset="1" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border x:Name="Track"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <Grid>
                                <Border x:Name="Knob"
                                        Width="22" Height="22"
                                        CornerRadius="11"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Margin="3,0,0,0"
                                        Background="{DynamicResource NeuBackgroundBrush}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#425c7d"
                                                          BlurRadius="60"
                                                          ShadowDepth="50"
                                                          Direction="315"
                                                          Opacity="0.5" />
                                    </Border.Effect>
                                </Border>
                            </Grid>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource NeuAccentBrush}" />
                            <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="Knob" Property="Margin" Value="0,0,3,0" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="OuterRing" Property="Opacity" Value="0.92" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Vertical sidebar host (raised neumorphic panel)
         ========================================================= -->
    <Style x:Key="NeuSidebarStyle" TargetType="ContentControl">
        <Setter Property="Background" Value="{DynamicResource NeuBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid>
                        <Border Background="{TemplateBinding Background}" CornerRadius="24">
                            <Border.Effect>
                                <DropShadowEffect Color="#425c7d"
                                                  BlurRadius="60"
                                                  ShadowDepth="50"
                                                  Direction="315"
                                                  Opacity="0.5" />
                            </Border.Effect>
                        </Border>
                        <Border Background="{TemplateBinding Background}" CornerRadius="24">
                            <Border.Effect>
                                <DropShadowEffect Color="#191e4f"
                                                  BlurRadius="60"
                                                  ShadowDepth="50"
                                                  Direction="135"
                                                  Opacity="0.4" />
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Sidebar nav item (RadioButton). Default raised, IsChecked = inset
         with a vertical accent indicator on the left edge.
         ========================================================= -->
    <Style x:Key="NeuNavItemStyle" TargetType="RadioButton">
        <Setter Property="Background" Value="{DynamicResource NeuBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource NeuTextPrimaryBrush}" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Margin" Value="0,4" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <Border x:Name="Indicator"
                                Width="3"
                                CornerRadius="2"
                                Margin="2,8"
                                HorizontalAlignment="Left"
                                Background="Transparent" />
                        <Border x:Name="HoverFill"
                                CornerRadius="14"
                                Margin="6,0,6,0"
                                Background="Transparent" />
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HoverFill" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource NeuAccentBrush}" />
                            <Setter TargetName="HoverFill" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource NeuAccentBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Small flat icon button used for the sidebar pane toggle.
         ========================================================= -->
    <Style x:Key="NeuPaneToggleStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource NeuTextSecondaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource NeuAccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Footer user pill (inset Border with rounded look)
         ========================================================= -->
    <Style x:Key="NeuUserPillStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource NeuInputFillBrush}" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0.2,0" EndPoint="0.8,1">
                    <GradientStop Color="{StaticResource NeuDarkShadowColor}" Offset="0" />
                    <GradientStop Color="{StaticResource NeuLightShadowColor}" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Sticky CTA: accent-filled raised button (Démarrer la journée).
         ========================================================= -->
    <Style x:Key="NeuStartDayButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource NeuAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root">
                        <Border x:Name="Shadow"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <Border.Effect>
                                <DropShadowEffect Color="#425c7d"
                                                  BlurRadius="60"
                                                  ShadowDepth="50"
                                                  Direction="315"
                                                  Opacity="0.5" />
                            </Border.Effect>
                        </Border>
                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                            <Border.Effect>
                                <DropShadowEffect Color="#191e4f"
                                                  BlurRadius="60"
                                                  ShadowDepth="50"
                                                  Direction="135"
                                                  Opacity="0.4" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource NeuAccentHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.92" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
