<ui:FluentWindow x:Class="BombaProMaxWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:BombaProMaxWPF"
        xmlns:loc="clr-namespace:BombaProMaxWPF.Localization"
        mc:Ignorable="d"
        Title="{Binding [AppName], Source={x:Static loc:LanguageManager.Instance}}"
        Height="650" Width="1000"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <ui:TitleBar Grid.Row="0"
                     Title="{Binding [AppName], Source={x:Static loc:LanguageManager.Instance}}"
                     ShowMaximize="True"
                     ShowMinimize="True"
                     ShowClose="True" />

        <!-- Top toolbar: theme + language -->
        <Border Grid.Row="1"
                Padding="24,12"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <!-- Language picker -->
                    <ui:SymbolIcon Symbol="Globe24"
                                   FontSize="18"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                    <TextBlock Text="{Binding [LanguageLabel], Source={x:Static loc:LanguageManager.Instance}}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ComboBox x:Name="LanguageComboBox"
                              Width="140"
                              SelectedIndex="0"
                              SelectionChanged="LanguageComboBox_SelectionChanged"
                              VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Français" Tag="fr" />
                        <ComboBoxItem Content="العربية" Tag="ar" />
                    </ComboBox>

                    <Border Width="1"
                            Margin="16,4"
                            Background="{DynamicResource ControlStrokeColorDefaultBrush}" />

                    <!-- Theme toggle -->
                    <ui:SymbolIcon x:Name="ThemeIcon"
                                   Symbol="WeatherSunny24"
                                   FontSize="18"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                    <TextBlock Text="{Binding [ThemeLabel], Source={x:Static loc:LanguageManager.Instance}}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:ToggleSwitch x:Name="ThemeToggle"
                                     Checked="ThemeToggle_Checked"
                                     Unchecked="ThemeToggle_Unchecked"
                                     VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content: welcome card -->
        <Grid Grid.Row="2">
            <ui:Card MaxWidth="640"
                     Padding="40"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Margin="24">
                <StackPanel HorizontalAlignment="Center">

                    <!-- Logo -->
                    <Image Source="pack://application:,,,/Logos/BPM.png"
                           Width="180" Height="180"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24" />

                    <!-- App name -->
                    <TextBlock Text="{Binding [AppName], Source={x:Static loc:LanguageManager.Instance}}"
                               FontSize="36"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                    <!-- Welcome -->
                    <TextBlock Text="{Binding [Welcome], Source={x:Static loc:LanguageManager.Instance}}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"
                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />

                    <!-- Tagline -->
                    <TextBlock Text="{Binding [Tagline], Source={x:Static loc:LanguageManager.Instance}}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,8,0,24"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                    <!-- CTA -->
                    <ui:Button Content="{Binding [GetStarted], Source={x:Static loc:LanguageManager.Instance}}"
                               Icon="{ui:SymbolIcon ArrowRight24}"
                               Appearance="Primary"
                               HorizontalAlignment="Center"
                               Padding="24,10"
                               FontSize="14" />
                </StackPanel>
            </ui:Card>
        </Grid>
    </Grid>
</ui:FluentWindow>
