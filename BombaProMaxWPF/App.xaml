<Application x:Class="BombaProMaxWPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:BombaProMaxWPF"
             xmlns:conv="clr-namespace:BombaProMaxWPF.Converters"
             >
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="Styles/Shadows.Light.xaml" />
                <ResourceDictionary Source="Styles/Neumorphic.Light.xaml" />
                <ResourceDictionary Source="Styles/SegmentedPill.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
            <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
