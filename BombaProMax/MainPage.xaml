<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BombaProMax.MainPage"
             BackgroundColor="#E0E5EC">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Neumorphic Table -->
            <Border StrokeThickness="0"
                    BackgroundColor="#E0E5EC"
                    Padding="0"
                    Margin="10">
                <Border.Shadow>
                    <Shadow Brush="#FFFFFF"
                            Offset="-8,-8"
                            Radius="15"
                            Opacity="1"/>
                </Border.Shadow>
                <Grid>
                    <Border StrokeThickness="0"
                            BackgroundColor="#E0E5EC">
                        <Border.Shadow>
                            <Shadow Brush="#A3B1C6"
                                    Offset="8,8"
                                    Radius="15"
                                    Opacity="0.8"/>
                        </Border.Shadow>

                        <Grid RowDefinitions="Auto,*" Padding="15">

                            <!-- Table Header -->
                            <Grid Grid.Row="0" ColumnDefinitions="*,*,*" ColumnSpacing="10" Margin="0,0,0,15">
                                <Label Grid.Column="0" 
                                       Text="test1" 
                                       FontSize="16" 
                                       FontAttributes="Bold"
                                       TextColor="#4A5568"
                                       HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="1" 
                                       Text="test2" 
                                       FontSize="16" 
                                       FontAttributes="Bold"
                                       TextColor="#4A5568"
                                       HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="2" 
                                       Text="test3" 
                                       FontSize="16" 
                                       FontAttributes="Bold"
                                       TextColor="#4A5568"
                                       HorizontalTextAlignment="Center"/>
                            </Grid>

                            <!-- Table Content (Sample Rows) -->
                            <VerticalStackLayout Grid.Row="1" Spacing="10">
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                                    <Label Grid.Column="0" Text="Data 1" TextColor="#718096" HorizontalTextAlignment="Center"/>
                                    <Label Grid.Column="1" Text="Data 2" TextColor="#718096" HorizontalTextAlignment="Center"/>
                                    <Label Grid.Column="2" Text="Data 3" TextColor="#718096" HorizontalTextAlignment="Center"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                                    <Label Grid.Column="0" Text="Data 4" TextColor="#718096" HorizontalTextAlignment="Center"/>
                                    <Label Grid.Column="1" Text="Data 5" TextColor="#718096" HorizontalTextAlignment="Center"/>
                                    <Label Grid.Column="2" Text="Data 6" TextColor="#718096" HorizontalTextAlignment="Center"/>
                                </Grid>
                            </VerticalStackLayout>

                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Neumorphic Button -->
            <Border StrokeThickness="0"
                    BackgroundColor="#E0E5EC"
                    Padding="0"
                    Margin="10"
                    HeightRequest="50"
                    WidthRequest="200"
                    HorizontalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="25"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#FFFFFF"
                            Offset="-6,-6"
                            Radius="12"
                            Opacity="1"/>
                </Border.Shadow>
                <Grid>
                    <Border StrokeThickness="0"
                            BackgroundColor="#E0E5EC">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="25"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#A3B1C6"
                                    Offset="6,6"
                                    Radius="12"
                                    Opacity="0.8"/>
                        </Border.Shadow>

                        <Label Text="Add Item"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#4A5568"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnButtonTapped"/>
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>