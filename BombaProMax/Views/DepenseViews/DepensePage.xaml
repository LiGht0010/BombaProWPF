<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:BombaProMax.ViewModels"
             xmlns:models="clr-namespace:BombaProMax.Models"
             x:Class="BombaProMax.Views.DepenseViews.DepensePage"
             x:DataType="viewmodels:DepenseViewModel"
             Style="{StaticResource DepensePageStyle}">

    <Grid RowDefinitions="*,Auto">
        
        <ScrollView Grid.Row="0" Style="{StaticResource DepensePageScrollView}">
            <VerticalStackLayout Style="{StaticResource DepensePageMainStack}">

                <!-- JOURNÉE PROGRESS BAR -->
                <Border BackgroundColor="#E3F2FD" 
                        Padding="15" 
                        Margin="0,0,0,10"
                        IsVisible="{Binding IsJourneeActive}" 
                        StrokeShape="RoundRectangle 10" 
                        Stroke="#1976D2">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Text="🚀" FontSize="24" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Margin="10,0">
                            <Label Text="{Binding JourneeStepInfo}" 
                                   FontAttributes="Bold" 
                                   TextColor="#1976D2" 
                                   FontSize="14"/>
                            <Label Text="Journée en cours - Suivez les étapes" 
                                   TextColor="#666" 
                                   FontSize="11"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="📋" FontSize="20" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- HEADER -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <VerticalStackLayout Style="{StaticResource DepensePageHeaderStack}">
                        <Label Text="💸 Gestion des Dépenses" 
                               Style="{StaticResource DepensePageTitleLabel}"/>
                        <Label Text="Suivez et gérez les dépenses de la station" 
                               Style="{StaticResource DepensePageSubtitleLabel}"/>
                    </VerticalStackLayout>
                    
                    <Button Grid.Column="1"
                            Text="+ Nouvelle Dépense"
                            Style="{StaticResource DepenseAddButton}"
                            Clicked="OnAddDepenseClicked"
                            VerticalOptions="Center"
                            IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"/>
                </Grid>

                <!-- STATS CARDS -->
                <Grid ColumnDefinitions="*,*,*,*" 
                      ColumnSpacing="16"
                      IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                    
                    <Border Grid.Column="0" Style="{StaticResource DepenseStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="📊" Style="{StaticResource DepenseStatIcon}"/>
                            <Label Text="{Binding TotalDepenses}" 
                                   Style="{StaticResource DepenseStatNumber}"
                                   TextColor="#1976D2"/>
                            <Label Text="Dépenses" 
                                   Style="{StaticResource DepenseStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource DepenseStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="💰" Style="{StaticResource DepenseStatIcon}"/>
                            <Label Text="{Binding TotalMontant, StringFormat='{0:N2}'}" 
                                   Style="{StaticResource DepenseStatNumber}"
                                   TextColor="#E53935"/>
                            <Label Text="MAD Total" 
                                   Style="{StaticResource DepenseStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource DepenseStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="📈" Style="{StaticResource DepenseStatIcon}"/>
                            <Label Text="{Binding MoyenneMontant, StringFormat='{0:N2}'}" 
                                   Style="{StaticResource DepenseStatNumber}"
                                   TextColor="#FF9800"/>
                            <Label Text="MAD Moyenne" 
                                   Style="{StaticResource DepenseStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource DepenseStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="⬆️" Style="{StaticResource DepenseStatIcon}"/>
                            <Label Text="{Binding MaxMontant, StringFormat='{0:N2}'}" 
                                   Style="{StaticResource DepenseStatNumber}"
                                   TextColor="#7B1FA2"/>
                            <Label Text="MAD Max" 
                                   Style="{StaticResource DepenseStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- FILTERS -->
                <Border Style="{StaticResource DepenseFilterContainer}"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                    <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*,Auto,Auto" ColumnSpacing="12">
                        <Label Text="📅 Du:" Style="{StaticResource DepenseFilterLabel}"/>
                        <DatePicker Grid.Column="1"
                                    Date="{Binding FilterStartDate}"
                                    Style="{StaticResource DepenseFilterDatePicker}"/>
                        <Label Grid.Column="2" Text="Au:" Style="{StaticResource DepenseFilterLabel}"/>
                        <DatePicker Grid.Column="3"
                                    Date="{Binding FilterEndDate}"
                                    Style="{StaticResource DepenseFilterDatePicker}"/>
                        <Label Grid.Column="4" Text="Catégorie:" Style="{StaticResource DepenseFilterLabel}"/>
                        <Picker Grid.Column="5"
                                ItemsSource="{Binding Categories}"
                                SelectedItem="{Binding SelectedCategory}"
                                Style="{StaticResource DepenseFilterPicker}"/>
                        <Button Grid.Column="6"
                                Text="🔍 Filtrer"
                                Command="{Binding LoadDepensesByFilterCommand}"
                                Style="{StaticResource DepenseFilterButton}"/>
                        <Button Grid.Column="7"
                                Text="🔄"
                                Command="{Binding LoadDepensesCommand}"
                                Style="{StaticResource DepenseResetButton}"/>
                    </Grid>
                </Border>

                <!-- Loading -->
                <ActivityIndicator Style="{StaticResource DepensePageLoadingIndicator}"
                                   IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"/>

                <!-- TABLE CARD -->
                <Border Style="{StaticResource DepenseTableCard}"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                    <VerticalStackLayout Style="{StaticResource DepenseTableContainer}">

                        <!-- Header -->
                        <Grid Style="{StaticResource DepenseTableHeaderGrid}">
                            <Label Grid.Column="0" Text="N° Dépense" Style="{StaticResource DepenseTableHeaderLabelLeft}"/>
                            <Label Grid.Column="1" Text="Date" Style="{StaticResource DepenseTableHeaderLabelLeft}"/>
                            <Label Grid.Column="2" Text="Catégorie" Style="{StaticResource DepenseTableHeaderLabelLeft}"/>
                            <Label Grid.Column="3" Text="Montant" Style="{StaticResource DepenseTableHeaderLabel}"/>
                            <Label Grid.Column="4" Text="Description" Style="{StaticResource DepenseTableHeaderLabelLeft}"/>
                            <Label Grid.Column="5" Text="Actions" Style="{StaticResource DepenseTableHeaderLabel}"/>
                        </Grid>

                        <!-- Rows using BindableLayout -->
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Depenses}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:DepenseDto">
                                    <VerticalStackLayout BackgroundColor="Transparent">
                                        <Grid Style="{StaticResource DepenseTableRowGrid}">
                                            
                                            <!-- N° Dépense -->
                                            <Label Grid.Column="0" 
                                                   Text="{Binding Numero}" 
                                                   Style="{StaticResource DepenseNumeroLabel}"/>

                                            <!-- Date -->
                                            <Label Grid.Column="1" 
                                                   Text="{Binding DateDisplay}" 
                                                   Style="{StaticResource DepenseDateLabel}"/>

                                            <!-- Catégorie -->
                                            <Border Grid.Column="2" Style="{StaticResource DepenseCategorieBadge}">
                                                <Label Text="{Binding Categorie}" 
                                                       Style="{StaticResource DepenseCategorieLabel}"/>
                                            </Border>

                                            <!-- Montant -->
                                            <Label Grid.Column="3" 
                                                   Text="{Binding Montant, StringFormat='{0:N2} MAD'}" 
                                                   Style="{StaticResource DepenseMontantLabel}"/>

                                            <!-- Description -->
                                            <Label Grid.Column="4" 
                                                   Text="{Binding Description, TargetNullValue='-'}" 
                                                   Style="{StaticResource DepenseDescriptionLabel}"/>

                                            <!-- Actions -->
                                            <HorizontalStackLayout Grid.Column="5" Style="{StaticResource DepenseActionsCell}">
                                                <Button Text="✏️"
                                                        Style="{StaticResource DepenseEditButton}"
                                                        Clicked="OnEditDepenseClicked"
                                                        CommandParameter="{Binding .}"/>
                                                <Button Text="🗑️"
                                                        Style="{StaticResource DepenseDeleteButton}"
                                                        Clicked="OnDeleteDepenseClicked"
                                                        CommandParameter="{Binding .}"/>
                                            </HorizontalStackLayout>
                                        </Grid>
                                        <BoxView Style="{StaticResource DepenseRowDivider}"/>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                            
                            <BindableLayout.EmptyView>
                                <VerticalStackLayout Style="{StaticResource DepenseEmptyView}">
                                    <Border BackgroundColor="#EEF1F5"
                                            WidthRequest="100"
                                            HeightRequest="100"
                                            StrokeThickness="0"
                                            Margin="0,0,0,16">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="50"/>
                                        </Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="#C5CAD1" Offset="6,6" Radius="12" Opacity="0.25"/>
                                        </Border.Shadow>
                                        <Label Text="💸" FontSize="48" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <Label Text="Aucune dépense trouvée" Style="{StaticResource DepenseEmptyTitle}"/>
                                    <Label Text="Commencez par ajouter une nouvelle dépense" 
                                           Style="{StaticResource DepenseEmptySubtitle}"/>
                                    <Button Text="+ Nouvelle Dépense"
                                            Style="{StaticResource DepenseEmptyButton}"
                                            Clicked="OnAddDepenseClicked"/>
                                </VerticalStackLayout>
                            </BindableLayout.EmptyView>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- JOURNÉE NAVIGATION BAR -->
        <Border Grid.Row="1" 
                BackgroundColor="#F5F5F5" 
                Padding="15" 
                IsVisible="{Binding IsJourneeActive}" 
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="#000" Offset="0,-2" Radius="8" Opacity="0.1"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                <Button Text="← Précédent" 
                        Command="{Binding JourneePrecedentCommand}"
                        BackgroundColor="#757575" 
                        TextColor="White" 
                        Padding="20,12" 
                        CornerRadius="8"
                        IsVisible="{Binding IsFirstStep, Converter={StaticResource InvertedBoolConverter}}"/>
                <BoxView Grid.Column="1" Color="Transparent"/>
                <Button Grid.Column="2" 
                        Text="Passer cette étape" 
                        Command="{Binding JourneePasserCommand}"
                        BackgroundColor="#FFA726" 
                        TextColor="White" 
                        Padding="20,12" 
                        CornerRadius="8"/>
                <Button Grid.Column="3" 
                        Text="{Binding IsLastStep, Converter={StaticResource BoolToTextConverter}, ConverterParameter='Terminer la journée|Suivant →'}"
                        Command="{Binding JourneeSuivantCommand}" 
                        BackgroundColor="#4CAF50" 
                        TextColor="White"
                        Padding="20,12" 
                        CornerRadius="8" 
                        FontAttributes="Bold"/>
            </Grid>
        </Border>

    </Grid>
</ContentPage>