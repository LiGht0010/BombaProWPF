<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.ServiceViews.ServiceCategorieCreatePopup"
               Color="Transparent">

    <Border BackgroundColor="White"       
            Padding="0"
            WidthRequest="500"
            HeightRequest="420"
            StrokeShape="RoundRectangle 12">
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- HEADER -->
            <Border Grid.Row="0" 
                    BackgroundColor="#0097A7" 
                    Padding="20">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout>
                        <Label x:Name="HeaderLabel"
                               Text="Nouvelle Categorie" 
                               FontSize="20" 
                               FontAttributes="Bold"
                               TextColor="White"/>
                        <Label Text="Creer une nouvelle categorie de services" 
                               FontSize="12"
                               TextColor="#B2EBF2"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" 
                            Text="X" 
                            BackgroundColor="Transparent"
                            TextColor="White"
                            FontSize="20"
                            Clicked="OnCancelClicked"/>
                </Grid>
            </Border>

            <!-- FORM CONTENT -->
            <ScrollView Grid.Row="1" Padding="20">
                <VerticalStackLayout Spacing="15">
                    
                    <!-- Nom -->
                    <Border BackgroundColor="#FFF3E0" 
                            Padding="12"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#FFB300">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Nom de la categorie *" 
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#E65100"/>
                            <Entry x:Name="NomEntry"
                                   Placeholder="Ex: Lavage, Vidange, Graissage..."
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#E65100"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Quick Categories -->
                    <Border BackgroundColor="#F5F5F5" 
                            Padding="12"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#E0E0E0">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Suggestions rapides" 
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#666"/>
                            <FlexLayout Wrap="Wrap" 
                                        JustifyContent="Start" 
                                        AlignItems="Center"
                                        Direction="Row">
                                <Button Text="Lavage" 
                                        Margin="0,0,8,8"
                                        Clicked="OnQuickCategoryClicked"
                                        BackgroundColor="#E0F7FA"
                                        TextColor="#0097A7"
                                        FontSize="12"
                                        Padding="12,8"
                                        CornerRadius="8"/>
                                <Button Text="Vidange" 
                                        Margin="0,0,8,8"
                                        Clicked="OnQuickCategoryClicked"
                                        BackgroundColor="#E0F7FA"
                                        TextColor="#0097A7"
                                        FontSize="12"
                                        Padding="12,8"
                                        CornerRadius="8"/>
                                <Button Text="Graissage" 
                                        Margin="0,0,8,8"
                                        Clicked="OnQuickCategoryClicked"
                                        BackgroundColor="#E0F7FA"
                                        TextColor="#0097A7"
                                        FontSize="12"
                                        Padding="12,8"
                                        CornerRadius="8"/>
                                <Button Text="Entretien" 
                                        Margin="0,0,8,8"
                                        Clicked="OnQuickCategoryClicked"
                                        BackgroundColor="#E0F7FA"
                                        TextColor="#0097A7"
                                        FontSize="12"
                                        Padding="12,8"
                                        CornerRadius="8"/>
                                <Button Text="Reparation" 
                                        Margin="0,0,8,8"
                                        Clicked="OnQuickCategoryClicked"
                                        BackgroundColor="#E0F7FA"
                                        TextColor="#0097A7"
                                        FontSize="12"
                                        Padding="12,8"
                                        CornerRadius="8"/>
                                <Button Text="Pneumatique" 
                                        Margin="0,0,8,8"
                                        Clicked="OnQuickCategoryClicked"
                                        BackgroundColor="#E0F7FA"
                                        TextColor="#0097A7"
                                        FontSize="12"
                                        Padding="12,8"
                                        CornerRadius="8"/>
                            </FlexLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Description -->
                    <Border BackgroundColor="#F8F8F8" 
                            Padding="12"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#E0E0E0">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Description (optionnel)" 
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#666"/>
                            <Editor x:Name="DescriptionEditor"
                                    Placeholder="Description de la categorie..."
                                    HeightRequest="80"
                                    FontSize="14"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- IsActive Toggle -->
                    <Border BackgroundColor="#E8F5E9" 
                            Padding="12"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#4CAF50">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Categorie active" 
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#2E7D32"/>
                                <Label Text="Les categories inactives ne seront pas proposees" 
                                       FontSize="11"
                                       TextColor="#666"/>
                            </VerticalStackLayout>
                            <Switch x:Name="IsActiveSwitch"
                                    Grid.Column="1"
                                    IsToggled="True"
                                    OnColor="#4CAF50"
                                    ThumbColor="White"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>

            <!-- FOOTER -->
            <Border Grid.Row="2" 
                    BackgroundColor="#F5F5F5" 
                    Padding="15">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="15">
                    <Label x:Name="ErrorLabel"
                           TextColor="#F44336"
                           FontSize="12"
                           IsVisible="False"
                           VerticalOptions="Center"/>

                    <Button Grid.Column="1"
                            Text="Annuler" 
                            BackgroundColor="#9E9E9E"
                            TextColor="White"
                            Padding="20,10"
                            CornerRadius="8"
                            Clicked="OnCancelClicked"/>

                    <Button x:Name="SaveButton"
                            Grid.Column="2"
                            Text="Enregistrer" 
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            Padding="20,10"
                            CornerRadius="8"
                            FontAttributes="Bold"
                            Clicked="OnSaveClicked"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>
