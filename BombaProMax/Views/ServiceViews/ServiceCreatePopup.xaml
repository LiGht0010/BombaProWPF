<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.ServiceViews.ServiceCreatePopup"
               Color="Transparent">

    <Border BackgroundColor="White"       
            Padding="0"
            WidthRequest="550"
            HeightRequest="520"
            StrokeShape="RoundRectangle 12">
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- HEADER -->
            <Border Grid.Row="0" 
                    BackgroundColor="#0097A7" 
                    Padding="20">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout>
                        <Label x:Name="HeaderLabel"
                               Text="Nouveau Service" 
                               FontSize="20" 
                               FontAttributes="Bold"
                               TextColor="White"/>
                        <Label Text="Enregistrer un nouveau service" 
                               FontSize="12"
                               TextColor="#B2EBF2"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" 
                            Text="X" 
                            BackgroundColor="Transparent"
                            TextColor="White"
                            FontSize="20"
                            Clicked="OnCancelClicked"/>
                </Grid>
            </Border>

            <!-- FORM CONTENT -->
            <ScrollView Grid.Row="1" Padding="20">
                <VerticalStackLayout Spacing="15">
                    
                    <!-- Numero & Categorie -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <Border BackgroundColor="#F8F8F8" 
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#E0E0E0">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Numero (auto)" 
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#666"/>
                                <Entry x:Name="NumeroEntry"
                                       Placeholder="Genere automatiquement"
                                       IsReadOnly="True"
                                       BackgroundColor="#EEEEEE"
                                       FontSize="14"/>
                            </VerticalStackLayout>
                        </Border>
                        
                        <Border Grid.Column="1"
                                BackgroundColor="#E0F7FA" 
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#0097A7">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Categorie" 
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#00838F"/>
                                <Picker x:Name="CategoriePicker"
                                        Title="Selectionner..."
                                        FontSize="14"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Description -->
                    <Border BackgroundColor="#FFF3E0" 
                            Padding="12"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#FFB300">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Description *" 
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#E65100"/>
                            <Entry x:Name="DescriptionEntry"
                                   Placeholder="Ex: Lavage complet, Vidange moteur..."
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#E65100"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Prix -->
                    <Border BackgroundColor="#E8F5E9" 
                            Padding="12"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#4CAF50">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Prix (DH) *" 
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#2E7D32"/>
                            <Entry x:Name="PrixEntry"
                                   Placeholder="0.00"
                                   Keyboard="Numeric"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#2E7D32"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Quick Prices -->
                    <Border BackgroundColor="#F5F5F5" 
                            Padding="12"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#E0E0E0">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Prix rapides" 
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#666"/>
                            <FlexLayout Wrap="Wrap" 
                                        JustifyContent="Start" 
                                        AlignItems="Center"
                                        Direction="Row">
                                <Button Text="20 DH" 
                                        Margin="0,0,8,8"
                                        Clicked="OnQuickPriceClicked"
                                        BackgroundColor="#E0F7FA"
                                        TextColor="#0097A7"
                                        FontSize="12"
                                        Padding="12,8"
                                        CornerRadius="8"/>
                                <Button Text="50 DH" 
                                        Margin="0,0,8,8"
                                        Clicked="OnQuickPriceClicked"
                                        BackgroundColor="#E0F7FA"
                                        TextColor="#0097A7"
                                        FontSize="12"
                                        Padding="12,8"
                                        CornerRadius="8"/>
                                <Button Text="80 DH" 
                                        Margin="0,0,8,8"
                                        Clicked="OnQuickPriceClicked"
                                        BackgroundColor="#E0F7FA"
                                        TextColor="#0097A7"
                                        FontSize="12"
                                        Padding="12,8"
                                        CornerRadius="8"/>
                                <Button Text="100 DH" 
                                        Margin="0,0,8,8"
                                        Clicked="OnQuickPriceClicked"
                                        BackgroundColor="#E0F7FA"
                                        TextColor="#0097A7"
                                        FontSize="12"
                                        Padding="12,8"
                                        CornerRadius="8"/>
                                <Button Text="150 DH" 
                                        Margin="0,0,8,8"
                                        Clicked="OnQuickPriceClicked"
                                        BackgroundColor="#E0F7FA"
                                        TextColor="#0097A7"
                                        FontSize="12"
                                        Padding="12,8"
                                        CornerRadius="8"/>
                                <Button Text="200 DH" 
                                        Margin="0,0,8,8"
                                        Clicked="OnQuickPriceClicked"
                                        BackgroundColor="#E0F7FA"
                                        TextColor="#0097A7"
                                        FontSize="12"
                                        Padding="12,8"
                                        CornerRadius="8"/>
                            </FlexLayout>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>

            <!-- FOOTER -->
            <Border Grid.Row="2" 
                    BackgroundColor="#F5F5F5" 
                    Padding="15">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="15">
                    <Label x:Name="ErrorLabel"
                           TextColor="#F44336"
                           FontSize="12"
                           IsVisible="False"
                           VerticalOptions="Center"/>

                    <Button Grid.Column="1"
                            Text="Annuler" 
                            BackgroundColor="#9E9E9E"
                            TextColor="White"
                            Padding="20,10"
                            CornerRadius="8"
                            Clicked="OnCancelClicked"/>

                    <Button x:Name="SaveButton"
                            Grid.Column="2"
                            Text="Enregistrer" 
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            Padding="20,10"
                            CornerRadius="8"
                            FontAttributes="Bold"
                            Clicked="OnSaveClicked"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>
