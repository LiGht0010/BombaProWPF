<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:BombaProMax.ViewModels"
             xmlns:models="clr-namespace:BombaProMax.Models"
             x:Class="BombaProMax.Views.ServiceViews.ServicePage"
             x:DataType="viewmodels:ServiceViewModel"
             Style="{StaticResource ServicePageStyle}">

    <Grid RowDefinitions="*">
        
        <ScrollView Grid.Row="0" Style="{StaticResource ServicePageScrollView}">
            <VerticalStackLayout Style="{StaticResource ServicePageMainStack}">

                <!-- HEADER -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <VerticalStackLayout Style="{StaticResource ServicePageHeaderStack}">
                        <Label Text="Gestion des Services" 
                               Style="{StaticResource ServicePageTitleLabel}"/>
                        <Label Text="Gerez les services et leurs categories" 
                               Style="{StaticResource ServicePageSubtitleLabel}"/>
                    </VerticalStackLayout>
                    
                    <Button Grid.Column="1"
                            Text="Rafraichir"
                            Style="{StaticResource ServiceAddCategoryButton}"
                            Command="{Binding InitializeCommand}"
                            VerticalOptions="Center"/>
                </Grid>

                <!-- STATS CARDS -->
                <Grid ColumnDefinitions="*,*,*,*" 
                      ColumnSpacing="16"
                      IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                    
                    <Border Grid.Column="0" Style="{StaticResource ServiceStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding TotalServices}" 
                                   Style="{StaticResource ServiceStatNumber}"
                                   TextColor="#0097A7"/>
                            <Label Text="Services" 
                                   Style="{StaticResource ServiceStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource ServiceStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding TotalRevenue, StringFormat='{0:N2}'}" 
                                   Style="{StaticResource ServiceStatNumber}"
                                   TextColor="#5EAA8D"/>
                            <Label Text="DH Total" 
                                   Style="{StaticResource ServiceStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource ServiceStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding TotalCategories}" 
                                   Style="{StaticResource ServiceStatNumber}"
                                   TextColor="#FF9800"/>
                            <Label Text="Categories" 
                                   Style="{StaticResource ServiceStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource ServiceStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding AveragePrice, StringFormat='{0:N2}'}" 
                                   Style="{StaticResource ServiceStatNumber}"
                                   TextColor="#7B1FA2"/>
                            <Label Text="DH Moy." 
                                   Style="{StaticResource ServiceStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   HeightRequest="50"
                                   WidthRequest="50"
                                   Color="#0097A7"/>

                <!-- TABS CARD -->
                <Border Style="{StaticResource ServiceTableCard}"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                    <VerticalStackLayout Style="{StaticResource ServiceTableContainer}">
                        
                        <!-- Tab Headers -->
                        <Grid ColumnDefinitions="*,*" 
                              BackgroundColor="{StaticResource ServiceNeuPrimary}"
                              Padding="0">
                            <Button x:Name="ServicesTabButton"
                                    Grid.Column="0"
                                    Text="Services"
                                    BackgroundColor="#0097A7"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    CornerRadius="0"
                                    Padding="20,14"
                                    Clicked="OnServicesTabClicked"/>
                            <Button x:Name="CategoriesTabButton"
                                    Grid.Column="1"
                                    Text="Categories"
                                    BackgroundColor="#00838F"
                                    TextColor="#B2EBF2"
                                    FontSize="14"
                                    CornerRadius="0"
                                    Padding="20,14"
                                    Clicked="OnCategoriesTabClicked"/>
                        </Grid>

                        <!-- TAB 1: SERVICES -->
                        <VerticalStackLayout x:Name="ServicesTab" 
                                             Spacing="0"
                                             Padding="0">
                            
                            <!-- Filters & Add Button Row -->
                            <Border BackgroundColor="{StaticResource ServiceNeuCardBg}" 
                                    Padding="20"
                                    StrokeThickness="0">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="12">
                                    <Label Text="Categorie:" 
                                           TextColor="{StaticResource ServiceNeuTextSecondary}"
                                           FontSize="13"
                                           VerticalTextAlignment="Center"/>
                                    <Picker Grid.Column="1"
                                            ItemsSource="{Binding Categories}"
                                            SelectedItem="{Binding SelectedCategory}"
                                            ItemDisplayBinding="{Binding Nom}"
                                            Title="Toutes"
                                            TextColor="{StaticResource ServiceNeuTextPrimary}"
                                            FontSize="14"/>
                                    <Button Grid.Column="2"
                                            Text="Filtrer"
                                            Command="{Binding FilterByCategoryCommand}"
                                            BackgroundColor="#E8ECF1"
                                            TextColor="#5A6068"
                                            FontSize="13"
                                            Padding="16,10"
                                            CornerRadius="8"/>
                                    <Button Grid.Column="3"
                                            Text="Reset"
                                            Command="{Binding LoadServicesCommand}"
                                            BackgroundColor="#78909C"
                                            TextColor="White"
                                            FontSize="13"
                                            Padding="16,10"
                                            CornerRadius="8"/>
                                    <Button Grid.Column="4"
                                            Text="+ Nouveau Service"
                                            Style="{StaticResource ServiceAddButton}"
                                            Clicked="OnAddServiceClicked"/>
                                </Grid>
                            </Border>

                            <!-- Services Table Header -->
                            <Grid Style="{StaticResource ServiceTableHeaderGrid}">
                                <Label Grid.Column="0" Text="Numero" Style="{StaticResource ServiceTableHeaderLabel}"/>
                                <Label Grid.Column="1" Text="Description" Style="{StaticResource ServiceTableHeaderLabelLeft}"/>
                                <Label Grid.Column="2" Text="Prix" Style="{StaticResource ServiceTableHeaderLabel}"/>
                                <Label Grid.Column="3" Text="Categorie" Style="{StaticResource ServiceTableHeaderLabel}"/>
                                <Label Grid.Column="4" Text="Actions" Style="{StaticResource ServiceTableHeaderLabel}"/>
                            </Grid>

                            <!-- Services Rows -->
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Services}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:ServiceDto">
                                        <VerticalStackLayout BackgroundColor="Transparent">
                                            <Grid Style="{StaticResource ServiceTableRowGrid}">
                                                
                                                <!-- Numero -->
                                                <Border Grid.Column="0" Style="{StaticResource ServiceNumberCell}">
                                                    <Label Text="{Binding Numero, FallbackValue='-'}" 
                                                           Style="{StaticResource ServiceNumberLabel}"/>
                                                </Border>

                                                <!-- Description -->
                                                <VerticalStackLayout Grid.Column="1" Style="{StaticResource ServiceDescriptionCell}">
                                                    <Label Text="{Binding Description, FallbackValue='Service sans description'}" 
                                                           Style="{StaticResource ServiceDescriptionLabel}"/>
                                                </VerticalStackLayout>

                                                <!-- Prix -->
                                                <Border Grid.Column="2" Style="{StaticResource ServicePriceCell}">
                                                    <Label Text="{Binding Prix, StringFormat='{0:N2} DH'}" 
                                                           Style="{StaticResource ServicePriceLabel}"/>
                                                </Border>

                                                <!-- Categorie -->
                                                <Border Grid.Column="3" Style="{StaticResource ServiceCategoryBadgeCell}">
                                                    <Label Text="{Binding ServiceCategorieNom, FallbackValue='Non categorise'}" 
                                                           Style="{StaticResource ServiceCategoryBadgeLabel}"/>
                                                </Border>

                                                <!-- Actions -->
                                                <HorizontalStackLayout Grid.Column="4" Style="{StaticResource ServiceActionsCell}">
                                                    <Button Text="Modifier"
                                                            Style="{StaticResource ServiceModifierButton}"
                                                            Clicked="OnEditServiceClicked"
                                                            CommandParameter="{Binding .}"/>
                                                    <Button Text="Supprimer"
                                                            Style="{StaticResource ServiceSupprimerButton}"
                                                            Clicked="OnDeleteServiceClicked"
                                                            CommandParameter="{Binding .}"/>
                                                </HorizontalStackLayout>
                                            </Grid>
                                            <BoxView Style="{StaticResource ServiceRowDivider}"/>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                                
                                <BindableLayout.EmptyView>
                                    <VerticalStackLayout Style="{StaticResource ServiceEmptyView}">
                                        <Border BackgroundColor="#EEF1F5"
                                                WidthRequest="100"
                                                HeightRequest="100"
                                                StrokeThickness="0"
                                                Margin="0,0,0,16">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="50"/>
                                            </Border.StrokeShape>
                                            <Border.Shadow>
                                                <Shadow Brush="#C5CAD1" Offset="6,6" Radius="12" Opacity="0.25"/>
                                            </Border.Shadow>
                                            <Label Text="S" FontSize="48" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                        <Label Text="Aucun service trouve" Style="{StaticResource ServiceEmptyTitle}"/>
                                        <Label Text="Commencez par ajouter un nouveau service" 
                                               Style="{StaticResource ServiceEmptySubtitle}"/>
                                        <Button Text="+ Nouveau Service"
                                                Style="{StaticResource ServiceEmptyButton}"
                                                Clicked="OnAddServiceClicked"/>
                                    </VerticalStackLayout>
                                </BindableLayout.EmptyView>
                            </VerticalStackLayout>
                        </VerticalStackLayout>

                        <!-- TAB 2: CATEGORIES -->
                        <VerticalStackLayout x:Name="CategoriesTab" 
                                             Spacing="0"
                                             Padding="0"
                                             IsVisible="False">
                            
                            <!-- Add Button Row -->
                            <Border BackgroundColor="{StaticResource ServiceNeuCardBg}" 
                                    Padding="20"
                                    StrokeThickness="0">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                        <CheckBox IsChecked="{Binding ShowInactiveCategories}"
                                                  Color="{StaticResource ServiceNeuPrimary}"/>
                                        <Label Text="Afficher les categories inactives" 
                                               TextColor="{StaticResource ServiceNeuTextSecondary}"
                                               FontSize="13"
                                               VerticalTextAlignment="Center"/>
                                    </HorizontalStackLayout>
                                    <Button Grid.Column="1"
                                            Text="Reset"
                                            Command="{Binding LoadCategoriesListCommand}"
                                            BackgroundColor="#78909C"
                                            TextColor="White"
                                            FontSize="13"
                                            Padding="16,10"
                                            CornerRadius="8"/>
                                    <Button Grid.Column="2"
                                            Text="+ Nouvelle Categorie"
                                            Style="{StaticResource ServiceAddButton}"
                                            Clicked="OnAddCategorieClicked"/>
                                </Grid>
                            </Border>

                            <!-- Categories Table Header -->
                            <Grid ColumnDefinitions="1.5*,2*,1*,1*"
                                  ColumnSpacing="8"
                                  Padding="20,16"
                                  BackgroundColor="{StaticResource ServiceNeuPrimary}">
                                <Label Grid.Column="0" Text="Nom" Style="{StaticResource ServiceTableHeaderLabelLeft}"/>
                                <Label Grid.Column="1" Text="Description" Style="{StaticResource ServiceTableHeaderLabelLeft}"/>
                                <Label Grid.Column="2" Text="Statut" Style="{StaticResource ServiceTableHeaderLabel}"/>
                                <Label Grid.Column="3" Text="Actions" Style="{StaticResource ServiceTableHeaderLabel}"/>
                            </Grid>

                            <!-- Categories Loading -->
                            <ActivityIndicator IsRunning="{Binding IsCategoriesLoading}"
                                               IsVisible="{Binding IsCategoriesLoading}"
                                               HeightRequest="50"
                                               WidthRequest="50"
                                               Color="#0097A7"/>

                            <!-- Categories Rows -->
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding CategoriesList}"
                                                 IsVisible="{Binding IsCategoriesLoading, Converter={StaticResource InvertedBoolConverter}}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:ServiceCategorieDto">
                                        <VerticalStackLayout BackgroundColor="Transparent">
                                            <Grid ColumnDefinitions="1.5*,2*,1*,1*"
                                                  ColumnSpacing="8"
                                                  Padding="20,14"
                                                  BackgroundColor="Transparent"
                                                  MinimumHeightRequest="60">
                                                
                                                <!-- Nom -->
                                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                                    <Label Text="{Binding Nom}" 
                                                           TextColor="{StaticResource ServiceNeuTextPrimary}"
                                                           FontSize="14"
                                                           FontAttributes="Bold"/>
                                                </VerticalStackLayout>

                                                <!-- Description -->
                                                <Label Grid.Column="1" 
                                                       Text="{Binding Description, TargetNullValue='-'}" 
                                                       TextColor="{StaticResource ServiceNeuTextSecondary}"
                                                       FontSize="13"
                                                       VerticalTextAlignment="Center"
                                                       LineBreakMode="TailTruncation"/>

                                                <!-- Statut Badge -->
                                                <Border Grid.Column="2"
                                                        BackgroundColor="{Binding IsActive, Converter={StaticResource BoolToColorConverter}}"
                                                        HeightRequest="28"
                                                        Padding="12,0"
                                                        StrokeThickness="0"
                                                        HorizontalOptions="Center"
                                                        VerticalOptions="Center">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="14"/>
                                                    </Border.StrokeShape>
                                                    <Label Text="{Binding IsActive, Converter={StaticResource BoolToTextConverter}, ConverterParameter='Actif|Inactif'}"
                                                           TextColor="White"
                                                           FontSize="10"
                                                           FontAttributes="Bold"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalTextAlignment="Center"/>
                                                </Border>

                                                <!-- Actions -->
                                                <HorizontalStackLayout Grid.Column="3" Style="{StaticResource ServiceActionsCell}">
                                                    <Button Text="Modifier"
                                                            Style="{StaticResource ServiceModifierButton}"
                                                            Clicked="OnEditCategorieClicked"
                                                            CommandParameter="{Binding .}"/>
                                                    <Button Text="Supprimer"
                                                            Style="{StaticResource ServiceSupprimerButton}"
                                                            Clicked="OnDeleteCategorieClicked"
                                                            CommandParameter="{Binding .}"/>
                                                </HorizontalStackLayout>
                                            </Grid>
                                            <BoxView Style="{StaticResource ServiceRowDivider}"/>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                                
                                <BindableLayout.EmptyView>
                                    <VerticalStackLayout Style="{StaticResource ServiceEmptyView}">
                                        <Border BackgroundColor="#EEF1F5"
                                                WidthRequest="100"
                                                HeightRequest="100"
                                                StrokeThickness="0"
                                                Margin="0,0,0,16">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="50"/>
                                            </Border.StrokeShape>
                                            <Border.Shadow>
                                                <Shadow Brush="#C5CAD1" Offset="6,6" Radius="12" Opacity="0.25"/>
                                            </Border.Shadow>
                                            <Label Text="C" FontSize="48" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                        <Label Text="Aucune categorie trouvee" Style="{StaticResource ServiceEmptyTitle}"/>
                                        <Label Text="Commencez par ajouter une nouvelle categorie de services" 
                                               Style="{StaticResource ServiceEmptySubtitle}"/>
                                        <Button Text="+ Nouvelle Categorie"
                                                Style="{StaticResource ServiceEmptyButton}"
                                                Clicked="OnAddCategorieClicked"/>
                                    </VerticalStackLayout>
                                </BindableLayout.EmptyView>
                            </VerticalStackLayout>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>