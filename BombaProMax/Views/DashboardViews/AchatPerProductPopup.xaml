<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:models="clr-namespace:BombaProMax.Models.Dashboard"
               x:Class="BombaProMax.Views.DashboardViews.AchatPerProductPopup"
               x:DataType="models:ProductCardModel"
               Color="Transparent">

    <Border BackgroundColor="#e8e8e8"
            Padding="0"
            WidthRequest="850"
            HeightRequest="650"
            StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="20"/>
        </Border.StrokeShape>
        <Border.Shadow>
            <Shadow Brush="#000000" Offset="0,8" Radius="30" Opacity="0.2"/>
        </Border.Shadow>

        <VerticalStackLayout Spacing="0">
            
            <!-- Header -->
            <Grid Padding="24,20" ColumnDefinitions="*,Auto" BackgroundColor="#F97316">
                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label Text="{Binding ProduitNom}" 
                           FontSize="20" 
                           FontAttributes="Bold" 
                           TextColor="White"/>
                    <Label Text="{Binding CategorieNom, StringFormat='Categorie: {0}'}" 
                           FontSize="13" 
                           TextColor="#FFFFFF" 
                           Opacity="0.9"/>
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        Text="X"
                        BackgroundColor="#FFFFFF"
                        TextColor="#F97316"
                        FontSize="16"
                        FontAttributes="Bold"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="20"
                        Padding="0"
                        Clicked="OnCloseClicked"/>
            </Grid>

            <!-- Table Header -->
            <Grid Padding="24,14" 
                  BackgroundColor="#E8ECF1"
                  ColumnDefinitions="1.2*,*,*,*">
                <Label Grid.Column="0" 
                       Text="DATE ACHAT" 
                       FontSize="11" 
                       FontAttributes="Bold" 
                       TextColor="#5A6068"
                       TextTransform="Uppercase"
                       CharacterSpacing="0.5"/>
                <Label Grid.Column="1" 
                       Text="QUANTITE" 
                       FontSize="11" 
                       FontAttributes="Bold" 
                       TextColor="#5A6068"
                       TextTransform="Uppercase"
                       CharacterSpacing="0.5"
                       HorizontalTextAlignment="Center"/>
                <Label Grid.Column="2" 
                       Text="PRIX ACHAT" 
                       FontSize="11" 
                       FontAttributes="Bold" 
                       TextColor="#5A6068"
                       TextTransform="Uppercase"
                       CharacterSpacing="0.5"
                       HorizontalTextAlignment="Center"/>
                <Label Grid.Column="3" 
                       Text="PRIX TOTAL" 
                       FontSize="11" 
                       FontAttributes="Bold" 
                       TextColor="#5A6068"
                       TextTransform="Uppercase"
                       CharacterSpacing="0.5"
                       HorizontalTextAlignment="End"/>
            </Grid>

            <!-- Divider -->
            <BoxView HeightRequest="1" Color="#D1D5DB" HorizontalOptions="Fill"/>

            <!-- Table Content -->
            <CollectionView x:Name="AchatsCollectionView"
                            MaximumHeightRequest="400"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:AchatAnalyticsRowDto">
                        <VerticalStackLayout>
                            <Grid Padding="24,14" 
                                  ColumnDefinitions="1.2*,*,*,*"
                                  BackgroundColor="Transparent">
                                <Label Grid.Column="0" 
                                       Text="{Binding DateAchat, StringFormat='{0:dd/MM/yyyy}'}" 
                                       FontSize="14" 
                                       TextColor="#2E2E2E"
                                       VerticalTextAlignment="Center"/>
                                <Label Grid.Column="1" 
                                       Text="{Binding Quantite}" 
                                       FontSize="14" 
                                       FontAttributes="Bold"
                                       TextColor="#22C55E"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"/>
                                <Label Grid.Column="2" 
                                       Text="{Binding PrixAchat, StringFormat='{0:N2} DH'}" 
                                       FontSize="14" 
                                       TextColor="#5A6068"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"/>
                                <Label Grid.Column="3" 
                                       Text="{Binding PrixTotal, StringFormat='{0:N2} DH'}" 
                                       FontSize="14" 
                                       FontAttributes="Bold"
                                       TextColor="#F97316"
                                       HorizontalTextAlignment="End"
                                       VerticalTextAlignment="Center"/>
                            </Grid>
                            <BoxView HeightRequest="1" Color="#E5E9EF" HorizontalOptions="Fill" Margin="24,0"/>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="40" HorizontalOptions="Center">
                        <Label Text="Aucun achat trouve" 
                               FontSize="14" 
                               TextColor="#8B939E"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>

            <!-- Total Row -->
            <BoxView HeightRequest="2" Color="#F97316" HorizontalOptions="Fill"/>
            <Grid Padding="24,16" 
                  BackgroundColor="#c3c0bc"
                  ColumnDefinitions="1.2*,*,*,*">                                                                                             <!--TOTAL BACKFROUND COLOR-->
                <Label Grid.Column="0" 
                       Text="TOTAL" 
                       FontSize="14" 
                       FontAttributes="Bold" 
                       TextColor="#F97316"
                       VerticalTextAlignment="Center"/>
                <Label Grid.Column="1" 
                       x:Name="TotalQuantiteLabel"
                       FontSize="16" 
                       FontAttributes="Bold"
                       TextColor="#22C55E"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"/>
                <Label Grid.Column="2" 
                       Text="-" 
                       FontSize="14" 
                       TextColor="#8B939E"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"/>
                <Label Grid.Column="3" 
                       x:Name="TotalPrixLabel"
                       FontSize="16" 
                       FontAttributes="Bold"
                       TextColor="#F97316"
                       HorizontalTextAlignment="End"
                       VerticalTextAlignment="Center"/>
            </Grid>

            <!-- Footer with count -->
            <Grid Padding="24,14" BackgroundColor="#E8ECF1">
                <Label x:Name="CountLabel"
                       FontSize="12" 
                       TextColor="#5A6068"
                       HorizontalTextAlignment="Center"/>
            </Grid>

        </VerticalStackLayout>
    </Border>
</toolkit:Popup>