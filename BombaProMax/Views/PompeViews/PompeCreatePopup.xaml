<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.PompeViews.PompeCreatePopup"
               Color="Transparent">

    <Border BackgroundColor="#F5F5F5" Padding="0" WidthRequest="620" HeightRequest="650" StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="12"/>
        </Border.StrokeShape>
        
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- ========================================= -->
            <!-- HEADER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="0" BackgroundColor="#E91E63" Padding="20,18" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="⛽ Nouvelle Pompe" 
                               FontSize="20" 
                               FontAttributes="Bold" 
                               TextColor="White"/>
                        <Label Text="Créer une nouvelle pompe à carburant" 
                               FontSize="12" 
                               TextColor="#F8BBD9"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" 
                            Text="✕" 
                            BackgroundColor="#C2185B" 
                            TextColor="White" 
                            FontSize="16" 
                            WidthRequest="36" 
                            HeightRequest="36" 
                            CornerRadius="18" 
                            Clicked="OnCancelClicked"/>
                </Grid>
            </Border>

            <!-- ========================================= -->
            <!-- CONTENT                                   -->
            <!-- ========================================= -->
            <ScrollView Grid.Row="1" Padding="20,15">
                <VerticalStackLayout Spacing="15">
                    
                    <!-- Basic Info Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="ℹ️ INFORMATIONS DE BASE" FontSize="11" FontAttributes="Bold" TextColor="#E91E63"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                                <VerticalStackLayout Grid.Column="0" Spacing="5">
                                    <Label Text="🔢 Numéro *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="NumeroEntry"
                                           Placeholder="Ex: P-001"
                                           FontSize="14"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="5">
                                    <Label Text="📊 Statut *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Picker x:Name="StatutPicker"
                                            Title="Sélectionnez un statut"
                                            FontSize="14"/>
                                </VerticalStackLayout>
                            </Grid>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="🛢️ Réservoir Associé *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                <Picker x:Name="ReservoirPicker"
                                        Title="Sélectionnez un réservoir"
                                        FontSize="14"/>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Meters Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="📊 COMPTEURS" FontSize="11" FontAttributes="Bold" TextColor="#E91E63"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                                <VerticalStackLayout Grid.Column="0" Spacing="5">
                                    <Label Text="⚡ Compteur Électronique (L)" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="CompteurElectroniqueEntry"
                                           Placeholder="Ex: 0.00"
                                           Keyboard="Numeric"
                                           FontSize="14"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="5">
                                    <Label Text="⚙️ Compteur Mécanique (L)" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="CompteurMecaniqueEntry"
                                           Placeholder="Ex: 0.00"
                                           Keyboard="Numeric"
                                           FontSize="14"/>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Info Note Card -->
                    <Border BackgroundColor="#E8F5E9" Padding="12" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="💡" FontSize="16" VerticalOptions="Center"/>
                            <Label Text="Les compteurs peuvent être laissés vides et seront initialisés à 0.00 L"
                                   FontSize="12"
                                   TextColor="#2E7D32"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ========================================= -->
            <!-- FOOTER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="2" BackgroundColor="White" Padding="20,15" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,-2" Radius="6" Opacity="0.06"/>
                </Border.Shadow>
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                    <Label x:Name="ErrorLabel" 
                           TextColor="#F44336" 
                           FontSize="12" 
                           IsVisible="False" 
                           VerticalOptions="Center"/>
                    <Button Grid.Column="1" 
                            Text="Annuler" 
                            BackgroundColor="#9E9E9E" 
                            TextColor="White" 
                            Padding="25,12" 
                            CornerRadius="8" 
                            Clicked="OnCancelClicked"/>
                    <Button Grid.Column="2" 
                            Text="✓ Créer la pompe" 
                            BackgroundColor="#4CAF50" 
                            TextColor="White" 
                            Padding="25,12" 
                            CornerRadius="8" 
                            FontAttributes="Bold" 
                            Clicked="OnCreateClicked"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>
