<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BombaProMax.Models"
             xmlns:viewmodels="clr-namespace:BombaProMax.ViewModels"
             x:Class="BombaProMax.Views.PompeViews.PompePage"
             x:DataType="viewmodels:PompeViewModel"
             Style="{StaticResource PompePageStyle}">

    <Grid RowDefinitions="*,Auto">
        <!-- Main Content -->
        <ScrollView Grid.Row="0" Style="{StaticResource PompePageScrollView}">
            <VerticalStackLayout Style="{StaticResource PompePageMainStack}">

                <!-- JOURNÉE PROGRESS BAR -->
                <Border BackgroundColor="#E3F2FD" Padding="15" Margin="0,0,0,10"
                        IsVisible="{Binding IsJourneeActive}" StrokeShape="RoundRectangle 10" Stroke="#1976D2">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Text="🚀" FontSize="24" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Margin="10,0">
                            <Label Text="{Binding JourneeStepInfo}" FontAttributes="Bold" TextColor="#1976D2" FontSize="14"/>
                            <Label Text="Journée en cours - Suivez les étapes" TextColor="#666" FontSize="11"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="📋" FontSize="20" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- ========================================= -->
                <!-- HEADER SECTION with Action Button         -->
                <!-- ========================================= -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <VerticalStackLayout Style="{StaticResource PompePageHeaderStack}">
                        <Label Text="Gestion des Pompes" 
                               Style="{StaticResource PompePageTitleLabel}"/>
                        <Label Text="{Binding Pompes.Count, StringFormat='{0} pompes enregistrées'}" 
                               Style="{StaticResource PompePageSubtitleLabel}"/>
                    </VerticalStackLayout>
                    
                    <!-- Add Button -->
                    <Button Grid.Column="1"
                            Text="+ Nouvelle Pompe"
                            Style="{StaticResource PompeAddButton}"
                            Command="{Binding AddPompeCommand}"
                            VerticalOptions="Center"
                            IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"/>
                </Grid>

                <!-- ========================================= -->
                <!-- STATS CARDS ROW - Neumorphic Raised       -->
                <!-- ========================================= -->
                <Grid ColumnDefinitions="*,*,*,*" 
                      ColumnSpacing="16"
                      IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                    
                    <!-- Total Pompes -->
                    <Border Grid.Column="0" Style="{StaticResource PompeStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Pompes.Count}" 
                                   Style="{StaticResource PompeStatNumber}"/>
                            <Label Text="Total Pompes" 
                                   Style="{StaticResource PompeStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Actives -->
                    <Border Grid.Column="1" Style="{StaticResource PompeStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding ActivesCount}" 
                                   Style="{StaticResource PompeStatNumber}"
                                   TextColor="#5EAA8D"/>
                            <Label Text="Actives" 
                                   Style="{StaticResource PompeStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- En Maintenance -->
                    <Border Grid.Column="2" Style="{StaticResource PompeStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding MaintenanceCount}" 
                                   Style="{StaticResource PompeStatNumber}"
                                   TextColor="#E8A84C"/>
                            <Label Text="Maintenance" 
                                   Style="{StaticResource PompeStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Hors Service -->
                    <Border Grid.Column="3" Style="{StaticResource PompeStatCard}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ShowHighDiscrepancyCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding HorsServiceCount}" 
                                   Style="{StaticResource PompeStatNumber}"
                                   TextColor="#E16C6C"/>
                            <Label Text="Hors Service" 
                                   Style="{StaticResource PompeStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- ========================================= -->
                <!-- SEARCH BAR - Neumorphic Inset             -->
                <!-- ========================================= -->
                <Border Style="{StaticResource PompeSearchContainer}"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Image Source="search.png"
                               WidthRequest="24"
                               HeightRequest="24"/>

                        <Entry Grid.Column="1"
                               Placeholder="Rechercher par numéro, statut, réservoir..."
                               Text="{Binding SearchText}"
                               Style="{StaticResource PompeSearchEntry}"/>
                        <Button Grid.Column="2"
                                Text="Rechercher"
                                Command="{Binding SearchPompesCommand}"
                                BackgroundColor="#E8ECF1"
                                TextColor="#5A6068"
                                FontSize="13"
                                FontAttributes="Bold"
                                Padding="16,10"
                                CornerRadius="10"/>
                    </Grid>
                </Border>

                <!-- Loading Indicator -->
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                  IsVisible="{Binding IsLoading}"
                                  HeightRequest="50"
                                  WidthRequest="50"
                                  Color="#4A8FBF"/>

                <!-- ========================================= -->
                <!-- TABLE CARD - Neumorphic Raised Container  -->
                <!-- ========================================= -->
                <Border Style="{StaticResource PompeTableCard}"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                    <VerticalStackLayout Style="{StaticResource PompeTableContainer}">

                        <!-- Table Header -->
                        <Grid Style="{StaticResource PompeTableHeaderGrid}">
                            <Label Grid.Column="0" 
                                   Text="ID" 
                                   Style="{StaticResource PompeTableHeaderLabel}"/>
                            <Label Grid.Column="1" 
                                   Text="Numéro" 
                                   Style="{StaticResource PompeTableHeaderLabel}"/>
                            <Label Grid.Column="2" 
                                   Text="Statut" 
                                   Style="{StaticResource PompeTableHeaderLabel}"/>
                            <Label Grid.Column="3" 
                                   Text="Réservoir" 
                                   Style="{StaticResource PompeTableHeaderLabel}"/>
                            <Label Grid.Column="4" 
                                   Text="Compteurs (L)" 
                                   Style="{StaticResource PompeTableHeaderLabel}"/>
                            <Label Grid.Column="5" 
                                   Text="Actions" 
                                   Style="{StaticResource PompeTableHeaderLabel}"/>
                        </Grid>

                        <!-- Table Rows with SwipeView -->
                        <CollectionView ItemsSource="{Binding Pompes}"
                                        Style="{StaticResource PompeTableCollectionView}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:PompeDto">
                                    <SwipeView BackgroundColor="Transparent">
                                        <!-- Left Swipe Actions -->
                                        <SwipeView.LeftItems>
                                            <SwipeItems Mode="Reveal">
                                                <SwipeItem Text="Détails"
                                                           BackgroundColor="#8FA3B8"
                                                           Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:PompeViewModel}}, Path=ShowDetailsCommand}"
                                                           CommandParameter="{Binding .}"/>
                                                <SwipeItem Text="Modifier"
                                                           BackgroundColor="#4A8FBF"
                                                           Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:PompeViewModel}}, Path=EditPompeCommand}"
                                                           CommandParameter="{Binding .}"/>
                                            </SwipeItems>
                                        </SwipeView.LeftItems>

                                        <!-- Right Swipe Actions -->
                                        <SwipeView.RightItems>
                                            <SwipeItems Mode="Reveal">
                                                <SwipeItem Text="Supprimer"
                                                           BackgroundColor="#E16C6C"
                                                           Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:PompeViewModel}}, Path=DeletePompeCommand}"
                                                           CommandParameter="{Binding .}"/>
                                            </SwipeItems>
                                        </SwipeView.RightItems>

                                        <!-- Row Content -->
                                        <VerticalStackLayout BackgroundColor="Transparent">
                                            <Grid Style="{StaticResource PompeTableRowGrid}">
                                                <Grid.GestureRecognizers>
                                                    <TapGestureRecognizer 
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:PompeViewModel}}, Path=ShowPompeRowDetailsCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Grid.GestureRecognizers>

                                                <!-- ID - Neumorphic Pill -->
                                                <Border Grid.Column="0" 
                                                        Style="{StaticResource PompeIdCell}">
                                                    <Label Text="{Binding ID}" 
                                                           Style="{StaticResource PompeIdLabel}"/>
                                                </Border>

                                                <!-- Numero Badge - Neumorphic -->
                                                <Border Grid.Column="1" 
                                                        Style="{StaticResource PompeNumeroBadge}">
                                                    <Label Text="{Binding Numero, FallbackValue='N/A'}" 
                                                           Style="{StaticResource PompeNumeroLabel}"/>
                                                </Border>

                                                <!-- Statut Badge - Neumorphic with dynamic color -->
                                                <Border Grid.Column="2" 
                                                        Style="{StaticResource PompeStatutBadge}">
                                                    <Label Text="{Binding Statut, FallbackValue='N/A'}" 
                                                           Style="{StaticResource PompeStatutLabel}"/>
                                                </Border>

                                                <!-- Reservoir - Neumorphic Badge -->
                                                <Border Grid.Column="3"
                                                        Style="{StaticResource PompeNumeroBadge}">
                                                    <Label Text="{Binding ReservoirNumero, FallbackValue='Non assigné'}"
                                                           Style="{StaticResource PompeNumeroLabel}"/>
                                                </Border>

                                                <!-- Meters (Electronic / Mechanical) -->
                                                <VerticalStackLayout Grid.Column="4" 
                                                                    Spacing="4"
                                                                    VerticalOptions="Center">
                                                    <Label Text="{Binding CompteurElectroniqueActuel, StringFormat='E: {0:N2}', FallbackValue='E: N/A'}" 
                                                           Style="{StaticResource PompeMetersLabel}"/>
                                                    <Label Text="{Binding CompteurMecaniqueActuel, StringFormat='M: {0:N2}', FallbackValue='M: N/A'}" 
                                                           Style="{StaticResource PompeMetersLabel}"/>
                                                </VerticalStackLayout>

                                                <!-- Actions -->
                                                <HorizontalStackLayout Grid.Column="5" 
                                                                       Style="{StaticResource PompeActionsCell}">
                                                    <Button Text="Détails"
                                                            Style="{StaticResource PompeDetailsButton}"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:PompeViewModel}}, Path=ShowDetailsCommand}"
                                                            CommandParameter="{Binding .}"/>
                                                    <Button Text="Modifier"
                                                            Style="{StaticResource PompeModifierButton}"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:PompeViewModel}}, Path=EditPompeCommand}"
                                                            CommandParameter="{Binding .}"/>
                                                    <Button Text="Supprimer"
                                                            Style="{StaticResource PompeSupprimerButton}"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:PompeViewModel}}, Path=DeletePompeCommand}"
                                                            CommandParameter="{Binding .}"/>
                                                </HorizontalStackLayout>
                                            </Grid>

                                            <!-- Row Divider -->
                                            <BoxView Style="{StaticResource PompeRowDivider}"/>
                                        </VerticalStackLayout>
                                    </SwipeView>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                            <!-- Modern Empty View - Neumorphic Style -->
                            <CollectionView.EmptyView>
                                <VerticalStackLayout Style="{StaticResource PompeEmptyView}">
                                    <!-- Neumorphic Icon Container -->
                                    <Border BackgroundColor="#EEF1F5"
                                            WidthRequest="100"
                                            HeightRequest="100"
                                            StrokeThickness="0"
                                            Margin="0,0,0,16">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="50"/>
                                        </Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="#C5CAD1"
                                                    Offset="6,6"
                                                    Radius="12"
                                                    Opacity="0.25"/>
                                        </Border.Shadow>
                                        <Label Text="⛽"
                                               FontSize="48"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>
                                    <Label Text="Aucune pompe disponible" 
                                           Style="{StaticResource PompeEmptyTitle}"/>
                                    <Label Text="Commencez par ajouter votre première pompe pour gérer vos distributions" 
                                           Style="{StaticResource PompeEmptySubtitle}"/>
                                    <Button Text="+ Ajouter une Pompe"
                                            Style="{StaticResource PompeEmptyButton}"
                                            Command="{Binding AddPompeCommand}"/>
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- JOURNÉE NAVIGATION BAR -->
        <Border Grid.Row="1" BackgroundColor="#F5F5F5" Padding="15" IsVisible="{Binding IsJourneeActive}" StrokeThickness="0">
            <Border.Shadow><Shadow Brush="#000" Offset="0,-2" Radius="8" Opacity="0.1"/></Border.Shadow>
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                <Button Text="← Précédent" Command="{Binding JourneePrecedentCommand}"
                        BackgroundColor="#757575" TextColor="White" Padding="20,12" CornerRadius="8"
                        IsVisible="{Binding IsFirstStep, Converter={StaticResource InvertedBoolConverter}}"/>
                <BoxView Grid.Column="1" Color="Transparent"/>
                <Button Grid.Column="2" Text="Passer cette étape" Command="{Binding JourneePasserCommand}"
                        BackgroundColor="#FFA726" TextColor="White" Padding="20,12" CornerRadius="8"/>
                <Button Grid.Column="3" Text="{Binding IsLastStep, Converter={StaticResource BoolToTextConverter}, ConverterParameter='Terminer la journée|Suivant →'}"
                        Command="{Binding JourneeSuivantCommand}" BackgroundColor="#4CAF50" TextColor="White"
                        Padding="20,12" CornerRadius="8" FontAttributes="Bold"/>
            </Grid>
        </Border>
    </Grid>
</ContentPage>