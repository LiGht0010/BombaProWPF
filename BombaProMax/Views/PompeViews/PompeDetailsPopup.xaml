<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.PompeViews.PompeDetailsPopup"
               Color="Transparent">

    <Border BackgroundColor="#F5F5F5" Padding="0" WidthRequest="700" HeightRequest="850" StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="12"/>
        </Border.StrokeShape>
        
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- ========================================= -->
            <!-- HEADER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="0" BackgroundColor="#E91E63" Padding="20,18" StrokeThickness="0">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                    <Border Grid.Column="0"
                            BackgroundColor="White"
                            WidthRequest="50"
                            HeightRequest="50"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="25"/>
                        </Border.StrokeShape>
                        <Label Text="⛽" 
                               FontSize="24"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                        <Label x:Name="PompeNumeroLabel"
                               FontSize="20" 
                               FontAttributes="Bold"
                               TextColor="White"/>
                        <Label x:Name="PompeStatutLabel"
                               FontSize="12"
                               TextColor="#F8BBD9"/>
                        <Label x:Name="PompeIdLabel"
                               FontSize="10"
                               TextColor="#F8BBD9"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="2" 
                            Text="✕" 
                            BackgroundColor="#C2185B" 
                            TextColor="White" 
                            FontSize="16" 
                            WidthRequest="36" 
                            HeightRequest="36" 
                            CornerRadius="18" 
                            Clicked="OnCloseClicked"/>
                </Grid>
            </Border>

            <!-- ========================================= -->
            <!-- CONTENT                                   -->
            <!-- ========================================= -->
            <ScrollView Grid.Row="1" Padding="20,15">
                <VerticalStackLayout Spacing="15">
                    
                    <!-- Stats Cards Row -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto" RowSpacing="12">
                        <!-- Electronic Meter Card -->
                        <Border Grid.Row="0" Grid.Column="0" BackgroundColor="White" Padding="15" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Label Text="📊" FontSize="26" HorizontalOptions="Center"/>
                                <Label x:Name="CompteurElectroniqueLabel"
                                       Text="0.00 L"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       TextColor="#1565C0"/>
                                <Label Text="Compteur Électronique"
                                       FontSize="11"
                                       HorizontalOptions="Center"
                                       TextColor="#666"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Mechanical Meter Card -->
                        <Border Grid.Row="0" Grid.Column="1" BackgroundColor="White" Padding="15" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Label Text="⚙️" FontSize="26" HorizontalOptions="Center"/>
                                <Label x:Name="CompteurMecaniqueLabel"
                                       Text="0.00 L"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       TextColor="#2E7D32"/>
                                <Label Text="Compteur Mécanique"
                                       FontSize="11"
                                       HorizontalOptions="Center"
                                       TextColor="#666"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Discrepancy Card -->
                        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" BackgroundColor="White" Padding="15" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Label Text="🔍" FontSize="26" HorizontalOptions="Center"/>
                                <Label x:Name="DiscrepancyLabel"
                                       Text="0.00 L"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       TextColor="#E65100"/>
                                <Label Text="Écart entre Compteurs"
                                       FontSize="11"
                                       HorizontalOptions="Center"
                                       TextColor="#666"/>
                                <Label x:Name="DiscrepancyStatusLabel"
                                       FontSize="10"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Pump Details Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="ℹ️ INFORMATIONS DÉTAILLÉES" FontSize="11" FontAttributes="Bold" TextColor="#E91E63"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" 
                                  ColumnDefinitions="180,*"
                                  RowSpacing="10">
                                <Label Grid.Row="0" Grid.Column="0" Text="Numéro:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="0" Grid.Column="1" x:Name="NumeroDetailLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="1" Grid.Column="0" Text="Statut:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="1" Grid.Column="1" x:Name="StatutDetailLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="2" Grid.Column="0" Text="Réservoir Associé:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="2" Grid.Column="1" x:Name="ReservoirDetailLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="3" Grid.Column="0" Text="Type de Carburant:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="3" Grid.Column="1" x:Name="CarburantDetailLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="4" Grid.Column="0" Text="Compteur Électronique:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="4" Grid.Column="1" x:Name="CompteurElectroniqueDetailLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="5" Grid.Column="0" Text="Compteur Mécanique:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="5" Grid.Column="1" x:Name="CompteurMecaniqueDetailLabel" FontSize="12" TextColor="#333"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Reservoir Info Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="🛢️ INFORMATIONS RÉSERVOIR" FontSize="11" FontAttributes="Bold" TextColor="#E91E63"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <Grid RowDefinitions="Auto,Auto,Auto" 
                                  ColumnDefinitions="180,*"
                                  RowSpacing="10">
                                <Label Grid.Row="0" Grid.Column="0" Text="Numéro Réservoir:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="0" Grid.Column="1" x:Name="ReservoirNumeroLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="1" Grid.Column="0" Text="Capacité Réservoir:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="1" Grid.Column="1" x:Name="ReservoirCapaciteLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="2" Grid.Column="0" Text="Niveau Actuel:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="2" Grid.Column="1" x:Name="ReservoirNiveauLabel" FontSize="12" TextColor="#333"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Audit Info Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="📅 INFORMATIONS D'AUDIT" FontSize="11" FontAttributes="Bold" TextColor="#E91E63"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" 
                                  ColumnDefinitions="180,*"
                                  RowSpacing="10">
                                <Label Grid.Row="0" Grid.Column="0" Text="Créé le:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="0" Grid.Column="1" x:Name="DateCreationLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="1" Grid.Column="0" Text="Ajouté par:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="1" Grid.Column="1" x:Name="AjouteParLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="2" Grid.Column="0" Text="Modifié le:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="2" Grid.Column="1" x:Name="DateModificationLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="3" Grid.Column="0" Text="Modifié par:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="3" Grid.Column="1" x:Name="ModifieParLabel" FontSize="12" TextColor="#333"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ========================================= -->
            <!-- FOOTER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="2" BackgroundColor="White" Padding="20,15" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,-2" Radius="6" Opacity="0.06"/>
                </Border.Shadow>
                <Button Text="✓ Fermer" 
                        BackgroundColor="#E91E63" 
                        TextColor="White" 
                        Padding="30,12" 
                        CornerRadius="8"
                        FontAttributes="Bold"
                        HorizontalOptions="End"
                        Clicked="OnCloseClicked"/>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>
