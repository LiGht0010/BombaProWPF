<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.PeriodeViews.PeriodeViewPopup">

    <Border BackgroundColor="#F5F5F5" Padding="0" WidthRequest="1300" HeightRequest="800" StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="16"/>
        </Border.StrokeShape>
        
        <Grid RowDefinitions="Auto,*">
            
            <!-- HEADER -->
            <Border Grid.Row="0" BackgroundColor="#1976D2" Padding="25,18" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="HeaderLabel" Text="Details de la Periode" FontSize="22" FontAttributes="Bold" TextColor="White"/>
                        <HorizontalStackLayout Spacing="25">
                            <Label x:Name="DateRangeLabel" Text="01/01/2025 10:00 - 10:00" FontSize="13" TextColor="#B3E5FC"/>
                            <Label x:Name="EmployeLabel" Text="Employe: Non assigne" FontSize="13" TextColor="#B3E5FC"/>
                            <Label x:Name="DureeLabel" Text="Duree: 8h 00min" FontSize="13" TextColor="#B3E5FC"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="X" BackgroundColor="#1565C0" TextColor="White" FontSize="16" WidthRequest="36" HeightRequest="36" CornerRadius="18" Clicked="OnCloseClicked"/>
                </Grid>
            </Border>
            
            <!-- CONTENT -->
            <ScrollView Grid.Row="1" Padding="25,20">
                <VerticalStackLayout Spacing="20">
                    
                    <!-- ROW 1: Financial Analytics -->
                    <Border BackgroundColor="White" Padding="20" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="150,*" ColumnSpacing="30">
                            <!-- Quantite Totale -->
                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label Text="Quantite Totale" FontSize="12" TextColor="#666"/>
                                <Label x:Name="TotalQuantiteLabel" Text="0.00 L" FontSize="26" FontAttributes="Bold" TextColor="#333"/>
                            </VerticalStackLayout>
                            <!-- Financial metrics -->
                            <Grid Grid.Column="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="40">
                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <Label Text="TPE" FontSize="12" TextColor="#666"/>
                                    <Label x:Name="TPELabel" Text="0.00 MAD" FontSize="18" FontAttributes="Bold" TextColor="#1976D2"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="Especes" FontSize="12" TextColor="#666"/>
                                    <Label x:Name="EspecesLabel" Text="0.00 MAD" FontSize="18" FontAttributes="Bold" TextColor="#2E7D32"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="2" Spacing="4">
                                    <Label Text="Recette" FontSize="12" TextColor="#666"/>
                                    <Label x:Name="RecetteLabel" Text="0.00 MAD" FontSize="18" FontAttributes="Bold" TextColor="#E65100"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="3" Spacing="4">
                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="Ecart" FontSize="12" TextColor="#666"/>
                                        <Label x:Name="EcartPercentLabel" Text="(0%)" FontSize="11" TextColor="#999"/>
                                    </HorizontalStackLayout>
                                    <Label x:Name="EcartLabel" Text="0.00 MAD" FontSize="18" FontAttributes="Bold" TextColor="#C62828"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Grid>
                    </Border>
                    
                    <!-- ROW 2: Totaux par Reservoir + Totaux par Produit -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                        <!-- Totaux par Reservoir -->
                        <Border Grid.Column="0" BackgroundColor="White" Padding="20" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="12">
                                <Label Text="Totaux par Reservoir" FontSize="14" FontAttributes="Bold" TextColor="#333"/>
                                <VerticalStackLayout x:Name="ReservoirsContainer" Spacing="8"/>
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Totaux par Produit -->
                        <Border Grid.Column="1" BackgroundColor="White" Padding="20" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="12">
                                <Label Text="Totaux par Produit" FontSize="14" FontAttributes="Bold" TextColor="#333"/>
                                <VerticalStackLayout x:Name="ProduitsContainer" Spacing="8"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                    
                    <!-- ROW 3: Stock Consumption Details (Marge) -->
                    <Border BackgroundColor="White" Padding="20" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Analyse des Marges (Stock FIFO)" FontSize="14" FontAttributes="Bold" TextColor="#333"/>
                            <VerticalStackLayout x:Name="MargeContainer" Spacing="8"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1" Margin="0,5,0,0"/>
                            <HorizontalStackLayout Spacing="30">
                                <Label x:Name="TotalMargeTitleLabel" Text="TOTAL MARGE" FontSize="13" FontAttributes="Bold" TextColor="#333" VerticalOptions="Center"/>
                                <Label x:Name="TotalCoutAchatLabel" Text="Cout: 0.00 MAD" FontSize="12" TextColor="#666" VerticalOptions="Center"/>
                                <Label x:Name="TotalVenteLabel" Text="Vente: 0.00 MAD" FontSize="12" TextColor="#666" VerticalOptions="Center"/>
                                <Label x:Name="TotalMargeLabel" Text="0.00 MAD" FontSize="16" FontAttributes="Bold" TextColor="#2E7D32" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- ROW 4: PUMP DETAILS TABLE -->
                    <Border BackgroundColor="White" Padding="0" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="0">
                            <Label Text="Details par Pompe" FontSize="14" FontAttributes="Bold" TextColor="#333" Margin="20,15,20,10"/>
                            
                            <!-- Table Header - Using * for equal distribution -->
                            <Grid ColumnDefinitions="1.2*,1.2*,1.2*,*,*,*,*,1.2*,1.5*" ColumnSpacing="10" Padding="20,10" BackgroundColor="#F8F9FA">
                                <Label Grid.Column="0" Text="POMPE" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Column="1" Text="PRODUIT" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Column="2" Text="RESERVOIR" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Column="3" Text="ELEC D" FontSize="10" FontAttributes="Bold" TextColor="#1976D2" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="4" Text="ELEC F" FontSize="10" FontAttributes="Bold" TextColor="#1976D2" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="5" Text="MECA D" FontSize="10" FontAttributes="Bold" TextColor="#795548" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="6" Text="MECA F" FontSize="10" FontAttributes="Bold" TextColor="#795548" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="7" Text="QUANTITE" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="8" Text="MONTANT" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                            </Grid>
                            
                            <!-- Table Body -->
                            <VerticalStackLayout x:Name="PompesContainer" Spacing="0"/>
                            
                            <!-- Table Footer -->
                            <Grid ColumnDefinitions="1.2*,1.2*,1.2*,*,*,*,*,1.2*,1.5*" ColumnSpacing="10" Padding="20,12" BackgroundColor="#E3F2FD">
                                <Label Grid.Column="0" Text="TOTAL" FontSize="11" FontAttributes="Bold" TextColor="#1976D2"/>
                                <Label Grid.Column="7" x:Name="TotalQteFooter" Text="0.00 L" FontSize="12" FontAttributes="Bold" TextColor="#1976D2" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="8" x:Name="TotalMontantFooter" Text="0.00 MAD" FontSize="12" FontAttributes="Bold" TextColor="#1976D2" HorizontalTextAlignment="End"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                    
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Border>
</toolkit:Popup>
