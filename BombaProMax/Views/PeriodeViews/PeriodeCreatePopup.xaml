<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:models="clr-namespace:BombaProMax.Models"
               xmlns:sys="clr-namespace:System;assembly=netstandard"
               x:Class="BombaProMax.Views.PeriodeViews.PeriodeCreatePopup"
               Color="Transparent">

    <Border BackgroundColor="White"       
           Padding="0"
           WidthRequest="1400"
           HeightRequest="800"
           StrokeShape="RoundRectangle 12">
        <Grid RowDefinitions="Auto,Auto,*,Auto">
            
            <!-- ========================================= -->
            <!-- HEADER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="0" 
                    BackgroundColor="#1976D2" 
                    Padding="20">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout>
                        <Label x:Name="HeaderLabel"
                               Text="⏱️ Nouvelle Période - Relevé des Compteurs" 
                               FontSize="20" 
                               FontAttributes="Bold"
                               TextColor="White"/>
                        <Label Text="Saisissez les compteurs finaux pour chaque pompe" 
                               FontSize="12"
                               TextColor="#B3E5FC"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" 
                            Text="✕" 
                            BackgroundColor="Transparent"
                            TextColor="White"
                            FontSize="20"
                            Clicked="OnCancelClicked"/>
                </Grid>
            </Border>

            <!-- ========================================= -->
            <!-- PERIOD INFO (Date Range + Employee)       -->
            <!-- ========================================= -->
            <Border Grid.Row="1" 
                    BackgroundColor="#F5F5F5" 
                    Padding="15">
                <Grid ColumnDefinitions="Auto,Auto,*,*,*" ColumnSpacing="15">
                    <!-- Date Début -->
                    <Border Grid.Column="0"
                           BackgroundColor="White" 
                           Padding="10"
                           StrokeShape="RoundRectangle 8"
                           Stroke="#E0E0E0">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="📅 Début" 
                                   FontSize="11"
                                   TextColor="#666"/>
                            <HorizontalStackLayout Spacing="8">
                                <DatePicker x:Name="DateDebutPicker"
                                            FontSize="12"
                                            DateSelected="OnDateRangeChanged"
                                            MaximumDate="{x:Static sys:DateTime.Today}"/>
                                <TimePicker x:Name="TimeDebutPicker"
                                            FontSize="12"
                                            Format="HH:mm"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Date Fin -->
                    <Border Grid.Column="1"
                           BackgroundColor="White" 
                           Padding="10"
                           StrokeShape="RoundRectangle 8"
                           Stroke="#E0E0E0">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="📅 Fin" 
                                   FontSize="11"
                                   TextColor="#666"/>
                            <HorizontalStackLayout Spacing="8">
                                <DatePicker x:Name="DateFinPicker"
                                            FontSize="12"
                                            DateSelected="OnDateRangeChanged"
                                            MaximumDate="{x:Static sys:DateTime.Today}"/>
                                <TimePicker x:Name="TimeFinPicker"
                                            FontSize="12"
                                            Format="HH:mm"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Employé -->
                    <Border Grid.Column="2"
                           BackgroundColor="White" 
                           Padding="10"
                           StrokeShape="RoundRectangle 8"
                           Stroke="#E0E0E0">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="👤 Employé Responsable" 
                                   FontSize="11"
                                   TextColor="#666"/>
                            <Picker x:Name="EmployePicker"
                                    Title="Sélectionner..."
                                    FontSize="12"
                                    ItemDisplayBinding="{Binding Nom}"/>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- TPE (Paiement par carte) -->
                    <Border Grid.Column="3"
                           BackgroundColor="White" 
                           Padding="10"
                           StrokeShape="RoundRectangle 8"
                           Stroke="#E0E0E0">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="💳 TPE (Carte)" 
                                   FontSize="11"
                                   TextColor="#666"/>
                            <Entry x:Name="TPEEntry"
                                   Placeholder="0.00"
                                   Keyboard="Numeric"
                                   FontSize="12"
                                   TextChanged="OnPaymentValueChanged"/>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Espèces (Cash) -->
                    <Border Grid.Column="4"
                           BackgroundColor="White" 
                           Padding="10"
                           StrokeShape="RoundRectangle 8"
                           Stroke="#E0E0E0">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="💵 Espèces" 
                                   FontSize="11"
                                   TextColor="#666"/>
                            <Entry x:Name="EspecesEntry"
                                   Placeholder="0.00"
                                   Keyboard="Numeric"
                                   FontSize="12"
                                   TextChanged="OnPaymentValueChanged"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Border>

            <!-- ========================================= -->
            <!-- MAIN CONTENT: Pumps + Credit Transactions -->
            <!-- ========================================= -->
            <Grid Grid.Row="2" 
                  ColumnDefinitions="2*,*"
                  ColumnSpacing="10"
                  Margin="15,10">
                
                <!-- LEFT: Pumps List -->
                <Border Grid.Column="0"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 8"
                        Stroke="#E0E0E0">
                    <Grid RowDefinitions="Auto,*">
                        <!-- Table Header -->
                        <Grid Grid.Row="0"
                              ColumnDefinitions="0.8*,1.2*,0.8*,1.2*,1.2*,1.2*,1.2*,0.8*"
                              Padding="10,12"
                              BackgroundColor="#ECEFF1">
                            <Label Text="Pompe" FontAttributes="Bold" TextColor="#37474F" FontSize="12"/>
                            <Label Grid.Column="1" Text="Produit" FontAttributes="Bold" TextColor="#37474F" FontSize="12"/>
                            <Label Grid.Column="2" Text="Prix/L" FontAttributes="Bold" TextColor="#37474F" FontSize="12" HorizontalOptions="Center"/>
                            <Label Grid.Column="3" Text="Élec. Début" FontAttributes="Bold" TextColor="#37474F" FontSize="12" HorizontalOptions="Center"/>
                            <Label Grid.Column="4" Text="Élec. Fin" FontAttributes="Bold" TextColor="#37474F" FontSize="12" HorizontalOptions="Center"/>
                            <Label Grid.Column="5" Text="Méca. Début" FontAttributes="Bold" TextColor="#37474F" FontSize="12" HorizontalOptions="Center"/>
                            <Label Grid.Column="6" Text="Méca. Fin" FontAttributes="Bold" TextColor="#37474F" FontSize="12" HorizontalOptions="Center"/>
                            <Label Grid.Column="7" Text="Qté" FontAttributes="Bold" TextColor="#37474F" FontSize="12" HorizontalOptions="Center"/>
                        </Grid>

                        <!-- Pumps List -->
                        <CollectionView x:Name="PompesCollectionView"
                                        Grid.Row="1"
                                        ItemsSource="{Binding PompeReadings}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <!-- Use VerticalStackLayout with BoxView for bottom border instead of StrokeThickness="0,0,0,1" -->
                                    <VerticalStackLayout>
                                        <Grid ColumnDefinitions="0.8*,1.2*,0.8*,1.2*,1.2*,1.2*,1.2*,0.8*" 
                                              ColumnSpacing="5"
                                              Padding="10,8"
                                              BackgroundColor="White">
                                            <Label Text="{Binding PompeNumero}"
                                                   FontAttributes="Bold"
                                                   TextColor="#1976D2"
                                                   VerticalOptions="Center"
                                                   FontSize="13"/>
                                            <Label Grid.Column="1"
                                                   Text="{Binding ProduitNom}"
                                                   TextColor="#666"
                                                   VerticalOptions="Center"
                                                   FontSize="12"/>
                                            <Label Grid.Column="2"
                                                   Text="{Binding PrixCarburant, StringFormat='{0:N2}'}"
                                                   TextColor="#E65100"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center"
                                                   HorizontalOptions="Center"
                                                   FontSize="12"/>
                                            <Border Grid.Column="3"
                                                    BackgroundColor="#F5F5F5"
                                                    Padding="5,3"
                                                    StrokeShape="RoundRectangle 4">
                                                <Label Text="{Binding CompteurElecDebut, StringFormat='{0:N2}'}"
                                                       TextColor="#666"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"
                                                       FontSize="11"/>
                                            </Border>
                                            <Entry Grid.Column="4"
                                                   Text="{Binding CompteurElecFin}"
                                                   Keyboard="Numeric"
                                                   BackgroundColor="#E3F2FD"
                                                   TextColor="#333"
                                                   FontSize="12"
                                                   HorizontalTextAlignment="Center"
                                                   TextChanged="OnMeterValueChanged"
                                                   PropertyChanged="OnPropChanged"/>
                                            <Border Grid.Column="5"
                                                    BackgroundColor="#F5F5F5"
                                                    Padding="5,3"
                                                    StrokeShape="RoundRectangle 4">
                                                <Label Text="{Binding CompteurMecaDebut, StringFormat='{0:N2}'}"
                                                       TextColor="#666"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"
                                                       FontSize="11"/>
                                            </Border>
                                            <Entry Grid.Column="6"
                                                   Text="{Binding CompteurMecaFin}"
                                                   Keyboard="Numeric"
                                                   BackgroundColor="#FFF3E0"
                                                   TextColor="#333"
                                                   FontSize="12"
                                                   HorizontalTextAlignment="Center"
                                                   TextChanged="OnMeterValueChanged"/>
                                            <Label Grid.Column="7"
                                                   Text="{Binding QuantiteVendue, StringFormat='{0:N1}L'}"
                                                   TextColor="#2E7D32"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center"
                                                   HorizontalOptions="Center"
                                                   FontSize="12"/>
                                        </Grid>
                                        <!-- Bottom border line -->
                                        <BoxView HeightRequest="1" Color="#F0F0F0" HorizontalOptions="Fill"/>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                </Border>

                <!-- RIGHT: Credit Transactions -->
                <Border Grid.Column="1"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 8"
                        Stroke="#E0E0E0">
                    <Grid RowDefinitions="Auto,Auto,*,Auto">
                        <!-- Section Header -->
                        <Border Grid.Row="0"
                                BackgroundColor="#FF9800"
                                Padding="12,10">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="💳" FontSize="16" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="Crédits Carburant" 
                                       FontSize="14" 
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Select All / Deselect Row -->
                        <HorizontalStackLayout Grid.Row="1" 
                                               Spacing="10" 
                                               Padding="10,8"
                                               BackgroundColor="#FFF8E1">
                            <Button Text="✓ Tout" 
                                    FontSize="11"
                                    Padding="8,4"
                                    BackgroundColor="#4CAF50"
                                    TextColor="White"
                                    CornerRadius="4"
                                    Clicked="OnSelectAllCreditsClicked"/>
                            <Button Text="✗ Aucun" 
                                    FontSize="11"
                                    Padding="8,4"
                                    BackgroundColor="#9E9E9E"
                                    TextColor="White"
                                    CornerRadius="4"
                                    Clicked="OnDeselectAllCreditsClicked"/>
                            <Label x:Name="CreditCountLabel"
                                   Text="0 sélectionné(s)"
                                   FontSize="11"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <!-- Credit Transactions Table Header -->
                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="Auto,*,60,80"
                                  ColumnSpacing="12"
                                  Padding="10,8"
                                  BackgroundColor="#ECEFF1">
                                <Label Text="✓" FontAttributes="Bold" TextColor="#37474F" FontSize="11"/>
                                <Label Grid.Column="1" Text="Client" FontAttributes="Bold" TextColor="#37474F" FontSize="11"/>
                                <Label Grid.Column="2" Text="Qté" FontAttributes="Bold" TextColor="#37474F" FontSize="11" HorizontalOptions="Center"/>
                                <Label Grid.Column="3" Text="Montant" FontAttributes="Bold" TextColor="#37474F" FontSize="11" HorizontalOptions="End"/>
                            </Grid>

                            <!-- Credit Transactions List -->
                            <CollectionView x:Name="CreditTransactionsCollectionView"
                                            Grid.Row="1"
                                            ItemsSource="{Binding PeriodeCreditTransactions}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:CreditTransactionDto">
                                        <!-- Use VerticalStackLayout with BoxView for bottom border -->
                                        <VerticalStackLayout>
                                            <Grid ColumnDefinitions="Auto,*,60,80" 
                                                  ColumnSpacing="12"
                                                  Padding="10,6"
                                                  BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToSelectionColorConverter}}">
                                                <Grid.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnCreditTransactionTapped" CommandParameter="{Binding .}"/>
                                                </Grid.GestureRecognizers>
                                                <CheckBox IsChecked="{Binding IsSelected}"
                                                          CheckedChanged="OnCreditCheckBoxChanged"
                                                          VerticalOptions="Center"
                                                          Scale="0.8"/>
                                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                                    <Label Text="{Binding ClientNom}"
                                                           FontSize="12"
                                                           FontAttributes="Bold"
                                                           TextColor="#333"
                                                           LineBreakMode="TailTruncation"/>
                                                    <Label Text="{Binding ProduitNom}"
                                                           FontSize="10"
                                                           TextColor="#888"
                                                           LineBreakMode="TailTruncation"/>
                                                </VerticalStackLayout>
                                                <Label Grid.Column="2"
                                                       Text="{Binding Quantite}"
                                                       FontSize="11"
                                                       TextColor="#666"
                                                       VerticalOptions="Center"
                                                       HorizontalOptions="Center"/>
                                                <Label Grid.Column="3"
                                                       Text="{Binding MontantTotal, StringFormat='{0:N2}'}"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="#E65100"
                                                       VerticalOptions="Center"
                                                       HorizontalOptions="End"/>
                                            </Grid>
                                            <!-- Bottom border line -->
                                            <BoxView HeightRequest="1" Color="#F0F0F0" HorizontalOptions="Fill"/>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                                <CollectionView.EmptyView>
                                    <VerticalStackLayout VerticalOptions="Center" 
                                                         HorizontalOptions="Center"
                                                         Padding="20">
                                        <Label Text="📋" FontSize="32" HorizontalOptions="Center"/>
                                        <Label Text="Aucun crédit carburant"
                                               FontSize="12"
                                               TextColor="#999"
                                               HorizontalOptions="Center"/>
                                        <Label Text="dans cette période"
                                               FontSize="11"
                                               TextColor="#BBB"
                                               HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </CollectionView.EmptyView>
                            </CollectionView>
                        </Grid>

                        <!-- Credit Total -->
                        <Border Grid.Row="3"
                                BackgroundColor="#FFF3E0"
                                Padding="12,10">
                            <HorizontalStackLayout HorizontalOptions="End" Spacing="8">
                                <Label Text="Total Crédité:"
                                       FontSize="13"
                                       TextColor="#666"
                                       VerticalOptions="Center"/>
                                <Label x:Name="TotalCrediteLabel"
                                       Text="0.00 MAD"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="#E65100"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ========================================= -->
            <!-- FOOTER: Summary + Actions                 -->
            <!-- ========================================= -->
            <Border Grid.Row="3" 
                    BackgroundColor="#F5F5F5" 
                    Padding="15">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="15">
                    <!-- Summary -->
                    <HorizontalStackLayout Spacing="12">
                        <Border BackgroundColor="#E8F5E9" 
                               Padding="10,6"
                               StrokeShape="RoundRectangle 8">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="⛽" FontSize="14" VerticalOptions="Center"/>
                                <VerticalStackLayout>
                                    <Label Text="Recette" FontSize="9" TextColor="#666"/>
                                    <Label x:Name="TotalRecetteLabel"
                                           Text="0.00"
                                           FontAttributes="Bold"
                                           TextColor="#2E7D32"
                                           FontSize="13"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>
                        
                        <Border BackgroundColor="#E3F2FD" 
                               Padding="10,6"
                               StrokeShape="RoundRectangle 8">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="💳" FontSize="14" VerticalOptions="Center"/>
                                <VerticalStackLayout>
                                    <Label Text="TPE" FontSize="9" TextColor="#666"/>
                                    <Label x:Name="TotalTPELabel"
                                           Text="0.00"
                                           FontAttributes="Bold"
                                           TextColor="#1565C0"
                                           FontSize="13"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>

                        <Border BackgroundColor="#FFF3E0" 
                               Padding="10,6"
                               StrokeShape="RoundRectangle 8">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="📝" FontSize="14" VerticalOptions="Center"/>
                                <VerticalStackLayout>
                                    <Label Text="Crédité" FontSize="9" TextColor="#666"/>
                                    <Label x:Name="TotalCrediteSummaryLabel"
                                           Text="0.00"
                                           FontAttributes="Bold"
                                           TextColor="#E65100"
                                           FontSize="13"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>

                        <Border BackgroundColor="#E8F5E9" 
                               Padding="10,6"
                               StrokeShape="RoundRectangle 8">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="🎯" FontSize="14" VerticalOptions="Center"/>
                                <VerticalStackLayout>
                                    <Label Text="Espèces Attendues" FontSize="9" TextColor="#666"/>
                                    <Label x:Name="EspecesAttenduesLabel"
                                           Text="0.00"
                                           FontAttributes="Bold"
                                           TextColor="#2E7D32"
                                           FontSize="13"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>
                        
                        <Border BackgroundColor="#F3E5F5" 
                               Padding="10,6"
                               StrokeShape="RoundRectangle 8">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="💵" FontSize="14" VerticalOptions="Center"/>
                                <VerticalStackLayout>
                                    <Label Text="Espèces Déclarées" FontSize="9" TextColor="#666"/>
                                    <Label x:Name="TotalEspecesLabel"
                                           Text="0.00"
                                           FontAttributes="Bold"
                                           TextColor="#7B1FA2"
                                           FontSize="13"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>
                        
                        <Border x:Name="ManqueBorder"
                               BackgroundColor="#FFEBEE" 
                               Padding="10,6"
                               StrokeShape="RoundRectangle 8">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="⚠️" FontSize="14" VerticalOptions="Center"/>
                                <VerticalStackLayout>
                                    <Label Text="Manque" FontSize="9" TextColor="#666"/>
                                    <Label x:Name="ManqueLabel"
                                           Text="0.00"
                                           FontAttributes="Bold"
                                           TextColor="#C62828"
                                           FontSize="13"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>
                    </HorizontalStackLayout>

                    <!-- Error Message -->
                    <Label x:Name="ErrorLabel"
                           Grid.Column="1"
                           TextColor="#F44336"
                           FontSize="12"
                           IsVisible="False"
                           VerticalOptions="Center"/>

                    <!-- Cancel Button -->
                    <Button Grid.Column="2"
                            Text="Annuler" 
                            BackgroundColor="#9E9E9E"
                            TextColor="White"
                            Padding="20,10"
                            CornerRadius="8"
                            Clicked="OnCancelClicked"/>

                    <!-- Save Button -->
                    <Button x:Name="SaveButton"
                            Grid.Column="3"
                            Text="✓ Enregistrer la Période" 
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            Padding="20,10"
                            CornerRadius="8"
                            FontAttributes="Bold"
                            Clicked="OnSaveClicked"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>