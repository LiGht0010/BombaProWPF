<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:BombaProMax.ViewModels"
             xmlns:models="clr-namespace:BombaProMax.Models"
             x:Class="BombaProMax.Views.PeriodeViews.PeriodePage"
             x:DataType="viewmodels:PeriodeViewModel"
             Style="{StaticResource PeriodePageStyle}">

    <Grid RowDefinitions="*,Auto">
        
        <ScrollView Grid.Row="0" Style="{StaticResource PeriodePageScrollView}">
            <VerticalStackLayout Style="{StaticResource PeriodePageMainStack}">

                <!-- JOURNÉE PROGRESS BAR -->
                <Border BackgroundColor="#E3F2FD" 
                        Padding="15" 
                        Margin="0,0,0,10"
                        IsVisible="{Binding IsJourneeActive}" 
                        StrokeShape="RoundRectangle 10" 
                        Stroke="#1976D2">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Text="🚀" FontSize="24" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Margin="10,0">
                            <Label Text="{Binding JourneeStepInfo}" 
                                   FontAttributes="Bold" 
                                   TextColor="#1976D2" 
                                   FontSize="14"/>
                            <Label Text="Journée en cours - Suivez les étapes" 
                                   TextColor="#666" 
                                   FontSize="11"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="📋" FontSize="20" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- HEADER -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <VerticalStackLayout Style="{StaticResource PeriodePageHeaderStack}">
                        <Label Text="⏱️ Gestion des Périodes" 
                               Style="{StaticResource PeriodePageTitleLabel}"/>
                        <Label Text="Gérez les shifts et relevés de compteurs" 
                               Style="{StaticResource PeriodePageSubtitleLabel}"/>
                    </VerticalStackLayout>
                    
                    <Button Grid.Column="1"
                            Text="+ Nouvelle Période"
                            Style="{StaticResource PeriodeAddButton}"
                            Clicked="OnAddPeriodeClicked"
                            VerticalOptions="Center"
                            IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"/>
                </Grid>

                <!-- FILTERS -->
                <Border Style="{StaticResource PeriodeFilterContainer}"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                    <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,Auto" ColumnSpacing="15">
                        <Label Text="📅 Du:" Style="{StaticResource PeriodeFilterLabel}"/>
                        <DatePicker Grid.Column="1"
                                    Date="{Binding FilterStartDate}"
                                    Style="{StaticResource PeriodeFilterDatePicker}"/>
                        <Label Grid.Column="2" Text="Au:" Style="{StaticResource PeriodeFilterLabel}"/>
                        <DatePicker Grid.Column="3"
                                    Date="{Binding FilterEndDate}"
                                    Style="{StaticResource PeriodeFilterDatePicker}"/>
                        <Button Grid.Column="4"
                                Text="🔍 Filtrer"
                                Command="{Binding LoadPeriodesByDateRangeCommand}"
                                Style="{StaticResource PeriodeFilterButton}"/>
                        <Button Grid.Column="5"
                                Text="🔄"
                                Command="{Binding LoadPeriodesCommand}"
                                Style="{StaticResource PeriodeResetButton}"/>
                    </Grid>
                </Border>

                <!-- Loading -->
                <ActivityIndicator Style="{StaticResource PeriodePageLoadingIndicator}"
                                   IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"/>

                <!-- MASTER-DETAIL LAYOUT -->
                <Grid ColumnDefinitions="380,*" 
                      ColumnSpacing="20"
                      IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                    
                    <!-- MASTER: Periodes List -->
                    <Border Grid.Column="0" Style="{StaticResource PeriodeMasterPanel}">
                        <VerticalStackLayout Spacing="0">
                            
                            <!-- List Header -->
                            <Grid Style="{StaticResource PeriodeMasterHeader}" ColumnDefinitions="*,Auto">
                                <Label Text="📋 Périodes" Style="{StaticResource PeriodeMasterHeaderLabel}"/>
                                <Button Grid.Column="1"
                                        Text="🔄"
                                        Command="{Binding LoadPeriodesCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="White"
                                        FontSize="16"
                                        Padding="8"/>
                            </Grid>
                            
                            <!-- Periodes List using BindableLayout -->
                            <VerticalStackLayout x:Name="PeriodesList"
                                                 BindableLayout.ItemsSource="{Binding Periodes}" 
                                                 Padding="0,8">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:PeriodeDto">
                                        <Border Style="{StaticResource PeriodeListItem}"
                                                Stroke="Transparent"
                                                StrokeThickness="0">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer 
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:PeriodeViewModel}}, Path=SelectPeriodeCommand}"
                                                    CommandParameter="{Binding .}"
                                                    Tapped="OnPeriodeItemTapped"/>
                                            </Border.GestureRecognizers>
                                            <VerticalStackLayout Spacing="6">
                                                <Label Text="{Binding DateDebut, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                                       Style="{StaticResource PeriodeListDateLabel}"/>
                                                <Label Text="{Binding DateFin, StringFormat='→ {0:dd/MM/yyyy HH:mm}'}"
                                                       Style="{StaticResource PeriodeListDateEndLabel}"/>
                                                <HorizontalStackLayout Spacing="6">
                                                    <Label Text="👤" FontSize="12"/>
                                                    <Label Text="{Binding EmployeNom, TargetNullValue='Non assigné'}"
                                                           Style="{StaticResource PeriodeListEmployeLabel}"/>
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                                
                                <BindableLayout.EmptyView>
                                    <VerticalStackLayout Style="{StaticResource PeriodeEmptyView}">
                                        <Label Text="📅" Style="{StaticResource PeriodeEmptyIcon}"/>
                                        <Label Text="Aucune période" Style="{StaticResource PeriodeEmptyTitle}"/>
                                        <Label Text="Créez une nouvelle période pour commencer" 
                                               Style="{StaticResource PeriodeEmptySubtitle}"/>
                                    </VerticalStackLayout>
                                </BindableLayout.EmptyView>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- DETAIL: Periode Details -->
                    <Border Grid.Column="1" 
                            Style="{StaticResource PeriodeDetailPanel}"
                            IsVisible="{Binding SelectedPeriode, Converter={StaticResource IsNotNullConverter}}">
                        <VerticalStackLayout Spacing="0">
                            
                            <!-- Detail Header -->
                            <Grid Style="{StaticResource PeriodeDetailHeader}" ColumnDefinitions="*,Auto,Auto,Auto">
                                <VerticalStackLayout>
                                    <Label Text="📊 Détails de la Période" 
                                           Style="{StaticResource PeriodeDetailHeaderTitle}"/>
                                    <Label Text="{Binding SelectedPeriode.DateDebut, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                           Style="{StaticResource PeriodeDetailHeaderSubtitle}"/>
                                </VerticalStackLayout>
                                <Button Grid.Column="1"
                                        Text="✏️"
                                        BackgroundColor="#1565C0"
                                        Style="{StaticResource PeriodeDetailActionButton}"
                                        Clicked="OnEditPeriodeClicked"/>
                                <Button Grid.Column="2"
                                        Text="🗑️"
                                        BackgroundColor="#C62828"
                                        Style="{StaticResource PeriodeDetailActionButton}"
                                        Clicked="OnDeletePeriodeClicked"
                                        Margin="8,0,0,0"/>
                                <Button Grid.Column="3"
                                        Text="+ Relevé"
                                        BackgroundColor="#2E7D32"
                                        Style="{StaticResource PeriodeDetailActionButton}"
                                        Clicked="OnAddDetailClicked"
                                        Margin="8,0,0,0"/>
                            </Grid>

                            <!-- Summary Cards -->
                            <Grid ColumnDefinitions="*,*,*,*,*,*" 
                                  ColumnSpacing="12"
                                  Padding="20">
                                
                                <Border Grid.Column="0" Style="{StaticResource PeriodeSummaryCard}" BackgroundColor="#E8F5E9">
                                    <VerticalStackLayout>
                                        <Label Text="⛽" Style="{StaticResource PeriodeSummaryIcon}"/>
                                        <Label Text="{Binding TotalQuantiteVendue, StringFormat='{0:N2} L'}"
                                               Style="{StaticResource PeriodeSummaryValue}"
                                               TextColor="#2E7D32"/>
                                        <Label Text="Vendu" Style="{StaticResource PeriodeSummaryLabel}"/>
                                    </VerticalStackLayout>
                                </Border>
                                
                                <Border Grid.Column="1" Style="{StaticResource PeriodeSummaryCard}" BackgroundColor="#FFF3E0">
                                    <VerticalStackLayout>
                                        <Label Text="💰" Style="{StaticResource PeriodeSummaryIcon}"/>
                                        <Label Text="{Binding TotalPrixTotal, StringFormat='{0:N2}'}"
                                               Style="{StaticResource PeriodeSummaryValue}"
                                               TextColor="#E65100"/>
                                        <Label Text="MAD Recette" Style="{StaticResource PeriodeSummaryLabel}"/>
                                    </VerticalStackLayout>
                                </Border>
                                
                                <Border Grid.Column="2" Style="{StaticResource PeriodeSummaryCard}" BackgroundColor="#E3F2FD">
                                    <VerticalStackLayout>
                                        <Label Text="💳" Style="{StaticResource PeriodeSummaryIcon}"/>
                                        <Label Text="{Binding TotalTPE, StringFormat='{0:N2}'}"
                                               Style="{StaticResource PeriodeSummaryValue}"
                                               TextColor="#1565C0"/>
                                        <Label Text="MAD TPE" Style="{StaticResource PeriodeSummaryLabel}"/>
                                    </VerticalStackLayout>
                                </Border>
                                
                                <Border Grid.Column="3" Style="{StaticResource PeriodeSummaryCard}" BackgroundColor="#F3E5F5">
                                    <VerticalStackLayout>
                                        <Label Text="💵" Style="{StaticResource PeriodeSummaryIcon}"/>
                                        <Label Text="{Binding TotalEspeces, StringFormat='{0:N2}'}"
                                               Style="{StaticResource PeriodeSummaryValue}"
                                               TextColor="#7B1FA2"/>
                                        <Label Text="MAD Espèces" Style="{StaticResource PeriodeSummaryLabel}"/>
                                    </VerticalStackLayout>
                                </Border>
                                
                                <Border Grid.Column="4" Style="{StaticResource PeriodeSummaryCard}" BackgroundColor="#FFEBEE">
                                    <VerticalStackLayout>
                                        <Label Text="⚠️" Style="{StaticResource PeriodeSummaryIcon}"/>
                                        <Label Text="{Binding EcartPaiement, StringFormat='{0:N2}'}"
                                               Style="{StaticResource PeriodeSummaryValue}"
                                               TextColor="#C62828"/>
                                        <Label Text="MAD Écart" Style="{StaticResource PeriodeSummaryLabel}"/>
                                    </VerticalStackLayout>
                                </Border>
                                
                                <Border Grid.Column="5" Style="{StaticResource PeriodeSummaryCard}" BackgroundColor="#ECEFF1">
                                    <VerticalStackLayout>
                                        <Label Text="📉" Style="{StaticResource PeriodeSummaryIcon}"/>
                                        <Label Text="{Binding TotalDifferenceQuantite, StringFormat='{0:N2} L'}"
                                               Style="{StaticResource PeriodeSummaryValue}"
                                               TextColor="#546E7A"/>
                                        <Label Text="Écart Compteur" Style="{StaticResource PeriodeSummaryLabel}"/>
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <!-- Details Table Header -->
                            <Grid Style="{StaticResource PeriodeDetailTableHeader}">
                                <Label Grid.Column="0" Text="Pompe" Style="{StaticResource PeriodeDetailTableHeaderLabel}"/>
                                <Label Grid.Column="1" Text="Produit" Style="{StaticResource PeriodeDetailTableHeaderLabel}"/>
                                <Label Grid.Column="2" Text="Élec. Début" Style="{StaticResource PeriodeDetailTableHeaderLabel}"/>
                                <Label Grid.Column="3" Text="Élec. Fin" Style="{StaticResource PeriodeDetailTableHeaderLabel}"/>
                                <Label Grid.Column="4" Text="Qté Élec." Style="{StaticResource PeriodeDetailTableHeaderLabel}"/>
                                <Label Grid.Column="5" Text="Qté Méca." Style="{StaticResource PeriodeDetailTableHeaderLabel}"/>
                                <Label Grid.Column="6" Text="Prix Total" Style="{StaticResource PeriodeDetailTableHeaderLabel}"/>
                                <Label Grid.Column="7" Text="Actions" Style="{StaticResource PeriodeDetailTableHeaderLabel}" HorizontalTextAlignment="Center"/>
                            </Grid>

                            <!-- Details List using BindableLayout -->
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding CurrentPeriodeDetails}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:PeriodeDetailsDto">
                                        <VerticalStackLayout BackgroundColor="Transparent">
                                            <Grid Style="{StaticResource PeriodeDetailTableRow}">
                                                <Label Grid.Column="0" 
                                                       Text="{Binding PompeNumero}"
                                                       Style="{StaticResource PeriodeDetailPompeLabel}"/>
                                                <Label Grid.Column="1"
                                                       Text="{Binding ProduitNom}"
                                                       Style="{StaticResource PeriodeDetailProduitLabel}"/>
                                                <Label Grid.Column="2"
                                                       Text="{Binding CompteurElectroniqueDebut, StringFormat='{0:N2}'}"
                                                       Style="{StaticResource PeriodeDetailValueLabel}"/>
                                                <Label Grid.Column="3"
                                                       Text="{Binding CompteurElectroniqueFinal, StringFormat='{0:N2}'}"
                                                       Style="{StaticResource PeriodeDetailValueLabel}"/>
                                                <Label Grid.Column="4"
                                                       Text="{Binding QuantiteElectronique, StringFormat='{0:N2} L'}"
                                                       Style="{StaticResource PeriodeDetailQuantiteLabel}"/>
                                                <Label Grid.Column="5"
                                                       Text="{Binding QuantiteMecanique, StringFormat='{0:N2} L'}"
                                                       Style="{StaticResource PeriodeDetailValueLabel}"/>
                                                <Label Grid.Column="6"
                                                       Text="{Binding PrixTotal, StringFormat='{0:N2}'}"
                                                       Style="{StaticResource PeriodeDetailPrixLabel}"/>
                                                <HorizontalStackLayout Grid.Column="7" 
                                                                       Style="{StaticResource PeriodeDetailActionsCell}">
                                                    <Button Text="✏️"
                                                            Style="{StaticResource PeriodeDetailEditButton}"
                                                            Clicked="OnEditDetailClicked"
                                                            CommandParameter="{Binding .}"/>
                                                    <Button Text="🗑️"
                                                            Style="{StaticResource PeriodeDetailDeleteButton}"
                                                            Clicked="OnDeleteDetailClicked"
                                                            CommandParameter="{Binding .}"/>
                                                </HorizontalStackLayout>
                                            </Grid>
                                            <BoxView Style="{StaticResource PeriodeRowDivider}"/>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                                
                                <BindableLayout.EmptyView>
                                    <VerticalStackLayout Style="{StaticResource PeriodeEmptyView}" Padding="40,60">
                                        <Label Text="📋" Style="{StaticResource PeriodeEmptyIcon}"/>
                                        <Label Text="Aucun relevé" Style="{StaticResource PeriodeEmptyTitle}"/>
                                        <Label Text="Ajoutez un relevé de compteur pour cette période" 
                                               Style="{StaticResource PeriodeEmptySubtitle}"/>
                                    </VerticalStackLayout>
                                </BindableLayout.EmptyView>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Empty State when no periode selected -->
                    <Border Grid.Column="1"
                            Style="{StaticResource PeriodeEmptyPanel}"
                            IsVisible="{Binding SelectedPeriode, Converter={StaticResource IsNullConverter}}">
                        <VerticalStackLayout Style="{StaticResource PeriodeEmptyView}">
                            <Border BackgroundColor="#EEF1F5"
                                    WidthRequest="100"
                                    HeightRequest="100"
                                    StrokeThickness="0"
                                    Margin="0,0,0,16">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="50"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#C5CAD1" Offset="6,6" Radius="12" Opacity="0.25"/>
                                </Border.Shadow>
                                <Label Text="👈" FontSize="48" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Sélectionnez une période" Style="{StaticResource PeriodeEmptyTitle}"/>
                            <Label Text="Choisissez une période dans la liste pour voir ses détails" 
                                   Style="{StaticResource PeriodeEmptySubtitle}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <!-- JOURNÉE NAVIGATION BAR -->
        <Border Grid.Row="1" 
                BackgroundColor="#F5F5F5" 
                Padding="15" 
                IsVisible="{Binding IsJourneeActive}" 
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="#000" Offset="0,-2" Radius="8" Opacity="0.1"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                <Button Text="← Précédent" 
                        Command="{Binding JourneePrecedentCommand}"
                        BackgroundColor="#757575" 
                        TextColor="White" 
                        Padding="20,12" 
                        CornerRadius="8"
                        IsVisible="{Binding IsFirstStep, Converter={StaticResource InvertedBoolConverter}}"/>
                <BoxView Grid.Column="1" Color="Transparent"/>
                <Button Grid.Column="2" 
                        Text="Passer cette étape" 
                        Command="{Binding JourneePasserCommand}"
                        BackgroundColor="#FFA726" 
                        TextColor="White" 
                        Padding="20,12" 
                        CornerRadius="8"/>
                <Button Grid.Column="3" 
                        Text="{Binding IsLastStep, Converter={StaticResource BoolToTextConverter}, ConverterParameter='Terminer la journée|Suivant →'}"
                        Command="{Binding JourneeSuivantCommand}" 
                        BackgroundColor="#4CAF50" 
                        TextColor="White"
                        Padding="20,12" 
                        CornerRadius="8" 
                        FontAttributes="Bold"/>
            </Grid>
        </Border>

    </Grid>
</ContentPage>