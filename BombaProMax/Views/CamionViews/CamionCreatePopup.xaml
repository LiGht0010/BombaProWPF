<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.CamionViews.CamionCreatePopup">

    <Border Style="{StaticResource CamionPopupContainer}">
        <ScrollView>
            <VerticalStackLayout Spacing="20">
                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="🚛 Créer un nouveau camion" 
                           Style="{StaticResource CamionPopupTitle}"/>
                    <Button Grid.Column="1" 
                            Text="✕" 
                            Style="{StaticResource CamionPopupCloseButton}"
                            Clicked="OnCancelClicked"/>
                </Grid>

                <BoxView Style="{StaticResource CamionPopupDivider}"/>

                <!-- Camion Form -->
                <VerticalStackLayout Spacing="18">

                    <!-- Basic Information Section -->
                    <Border Style="{StaticResource CamionPopupSectionCard}">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="ℹ️ Informations de Base" 
                                   Style="{StaticResource CamionPopupSectionTitle}"/>

                            <BoxView Style="{StaticResource CamionPopupDivider}"/>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                                <!-- Matricule -->
                                <VerticalStackLayout Grid.Column="0" Spacing="8">
                                    <Label Text="Matricule *" 
                                           Style="{StaticResource CamionPopupFieldLabel}"/>
                                    <Border Style="{StaticResource CamionPopupInputContainer}">
                                        <Entry x:Name="MatriculeEntry"
                                               Placeholder="Ex: ABC-1234"
                                               Style="{StaticResource CamionPopupEntry}"/>
                                    </Border>
                                </VerticalStackLayout>

                                <!-- Marque -->
                                <VerticalStackLayout Grid.Column="1" Spacing="8">
                                    <Label Text="Marque" 
                                           Style="{StaticResource CamionPopupFieldLabel}"/>
                                    <Border Style="{StaticResource CamionPopupInputContainer}">
                                        <Entry x:Name="MarqueEntry"
                                               Placeholder="Ex: Mercedes, Volvo"
                                               Style="{StaticResource CamionPopupEntry}"/>
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Assignment Section -->
                    <Border Style="{StaticResource CamionPopupSectionCard}">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="🔗 Affectations" 
                                   Style="{StaticResource CamionPopupSectionTitle}"/>

                            <BoxView Style="{StaticResource CamionPopupDivider}"/>

                            <!-- Fournisseur Picker -->
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Fournisseur *" 
                                       Style="{StaticResource CamionPopupFieldLabel}"/>
                                <Border Style="{StaticResource CamionPopupInputContainer}">
                                    <Picker x:Name="FournisseurPicker"
                                            Title="Sélectionnez un fournisseur"
                                            Style="{StaticResource CamionPopupPicker}"/>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Citerne Picker -->
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Citerne (Optionnel)" 
                                       Style="{StaticResource CamionPopupFieldLabel}"/>
                                <Border Style="{StaticResource CamionPopupInputContainer}">
                                    <Picker x:Name="CiternePicker"
                                            Title="Sélectionnez une citerne"
                                            Style="{StaticResource CamionPopupPicker}"/>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Error Message -->
                    <Label x:Name="ErrorLabel"
                           Style="{StaticResource CamionPopupErrorLabel}"
                           IsVisible="False"/>

                    <!-- Action Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,10,0,0">
                        <!-- Cancel Button -->
                        <Button Grid.Column="0"
                                Text="Annuler"
                                Style="{StaticResource CamionPopupCancelButton}"
                                Clicked="OnCancelClicked"/>

                        <!-- Create Button -->
                        <Button Grid.Column="1"
                                Text="✓ Créer le camion"
                                Style="{StaticResource CamionPopupCreateButton}"
                                Clicked="OnCreateClicked"/>
                    </Grid>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Border>
</toolkit:Popup>
