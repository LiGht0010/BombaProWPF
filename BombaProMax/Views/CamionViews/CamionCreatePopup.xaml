<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.CamionViews.CamionCreatePopup"
               Color="Transparent">

    <Border BackgroundColor="White"       
            Padding="0"
            WidthRequest="550"
            HeightRequest="520"
            StrokeShape="RoundRectangle 12">
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- ========================================= -->
            <!-- HEADER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="0" 
                    BackgroundColor="#1565C0" 
                    Padding="20">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout>
                        <Label Text="🚛 Nouveau Camion" 
                               FontSize="20" 
                               FontAttributes="Bold"
                               TextColor="White"/>
                        <Label Text="Enregistrer un nouveau camion" 
                               FontSize="12"
                               TextColor="#BBDEFB"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" 
                            Text="✕" 
                            BackgroundColor="Transparent"
                            TextColor="White"
                            FontSize="20"
                            Clicked="OnCancelClicked"/>
                </Grid>
            </Border>

            <!-- ========================================= -->
            <!-- FORM CONTENT                              -->
            <!-- ========================================= -->
            <ScrollView Grid.Row="1" Padding="20">
                <VerticalStackLayout Spacing="15">
                    
                    <!-- Matricule & Marque -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <Border BackgroundColor="#E3F2FD" 
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#1565C0">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="🔢 Matricule *" 
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#0D47A1"/>
                                <Entry x:Name="MatriculeEntry"
                                       Placeholder="Ex: ABC-1234"
                                       FontSize="14"
                                       TextColor="#0D47A1"/>
                            </VerticalStackLayout>
                        </Border>
                        
                        <Border Grid.Column="1"
                                BackgroundColor="#F8F8F8" 
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#E0E0E0">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="🏭 Marque" 
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#666"/>
                                <Entry x:Name="MarqueEntry"
                                       Placeholder="Ex: Mercedes, Volvo"
                                       FontSize="14"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Fournisseur -->
                    <Border BackgroundColor="#FFF3E0" 
                            Padding="12"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#FFB300">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="🏢 Fournisseur *" 
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#E65100"/>
                            <Picker x:Name="FournisseurPicker"
                                    Title="Sélectionner un fournisseur..."
                                    ItemDisplayBinding="{Binding Societe}"
                                    FontSize="14"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Citerne -->
                    <Border BackgroundColor="#E8F5E9" 
                            Padding="12"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#4CAF50">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="🛢️ Citerne (Optionnel)" 
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#2E7D32"/>
                            <Picker x:Name="CiternePicker"
                                    Title="Sélectionner une citerne..."
                                    FontSize="14"/>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ========================================= -->
            <!-- FOOTER: Error + Actions                   -->
            <!-- ========================================= -->
            <Border Grid.Row="2" 
                    BackgroundColor="#F5F5F5" 
                    Padding="15">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="15">
                    <!-- Error Message -->
                    <Label x:Name="ErrorLabel"
                           TextColor="#F44336"
                           FontSize="12"
                           IsVisible="False"
                           VerticalOptions="Center"/>

                    <!-- Cancel Button -->
                    <Button Grid.Column="1"
                            Text="Annuler" 
                            BackgroundColor="#9E9E9E"
                            TextColor="White"
                            Padding="20,10"
                            CornerRadius="8"
                            Clicked="OnCancelClicked"/>

                    <!-- Create Button -->
                    <Button Grid.Column="2"
                            Text="✓ Créer" 
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            Padding="20,10"
                            CornerRadius="8"
                            FontAttributes="Bold"
                            Clicked="OnCreateClicked"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>
