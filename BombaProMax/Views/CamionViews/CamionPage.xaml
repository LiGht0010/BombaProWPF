<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BombaProMax.Models"
             xmlns:viewmodels="clr-namespace:BombaProMax.ViewModels"
             x:Class="BombaProMax.Views.CamionViews.CamionPage"
             x:DataType="viewmodels:CamionViewModel"
             Style="{StaticResource CamionPageStyle}">

    <Grid RowDefinitions="*,Auto">
        
        <ScrollView Grid.Row="0" Style="{StaticResource CamionPageScrollView}">
            <VerticalStackLayout Style="{StaticResource CamionPageMainStack}">

                <!-- JOURNÉE PROGRESS BAR -->
                <Border BackgroundColor="#E3F2FD" 
                        Padding="15" 
                        Margin="0,0,0,10"
                        IsVisible="{Binding IsJourneeActive}" 
                        StrokeShape="RoundRectangle 10" 
                        Stroke="#1976D2">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Text="🚀" FontSize="24" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Margin="10,0">
                            <Label Text="{Binding JourneeStepInfo}" 
                                   FontAttributes="Bold" 
                                   TextColor="#1976D2" 
                                   FontSize="14"/>
                            <Label Text="Journée en cours - Suivez les étapes" 
                                   TextColor="#666" 
                                   FontSize="11"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="📋" FontSize="20" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- HEADER -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <VerticalStackLayout Style="{StaticResource CamionPageHeaderStack}">
                        <Label Text="Gestion des Camions" 
                               Style="{StaticResource CamionPageTitleLabel}"/>
                        <Label Text="{Binding Camions.Count, StringFormat='{0} camions enregistrés'}" 
                               Style="{StaticResource CamionPageSubtitleLabel}"/>
                    </VerticalStackLayout>
                    
                    <Button Grid.Column="1"
                            Text="+ Nouveau Camion"
                            Style="{StaticResource CamionAddButton}"
                            Command="{Binding AddCamionCommand}"
                            VerticalOptions="Center"
                            IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"/>
                </Grid>

                <!-- STATS CARDS -->
                <Grid ColumnDefinitions="*,*,*,*" 
                      ColumnSpacing="16"
                      IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                    
                    <Border Grid.Column="0" Style="{StaticResource CamionStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Camions.Count}" 
                                   Style="{StaticResource CamionStatNumber}"/>
                            <Label Text="Total Camions" 
                                   Style="{StaticResource CamionStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CamionStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="—" 
                                   Style="{StaticResource CamionStatNumber}"
                                   TextColor="#5EAA8D"/>
                            <Label Text="Avec Citerne" 
                                   Style="{StaticResource CamionStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CamionStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="—" 
                                   Style="{StaticResource CamionStatNumber}"
                                   TextColor="#E8A84C"/>
                            <Label Text="Sans Citerne" 
                                   Style="{StaticResource CamionStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource CamionStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="—" 
                                   Style="{StaticResource CamionStatNumber}"
                                   TextColor="#8FA3B8"/>
                            <Label Text="En Service" 
                                   Style="{StaticResource CamionStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- SEARCH BAR -->
                <Border Style="{StaticResource CamionSearchContainer}"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Image Source="search.png" WidthRequest="24" HeightRequest="24"/>
                        <Entry Grid.Column="1"
                               Placeholder="Rechercher par matricule, marque, fournisseur..."
                               Text="{Binding SearchText}"
                               Style="{StaticResource CamionSearchEntry}"/>
                        <Button Grid.Column="2"
                                Text="Rechercher"
                                Command="{Binding SearchCamionsCommand}"
                                BackgroundColor="#E8ECF1"
                                TextColor="#5A6068"
                                FontSize="13"
                                FontAttributes="Bold"
                                Padding="16,10"
                                CornerRadius="10"/>
                    </Grid>
                </Border>

                <!-- Loading -->
                <ActivityIndicator Style="{StaticResource CamionPageLoadingIndicator}"
                                   IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"/>

                <!-- TABLE -->
                <Border Style="{StaticResource CamionTableCard}"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                    <VerticalStackLayout Style="{StaticResource CamionTableContainer}">

                        <!-- Header -->
                        <Grid Style="{StaticResource CamionTableHeaderGrid}">
                            <Label Grid.Column="0" Text="ID" Style="{StaticResource CamionTableHeaderLabel}"/>
                            <Label Grid.Column="1" Text="Matricule" Style="{StaticResource CamionTableHeaderLabel}"/>
                            <Label Grid.Column="2" Text="Marque" Style="{StaticResource CamionTableHeaderLabel}"/>
                            <Label Grid.Column="3" Text="Fournisseur" Style="{StaticResource CamionTableHeaderLabel}"/>
                            <Label Grid.Column="4" Text="Citerne" Style="{StaticResource CamionTableHeaderLabel}"/>
                            <Label Grid.Column="5" Text="Actions" Style="{StaticResource CamionTableHeaderLabel}"/>
                        </Grid>

                        <!-- Rows using BindableLayout -->
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Camions}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:CamionDto">
                                    <VerticalStackLayout BackgroundColor="Transparent">
                                        <Grid Style="{StaticResource CamionTableRowGrid}">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer 
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CamionViewModel}}, Path=ShowCamionRowDetailsCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Grid.GestureRecognizers>

                                            <Border Grid.Column="0" Style="{StaticResource CamionIdCell}">
                                                <Label Text="{Binding ID}" Style="{StaticResource CamionIdLabel}"/>
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1" Style="{StaticResource CamionMatriculeCell}">
                                                <Label Text="{Binding Matricule, TargetNullValue='N/A'}" 
                                                       Style="{StaticResource CamionMatriculeLabel}"/>
                                            </VerticalStackLayout>

                                            <Label Grid.Column="2" 
                                                   Text="{Binding Marque, TargetNullValue='N/A'}" 
                                                   Style="{StaticResource CamionMarqueLabel}"/>

                                            <Label Grid.Column="3" 
                                                   Text="{Binding FournisseurNom, TargetNullValue='N/A'}"
                                                   Style="{StaticResource CamionFournisseurLabel}"/>

                                            <Border Grid.Column="4" 
                                                    Style="{StaticResource CamionCiterneStatusBadge}"
                                                    BackgroundColor="{Binding CiterneID, Converter={StaticResource CiterneIdToColorConverter}}">
                                                <Label Text="{Binding CiterneNumero, TargetNullValue='Sans citerne'}"
                                                       Style="{StaticResource CamionCiterneStatusLabel}"/>
                                            </Border>

                                            <HorizontalStackLayout Grid.Column="5" Style="{StaticResource CamionActionsCell}">
                                                <Button Text="Détails"
                                                        Style="{StaticResource CamionDetailsButton}"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CamionViewModel}}, Path=ShowDetailsCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                <Button Text="Modifier"
                                                        Style="{StaticResource CamionModifierButton}"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CamionViewModel}}, Path=EditCamionCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                <Button Text="Supprimer"
                                                        Style="{StaticResource CamionSupprimerButton}"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CamionViewModel}}, Path=DeleteCamionCommand}"
                                                        CommandParameter="{Binding .}"/>
                                            </HorizontalStackLayout>
                                        </Grid>
                                        <BoxView Style="{StaticResource CamionRowDivider}"/>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                            
                            <BindableLayout.EmptyView>
                                <VerticalStackLayout Style="{StaticResource CamionEmptyView}">
                                    <Border BackgroundColor="#EEF1F5"
                                            WidthRequest="100"
                                            HeightRequest="100"
                                            StrokeThickness="0"
                                            Margin="0,0,0,16">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="50"/>
                                        </Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="#C5CAD1" Offset="6,6" Radius="12" Opacity="0.25"/>
                                        </Border.Shadow>
                                        <Label Text="🚛" FontSize="48" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <Label Text="Aucun camion disponible" Style="{StaticResource CamionEmptyTitle}"/>
                                    <Label Text="Commencez par ajouter votre premier camion" 
                                           Style="{StaticResource CamionEmptySubtitle}"/>
                                    <Button Text="+ Ajouter un Camion"
                                            Style="{StaticResource CamionEmptyButton}"
                                            Command="{Binding AddCamionCommand}"/>
                                </VerticalStackLayout>
                            </BindableLayout.EmptyView>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- JOURNÉE NAV BAR -->
        <Border Grid.Row="1" 
                BackgroundColor="#F5F5F5" 
                Padding="15" 
                IsVisible="{Binding IsJourneeActive}" 
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="#000" Offset="0,-2" Radius="8" Opacity="0.1"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                <Button Text="← Précédent" 
                        Command="{Binding JourneePrecedentCommand}"
                        BackgroundColor="#757575" 
                        TextColor="White" 
                        Padding="20,12" 
                        CornerRadius="8"
                        IsVisible="{Binding IsFirstStep, Converter={StaticResource InvertedBoolConverter}}"/>
                <BoxView Grid.Column="1" Color="Transparent"/>
                <Button Grid.Column="2" 
                        Text="Passer cette étape" 
                        Command="{Binding JourneePasserCommand}"
                        BackgroundColor="#FFA726" 
                        TextColor="White" 
                        Padding="20,12" 
                        CornerRadius="8"/>
                <Button Grid.Column="3" 
                        Text="{Binding IsLastStep, Converter={StaticResource BoolToTextConverter}, ConverterParameter='Terminer la journée|Suivant →'}"
                        Command="{Binding JourneeSuivantCommand}" 
                        BackgroundColor="#4CAF50" 
                        TextColor="White"
                        Padding="20,12" 
                        CornerRadius="8" 
                        FontAttributes="Bold"/>
            </Grid>
        </Border>

    </Grid>
</ContentPage>