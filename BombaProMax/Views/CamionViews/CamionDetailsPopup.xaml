<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.CamionViews.CamionDetailsPopup"
               Color="Transparent">

    <Border BackgroundColor="White"       
            Padding="0"
            WidthRequest="550"
            HeightRequest="620"
            StrokeShape="RoundRectangle 12">
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- ========================================= -->
            <!-- HEADER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="0" 
                    BackgroundColor="#5C6BC0" 
                    Padding="20">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                    <Border Grid.Column="0"
                            BackgroundColor="#3F51B5"
                            WidthRequest="50"
                            HeightRequest="50"
                            StrokeShape="RoundRectangle 25"
                            StrokeThickness="0">
                        <Label Text="🚛" 
                               FontSize="24"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                        <Label Text="Détails du Camion" 
                               FontSize="18" 
                               FontAttributes="Bold"
                               TextColor="White"/>
                        <Label x:Name="MatriculeLabel"
                               Text="Matricule" 
                               FontSize="14"
                               TextColor="#C5CAE9"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="2" 
                            Text="✕" 
                            BackgroundColor="Transparent"
                            TextColor="White"
                            FontSize="20"
                            Clicked="OnCloseClicked"
                            VerticalOptions="Start"/>
                </Grid>
            </Border>

            <!-- ========================================= -->
            <!-- CONTENT                                   -->
            <!-- ========================================= -->
            <ScrollView Grid.Row="1" Padding="20">
                <VerticalStackLayout Spacing="15">

                    <!-- Statistics Cards -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <!-- Achats Card -->
                        <Border Grid.Column="0"
                                BackgroundColor="#E3F2FD"
                                Padding="15"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#2196F3"
                                StrokeThickness="2">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="🛒" 
                                       FontSize="24"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="AchatsCountLabel"
                                       Text="0" 
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       TextColor="#1565C0"/>
                                <Label Text="ACHATS" 
                                       FontSize="10"
                                       HorizontalOptions="Center"
                                       TextColor="#666"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Fournisseur Card -->
                        <Border Grid.Column="1"
                                BackgroundColor="#FFF3E0"
                                Padding="15"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#FF9800"
                                StrokeThickness="2">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="🏢" 
                                       FontSize="24"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="FournisseurLabel"
                                       Text="N/A" 
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       TextColor="#E65100"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1"/>
                                <Label Text="FOURNISSEUR" 
                                       FontSize="10"
                                       HorizontalOptions="Center"
                                       TextColor="#666"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Basic Information Section -->
                    <Border BackgroundColor="#F8F8F8" 
                            Padding="15"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#E0E0E0">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="ℹ️ Informations de Base" 
                                   FontAttributes="Bold" 
                                   TextColor="#333" 
                                   FontSize="14"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>

                            <Grid RowDefinitions="Auto,Auto,Auto" 
                                  ColumnDefinitions="120,*"
                                  RowSpacing="10">

                                <Label Grid.Row="0" Grid.Column="0" Text="ID:" FontAttributes="Bold" TextColor="#666" FontSize="13"/>
                                <Label Grid.Row="0" Grid.Column="1" x:Name="IdLabel" Text="N/A" TextColor="#333" FontSize="13"/>

                                <Label Grid.Row="1" Grid.Column="0" Text="Matricule:" FontAttributes="Bold" TextColor="#666" FontSize="13"/>
                                <Label Grid.Row="1" Grid.Column="1" x:Name="MatriculeValueLabel" Text="N/A" TextColor="#333" FontSize="13" FontAttributes="Bold"/>

                                <Label Grid.Row="2" Grid.Column="0" Text="Marque:" FontAttributes="Bold" TextColor="#666" FontSize="13"/>
                                <Label Grid.Row="2" Grid.Column="1" x:Name="MarqueLabel" Text="N/A" TextColor="#333" FontSize="13"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Citerne Section -->
                    <Border BackgroundColor="#E8F5E9" 
                            Padding="15"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#4CAF50">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="🛢️ Citerne Assignée" 
                                   FontAttributes="Bold" 
                                   TextColor="#2E7D32" 
                                   FontSize="14"/>
                            <BoxView Color="#C8E6C9" HeightRequest="1"/>

                            <HorizontalStackLayout Spacing="10">
                                <Border x:Name="CiterneStatusBadge"
                                        BackgroundColor="#9E9E9E"
                                        Padding="10,5"
                                        StrokeShape="RoundRectangle 4"
                                        StrokeThickness="0">
                                    <Label x:Name="CiterneStatusLabel"
                                           Text="Non assignée"
                                           TextColor="White"
                                           FontSize="12"
                                           FontAttributes="Bold"/>
                                </Border>
                                <Label x:Name="CiterneDetailsLabel"
                                       Text=""
                                       TextColor="#333"
                                       FontSize="13"
                                       VerticalTextAlignment="Center"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Metadata Section -->
                    <Border BackgroundColor="#F3E5F5" 
                            Padding="15"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#9C27B0">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="📅 Informations d'Audit" 
                                   FontAttributes="Bold" 
                                   TextColor="#7B1FA2" 
                                   FontSize="14"/>
                            <BoxView Color="#E1BEE7" HeightRequest="1"/>

                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" 
                                  ColumnDefinitions="140,*"
                                  RowSpacing="10">

                                <Label Grid.Row="0" Grid.Column="0" Text="Créé par:" FontAttributes="Bold" TextColor="#666" FontSize="13"/>
                                <Label Grid.Row="0" Grid.Column="1" x:Name="CreatedByLabel" Text="Chargement..." TextColor="#333" FontSize="13"/>

                                <Label Grid.Row="1" Grid.Column="0" Text="Créé le:" FontAttributes="Bold" TextColor="#666" FontSize="13"/>
                                <Label Grid.Row="1" Grid.Column="1" x:Name="DateCreationLabel" Text="N/A" TextColor="#333" FontSize="13"/>

                                <Label Grid.Row="2" Grid.Column="0" Text="Modifié par:" FontAttributes="Bold" TextColor="#666" FontSize="13"/>
                                <Label Grid.Row="2" Grid.Column="1" x:Name="ModifiedByLabel" Text="Chargement..." TextColor="#333" FontSize="13"/>

                                <Label Grid.Row="3" Grid.Column="0" Text="Modifié le:" FontAttributes="Bold" TextColor="#666" FontSize="13"/>
                                <Label Grid.Row="3" Grid.Column="1" x:Name="DateModificationLabel" Text="N/A" TextColor="#333" FontSize="13"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ========================================= -->
            <!-- FOOTER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="2" 
                    BackgroundColor="#F5F5F5" 
                    Padding="15">
                <Button Text="Fermer" 
                        BackgroundColor="#5C6BC0"
                        TextColor="White"
                        Padding="30,10"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"
                        Clicked="OnCloseClicked"/>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>
