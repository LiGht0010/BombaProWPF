<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.AchatViews.AchatDetailsPopup">

    <Border BackgroundColor="#F5F5F5" Padding="0" WidthRequest="1000" HeightRequest="750" StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="16"/>
        </Border.StrokeShape>
        
        <Grid RowDefinitions="Auto,*">
            
            <!-- HEADER -->
            <Border Grid.Row="0" BackgroundColor="#E8A84C" Padding="25,18" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label x:Name="HeaderLabel" Text="Détails de l'Achat" FontSize="22" FontAttributes="Bold" TextColor="White"/>
                        <HorizontalStackLayout Spacing="25">
                            <Label x:Name="NumeroLabel" Text="ACH-2025-001" FontSize="13" TextColor="#FFF3E0"/>
                            <Label x:Name="DateLabel" Text="01/01/2025" FontSize="13" TextColor="#FFF3E0"/>
                            <Label x:Name="FournisseurHeaderLabel" Text="Fournisseur: -" FontSize="13" TextColor="#FFF3E0"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                    
                    <!-- PDF Button -->
                    <Button Grid.Column="1" 
                            x:Name="PdfButton"
                            Text="📄 Enregistrer PDF" 
                            BackgroundColor="#2E7D32" 
                            TextColor="White" 
                            FontSize="13"
                            FontAttributes="Bold"
                            Padding="16,10"
                            CornerRadius="8" 
                            Margin="0,0,12,0"
                            Clicked="OnEnregistrerPdfClicked"/>
                    
                    <!-- Close Button -->
                    <Button Grid.Column="2" Text="✕" BackgroundColor="#D4943C" TextColor="White" FontSize="16" WidthRequest="36" HeightRequest="36" CornerRadius="18" Clicked="OnCloseClicked"/>
                </Grid>
            </Border>
            
            <!-- CONTENT -->
            <ScrollView Grid.Row="1" Padding="25,20">
                <VerticalStackLayout Spacing="20">
                    
                    <!-- ROW 1: Purchase Info + Financial Summary -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                        
                        <!-- Purchase Info Card -->
                        <Border Grid.Column="0" BackgroundColor="White" Padding="20" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="INFORMATIONS ACHAT" FontSize="12" FontAttributes="Bold" TextColor="#E8A84C"/>
                                <BoxView Color="#E0E0E0" HeightRequest="1" Margin="0,4"/>
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="6">
                                    <Label Grid.Row="0" Grid.Column="0" Text="Fournisseur:" FontSize="12" TextColor="#666"/>
                                    <Label Grid.Row="0" Grid.Column="1" x:Name="FournisseurLabel" Text="-" FontSize="12" FontAttributes="Bold" TextColor="#333"/>
                                    <Label Grid.Row="1" Grid.Column="0" Text="Produit:" FontSize="12" TextColor="#666"/>
                                    <Label Grid.Row="1" Grid.Column="1" x:Name="ProduitLabel" Text="-" FontSize="12" FontAttributes="Bold" TextColor="#333"/>
                                    <Label Grid.Row="2" Grid.Column="0" Text="Quantité:" FontSize="12" TextColor="#666"/>
                                    <Label Grid.Row="2" Grid.Column="1" x:Name="QuantiteLabel" Text="0 L" FontSize="12" FontAttributes="Bold" TextColor="#333"/>
                                    <Label Grid.Row="3" Grid.Column="0" Text="Date:" FontSize="12" TextColor="#666"/>
                                    <Label Grid.Row="3" Grid.Column="1" x:Name="DateInfoLabel" Text="-" FontSize="12" TextColor="#333"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Financial Summary Card -->
                        <Border Grid.Column="1" BackgroundColor="White" Padding="20" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="RESUME FINANCIER" FontSize="12" FontAttributes="Bold" TextColor="#E8A84C"/>
                                <BoxView Color="#E0E0E0" HeightRequest="1" Margin="0,4"/>
                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="20" RowSpacing="12">
                                    <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="2">
                                        <Label Text="Prix Unitaire" FontSize="11" TextColor="#666"/>
                                        <Label x:Name="PrixUnitaireLabel" Text="0.00 DH/L" FontSize="16" FontAttributes="Bold" TextColor="#333"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="2">
                                        <Label Text="Quantité" FontSize="11" TextColor="#666"/>
                                        <Label x:Name="QuantiteValueLabel" Text="0 L" FontSize="16" FontAttributes="Bold" TextColor="#333"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="2">
                                        <Label Text="Coût Total" FontSize="11" TextColor="#666"/>
                                        <Label x:Name="CoutTotalLabel" Text="0.00 DH" FontSize="26" FontAttributes="Bold" TextColor="#E8A84C"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                    
                    <!-- ROW 2: Transport Info + Delivery Status -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                        
                        <!-- Transport Info Card -->
                        <Border Grid.Column="0" BackgroundColor="White" Padding="20" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="🚚 TRANSPORT" FontSize="12" FontAttributes="Bold" TextColor="#E8A84C"/>
                                <BoxView Color="#E0E0E0" HeightRequest="1" Margin="0,4"/>
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="6">
                                    <Label Grid.Row="0" Grid.Column="0" Text="Chauffeur:" FontSize="12" TextColor="#666"/>
                                    <Label Grid.Row="0" Grid.Column="1" x:Name="ChauffeurLabel" Text="-" FontSize="12" FontAttributes="Bold" TextColor="#333"/>
                                    <Label Grid.Row="1" Grid.Column="0" Text="Camion:" FontSize="12" TextColor="#666"/>
                                    <Label Grid.Row="1" Grid.Column="1" x:Name="CamionLabel" Text="-" FontSize="12" FontAttributes="Bold" TextColor="#333"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Delivery Status Card -->
                        <Border Grid.Column="1" x:Name="DeliveryStatusCard" BackgroundColor="White" Padding="20" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="STATUT LIVRAISON" FontSize="12" FontAttributes="Bold" TextColor="#E8A84C"/>
                                <BoxView Color="#E0E0E0" HeightRequest="1" Margin="0,4"/>
                                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                    <Label x:Name="DeliveryStatusIcon" Text="✓" FontSize="24" TextColor="#2E7D32"/>
                                    <VerticalStackLayout Spacing="2">
                                        <Label x:Name="DeliveryStatusLabel" Text="Livraison OK" FontSize="14" FontAttributes="Bold" TextColor="#2E7D32"/>
                                        <Label x:Name="DeliveryStatusSubLabel" Text="Aucun problème signalé" FontSize="11" TextColor="#666"/>
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                    
                    <!-- ROW 3: Allocation Status -->
                    <Border BackgroundColor="White" Padding="20" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="⛽ ALLOCATION AUX RESERVOIRS" FontSize="12" FontAttributes="Bold" TextColor="#E8A84C"/>
                                <Border Grid.Column="1" x:Name="AllocationStatusBadge" BackgroundColor="#E8F5E9" Padding="10,5" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Label x:Name="AllocationStatusLabel" Text="Entièrement alloué" FontSize="11" FontAttributes="Bold" TextColor="#2E7D32"/>
                                </Border>
                            </Grid>
                            
                            <!-- Allocation Summary -->
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="20">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Quantité Achetée" FontSize="11" TextColor="#666"/>
                                    <Label x:Name="AllocationTotalLabel" Text="0 L" FontSize="16" FontAttributes="Bold" TextColor="#333"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Quantité Allouée" FontSize="11" TextColor="#666"/>
                                    <Label x:Name="AllocationAlloueeLabel" Text="0 L" FontSize="16" FontAttributes="Bold" TextColor="#2E7D32"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Quantité Restante" FontSize="11" TextColor="#666"/>
                                    <Label x:Name="AllocationRestanteLabel" Text="0 L" FontSize="16" FontAttributes="Bold" TextColor="#E65100"/>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- ROW 4: ALLOCATIONS TABLE (if carburant) -->
                    <Border x:Name="AllocationsTableSection" BackgroundColor="White" Padding="0" StrokeThickness="0" IsVisible="False">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="0">
                            <Label Text="DETAILS DES ALLOCATIONS" FontSize="12" FontAttributes="Bold" TextColor="#E8A84C" Margin="20,15,20,10"/>
                            
                            <!-- Table Header -->
                            <Grid ColumnDefinitions="1.5*,1.5*,*,*,*" ColumnSpacing="10" Padding="20,10" BackgroundColor="#F8F9FA">
                                <Label Grid.Column="0" Text="RESERVOIR" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Column="1" Text="PRODUIT" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Column="2" Text="QUANTITE" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="3" Text="DATE" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="4" Text="STATUT" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="Center"/>
                            </Grid>
                            
                            <!-- Table Body -->
                            <VerticalStackLayout x:Name="AllocationsContainer" Spacing="0"/>
                            
                            <!-- Table Footer -->
                            <Grid ColumnDefinitions="1.5*,1.5*,*,*,*" ColumnSpacing="10" Padding="20,12" BackgroundColor="#FFF3E0">
                                <Label Grid.Column="0" Text="TOTAL" FontSize="11" FontAttributes="Bold" TextColor="#E8A84C"/>
                                <Label Grid.Column="1" Text="" FontSize="11"/>
                                <Label Grid.Column="2" x:Name="TotalAllocationsFooter" Text="0 L" FontSize="12" FontAttributes="Bold" TextColor="#E8A84C" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="3" Text="" FontSize="11"/>
                                <Label Grid.Column="4" Text="" FontSize="11"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Non-Carburant Message -->
                    <Border x:Name="NonCarburantSection" BackgroundColor="#E3F2FD" Padding="20" StrokeThickness="0" IsVisible="False">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <HorizontalStackLayout Spacing="12">
                            <Label Text="ℹ️" FontSize="24"/>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Produit Non-Carburant" FontSize="14" FontAttributes="Bold" TextColor="#1976D2"/>
                                <Label Text="Le stock a été automatiquement mis à jour lors de la création de l'achat." FontSize="12" TextColor="#666"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>
                    
                    <!-- Signature Section -->
                    <Grid ColumnDefinitions="*,50,*" Margin="0,20,0,0">
                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="Signature Réceptionnaire:" FontSize="10" TextColor="#666"/>
                            <BoxView Color="#999" HeightRequest="1"/>
                            <BoxView HeightRequest="40" Color="Transparent"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="5">
                            <Label Text="Cachet et Signature:" FontSize="10" TextColor="#666"/>
                            <BoxView Color="#999" HeightRequest="1"/>
                            <BoxView HeightRequest="40" Color="Transparent"/>
                        </VerticalStackLayout>
                    </Grid>
                    
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Border>
</toolkit:Popup>
