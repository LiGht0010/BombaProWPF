<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.AchatViews.PasswordConfirmationPopup"
               Color="Transparent">

    <Border BackgroundColor="#F5F5F5" Padding="0" WidthRequest="400" HeightRequest="320" StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="12"/>
        </Border.StrokeShape>
        
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- ========================================= -->
            <!-- HEADER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="0" BackgroundColor="#3F51B5" Padding="20,18" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="?? Confirmation" FontSize="20" FontAttributes="Bold" TextColor="White"/>
                        <Label Text="Veuillez confirmer votre mot de passe" FontSize="12" TextColor="#C5CAE9"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="?" BackgroundColor="#303F9F" TextColor="White" FontSize="16" WidthRequest="36" HeightRequest="36" CornerRadius="18" Clicked="OnCancelClicked"/>
                </Grid>
            </Border>

            <!-- ========================================= -->
            <!-- CONTENT                                   -->
            <!-- ========================================= -->
            <VerticalStackLayout Grid.Row="1" Padding="20,20" Spacing="15" VerticalOptions="Center">
                
                <!-- Info Message -->
                <Border BackgroundColor="#E3F2FD" Padding="12" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="??" FontSize="18" VerticalOptions="Center"/>
                        <Label Text="Pour continuer avec l'allocation de carburant, veuillez saisir votre mot de passe." 
                               FontSize="12" 
                               TextColor="#1565C0" 
                               VerticalOptions="Center"
                               LineBreakMode="WordWrap"
                               MaxLines="3"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Password Entry -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="?? Mot de passe" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                    <Entry x:Name="PasswordEntry" 
                           Placeholder="Entrez votre mot de passe" 
                           IsPassword="True" 
                           FontSize="14"
                           ReturnType="Done"
                           Completed="OnPasswordEntryCompleted"/>
                </VerticalStackLayout>

                <!-- Error Label -->
                <Label x:Name="ErrorLabel" 
                       TextColor="#F44336" 
                       FontSize="12" 
                       IsVisible="False" 
                       HorizontalOptions="Center"/>
                
            </VerticalStackLayout>

            <!-- ========================================= -->
            <!-- FOOTER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="2" BackgroundColor="White" Padding="20,15" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,-2" Radius="6" Opacity="0.06"/>
                </Border.Shadow>
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                    <ActivityIndicator x:Name="LoadingIndicator" 
                                       IsRunning="False" 
                                       IsVisible="False" 
                                       Color="#3F51B5"
                                       VerticalOptions="Center"/>
                    <Button x:Name="CancelButton"
                            Grid.Column="1" 
                            Text="Annuler" 
                            BackgroundColor="#9E9E9E" 
                            TextColor="White" 
                            Padding="25,12" 
                            CornerRadius="8" 
                            Clicked="OnCancelClicked"/>
                    <Button x:Name="ConfirmButton"
                            Grid.Column="2" 
                            Text="? Confirmer" 
                            BackgroundColor="#4CAF50" 
                            TextColor="White" 
                            Padding="25,12" 
                            CornerRadius="8" 
                            FontAttributes="Bold" 
                            Clicked="OnConfirmClicked"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>
