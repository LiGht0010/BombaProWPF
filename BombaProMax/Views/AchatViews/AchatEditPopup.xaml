<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.AchatViews.AchatEditPopup"
               CanBeDismissedByTappingOutsideOfPopup="False"
               Color="Transparent">

    <Border BackgroundColor="#F5F5F5" Padding="0" WidthRequest="650" HeightRequest="750" StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="12"/>
        </Border.StrokeShape>
        
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- ========================================= -->
            <!-- HEADER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="0" BackgroundColor="#FF8F00" Padding="20,18" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="✏️ Modifier l'Achat" FontSize="20" FontAttributes="Bold" TextColor="White"/>
                        <Label Text="Mettre à jour les informations de l'achat" FontSize="12" TextColor="#FFE082"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="✕" BackgroundColor="#E65100" TextColor="White" FontSize="16" WidthRequest="36" HeightRequest="36" CornerRadius="18" Clicked="OnCancelClicked"/>
                </Grid>
            </Border>

            <!-- ========================================= -->
            <!-- CONTENT                                   -->
            <!-- ========================================= -->
            <ScrollView Grid.Row="1" Padding="20,15">
                <VerticalStackLayout Spacing="15">
                    
                    <!-- Date & Numéro Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="INFORMATIONS GÉNÉRALES" FontSize="11" FontAttributes="Bold" TextColor="#FF8F00"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                                <VerticalStackLayout Grid.Column="0" Spacing="5">
                                    <Label Text="📅 Date *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <DatePicker x:Name="AchatDatePicker" Format="dd/MM/yyyy" FontSize="14"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="5">
                                    <Label Text="🔢 N° Achat" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="NumeroEntry" Placeholder="ACH-XXXX-XXX" IsReadOnly="True" BackgroundColor="#EEEEEE" FontSize="13"/>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Fournisseur & Produit Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="FOURNISSEUR &amp; PRODUIT" FontSize="11" FontAttributes="Bold" TextColor="#FF8F00"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="🏢 Fournisseur *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                <Picker x:Name="FournisseurPicker" Title="Sélectionner un fournisseur..." ItemDisplayBinding="{Binding Societe}" FontSize="14" SelectedIndexChanged="OnFournisseurChanged"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="📦 Produit *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                <Picker x:Name="ProduitPicker" Title="Sélectionner un produit..." ItemDisplayBinding="{Binding Description}" FontSize="14" SelectedIndexChanged="OnProduitChanged"/>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Quantité & Prix Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="QUANTITÉ &amp; PRIX" FontSize="11" FontAttributes="Bold" TextColor="#FF8F00"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                                <VerticalStackLayout Grid.Column="0" Spacing="5">
                                    <Label Text="⛽ Quantité (L) *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="QuantiteEntry" Placeholder="Ex: 5000" Keyboard="Numeric" FontSize="14" TextChanged="OnQuantityOrPriceChanged"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="5">
                                    <Label Text="💲 Prix Unitaire (DH) *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="PrixUnitaireEntry" Placeholder="Ex: 10.50" Keyboard="Numeric" FontSize="14" TextChanged="OnQuantityOrPriceChanged"/>
                                </VerticalStackLayout>
                            </Grid>
                            <!-- Total -->
                            <Border BackgroundColor="#FFF3E0" Padding="12" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="💰 Coût Total" FontSize="13" FontAttributes="Bold" TextColor="#E65100" VerticalTextAlignment="Center"/>
                                    <Label x:Name="CoutTotalLabel" Grid.Column="1" Text="0.00 DH" FontSize="20" FontAttributes="Bold" TextColor="#FF8F00"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Transport Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="🚚 TRANSPORT (Optionnel)" FontSize="11" FontAttributes="Bold" TextColor="#FF8F00"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                                <VerticalStackLayout Grid.Column="0" Spacing="5">
                                    <Label Text="Chauffeur" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Picker x:Name="ChauffeurPicker" Title="Sélectionner..." ItemDisplayBinding="{Binding Nom}" FontSize="13"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="5">
                                    <Label Text="Camion" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Picker x:Name="CamionPicker" Title="Sélectionner..." ItemDisplayBinding="{Binding Matricule}" FontSize="13"/>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Livraison Défectueuse Card -->
                    <Border BackgroundColor="#FFEBEE" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="⚠️ Livraison Défectueuse" FontSize="13" FontAttributes="Bold" TextColor="#C62828"/>
                                <Label Text="Cocher si la livraison présente des problèmes" FontSize="11" TextColor="#666"/>
                            </VerticalStackLayout>
                            <Switch x:Name="LivraisonDefectueuseSwitch" Grid.Column="1" IsToggled="False" OnColor="#F44336"/>
                        </Grid>
                    </Border>

                    <!-- Warning about stock changes -->
                    <Border BackgroundColor="#E3F2FD" Padding="12" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="ℹ️" FontSize="16" VerticalTextAlignment="Center"/>
                            <Label Text="La modification de la quantité ou du produit peut affecter le stock." FontSize="12" TextColor="#1565C0" VerticalTextAlignment="Center"/>
                        </HorizontalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ========================================= -->
            <!-- FOOTER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="2" BackgroundColor="White" Padding="20,15" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,-2" Radius="6" Opacity="0.06"/>
                </Border.Shadow>
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                    <Label x:Name="ErrorLabel" TextColor="#F44336" FontSize="12" IsVisible="False" VerticalOptions="Center"/>
                    <Button Grid.Column="1" Text="Annuler" BackgroundColor="#9E9E9E" TextColor="White" Padding="25,12" CornerRadius="8" Clicked="OnCancelClicked"/>
                    <Button Grid.Column="2" Text="💾 Enregistrer" BackgroundColor="#4CAF50" TextColor="White" Padding="25,12" CornerRadius="8" FontAttributes="Bold" Clicked="OnSaveClicked"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>
