<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BombaProMax.Models"
             xmlns:viewmodels="clr-namespace:BombaProMax.ViewModels"
             x:Class="BombaProMax.Views.AchatViews.AchatPage"
             x:DataType="viewmodels:AchatViewModel"
             Style="{StaticResource AchatPageStyle}">

    <Grid RowDefinitions="*,Auto">
        <!-- Main Content -->
        <ScrollView Grid.Row="0" Style="{StaticResource AchatPageScrollView}">
            <VerticalStackLayout Style="{StaticResource AchatPageMainStack}">

                <!-- JOURNÉE PROGRESS BAR -->
                <Border BackgroundColor="#E3F2FD" Padding="15" Margin="0,0,0,10"
                        IsVisible="{Binding IsJourneeActive}" StrokeShape="RoundRectangle 10" Stroke="#1976D2">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Text="🚀" FontSize="24" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Margin="10,0">
                            <Label Text="{Binding JourneeStepInfo}" FontAttributes="Bold" TextColor="#1976D2" FontSize="14"/>
                            <Label Text="Journée en cours - Suivez les étapes" TextColor="#666" FontSize="11"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="📋" FontSize="20" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- HEADER SECTION with Action Button -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <VerticalStackLayout Style="{StaticResource AchatPageHeaderStack}">
                        <Label Text="Gestion des Achats" Style="{StaticResource AchatPageTitleLabel}"/>
                        <Label Text="{Binding Achats.Count, StringFormat='{0} achats enregistrés'}" Style="{StaticResource AchatPageSubtitleLabel}"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="+ Nouvel Achat" Style="{StaticResource AchatAddButton}"
                            Command="{Binding AddAchatCommand}" VerticalOptions="Center"
                            IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"/>
                </Grid>

                <!-- STATS CARDS ROW - Neumorphic Raised -->
                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="16"
                      IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                    <Border Grid.Column="0" Style="{StaticResource AchatStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Achats.Count}" Style="{StaticResource AchatStatNumber}"/>
                            <Label Text="Total Achats" Style="{StaticResource AchatStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource AchatStatCard}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FilterByThisMonthCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding ThisMonthCount}" Style="{StaticResource AchatStatNumber}" TextColor="#5EAA8D"/>
                            <Label Text="Ce Mois" Style="{StaticResource AchatStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource AchatStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding TotalVolume, StringFormat='{0:N0}'}" Style="{StaticResource AchatStatNumber}" TextColor="#E8A84C"/>
                            <Label Text="Volume Total (L)" Style="{StaticResource AchatStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="3" Style="{StaticResource AchatStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding TotalCost, StringFormat='{0:N0}'}" Style="{StaticResource AchatStatNumber}" TextColor="#8FA3B8"/>
                            <Label Text="Coût Total (DH)" Style="{StaticResource AchatStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- SEARCH BAR - Neumorphic Inset -->
                <Border Style="{StaticResource AchatSearchContainer}"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Image Source="search.png" WidthRequest="24" HeightRequest="24"/>
                        <Entry Grid.Column="1" Placeholder="Rechercher par numéro, fournisseur, produit..."
                               Text="{Binding SearchText}" Style="{StaticResource AchatSearchEntry}"/>
                        <Button Grid.Column="2" Text="Rechercher" Command="{Binding SearchAchatsCommand}"
                                BackgroundColor="#E8ECF1" TextColor="#5A6068" FontSize="13" FontAttributes="Bold"
                                Padding="16,10" CornerRadius="10"/>
                    </Grid>
                </Border>

                <!-- Loading Indicator -->
                <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                                  HeightRequest="50" WidthRequest="50" Color="#4A8FBF"/>

                <!-- TABLE CARD - Neumorphic Raised Container -->
                <Border Style="{StaticResource AchatTableCard}"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                    <VerticalStackLayout Style="{StaticResource AchatTableContainer}">
                        <!-- Table Header -->
                        <Grid Style="{StaticResource AchatTableHeaderGrid}">
                            <!-- Numéro - Sortable -->
                            <Border Grid.Column="0" BackgroundColor="Transparent" Padding="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SortByColumnCommand}" CommandParameter="Numero"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                                    <Label Text="Numéro" Style="{StaticResource AchatTableHeaderLabel}"/>
                                    <Label Text="{Binding NumeroSortIndicator}" Style="{StaticResource AchatTableHeaderLabel}"/>
                                </HorizontalStackLayout>
                            </Border>
                            
                            <!-- Date - Sortable (Default) -->
                            <Border Grid.Column="1" BackgroundColor="Transparent" Padding="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SortByColumnCommand}" CommandParameter="Date"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                                    <Label Text="Date" Style="{StaticResource AchatTableHeaderLabel}"/>
                                    <Label Text="{Binding DateSortIndicator}" Style="{StaticResource AchatTableHeaderLabel}"/>
                                </HorizontalStackLayout>
                            </Border>
                            
                            <!-- Fournisseur - Sortable -->
                            <Border Grid.Column="2" BackgroundColor="Transparent" Padding="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SortByColumnCommand}" CommandParameter="Fournisseur"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout HorizontalOptions="Start" Spacing="4">
                                    <Label Text="Fournisseur" Style="{StaticResource AchatTableHeaderLabelLeft}"/>
                                    <Label Text="{Binding FournisseurSortIndicator}" Style="{StaticResource AchatTableHeaderLabel}"/>
                                </HorizontalStackLayout>
                            </Border>
                            
                            <!-- Produit - Sortable -->
                            <Border Grid.Column="3" BackgroundColor="Transparent" Padding="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SortByColumnCommand}" CommandParameter="Produit"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout HorizontalOptions="Start" Spacing="4">
                                    <Label Text="Produit" Style="{StaticResource AchatTableHeaderLabelLeft}"/>
                                    <Label Text="{Binding ProduitSortIndicator}" Style="{StaticResource AchatTableHeaderLabel}"/>
                                </HorizontalStackLayout>
                            </Border>
                            
                            <!-- Quantité - Sortable -->
                            <Border Grid.Column="4" BackgroundColor="Transparent" Padding="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SortByColumnCommand}" CommandParameter="Quantite"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                                    <Label Text="Quantité" Style="{StaticResource AchatTableHeaderLabel}"/>
                                    <Label Text="{Binding QuantiteSortIndicator}" Style="{StaticResource AchatTableHeaderLabel}"/>
                                </HorizontalStackLayout>
                            </Border>
                            
                            <!-- Coût Total - Sortable -->
                            <Border Grid.Column="5" BackgroundColor="Transparent" Padding="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SortByColumnCommand}" CommandParameter="Cout"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                                    <Label Text="Coût Total" Style="{StaticResource AchatTableHeaderLabel}"/>
                                    <Label Text="{Binding CoutSortIndicator}" Style="{StaticResource AchatTableHeaderLabel}"/>
                                </HorizontalStackLayout>
                            </Border>
                            
                            <!-- Actions - Not Sortable -->
                            <Label Grid.Column="6" Text="Actions" Style="{StaticResource AchatTableHeaderLabel}"/>
                        </Grid>

                        <!-- Table Rows with SwipeView -->
                        <CollectionView ItemsSource="{Binding Achats}" Style="{StaticResource AchatTableCollectionView}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:AchatDto">
                                    <SwipeView BackgroundColor="Transparent">
                                        <!-- Left Swipe Actions -->
                                        <SwipeView.LeftItems>
                                            <SwipeItems Mode="Reveal">
                                                <SwipeItem Text="Détails" BackgroundColor="#8FA3B8"
                                                           Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:AchatViewModel}}, Path=ShowDetailsCommand}"
                                                           CommandParameter="{Binding .}"/>
                                                <SwipeItem Text="Modifier" BackgroundColor="#5EAA8D"
                                                           Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:AchatViewModel}}, Path=EditAchatCommand}"
                                                           CommandParameter="{Binding .}"/>
                                            </SwipeItems>
                                        </SwipeView.LeftItems>

                                        <!-- Right Swipe Actions -->
                                        <SwipeView.RightItems>
                                            <SwipeItems Mode="Reveal">
                                                <SwipeItem Text="Supprimer" BackgroundColor="#E16C6C"
                                                           Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:AchatViewModel}}, Path=DeleteAchatCommand}"
                                                           CommandParameter="{Binding .}"/>
                                            </SwipeItems>
                                        </SwipeView.RightItems>

                                        <!-- Row Content -->
                                        <VerticalStackLayout BackgroundColor="Transparent">
                                            <Grid Style="{StaticResource AchatTableRowGrid}">
                                                <Grid.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:AchatViewModel}}, Path=ShowAchatRowDetailsCommand}"
                                                                          CommandParameter="{Binding .}"/>
                                                </Grid.GestureRecognizers>

                                                <!-- Achat Number - Neumorphic Pill -->
                                                <Border Grid.Column="0" Style="{StaticResource AchatNumberCell}">
                                                    <Label Text="{Binding Numero, FallbackValue='N/A'}" Style="{StaticResource AchatNumberLabel}"/>
                                                </Border>

                                                <!-- Date -->
                                                <Label Grid.Column="1" Text="{Binding Date, StringFormat='{0:dd/MM/yyyy}'}" Style="{StaticResource AchatDateCell}"/>

                                                <!-- Fournisseur -->
                                                <Label Grid.Column="2" Text="{Binding FournisseurNom, FallbackValue='N/A'}" Style="{StaticResource AchatFournisseurCell}"/>

                                                <!-- Produit -->
                                                <Label Grid.Column="3" Text="{Binding ProduitNom, FallbackValue='N/A'}" Style="{StaticResource AchatProduitCell}"/>

                                                <!-- Quantité -->
                                                <Label Grid.Column="4" Text="{Binding Quantite, StringFormat='{0} L'}" Style="{StaticResource AchatQuantiteCell}"/>

                                                <!-- Coût Total -->
                                                <Label Grid.Column="5" Text="{Binding Cout, StringFormat='{0:N2} DH'}" Style="{StaticResource AchatCoutCell}"/>

                                                <!-- Actions -->
                                                <HorizontalStackLayout Grid.Column="6" Style="{StaticResource AchatActionsCell}">
                                                    <Button Text="Détails" Style="{StaticResource AchatDetailsButton}"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:AchatViewModel}}, Path=ShowDetailsCommand}"
                                                            CommandParameter="{Binding .}"/>
                                                    <Button Text="Allocation" Style="{StaticResource AchatAllocationButton}"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:AchatViewModel}}, Path=ShowAllocationCommand}"
                                                            CommandParameter="{Binding .}"/>
                                                    <Button Text="Modifier" Style="{StaticResource AchatModifierButton}"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:AchatViewModel}}, Path=EditAchatCommand}"
                                                            CommandParameter="{Binding .}"/>
                                                    <Button Text="Supprimer" Style="{StaticResource AchatSupprimerButton}"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:AchatViewModel}}, Path=DeleteAchatCommand}"
                                                            CommandParameter="{Binding .}"/>
                                                </HorizontalStackLayout>
                                            </Grid>

                                            <!-- Row Divider -->
                                            <BoxView Style="{StaticResource AchatRowDivider}"/>
                                        </VerticalStackLayout>
                                    </SwipeView>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                            <!-- Modern Empty View - Neumorphic Style -->
                            <CollectionView.EmptyView>
                                <VerticalStackLayout Style="{StaticResource AchatEmptyView}">
                                    <!-- Neumorphic Icon Container -->
                                    <Border BackgroundColor="#EEF1F5" WidthRequest="100" HeightRequest="100" StrokeThickness="0" Margin="0,0,0,16">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="50"/></Border.StrokeShape>
                                        <Border.Shadow><Shadow Brush="#C5CAD1" Offset="6,6" Radius="12" Opacity="0.25"/></Border.Shadow>
                                        <Label Text="🛒" FontSize="48" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <Label Text="Aucun achat disponible" Style="{StaticResource AchatEmptyTitle}"/>
                                    <Label Text="Commencez par ajouter votre premier achat pour gérer vos approvisionnements" Style="{StaticResource AchatEmptySubtitle}"/>
                                    <Button Text="+ Ajouter un Achat" Style="{StaticResource AchatEmptyButton}" Command="{Binding AddAchatCommand}"/>
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- JOURNÉE NAVIGATION BAR -->
        <Border Grid.Row="1" BackgroundColor="#F5F5F5" Padding="15" IsVisible="{Binding IsJourneeActive}" StrokeThickness="0">
            <Border.Shadow><Shadow Brush="#000" Offset="0,-2" Radius="8" Opacity="0.1"/></Border.Shadow>
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                <Button Text="← Précédent" Command="{Binding JourneePrecedentCommand}"
                        BackgroundColor="#757575" TextColor="White" Padding="20,12" CornerRadius="8"
                        IsVisible="{Binding IsFirstStep, Converter={StaticResource InvertedBoolConverter}}"/>
                <BoxView Grid.Column="1" Color="Transparent"/>
                <Button Grid.Column="2" Text="Passer cette étape" Command="{Binding JourneePasserCommand}"
                        BackgroundColor="#FFA726" TextColor="White" Padding="20,12" CornerRadius="8"/>
                <Button Grid.Column="3" Text="{Binding IsLastStep, Converter={StaticResource BoolToTextConverter}, ConverterParameter='Terminer la journée|Suivant →'}"
                        Command="{Binding JourneeSuivantCommand}" BackgroundColor="#4CAF50" TextColor="White"
                        Padding="20,12" CornerRadius="8" FontAttributes="Bold"/>
            </Grid>
        </Border>
    </Grid>
</ContentPage>