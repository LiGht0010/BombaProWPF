<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.ChauffeurViews.ChauffeurDetailsPopup">

    <Border BackgroundColor="White"       
           Padding="20"
           WidthRequest="600">
        <ScrollView>
            <VerticalStackLayout Spacing="20">
                <!-- Header with Chauffeur Badge -->
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                    <Border Grid.Column="0"
                            BackgroundColor="#336860"
                            WidthRequest="50"
                            HeightRequest="50"
                            StrokeShape="RoundRectangle 25">
                        <Label Text="🚗" 
                               FontSize="24"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label x:Name="ChauffeurNameLabel"
                               FontSize="20" 
                               FontAttributes="Bold"
                               TextColor="#2C3E50"/>
                        <Border BackgroundColor="#336860"
                               Padding="6,2"
                               HorizontalOptions="Start"
                               StrokeShape="RoundRectangle 4">
                            <Label x:Name="ChauffeurCINLabel"
                                   FontSize="12"
                                   TextColor="White"/>
                        </Border>
                    </VerticalStackLayout>

                    <Button Grid.Column="2" 
                            Text="✕" 
                            BackgroundColor="Transparent"
                            TextColor="#666"
                            FontSize="20"
                            Clicked="OnCloseClicked"
                            VerticalOptions="Start"/>
                </Grid>

                <BoxView Color="#E0E0E0" HeightRequest="1"/>

                <!-- Statistics Cards -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <!-- Total Achats Card -->
                    <Border Grid.Column="0"
                            BackgroundColor="#E3F2FD"
                            Padding="15"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#2196F3"
                            StrokeThickness="2">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="🛒" 
                                   FontSize="24"
                                   HorizontalOptions="Center"/>
                            <Label x:Name="TotalAchatsLabel"
                                   Text="0" 
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   TextColor="#333"/>
                            <Label Text="TOTAL ACHATS" 
                                   FontSize="10"
                                   HorizontalOptions="Center"
                                   TextColor="#666"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Fournisseur Card -->
                    <Border Grid.Column="1"
                            BackgroundColor="#FFF3E0"
                            Padding="15"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#FF9800"
                            StrokeThickness="2">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="🚚" 
                                   FontSize="24"
                                   HorizontalOptions="Center"/>
                            <Label x:Name="FournisseurLabel"
                                   Text="N/A" 
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   TextColor="#333"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"/>
                            <Label Text="FOURNISSEUR" 
                                   FontSize="10"
                                   HorizontalOptions="Center"
                                   TextColor="#666"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <BoxView Color="#E0E0E0" HeightRequest="1"/>

                <!-- Chauffeur Details Section -->
                <Border BackgroundColor="#F8F8F8" 
                       Padding="15"
                       StrokeShape="RoundRectangle 8">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="📋 Informations du chauffeur" 
                               FontAttributes="Bold" 
                               TextColor="#333" 
                               FontSize="16"/>
                        <BoxView Color="#E0E0E0" HeightRequest="1"/>

                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" 
                              ColumnDefinitions="140,*"
                              RowSpacing="10">

                            <Label Grid.Row="0" Grid.Column="0" Text="Nom:" FontAttributes="Bold" TextColor="#666"/>
                            <Label Grid.Row="0" Grid.Column="1" x:Name="NomDetailLabel" TextColor="#333"/>

                            <Label Grid.Row="1" Grid.Column="0" Text="Prénom:" FontAttributes="Bold" TextColor="#666"/>
                            <Label Grid.Row="1" Grid.Column="1" x:Name="PrenomDetailLabel" TextColor="#333"/>

                            <Label Grid.Row="2" Grid.Column="0" Text="CIN:" FontAttributes="Bold" TextColor="#666"/>
                            <Label Grid.Row="2" Grid.Column="1" x:Name="CINDetailLabel" TextColor="#333"/>

                            <Label Grid.Row="3" Grid.Column="0" Text="Téléphone:" FontAttributes="Bold" TextColor="#666"/>
                            <Label Grid.Row="3" Grid.Column="1" x:Name="TelephoneDetailLabel" TextColor="#333"/>

                            <Label Grid.Row="4" Grid.Column="0" Text="N° Permis:" FontAttributes="Bold" TextColor="#666"/>
                            <Label Grid.Row="4" Grid.Column="1" x:Name="PermisDetailLabel" TextColor="#333"/>

                            <Label Grid.Row="5" Grid.Column="0" Text="Créé le:" FontAttributes="Bold" TextColor="#666"/>
                            <Label Grid.Row="5" Grid.Column="1" x:Name="DateCreationLabel" TextColor="#333"/>

                            <Label Grid.Row="6" Grid.Column="0" Text="Modifié le:" FontAttributes="Bold" TextColor="#666"/>
                            <Label Grid.Row="6" Grid.Column="1" x:Name="DateModificationLabel" TextColor="#333"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Close Button -->
                <Button Text="Fermer" 
                        BackgroundColor="#336860"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="45"
                        Clicked="OnCloseClicked"/>
            </VerticalStackLayout>
        </ScrollView>
    </Border>
</toolkit:Popup>
