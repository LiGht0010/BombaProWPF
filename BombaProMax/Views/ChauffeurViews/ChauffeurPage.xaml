<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BombaProMax.Models"
             xmlns:viewmodels="clr-namespace:BombaProMax.ViewModels"
             x:Class="BombaProMax.Views.ChauffeurViews.ChauffeurPage"
             x:DataType="viewmodels:ChauffeurViewModel"
             Style="{StaticResource ChauffeurPageStyle}">

    <ScrollView Style="{StaticResource ChauffeurPageScrollView}">
        <VerticalStackLayout Style="{StaticResource ChauffeurPageMainStack}">

            <!-- ========================================= -->
            <!-- HEADER SECTION with Action Button         -->
            <!-- ========================================= -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                <VerticalStackLayout Style="{StaticResource ChauffeurPageHeaderStack}">
                    <Label Text="Chauffeurs" 
                           Style="{StaticResource ChauffeurPageTitleLabel}"/>
                    <Label Text="{Binding Chauffeurs.Count, StringFormat='{0} chauffeurs enregistrés'}" 
                           Style="{StaticResource ChauffeurPageSubtitleLabel}"/>
                </VerticalStackLayout>
                
                <!-- Add Button -->
                <Button Grid.Column="1"
                        Text="+ Nouveau Chauffeur"
                        Style="{StaticResource ChauffeurAddButton}"
                        Command="{Binding AddChauffeurCommand}"
                        VerticalOptions="Center"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"/>
            </Grid>

            <!-- ========================================= -->
            <!-- STATS CARDS ROW - Neumorphic Raised       -->
            <!-- ========================================= -->
            <Grid ColumnDefinitions="*,*,*,*" 
                  ColumnSpacing="16"
                  IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                
                <!-- Total Chauffeurs -->
                <Border Grid.Column="0" Style="{StaticResource ChauffeurStatCard}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding Chauffeurs.Count}" 
                               Style="{StaticResource ChauffeurStatNumber}"/>
                        <Label Text="Total Chauffeurs" 
                               Style="{StaticResource ChauffeurStatLabel}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Active Today -->
                <Border Grid.Column="1" Style="{StaticResource ChauffeurStatCard}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="—" 
                               Style="{StaticResource ChauffeurStatNumber}"
                               TextColor="#5EAA8D"/>
                        <Label Text="Actifs Aujourd'hui" 
                               Style="{StaticResource ChauffeurStatLabel}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Deliveries -->
                <Border Grid.Column="2" Style="{StaticResource ChauffeurStatCard}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="—" 
                               Style="{StaticResource ChauffeurStatNumber}"
                               TextColor="#E8A84C"/>
                        <Label Text="Livraisons Mois" 
                               Style="{StaticResource ChauffeurStatLabel}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Disponibles -->
                <Border Grid.Column="3" Style="{StaticResource ChauffeurStatCard}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="—" 
                               Style="{StaticResource ChauffeurStatNumber}"
                               TextColor="#8FA3B8"/>
                        <Label Text="Disponibles" 
                               Style="{StaticResource ChauffeurStatLabel}"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- ========================================= -->
            <!-- SEARCH BAR - Neumorphic Inset             -->
            <!-- ========================================= -->
            <Border Style="{StaticResource ChauffeurSearchContainer}"
                    IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <!--<Label Grid.Column="0" 
                           Text="🔍" 
                           
                           FontSize="18"
                           TextColor="#8B939E"
                           VerticalOptions="Center"/>-->
                    <Image Source="search.png"
                           Width="24"
                           Height="24"/>

                    <Entry Grid.Column="1"
                           Placeholder="Rechercher par nom, CIN, téléphone..."
                           Style="{StaticResource ChauffeurSearchEntry}"/>
                    <Button Grid.Column="2"
                            Text="Filtres"
                            BackgroundColor="#E8ECF1"
                            TextColor="#5A6068"
                            FontSize="13"
                            FontAttributes="Bold"
                            Padding="16,10"
                            CornerRadius="10"/>
                </Grid>
            </Border>

            <!-- Loading Indicator -->
            <ActivityIndicator Style="{StaticResource ChauffeurPageLoadingIndicator}"
                              IsRunning="{Binding IsLoading}"
                              IsVisible="{Binding IsLoading}"/>

            <!-- ========================================= -->
            <!-- TABLE CARD - Neumorphic Raised Container  -->
            <!-- ========================================= -->
            <Border Style="{StaticResource ChauffeurTableCard}"
                    IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                <VerticalStackLayout Style="{StaticResource ChauffeurTableContainer}">

                    <!-- Table Header -->
                    <Grid Style="{StaticResource ChauffeurTableHeaderGrid}">
                        <Label Grid.Column="0" 
                               Text="Nom" 
                               Style="{StaticResource ChauffeurTableHeaderLabelLeft}"/>
                        <Label Grid.Column="1" 
                               Text="Prénom" 
                               Style="{StaticResource ChauffeurTableHeaderLabelLeft}"/>
                        <Label Grid.Column="2" 
                               Text="CIN" 
                               Style="{StaticResource ChauffeurTableHeaderLabel}"/>
                        <Label Grid.Column="3" 
                               Text="Téléphone" 
                               Style="{StaticResource ChauffeurTableHeaderLabel}"/>
                        <Label Grid.Column="4" 
                               Text="N° Permis" 
                               Style="{StaticResource ChauffeurTableHeaderLabel}"/>
                        <Label Grid.Column="5" 
                               Text="Actions" 
                               Style="{StaticResource ChauffeurTableHeaderLabel}"/>
                    </Grid>

                    <!-- Table Rows with SwipeView -->
                    <CollectionView ItemsSource="{Binding Chauffeurs}"
                                    Style="{StaticResource ChauffeurTableCollectionView}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ChauffeurDto">
                                <SwipeView BackgroundColor="Transparent">
                                    <!-- Left Swipe Actions -->
                                    <SwipeView.LeftItems>
                                        <SwipeItems Mode="Reveal">
                                            <SwipeItem Text="Détails"
                                                       BackgroundColor="#4A8FBF"
                                                       Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ChauffeurViewModel}}, Path=ShowDetailsCommand}"
                                                       CommandParameter="{Binding .}"/>
                                            <SwipeItem Text="Modifier"
                                                       BackgroundColor="#E8A84C"
                                                       Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ChauffeurViewModel}}, Path=EditChauffeurCommand}"
                                                       CommandParameter="{Binding .}"/>
                                        </SwipeItems>
                                    </SwipeView.LeftItems>

                                    <!-- Right Swipe Actions -->
                                    <SwipeView.RightItems>
                                        <SwipeItems Mode="Reveal">
                                            <SwipeItem Text="Supprimer"
                                                       BackgroundColor="#E16C6C"
                                                       Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ChauffeurViewModel}}, Path=DeleteChauffeurCommand}"
                                                       CommandParameter="{Binding .}"/>
                                        </SwipeItems>
                                    </SwipeView.RightItems>

                                    <!-- Row Content -->
                                    <VerticalStackLayout BackgroundColor="Transparent">
                                        <Grid Style="{StaticResource ChauffeurTableRowGrid}">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer 
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ChauffeurViewModel}}, Path=ShowDetailsCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Grid.GestureRecognizers>

                                            <!-- Nom with Neumorphic Avatar -->
                                            <HorizontalStackLayout Grid.Column="0" Spacing="12" VerticalOptions="Center">
                                                <Border BackgroundColor="#E8ECF1"
                                                        WidthRequest="42"
                                                        HeightRequest="42"
                                                        StrokeThickness="0">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="21"/>
                                                    </Border.StrokeShape>
                                                    <Border.Shadow>
                                                        <Shadow Brush="#C5CAD1"
                                                                Offset="2,2"
                                                                Radius="4"
                                                                Opacity="0.2"/>
                                                    </Border.Shadow>
                                                    <Label Text="{Binding Nom, Converter={StaticResource FirstLetterConverter}, FallbackValue='?'}"
                                                           TextColor="#4A8FBF"
                                                           FontSize="16"
                                                           FontAttributes="Bold"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center"/>
                                                </Border>
                                                <Label Text="{Binding Nom, FallbackValue='Sans nom'}" 
                                                       Style="{StaticResource ChauffeurNameCell}"/>
                                            </HorizontalStackLayout>

                                            <!-- Prénom -->
                                            <Label Grid.Column="1" 
                                                   Text="{Binding Prenom, FallbackValue='N/A'}" 
                                                   Style="{StaticResource ChauffeurPrenomCell}"/>

                                            <!-- CIN Badge - Neumorphic Pill -->
                                            <Border Grid.Column="2" 
                                                    Style="{StaticResource ChauffeurCINCell}">
                                                <Label Text="{Binding CIN, FallbackValue='N/A'}" 
                                                       Style="{StaticResource ChauffeurCINLabel}"/>
                                            </Border>

                                            <!-- Téléphone -->
                                            <Label Grid.Column="3" 
                                                   Text="{Binding Telephone, FallbackValue='—'}" 
                                                   Style="{StaticResource ChauffeurTelephoneCell}"/>

                                            <!-- N° Permis -->
                                            <Label Grid.Column="4" 
                                                   Text="{Binding NumeroPermis, FallbackValue='—'}" 
                                                   Style="{StaticResource ChauffeurPermisCell}"/>

                                            <!-- Actions -->
                                            <HorizontalStackLayout Grid.Column="5" 
                                                                   Style="{StaticResource ChauffeurActionsCell}">

                                                <Button Text="Modifier"
                                                        Style="{StaticResource ChauffeurModifierButton}"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ChauffeurViewModel}}, Path=EditChauffeurCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                <Button Text="Supprimer"
                                                        Style="{StaticResource ChauffeurSupprimerButton}"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ChauffeurViewModel}}, Path=DeleteChauffeurCommand}"
                                                        CommandParameter="{Binding .}"/>
                                            </HorizontalStackLayout>
                                        </Grid>

                                        <!-- Row Divider -->
                                        <BoxView Style="{StaticResource ChauffeurRowDivider}"/>
                                    </VerticalStackLayout>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                        <!-- Modern Empty View - Neumorphic Style -->
                        <CollectionView.EmptyView>
                            <VerticalStackLayout Style="{StaticResource ChauffeurEmptyView}">
                                <!-- Neumorphic Icon Container -->
                                <Border BackgroundColor="#EEF1F5"
                                        WidthRequest="100"
                                        HeightRequest="100"
                                        StrokeThickness="0"
                                        Margin="0,0,0,16">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="50"/>
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="#C5CAD1"
                                                Offset="6,6"
                                                Radius="12"
                                                Opacity="0.25"/>
                                    </Border.Shadow>
                                    <Label Text="👤"
                                           FontSize="48"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <Label Text="Aucun chauffeur" 
                                       Style="{StaticResource ChauffeurEmptyTitle}"/>
                                <Label Text="Commencez par ajouter votre premier chauffeur pour gérer votre flotte de livraison" 
                                       Style="{StaticResource ChauffeurEmptySubtitle}"/>
                                <Button Text="+ Ajouter un Chauffeur"
                                        Style="{StaticResource ChauffeurEmptyButton}"
                                        Command="{Binding AddChauffeurCommand}"/>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>