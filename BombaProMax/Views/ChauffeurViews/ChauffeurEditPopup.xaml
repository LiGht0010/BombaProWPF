<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.ChauffeurViews.ChauffeurEditPopup"
               Color="Transparent">

    <Border BackgroundColor="White"       
            Padding="0"
            WidthRequest="550"
            HeightRequest="620"
            StrokeShape="RoundRectangle 12">
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- ========================================= -->
            <!-- HEADER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="0" 
                    BackgroundColor="#FF8F00" 
                    Padding="20">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout>
                        <Label Text="✏️ Modifier le Chauffeur" 
                               FontSize="20" 
                               FontAttributes="Bold"
                               TextColor="White"/>
                        <Label Text="Mettre à jour les informations du chauffeur" 
                               FontSize="12"
                               TextColor="#FFE082"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" 
                            Text="✕" 
                            BackgroundColor="Transparent"
                            TextColor="White"
                            FontSize="20"
                            Clicked="OnCancelClicked"/>
                </Grid>
            </Border>

            <!-- ========================================= -->
            <!-- FORM CONTENT                              -->
            <!-- ========================================= -->
            <ScrollView Grid.Row="1" Padding="20">
                <VerticalStackLayout Spacing="15">
                    
                    <!-- Nom & Prénom -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <Border BackgroundColor="#FFF3E0" 
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#FF8F00">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="👤 Nom *" 
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#E65100"/>
                                <Entry x:Name="NomEntry"
                                       Placeholder="Entrez le nom"
                                       FontSize="14"
                                       TextColor="#E65100"/>
                            </VerticalStackLayout>
                        </Border>
                        
                        <Border Grid.Column="1"
                                BackgroundColor="#F8F8F8" 
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#E0E0E0">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="👤 Prénom" 
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#666"/>
                                <Entry x:Name="PrenomEntry"
                                       Placeholder="Entrez le prénom"
                                       FontSize="14"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- CIN & Téléphone -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <Border BackgroundColor="#F8F8F8" 
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#E0E0E0">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="🪪 CIN" 
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#666"/>
                                <Entry x:Name="CINEntry"
                                       Placeholder="Carte d'identité nationale"
                                       FontSize="14"/>
                            </VerticalStackLayout>
                        </Border>
                        
                        <Border Grid.Column="1"
                                BackgroundColor="#E3F2FD" 
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#1565C0">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="📞 Téléphone" 
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#0D47A1"/>
                                <Entry x:Name="TelephoneEntry"
                                       Placeholder="Ex: +212 6XX XXX XXX"
                                       Keyboard="Telephone"
                                       FontSize="14"
                                       TextColor="#0D47A1"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Numéro Permis -->
                    <Border BackgroundColor="#F3E5F5" 
                            Padding="12"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#7B1FA2">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="🚗 Numéro de Permis" 
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#7B1FA2"/>
                            <Entry x:Name="NumeroPermisEntry"
                                   Placeholder="Numéro de permis de conduire"
                                   FontSize="14"
                                   TextColor="#7B1FA2"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Fournisseur -->
                    <Border BackgroundColor="#E0F2F1" 
                            Padding="12"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#00796B">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="🏢 Fournisseur associé" 
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#00695C"/>
                            <Picker x:Name="FournisseurPicker"
                                    Title="Sélectionner un fournisseur..."
                                    ItemDisplayBinding="{Binding Societe}"
                                    FontSize="14"/>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ========================================= -->
            <!-- FOOTER: Error + Actions                   -->
            <!-- ========================================= -->
            <Border Grid.Row="2" 
                    BackgroundColor="#F5F5F5" 
                    Padding="15">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="15">
                    <!-- Error Message -->
                    <Label x:Name="ErrorLabel"
                           TextColor="#F44336"
                           FontSize="12"
                           IsVisible="False"
                           VerticalOptions="Center"/>

                    <!-- Cancel Button -->
                    <Button Grid.Column="1"
                            Text="Annuler" 
                            BackgroundColor="#9E9E9E"
                            TextColor="White"
                            Padding="20,10"
                            CornerRadius="8"
                            Clicked="OnCancelClicked"/>

                    <!-- Save Button -->
                    <Button Grid.Column="2"
                            Text="💾 Enregistrer" 
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            Padding="20,10"
                            CornerRadius="8"
                            FontAttributes="Bold"
                            Clicked="OnSaveClicked"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>
