<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:models="clr-namespace:BombaProMax.Models"
               x:Class="BombaProMax.Views.User.UserDetailsPopup"
               x:DataType="models:UserDto"
               Color="Transparent">

    <Border Style="{StaticResource UserPopupContainer}" WidthRequest="580">
        <ScrollView>
            <VerticalStackLayout Spacing="20">
                
                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="📋 Détails de l'utilisateur" 
                           Style="{StaticResource UserPopupTitle}"/>
                    <Button Grid.Column="1" 
                            Text="✕" 
                            Style="{StaticResource UserPopupCloseButton}"
                            Clicked="OnCloseClicked"/>
                </Grid>

                <BoxView Style="{StaticResource UserPopupDivider}"/>

                <!-- User Profile Card -->
                <Border BackgroundColor="#EDE7F6" 
                        Padding="20"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16">
                    <Border.Shadow>
                        <Shadow Brush="#9B6DD8" Offset="0,4" Radius="12" Opacity="0.18"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border BackgroundColor="#9B6DD8"
                                WidthRequest="64"
                                HeightRequest="64"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 32">
                            <Label Text="👤" 
                                   FontSize="28"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4" Margin="16,0">
                            <Label Text="{Binding Name}" 
                                   FontAttributes="Bold"
                                   TextColor="#5E35B1"
                                   FontSize="18"/>
                            <Label Text="{Binding Email}" 
                                   TextColor="#7E57C2"
                                   FontSize="13"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="8" VerticalOptions="Center">
                            <Border BackgroundColor="{Binding RoleColor}"
                                    Padding="12,6"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    HorizontalOptions="End">
                                <Label Text="{Binding RoleText}" 
                                       TextColor="White" 
                                       FontSize="11"
                                       FontAttributes="Bold"/>
                            </Border>
                            <Border BackgroundColor="{Binding StatusColor}"
                                    Padding="12,6"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    HorizontalOptions="End">
                                <Label Text="{Binding StatusText}" 
                                       TextColor="White" 
                                       FontSize="11"
                                       FontAttributes="Bold"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Account Information Section -->
                <Border Style="{StaticResource UserPopupSectionCard}">
                    <VerticalStackLayout Spacing="16">
                        <Label Text="ℹ️ Informations du compte" Style="{StaticResource UserPopupSectionTitle}"/>
                        
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" RowSpacing="16" ColumnSpacing="20">
                            <!-- Name -->
                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
                                <Label Text="Nom complet" Style="{StaticResource UserPopupFieldLabel}"/>
                                <Label Text="{Binding Name}" Style="{StaticResource UserDetailsValueLabel}"/>
                            </VerticalStackLayout>

                            <!-- Email -->
                            <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="6">
                                <Label Text="Adresse email" Style="{StaticResource UserPopupFieldLabel}"/>
                                <Label Text="{Binding Email}" Style="{StaticResource UserDetailsValueLabel}"/>
                            </VerticalStackLayout>

                            <!-- Role -->
                            <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="6">
                                <Label Text="Rôle assigné" Style="{StaticResource UserPopupFieldLabel}"/>
                                <Label Text="{Binding RoleText}" Style="{StaticResource UserDetailsValueLabel}" FontAttributes="Bold" TextColor="#9B6DD8"/>
                            </VerticalStackLayout>

                            <!-- Created Date -->
                            <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="6">
                                <Label Text="Date de création" Style="{StaticResource UserPopupFieldLabel}"/>
                                <Label Text="{Binding CreatedAt, StringFormat='{0:dd/MM/yyyy à HH:mm}'}" Style="{StaticResource UserDetailsValueLabel}"/>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Permissions Section -->
                <Border Style="{StaticResource UserPopupSectionCard}">
                    <VerticalStackLayout Spacing="16">
                        <Label Text="🔐 Permissions accordées" Style="{StaticResource UserPopupSectionTitle}"/>
                        
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Permissions}" Spacing="10">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Border BackgroundColor="#F0F4F8" 
                                            Padding="14,10" 
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Label Text="✓" 
                                                   TextColor="#5EAA8D" 
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center"
                                                   Margin="0,0,10,0"/>
                                            <Label Grid.Column="1" 
                                                   Text="{Binding .}" 
                                                   TextColor="#5A6068"
                                                   FontSize="13"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                            
                            <BindableLayout.EmptyView>
                                <Border BackgroundColor="#FFF3E0" 
                                        Padding="14,10" 
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8">
                                    <Label Text="Aucune permission spéciale assignée" 
                                           TextColor="#E65100"
                                           FontSize="13"
                                           HorizontalTextAlignment="Center"/>
                                </Border>
                            </BindableLayout.EmptyView>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Close Button -->
                <Button Text="Fermer" 
                        Style="{StaticResource UserDetailsCloseButton}"
                        Clicked="OnCloseClicked"/>
            </VerticalStackLayout>
        </ScrollView>
    </Border>
</toolkit:Popup>