<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:models="clr-namespace:BombaProMax.Models"
               x:Class="BombaProMax.Views.User.UserEditPopup"
               x:DataType="models:UserDto"
               Color="Transparent">

    <Border BackgroundColor="#F5F5F5" Padding="0" WidthRequest="800" HeightRequest="720" StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="12"/>
        </Border.StrokeShape>
        
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- ========================================= -->
            <!-- HEADER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="0" BackgroundColor="#FF8F00" Padding="20,18" StrokeThickness="0">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                    <Border Grid.Column="0" BackgroundColor="#E65100" WidthRequest="50" HeightRequest="50" StrokeShape="RoundRectangle 25" StrokeThickness="0">
                        <Label Text="👤" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                        <Label Text="✏️ Modifier l'Utilisateur" FontSize="20" FontAttributes="Bold" TextColor="White"/>
                        <Label Text="{Binding Email, TargetNullValue='email@example.com'}" FontSize="12" TextColor="#FFE082"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="2" Text="✕" BackgroundColor="#E65100" TextColor="White" FontSize="16" WidthRequest="36" HeightRequest="36" CornerRadius="18" Clicked="OnCancelClicked"/>
                </Grid>
            </Border>

            <!-- ========================================= -->
            <!-- CONTENT (Single ScrollView)               -->
            <!-- ========================================= -->
            <ScrollView Grid.Row="1" Padding="20,15">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                    
                    <!-- LEFT COLUMN -->
                    <VerticalStackLayout Grid.Column="0" Spacing="12">
                        
                        <!-- User Information Card -->
                        <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="10">
                                <Label Text="INFORMATIONS UTILISATEUR" FontSize="11" FontAttributes="Bold" TextColor="#FF8F00"/>
                                <BoxView Color="#E0E0E0" HeightRequest="1"/>
                                
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="👤 Nom d'utilisateur *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="NameEntry" Text="{Binding Name}" Placeholder="Entrez le nom complet" FontSize="13"/>
                                </VerticalStackLayout>
                                
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="📧 Adresse Email *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="EmailEntry" Text="{Binding Email}" Placeholder="exemple@email.com" Keyboard="Email" FontSize="13"/>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Change Password Card -->
                        <Border BackgroundColor="#FFF3E0" Padding="15" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="🔑 CHANGER MOT DE PASSE" FontSize="11" FontAttributes="Bold" TextColor="#E65100"/>
                                    <Switch x:Name="ChangePasswordSwitch" Grid.Column="1" OnColor="#FF9800" Toggled="OnChangePasswordToggled"/>
                                </Grid>
                                <BoxView Color="#FFE0B2" HeightRequest="1"/>
                                
                                <VerticalStackLayout x:Name="PasswordSection" Spacing="10" IsVisible="False">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Nouveau mot de passe" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                        <Entry x:Name="NewPasswordEntry" Placeholder="Minimum 8 caractères" IsPassword="True" FontSize="13" BackgroundColor="White"/>
                                    </VerticalStackLayout>
                                    
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Confirmer le mot de passe" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                        <Entry x:Name="ConfirmPasswordEntry" Placeholder="Répétez le mot de passe" IsPassword="True" FontSize="13" BackgroundColor="White"/>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                                
                                <Label x:Name="PasswordHint" Text="Activez pour changer le mot de passe" FontSize="10" TextColor="#999" IsVisible="True"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Role & Status Card -->
                        <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="10">
                                <Label Text="⚙️ RÔLE ET STATUT" FontSize="11" FontAttributes="Bold" TextColor="#FF8F00"/>
                                <BoxView Color="#E0E0E0" HeightRequest="1"/>
                                
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Rôle *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Picker x:Name="RolePicker" Title="Sélectionnez un rôle" FontSize="13">
                                        <Picker.Items>
                                            <x:String>Utilisateur</x:String>
                                            <x:String>Administrateur</x:String>
                                            <x:String>Superviseur</x:String>
                                        </Picker.Items>
                                    </Picker>
                                </VerticalStackLayout>
                                
                                <Border BackgroundColor="#FFF3E0" Padding="10" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                            <Label Text="Compte actif" TextColor="#5A6068" FontSize="12"/>
                                            <Label x:Name="StatusLabel" Text="Peut se connecter" TextColor="#FF8F00" FontSize="10"/>
                                        </VerticalStackLayout>
                                        <Switch x:Name="StatusSwitch" Grid.Column="1" IsToggled="{Binding IsActive}" OnColor="#FF8F00" Toggled="OnStatusToggled" VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Last Modified -->
                        <Border BackgroundColor="#ECEFF1" Padding="8" StrokeThickness="0" StrokeShape="RoundRectangle 8">
                            <Label Text="{Binding UpdatedAt, StringFormat='Dernière modification: {0:dd/MM/yyyy HH:mm}'}" TextColor="#78909C" FontSize="10" HorizontalTextAlignment="Center"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- RIGHT COLUMN: Permissions -->
                    <Border Grid.Column="1" BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="🔐 PERMISSIONS" FontSize="11" FontAttributes="Bold" TextColor="#FF8F00"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            
                            <!-- All permissions displayed directly -->
                            <Border BackgroundColor="#F8F9FA" Padding="10,8" StrokeThickness="0" StrokeShape="RoundRectangle 6">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <CheckBox x:Name="ViewReportsPermission" IsChecked="{Binding CanViewReports}" Color="#FF8F00" VerticalOptions="Center" Scale="0.9"/>
                                    <Label Grid.Column="1" Text="📊 Consulter les rapports" TextColor="#5A6068" FontSize="12" VerticalOptions="Center"/>
                                </Grid>
                            </Border>

                            <Border BackgroundColor="#F8F9FA" Padding="10,8" StrokeThickness="0" StrokeShape="RoundRectangle 6">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <CheckBox x:Name="EditReportsPermission" IsChecked="{Binding CanViewReports}" Color="#FF8F00" VerticalOptions="Center" Scale="0.9"/>
                                    <Label Grid.Column="1" Text="✏️ Modifier les rapports" TextColor="#5A6068" FontSize="12" VerticalOptions="Center"/>
                                </Grid>
                            </Border>

                            <Border BackgroundColor="#F8F9FA" Padding="10,8" StrokeThickness="0" StrokeShape="RoundRectangle 6">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <CheckBox x:Name="ManageUsersPermission" IsChecked="{Binding CanManageUsers}" Color="#FF8F00" VerticalOptions="Center" Scale="0.9"/>
                                    <Label Grid.Column="1" Text="👥 Gérer les utilisateurs" TextColor="#5A6068" FontSize="12" VerticalOptions="Center"/>
                                </Grid>
                            </Border>

                            <Border BackgroundColor="#F8F9FA" Padding="10,8" StrokeThickness="0" StrokeShape="RoundRectangle 6">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <CheckBox x:Name="SystemSettingsPermission" IsChecked="{Binding CanManageSettings}" Color="#FF8F00" VerticalOptions="Center" Scale="0.9"/>
                                    <Label Grid.Column="1" Text="⚙️ Paramètres système" TextColor="#5A6068" FontSize="12" VerticalOptions="Center"/>
                                </Grid>
                            </Border>

                            <Border BackgroundColor="#F8F9FA" Padding="10,8" StrokeThickness="0" StrokeShape="RoundRectangle 6">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <CheckBox x:Name="ManageProductsPermission" IsChecked="{Binding CanManageProducts}" Color="#FF8F00" VerticalOptions="Center" Scale="0.9"/>
                                    <Label Grid.Column="1" Text="📦 Gérer les produits" TextColor="#5A6068" FontSize="12" VerticalOptions="Center"/>
                                </Grid>
                            </Border>

                            <Border BackgroundColor="#F8F9FA" Padding="10,8" StrokeThickness="0" StrokeShape="RoundRectangle 6">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <CheckBox x:Name="ManageClientsPermission" IsChecked="{Binding CanManageCustomers}" Color="#FF8F00" VerticalOptions="Center" Scale="0.9"/>
                                    <Label Grid.Column="1" Text="🧑‍💼 Gérer les clients" TextColor="#5A6068" FontSize="12" VerticalOptions="Center"/>
                                </Grid>
                            </Border>

                            <Border BackgroundColor="#F8F9FA" Padding="10,8" StrokeThickness="0" StrokeShape="RoundRectangle 6">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <CheckBox x:Name="ManageSalesPermission" IsChecked="{Binding CanManageSales}" Color="#FF8F00" VerticalOptions="Center" Scale="0.9"/>
                                    <Label Grid.Column="1" Text="💰 Gérer les ventes" TextColor="#5A6068" FontSize="12" VerticalOptions="Center"/>
                                </Grid>
                            </Border>

                            <Border BackgroundColor="#F8F9FA" Padding="10,8" StrokeThickness="0" StrokeShape="RoundRectangle 6">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <CheckBox x:Name="ManageExpensesPermission" IsChecked="{Binding ShowDepenses}" Color="#FF8F00" VerticalOptions="Center" Scale="0.9"/>
                                    <Label Grid.Column="1" Text="💸 Gérer les dépenses" TextColor="#5A6068" FontSize="12" VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </ScrollView>

            <!-- ========================================= -->
            <!-- FOOTER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="2" BackgroundColor="White" Padding="20,15" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,-2" Radius="6" Opacity="0.06"/>
                </Border.Shadow>
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                    <Label x:Name="ErrorLabel" TextColor="#F44336" FontSize="12" IsVisible="False" VerticalOptions="Center"/>
                    <Button Grid.Column="1" Text="Annuler" BackgroundColor="#9E9E9E" TextColor="White" Padding="25,12" CornerRadius="8" Clicked="OnCancelClicked"/>
                    <Button Grid.Column="2" Text="💾 Enregistrer" BackgroundColor="#4CAF50" TextColor="White" Padding="25,12" CornerRadius="8" FontAttributes="Bold" Clicked="OnSaveClicked"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>