<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.User.UserCreatePopup"
               Color="Transparent">

    <Border BackgroundColor="#F5F5F5" Padding="0" WidthRequest="800" HeightRequest="700" StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="12"/>
        </Border.StrokeShape>
        
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- ========================================= -->
            <!-- HEADER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="0" BackgroundColor="#7B1FA2" Padding="20,18" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="👤 Nouvel Utilisateur" FontSize="20" FontAttributes="Bold" TextColor="White"/>
                        <Label Text="Créer un nouveau compte utilisateur" FontSize="12" TextColor="#E1BEE7"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="✕" BackgroundColor="#6A1B9A" TextColor="White" FontSize="16" WidthRequest="36" HeightRequest="36" CornerRadius="18" Clicked="OnCancelClicked"/>
                </Grid>
            </Border>

            <!-- ========================================= -->
            <!-- CONTENT (Single ScrollView)               -->
            <!-- ========================================= -->
            <ScrollView Grid.Row="1" Padding="20,15">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                    
                    <!-- LEFT COLUMN -->
                    <VerticalStackLayout Grid.Column="0" Spacing="12">
                        
                        <!-- User Information Card -->
                        <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="10">
                                <Label Text="INFORMATIONS UTILISATEUR" FontSize="11" FontAttributes="Bold" TextColor="#7B1FA2"/>
                                <BoxView Color="#E0E0E0" HeightRequest="1"/>
                                
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="👤 Nom d'utilisateur *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="NameEntry" Placeholder="Entrez le nom complet" FontSize="13"/>
                                </VerticalStackLayout>
                                
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="📧 Adresse Email *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="EmailEntry" Placeholder="exemple@email.com" Keyboard="Email" FontSize="13"/>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Security Card -->
                        <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="10">
                                <Label Text="🔒 SÉCURITÉ" FontSize="11" FontAttributes="Bold" TextColor="#7B1FA2"/>
                                <BoxView Color="#E0E0E0" HeightRequest="1"/>
                                
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Mot de passe *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="PasswordEntry" Placeholder="Minimum 4 caractères" IsPassword="True" FontSize="13"/>
                                </VerticalStackLayout>
                                
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Confirmer le mot de passe *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="ConfirmPasswordEntry" Placeholder="Répétez le mot de passe" IsPassword="True" FontSize="13"/>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Role & Status Card -->
                        <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="10">
                                <Label Text="⚙️ RÔLE ET STATUT" FontSize="11" FontAttributes="Bold" TextColor="#7B1FA2"/>
                                <BoxView Color="#E0E0E0" HeightRequest="1"/>
                                
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Rôle *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Picker x:Name="RolePicker" Title="Sélectionnez un rôle" FontSize="13">
                                        <Picker.Items>
                                            <x:String>Utilisateur</x:String>
                                            <x:String>Administrateur</x:String>
                                            <x:String>Superviseur</x:String>
                                        </Picker.Items>
                                    </Picker>
                                </VerticalStackLayout>
                                
                                <Border BackgroundColor="#F3E5F5" Padding="10" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                            <Label Text="Compte actif" TextColor="#5A6068" FontSize="12"/>
                                            <Label Text="L'utilisateur peut se connecter" TextColor="#7B1FA2" FontSize="10"/>
                                        </VerticalStackLayout>
                                        <Switch x:Name="StatusSwitch" Grid.Column="1" IsToggled="True" OnColor="#7B1FA2" VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <!-- RIGHT COLUMN: Permissions -->
                    <Border Grid.Column="1" BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="🔐 PERMISSIONS" FontSize="11" FontAttributes="Bold" TextColor="#7B1FA2"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            
                            <!-- All permissions displayed directly -->
                            <Border BackgroundColor="#F8F9FA" Padding="10,8" StrokeThickness="0" StrokeShape="RoundRectangle 6">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <CheckBox x:Name="ViewReportsPermission" Color="#7B1FA2" VerticalOptions="Center" Scale="0.9"/>
                                    <Label Grid.Column="1" Text="📊 Consulter les rapports" TextColor="#5A6068" FontSize="12" VerticalOptions="Center"/>
                                </Grid>
                            </Border>

                            <Border BackgroundColor="#F8F9FA" Padding="10,8" StrokeThickness="0" StrokeShape="RoundRectangle 6">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <CheckBox x:Name="EditReportsPermission" Color="#7B1FA2" VerticalOptions="Center" Scale="0.9"/>
                                    <Label Grid.Column="1" Text="✏️ Modifier les rapports" TextColor="#5A6068" FontSize="12" VerticalOptions="Center"/>
                                </Grid>
                            </Border>

                            <Border BackgroundColor="#F8F9FA" Padding="10,8" StrokeThickness="0" StrokeShape="RoundRectangle 6">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <CheckBox x:Name="ManageUsersPermission" Color="#7B1FA2" VerticalOptions="Center" Scale="0.9"/>
                                    <Label Grid.Column="1" Text="👥 Gérer les utilisateurs" TextColor="#5A6068" FontSize="12" VerticalOptions="Center"/>
                                </Grid>
                            </Border>

                            <Border BackgroundColor="#F8F9FA" Padding="10,8" StrokeThickness="0" StrokeShape="RoundRectangle 6">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <CheckBox x:Name="SystemSettingsPermission" Color="#7B1FA2" VerticalOptions="Center" Scale="0.9"/>
                                    <Label Grid.Column="1" Text="⚙️ Paramètres système" TextColor="#5A6068" FontSize="12" VerticalOptions="Center"/>
                                </Grid>
                            </Border>

                            <Border BackgroundColor="#F8F9FA" Padding="10,8" StrokeThickness="0" StrokeShape="RoundRectangle 6">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <CheckBox x:Name="ManageProductsPermission" Color="#7B1FA2" VerticalOptions="Center" Scale="0.9"/>
                                    <Label Grid.Column="1" Text="📦 Gérer les produits" TextColor="#5A6068" FontSize="12" VerticalOptions="Center"/>
                                </Grid>
                            </Border>

                            <Border BackgroundColor="#F8F9FA" Padding="10,8" StrokeThickness="0" StrokeShape="RoundRectangle 6">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <CheckBox x:Name="ManageClientsPermission" Color="#7B1FA2" VerticalOptions="Center" Scale="0.9"/>
                                    <Label Grid.Column="1" Text="🧑‍💼 Gérer les clients" TextColor="#5A6068" FontSize="12" VerticalOptions="Center"/>
                                </Grid>
                            </Border>

                            <Border BackgroundColor="#F8F9FA" Padding="10,8" StrokeThickness="0" StrokeShape="RoundRectangle 6">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <CheckBox x:Name="ManageSalesPermission" Color="#7B1FA2" VerticalOptions="Center" Scale="0.9"/>
                                    <Label Grid.Column="1" Text="💰 Gérer les ventes" TextColor="#5A6068" FontSize="12" VerticalOptions="Center"/>
                                </Grid>
                            </Border>

                            <Border BackgroundColor="#F8F9FA" Padding="10,8" StrokeThickness="0" StrokeShape="RoundRectangle 6">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <CheckBox x:Name="ManageExpensesPermission" Color="#7B1FA2" VerticalOptions="Center" Scale="0.9"/>
                                    <Label Grid.Column="1" Text="💸 Gérer les dépenses" TextColor="#5A6068" FontSize="12" VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </ScrollView>

            <!-- ========================================= -->
            <!-- FOOTER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="2" BackgroundColor="White" Padding="20,15" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,-2" Radius="6" Opacity="0.06"/>
                </Border.Shadow>
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                    <Label x:Name="ErrorLabel" TextColor="#F44336" FontSize="12" IsVisible="False" VerticalOptions="Center"/>
                    <Button Grid.Column="1" Text="Annuler" BackgroundColor="#9E9E9E" TextColor="White" Padding="25,12" CornerRadius="8" Clicked="OnCancelClicked"/>
                    <Button Grid.Column="2" Text="✓ Créer l'utilisateur" BackgroundColor="#4CAF50" TextColor="White" Padding="25,12" CornerRadius="8" FontAttributes="Bold" Clicked="OnCreateClicked"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>