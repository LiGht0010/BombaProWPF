<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:BombaProMax.ViewModels"
             x:Class="BombaProMax.Views.SettingsViews.StationInfoPage"
             x:DataType="viewmodels:StationInfoViewModel"
             Title="Informations Station"
             BackgroundColor="#F4F6F8">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20">

            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Informations Station" 
                           FontSize="24" 
                           FontAttributes="Bold" 
                           TextColor="#2A3540"/>
                    <Label Text="Configurez les informations de votre station pour les documents officiels" 
                           FontSize="14" 
                           TextColor="#5A6068"/>
                </VerticalStackLayout>
                
                <Button Grid.Column="1"
                        Text="{Binding HasStationInfo, Converter={StaticResource BoolToEditCreateTextConverter}}"
                        Command="{Binding EditStationInfoCommand}"
                        BackgroundColor="#4A8FBF"
                        TextColor="White"
                        FontSize="14"
                        FontAttributes="Bold"
                        Padding="20,12"
                        CornerRadius="10"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"/>
            </Grid>

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                              IsVisible="{Binding IsLoading}"
                              Color="#4A8FBF"
                              HeightRequest="50"/>

            <Border IsVisible="{Binding HasStationInfo, Converter={StaticResource InvertedBoolConverter}}"
                    BackgroundColor="White"
                    Padding="40"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#20000000" Offset="0,2" Radius="8"/>
                </Border.Shadow>
                
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <Border BackgroundColor="#EEF1F5" 
                            WidthRequest="100" 
                            HeightRequest="100" 
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="50"/>
                        </Border.StrokeShape>
                        <Label Text="S" FontSize="48" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#4A8FBF"/>
                    </Border>
                    <Label Text="Aucune information configuree" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="#3A4550"
                           HorizontalOptions="Center"/>
                    <Label Text="Configurez les informations de votre station pour qu elles apparaissent sur vos factures." 
                           FontSize="14" 
                           TextColor="#5A6068"
                           HorizontalTextAlignment="Center"
                           MaximumWidthRequest="400"/>
                    <Button Text="+ Configurer la Station"
                            Command="{Binding CreateStationInfoCommand}"
                            BackgroundColor="#5EAA8D"
                            TextColor="White"
                            FontSize="14"
                            FontAttributes="Bold"
                            Padding="24,14"
                            CornerRadius="10"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="16" IsVisible="{Binding HasStationInfo}">

                <Border BackgroundColor="White" Padding="24" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="8"/>
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="24">
                        <VerticalStackLayout Spacing="12" WidthRequest="150">
                            <Border BackgroundColor="#F4F6F8" 
                                    WidthRequest="120" 
                                    HeightRequest="120" 
                                    StrokeThickness="1"
                                    Stroke="#E0E0E0"
                                    HorizontalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Grid>
                                    <Image x:Name="LogoImage" Aspect="AspectFit" IsVisible="False"/>
                                    <Label Text="S" FontSize="48" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#4A8FBF" x:Name="LogoPlaceholder"/>
                                </Grid>
                            </Border>
                            
                            <Button Text="Changer Logo"
                                    Command="{Binding PickLogoCommand}"
                                    BackgroundColor="#E8ECF1"
                                    TextColor="#5A6068"
                                    FontSize="12"
                                    Padding="12,8"
                                    CornerRadius="8"
                                    HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                            <Label Text="{Binding StationInfo.StationName, FallbackValue='Station Service'}" 
                                   FontSize="22" 
                                   FontAttributes="Bold" 
                                   TextColor="#2A3540"/>
                            
                            <Label Text="{Binding StationInfo.Adresse}" FontSize="14" TextColor="#5A6068"/>
                            <Label Text="{Binding StationInfo.Ville}" FontSize="14" TextColor="#5A6068"/>
                            
                            <HorizontalStackLayout Spacing="16" Margin="0,8,0,0">
                                <Label Text="{Binding StationInfo.Tel, StringFormat='Tel: {0}'}" FontSize="13" TextColor="#4A8FBF"/>
                                <Label Text="{Binding StationInfo.Email}" FontSize="13" TextColor="#4A8FBF"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border BackgroundColor="White" Padding="24" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="8"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="16">
                        <Label Text="Informations Fiscales" FontSize="16" FontAttributes="Bold" TextColor="#2A3540"/>
                        <BoxView HeightRequest="1" BackgroundColor="#E8ECF1"/>
                        
                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="24" RowSpacing="16">
                            <VerticalStackLayout Grid.Column="0" Grid.Row="0" Spacing="4">
                                <Label Text="ICE" FontSize="12" TextColor="#8FA3B8" FontAttributes="Bold"/>
                                <Label Text="{Binding StationInfo.ICE, FallbackValue='Non renseigne', TargetNullValue='Non renseigne'}" FontSize="14" TextColor="#3A4550"/>
                            </VerticalStackLayout>
                            
                            <VerticalStackLayout Grid.Column="1" Grid.Row="0" Spacing="4">
                                <Label Text="IF (Identifiant Fiscal)" FontSize="12" TextColor="#8FA3B8" FontAttributes="Bold"/>
                                <Label Text="{Binding StationInfo.IF, FallbackValue='Non renseigne', TargetNullValue='Non renseigne'}" FontSize="14" TextColor="#3A4550"/>
                            </VerticalStackLayout>
                            
                            <VerticalStackLayout Grid.Column="2" Grid.Row="0" Spacing="4">
                                <Label Text="RC (Registre Commerce)" FontSize="12" TextColor="#8FA3B8" FontAttributes="Bold"/>
                                <Label Text="{Binding StationInfo.RC, FallbackValue='Non renseigne', TargetNullValue='Non renseigne'}" FontSize="14" TextColor="#3A4550"/>
                            </VerticalStackLayout>
                            
                            <VerticalStackLayout Grid.Column="0" Grid.Row="1" Spacing="4">
                                <Label Text="TP (Taxe Professionnelle)" FontSize="12" TextColor="#8FA3B8" FontAttributes="Bold"/>
                                <Label Text="{Binding StationInfo.TP, FallbackValue='Non renseigne', TargetNullValue='Non renseigne'}" FontSize="14" TextColor="#3A4550"/>
                            </VerticalStackLayout>
                            
                            <VerticalStackLayout Grid.Column="1" Grid.Row="1" Spacing="4">
                                <Label Text="CNSS" FontSize="12" TextColor="#8FA3B8" FontAttributes="Bold"/>
                                <Label Text="{Binding StationInfo.CNSS, FallbackValue='Non renseigne', TargetNullValue='Non renseigne'}" FontSize="14" TextColor="#3A4550"/>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White" Padding="24" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="8"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="16">
                        <Label Text="Coordonnees" FontSize="16" FontAttributes="Bold" TextColor="#2A3540"/>
                        <BoxView HeightRequest="1" BackgroundColor="#E8ECF1"/>
                        
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="24">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="Telephone" FontSize="12" TextColor="#8FA3B8" FontAttributes="Bold"/>
                                <Label Text="{Binding StationInfo.Tel, FallbackValue='Non renseigne', TargetNullValue='Non renseigne'}" FontSize="14" TextColor="#3A4550"/>
                            </VerticalStackLayout>
                            
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Fax" FontSize="12" TextColor="#8FA3B8" FontAttributes="Bold"/>
                                <Label Text="{Binding StationInfo.Fax, FallbackValue='Non renseigne', TargetNullValue='Non renseigne'}" FontSize="14" TextColor="#3A4550"/>
                            </VerticalStackLayout>
                            
                            <VerticalStackLayout Grid.Column="2" Spacing="4">
                                <Label Text="Site Web" FontSize="12" TextColor="#8FA3B8" FontAttributes="Bold"/>
                                <Label Text="{Binding StationInfo.SiteWeb, FallbackValue='Non renseigne', TargetNullValue='Non renseigne'}" FontSize="14" TextColor="#4A8FBF"/>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
