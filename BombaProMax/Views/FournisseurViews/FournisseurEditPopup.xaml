<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.FournisseurViews.FournisseurEditPopup"
               Color="Transparent">

    <Border BackgroundColor="#F5F5F5" Padding="0" WidthRequest="650" HeightRequest="780" StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="12"/>
        </Border.StrokeShape>
        
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- ========================================= -->
            <!-- HEADER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="0" BackgroundColor="#FF9800" Padding="20,18" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="✏️ Modifier le Fournisseur" 
                               FontSize="20" 
                               FontAttributes="Bold" 
                               TextColor="White"/>
                        <Label Text="Mettre à jour les informations du fournisseur" 
                               FontSize="12" 
                               TextColor="#FFE0B2"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" 
                            Text="✕" 
                            BackgroundColor="#F57C00" 
                            TextColor="White" 
                            FontSize="16" 
                            WidthRequest="36" 
                            HeightRequest="36" 
                            CornerRadius="18" 
                            Clicked="OnCancelClicked"/>
                </Grid>
            </Border>

            <!-- ========================================= -->
            <!-- CONTENT                                   -->
            <!-- ========================================= -->
            <ScrollView Grid.Row="1" Padding="20,15">
                <VerticalStackLayout Spacing="15">
                    
                    <!-- Basic Info Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="👤 INFORMATIONS DE BASE" FontSize="11" FontAttributes="Bold" TextColor="#FF9800"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                                <VerticalStackLayout Grid.Column="0" Spacing="5">
                                    <Label Text="Prénom" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="PrenomEntry"
                                           Placeholder="Ex: Mohamed"
                                           FontSize="14"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="5">
                                    <Label Text="Nom" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="NomEntry"
                                           Placeholder="Ex: Alami"
                                           FontSize="14"/>
                                </VerticalStackLayout>
                            </Grid>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="🏢 Société" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                <Entry x:Name="SocieteEntry"
                                       Placeholder="Ex: SARL Distribution Maroc"
                                       FontSize="14"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="📊 Statut" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                <Picker x:Name="StatutPicker"
                                        Title="Sélectionnez un statut"
                                        FontSize="14">
                                    <Picker.Items>
                                        <x:String>Actif</x:String>
                                        <x:String>Inactif</x:String>
                                        <x:String>En attente</x:String>
                                        <x:String>Suspendu</x:String>
                                    </Picker.Items>
                                </Picker>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Contact Info Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="📞 INFORMATIONS DE CONTACT" FontSize="11" FontAttributes="Bold" TextColor="#FF9800"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="📍 Adresse" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                <Entry x:Name="AdresseEntry"
                                       Placeholder="Ex: 123 Rue Mohammed V, Casablanca"
                                       FontSize="14"/>
                            </VerticalStackLayout>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                                <VerticalStackLayout Grid.Column="0" Spacing="5">
                                    <Label Text="📱 Téléphone" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="TelephoneEntry"
                                           Placeholder="Ex: 0612345678"
                                           Keyboard="Telephone"
                                           FontSize="14"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="5">
                                    <Label Text="✉️ Email" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="EmailEntry"
                                           Placeholder="Ex: contact@fournisseur.ma"
                                           Keyboard="Email"
                                           FontSize="14"/>
                                </VerticalStackLayout>
                            </Grid>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="👤 Personne de Contact" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                <Entry x:Name="ContactEntry"
                                       Placeholder="Ex: Ahmed Bennani"
                                       FontSize="14"/>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Financial Info Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="💳 INFORMATIONS FINANCIÈRES" FontSize="11" FontAttributes="Bold" TextColor="#FF9800"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="🏦 Numéro de Compte Bancaire (RIB)" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                <Entry x:Name="RIBEntry"
                                       Placeholder="Ex: 1234567890123456789012"
                                       Keyboard="Numeric"
                                       MaxLength="30"
                                       FontSize="14"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="📋 Conditions de Paiement" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                <Entry x:Name="ConditionsPaiementEntry"
                                       Placeholder="Ex: 30 jours fin de mois"
                                       FontSize="14"/>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ========================================= -->
            <!-- FOOTER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="2" BackgroundColor="White" Padding="20,15" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,-2" Radius="6" Opacity="0.06"/>
                </Border.Shadow>
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                    <Label x:Name="ErrorLabel" 
                           TextColor="#F44336" 
                           FontSize="12" 
                           IsVisible="False" 
                           VerticalOptions="Center"/>
                    <Button Grid.Column="1" 
                            Text="Annuler" 
                            BackgroundColor="#9E9E9E" 
                            TextColor="White" 
                            Padding="25,12" 
                            CornerRadius="8" 
                            Clicked="OnCancelClicked"/>
                    <Button Grid.Column="2" 
                            Text="💾 Enregistrer" 
                            BackgroundColor="#FF9800" 
                            TextColor="White" 
                            Padding="25,12" 
                            CornerRadius="8" 
                            FontAttributes="Bold" 
                            Clicked="OnSaveClicked"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>
