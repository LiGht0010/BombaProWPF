<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.FournisseurViews.FournisseurCreatePopup">

    <Border Style="{StaticResource FournisseurPopupContainer}">
        <ScrollView>
            <VerticalStackLayout Spacing="20">
                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="🏭 Créer un nouveau fournisseur" 
                           Style="{StaticResource FournisseurPopupTitle}"/>
                    <Button Grid.Column="1" 
                            Text="✕" 
                            Style="{StaticResource FournisseurPopupCloseButton}"
                            Clicked="OnCancelClicked"/>
                </Grid>

                <BoxView Style="{StaticResource FournisseurPopupDivider}"/>

                <!-- Fournisseur Form -->
                <VerticalStackLayout Spacing="18">

                    <!-- Basic Information Section -->
                    <Border Style="{StaticResource FournisseurPopupSectionCard}">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="👤 Informations de Base" 
                                   Style="{StaticResource FournisseurPopupSectionTitle}"/>

                            <BoxView Style="{StaticResource FournisseurPopupDivider}"/>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                                <!-- Prénom -->
                                <VerticalStackLayout Grid.Column="0" Spacing="8">
                                    <Label Text="Prénom" 
                                           Style="{StaticResource FournisseurPopupFieldLabel}"/>
                                    <Border Style="{StaticResource FournisseurPopupInputContainer}">
                                        <Entry x:Name="PrenomEntry"
                                               Placeholder="Ex: Mohamed"
                                               Style="{StaticResource FournisseurPopupEntry}"/>
                                    </Border>
                                </VerticalStackLayout>

                                <!-- Nom -->
                                <VerticalStackLayout Grid.Column="1" Spacing="8">
                                    <Label Text="Nom" 
                                           Style="{StaticResource FournisseurPopupFieldLabel}"/>
                                    <Border Style="{StaticResource FournisseurPopupInputContainer}">
                                        <Entry x:Name="NomEntry"
                                               Placeholder="Ex: Alami"
                                               Style="{StaticResource FournisseurPopupEntry}"/>
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Société -->
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Société" 
                                       Style="{StaticResource FournisseurPopupFieldLabel}"/>
                                <Border Style="{StaticResource FournisseurPopupInputContainer}">
                                    <Entry x:Name="SocieteEntry"
                                           Placeholder="Ex: SARL Distribution Maroc"
                                           Style="{StaticResource FournisseurPopupEntry}"/>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Statut Picker -->
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Statut" 
                                       Style="{StaticResource FournisseurPopupFieldLabel}"/>
                                <Border Style="{StaticResource FournisseurPopupInputContainer}">
                                    <Picker x:Name="StatutPicker"
                                            Title="Sélectionnez un statut"
                                            Style="{StaticResource FournisseurPopupPicker}">
                                        <Picker.Items>
                                            <x:String>Actif</x:String>
                                            <x:String>Inactif</x:String>
                                            <x:String>En attente</x:String>
                                            <x:String>Suspendu</x:String>
                                        </Picker.Items>
                                    </Picker>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Contact Information Section -->
                    <Border Style="{StaticResource FournisseurPopupSectionCard}">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="📞 Informations de Contact" 
                                   Style="{StaticResource FournisseurPopupSectionTitle}"/>

                            <BoxView Style="{StaticResource FournisseurPopupDivider}"/>

                            <!-- Adresse -->
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Adresse" 
                                       Style="{StaticResource FournisseurPopupFieldLabel}"/>
                                <Border Style="{StaticResource FournisseurPopupInputContainer}">
                                    <Entry x:Name="AdresseEntry"
                                           Placeholder="Ex: 123 Rue Mohammed V, Casablanca"
                                           Style="{StaticResource FournisseurPopupEntry}"/>
                                </Border>
                            </VerticalStackLayout>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                                <!-- Téléphone -->
                                <VerticalStackLayout Grid.Column="0" Spacing="8">
                                    <Label Text="Téléphone" 
                                           Style="{StaticResource FournisseurPopupFieldLabel}"/>
                                    <Border Style="{StaticResource FournisseurPopupInputContainer}">
                                        <Entry x:Name="TelephoneEntry"
                                               Placeholder="Ex: 0612345678"
                                               Keyboard="Telephone"
                                               Style="{StaticResource FournisseurPopupEntry}"/>
                                    </Border>
                                </VerticalStackLayout>

                                <!-- Email -->
                                <VerticalStackLayout Grid.Column="1" Spacing="8">
                                    <Label Text="Email" 
                                           Style="{StaticResource FournisseurPopupFieldLabel}"/>
                                    <Border Style="{StaticResource FournisseurPopupInputContainer}">
                                        <Entry x:Name="EmailEntry"
                                               Placeholder="Ex: contact@fournisseur.ma"
                                               Keyboard="Email"
                                               Style="{StaticResource FournisseurPopupEntry}"/>
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Contact -->
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Personne de Contact" 
                                       Style="{StaticResource FournisseurPopupFieldLabel}"/>
                                <Border Style="{StaticResource FournisseurPopupInputContainer}">
                                    <Entry x:Name="ContactEntry"
                                           Placeholder="Ex: Ahmed Bennani"
                                           Style="{StaticResource FournisseurPopupEntry}"/>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Financial Information Section -->
                    <Border Style="{StaticResource FournisseurPopupSectionCard}">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="💳 Informations Financières" 
                                   Style="{StaticResource FournisseurPopupSectionTitle}"/>

                            <BoxView Style="{StaticResource FournisseurPopupDivider}"/>

                            <!-- RIB -->
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Numéro de Compte Bancaire (RIB)" 
                                       Style="{StaticResource FournisseurPopupFieldLabel}"/>
                                <Border Style="{StaticResource FournisseurPopupInputContainer}">
                                    <Entry x:Name="RIBEntry"
                                           Placeholder="Ex: 1234567890123456789012"
                                           Keyboard="Numeric"
                                           MaxLength="30"
                                           Style="{StaticResource FournisseurPopupEntry}"/>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Conditions de Paiement -->
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Conditions de Paiement" 
                                       Style="{StaticResource FournisseurPopupFieldLabel}"/>
                                <Border Style="{StaticResource FournisseurPopupInputContainer}">
                                    <Entry x:Name="ConditionsPaiementEntry"
                                           Placeholder="Ex: 30 jours fin de mois"
                                           Style="{StaticResource FournisseurPopupEntry}"/>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Error Message -->
                    <Label x:Name="ErrorLabel"
                           Style="{StaticResource FournisseurPopupErrorLabel}"
                           IsVisible="False"/>

                    <!-- Action Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,10,0,0">
                        <!-- Cancel Button -->
                        <Button Grid.Column="0"
                                Text="Annuler"
                                Style="{StaticResource FournisseurPopupCancelButton}"
                                Clicked="OnCancelClicked"/>

                        <!-- Create Button -->
                        <Button Grid.Column="1"
                                Text="✓ Créer le fournisseur"
                                Style="{StaticResource FournisseurPopupCreateButton}"
                                Clicked="OnCreateClicked"/>
                    </Grid>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Border>
</toolkit:Popup>
