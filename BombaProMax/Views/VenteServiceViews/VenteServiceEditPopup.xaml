<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:sys="clr-namespace:System;assembly=netstandard"
               x:Class="BombaProMax.Views.VenteServiceViews.VenteServiceEditPopup"
               Color="Transparent">

    <Border BackgroundColor="White" Padding="0" WidthRequest="650" HeightRequest="720">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="12"/>
        </Border.StrokeShape>
        <Grid RowDefinitions="Auto,*,Auto">
            <!-- HEADER -->
            <Border Grid.Row="0" BackgroundColor="#1976D2" Padding="20">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout>
                        <Label Text="Modifier la Vente de Service" FontSize="20" FontAttributes="Bold" TextColor="White"/>
                        <Label x:Name="NumeroLabel" Text="VS-XXXX" FontSize="12" TextColor="#BBDEFB"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="X" BackgroundColor="Transparent" TextColor="White" FontSize="20" Clicked="OnCancelClicked"/>
                </Grid>
            </Border>

            <ScrollView Grid.Row="1" Padding="20">
                <VerticalStackLayout Spacing="15">
                    <!-- Date and Service Row -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <Border BackgroundColor="#F8F8F8" Padding="12" Stroke="#E0E0E0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Date *" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <DatePicker x:Name="DatePicker" FontSize="14" MaximumDate="{x:Static sys:DateTime.Today}"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="#F8F8F8" Padding="12" Stroke="#E0E0E0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="N Vente" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Entry x:Name="NumeroEntry" IsReadOnly="True" BackgroundColor="#EEEEEE" FontSize="14"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Service Selection -->
                    <Border BackgroundColor="#E0F2F1" Padding="12" Stroke="#00796B">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Service *" FontSize="12" FontAttributes="Bold" TextColor="#00695C"/>
                            <Picker x:Name="ServicePicker" Title="Selectionner un service..." FontSize="14" SelectedIndexChanged="OnServiceSelected"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Quantity and Price -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <Border BackgroundColor="#F3E5F5" Padding="12" Stroke="#7B1FA2">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Quantite *" FontSize="12" FontAttributes="Bold" TextColor="#7B1FA2"/>
                                <Entry x:Name="QuantiteEntry" Placeholder="1" Keyboard="Numeric" FontSize="16" FontAttributes="Bold" TextColor="#7B1FA2" HorizontalTextAlignment="Center" TextChanged="OnQuantityOrPriceChanged"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="#E8F5E9" Padding="12" Stroke="#4CAF50">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Prix Unitaire (DH) *" FontSize="12" FontAttributes="Bold" TextColor="#2E7D32"/>
                                <Entry x:Name="PrixEntry" Placeholder="0.00" Keyboard="Numeric" FontSize="16" FontAttributes="Bold" TextColor="#2E7D32" HorizontalTextAlignment="Center" TextChanged="OnQuantityOrPriceChanged"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Payment Method -->
                    <Border BackgroundColor="#FFF3E0" Padding="12" Stroke="#FF9800">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Moyen de Paiement" FontSize="12" FontAttributes="Bold" TextColor="#E65100"/>
                            <Picker x:Name="MoyenPaiementPicker" Title="Selectionner un moyen de paiement..." FontSize="14"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Client Selection -->
                    <Border BackgroundColor="#E3F2FD" Padding="12" Stroke="#1976D2">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Client (optionnel)" FontSize="12" FontAttributes="Bold" TextColor="#1565C0"/>
                            <Picker x:Name="ClientPicker" Title="Comptant (sans client)" FontSize="14"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Status Selection -->
                    <Border BackgroundColor="#F8F8F8" Padding="12" Stroke="#E0E0E0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Statut" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                            <Picker x:Name="StatutPicker" FontSize="14">
                                <Picker.ItemsSource>
                                    <x:Array Type="{x:Type x:String}">
                                        <x:String>Confirmee</x:String>
                                        <x:String>En attente</x:String>
                                        <x:String>Annulee</x:String>
                                    </x:Array>
                                </Picker.ItemsSource>
                            </Picker>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Notes -->
                    <Border BackgroundColor="#F8F8F8" Padding="12" Stroke="#E0E0E0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Notes (optionnel)" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                            <Editor x:Name="NotesEditor" Placeholder="Remarques ou details..." HeightRequest="60" FontSize="14"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Summary -->
                    <Border BackgroundColor="#E8F5E9" Padding="15" Stroke="#4CAF50" x:Name="SummaryCard">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="20">
                            <VerticalStackLayout HorizontalOptions="Center">
                                <Label Text="Montant Total" FontSize="11" TextColor="#666"/>
                                <Label x:Name="TotalLabel" Text="0.00 DH" FontAttributes="Bold" TextColor="#2E7D32" FontSize="20"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Audit Info (Read-only) -->
                    <Border BackgroundColor="#ECEFF1" Padding="12" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="15" RowSpacing="6">
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="5">
                                <Label Text="Cree:" FontSize="10" TextColor="#78909C"/>
                                <Label x:Name="DateCreationLabel" Text="-" FontSize="10" TextColor="#546E7A"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="5">
                                <Label Text="Par:" FontSize="10" TextColor="#78909C"/>
                                <Label x:Name="CreeParLabel" Text="-" FontSize="10" TextColor="#546E7A"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="5">
                                <Label Text="Modifie:" FontSize="10" TextColor="#78909C"/>
                                <Label x:Name="DateModificationLabel" Text="-" FontSize="10" TextColor="#546E7A"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="5">
                                <Label Text="Par:" FontSize="10" TextColor="#78909C"/>
                                <Label x:Name="ModifieParLabel" Text="-" FontSize="10" TextColor="#546E7A"/>
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>

            <!-- FOOTER -->
            <Border Grid.Row="2" BackgroundColor="#F5F5F5" Padding="15">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="15">
                    <Label x:Name="ErrorLabel" TextColor="#F44336" FontSize="12" IsVisible="False" VerticalOptions="Center"/>
                    <Button Grid.Column="1" Text="Annuler" BackgroundColor="#9E9E9E" TextColor="White" Padding="20,10" CornerRadius="8" Clicked="OnCancelClicked"/>
                    <Button Grid.Column="2" Text="Enregistrer" BackgroundColor="#1976D2" TextColor="White" Padding="20,10" CornerRadius="8" FontAttributes="Bold" Clicked="OnSaveClicked"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>
