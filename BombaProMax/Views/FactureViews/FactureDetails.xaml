<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.FactureViews.FactureDetails">

    <Border BackgroundColor="#F5F5F5" Padding="0" WidthRequest="1000" HeightRequest="750" StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="16"/>
        </Border.StrokeShape>
        
        <Grid RowDefinitions="Auto,*">
            
            <!-- HEADER -->
            <Border Grid.Row="0" BackgroundColor="#5EAA8D" Padding="25,18" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label x:Name="HeaderLabel" Text="Facture" FontSize="22" FontAttributes="Bold" TextColor="White"/>
                        <HorizontalStackLayout Spacing="25">
                            <Label x:Name="NumeroLabel" Text="FAC-2025-00001" FontSize="13" TextColor="#C8E6C9"/>
                            <Label x:Name="DateLabel" Text="01/01/2025" FontSize="13" TextColor="#C8E6C9"/>
                            <Label x:Name="ClientLabel" Text="Client: Non assigne" FontSize="13" TextColor="#C8E6C9"/>
                            <Label x:Name="StatutLabel" Text="Non Payee" FontSize="13" TextColor="#C8E6C9"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                    
                    <!-- PDF Button -->
                    <Button Grid.Column="1" 
                            x:Name="PdfButton"
                            Text="📄 Enregistrer PDF" 
                            BackgroundColor="#2E7D32" 
                            TextColor="White" 
                            FontSize="13"
                            FontAttributes="Bold"
                            Padding="16,10"
                            CornerRadius="8" 
                            Margin="0,0,12,0"
                            Clicked="OnEnregistrerPdfClicked"/>
                    
                    <!-- Close Button -->
                    <Button Grid.Column="2" Text="✕" BackgroundColor="#4A9A7D" TextColor="White" FontSize="16" WidthRequest="36" HeightRequest="36" CornerRadius="18" Clicked="OnCloseClicked"/>
                </Grid>
            </Border>
            
            <!-- CONTENT -->
            <ScrollView Grid.Row="1" Padding="25,20">
                <VerticalStackLayout Spacing="20">
                    
                    <!-- ROW 1: Client Info + Financial Summary -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                        
                        <!-- Client Info Card -->
                        <Border Grid.Column="0" BackgroundColor="White" Padding="20" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="INFORMATIONS CLIENT" FontSize="12" FontAttributes="Bold" TextColor="#5EAA8D"/>
                                <BoxView Color="#E0E0E0" HeightRequest="1" Margin="0,4"/>
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="6">
                                    <Label Grid.Row="0" Grid.Column="0" Text="Client:" FontSize="12" TextColor="#666"/>
                                    <Label Grid.Row="0" Grid.Column="1" x:Name="ClientNomLabel" Text="-" FontSize="12" FontAttributes="Bold" TextColor="#333"/>
                                    <Label Grid.Row="1" Grid.Column="0" Text="N° Client:" FontSize="12" TextColor="#666"/>
                                    <Label Grid.Row="1" Grid.Column="1" x:Name="ClientNumeroLabel" Text="-" FontSize="12" TextColor="#333"/>
                                    <Label Grid.Row="2" Grid.Column="0" Text="Contact:" FontSize="12" TextColor="#666"/>
                                    <Label Grid.Row="2" Grid.Column="1" x:Name="ClientContactLabel" Text="-" FontSize="12" TextColor="#333"/>
                                    <Label Grid.Row="3" Grid.Column="0" Text="Paiement:" FontSize="12" TextColor="#666"/>
                                    <Label Grid.Row="3" Grid.Column="1" x:Name="PaiementLabel" Text="-" FontSize="12" TextColor="#333"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Financial Summary Card -->
                        <Border Grid.Column="1" BackgroundColor="White" Padding="20" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="RESUME FINANCIER" FontSize="12" FontAttributes="Bold" TextColor="#5EAA8D"/>
                                <BoxView Color="#E0E0E0" HeightRequest="1" Margin="0,4"/>
                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="20" RowSpacing="10">
                                    <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="2">
                                        <Label Text="Nombre d'elements" FontSize="11" TextColor="#666"/>
                                        <Label x:Name="NbElementsLabel" Text="0" FontSize="16" FontAttributes="Bold" TextColor="#333"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="2">
                                        <Label Text="Statut" FontSize="11" TextColor="#666"/>
                                        <Label x:Name="StatutValueLabel" Text="Non Payee" FontSize="16" FontAttributes="Bold" TextColor="#E65100"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="2">
                                        <Label Text="Montant Total TTC" FontSize="11" TextColor="#666"/>
                                        <Label x:Name="MontantTotalLabel" Text="0.00 MAD" FontSize="26" FontAttributes="Bold" TextColor="#5EAA8D"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Row="2" Grid.Column="0" Spacing="2" IsVisible="False" x:Name="DatePaiementStack">
                                        <Label Text="Date Paiement" FontSize="11" TextColor="#666"/>
                                        <Label x:Name="DatePaiementLabel" Text="-" FontSize="14" FontAttributes="Bold" TextColor="#2E7D32"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                    
                    <!-- ROW 2: Linked BLs (if any) -->
                    <Border x:Name="BLsSection" BackgroundColor="White" Padding="20" StrokeThickness="0" IsVisible="False">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="BONS DE LIVRAISON LIES" FontSize="12" FontAttributes="Bold" TextColor="#5EAA8D"/>
                            <VerticalStackLayout x:Name="BLsContainer" Spacing="8"/>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- ROW 3: ELEMENTS TABLE -->
                    <Border BackgroundColor="White" Padding="0" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="0">
                            <Label Text="ELEMENTS DE LA FACTURE" FontSize="12" FontAttributes="Bold" TextColor="#5EAA8D" Margin="20,15,20,10"/>
                            
                            <!-- Table Header -->
                            <Grid ColumnDefinitions="2*,0.8*,0.8*,0.6*,1.2*,1.5*" ColumnSpacing="8" Padding="20,10" BackgroundColor="#F8F9FA">
                                <Label Grid.Column="0" Text="DESIGNATION" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Column="1" Text="QTE" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="2" Text="P.U HT" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                                <Label Grid.Column="3" Text="TVA" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="4" Text="P.U TTC" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                                <Label Grid.Column="5" Text="TOTAL TTC" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                            </Grid>
                            
                            <!-- Table Body -->
                            <VerticalStackLayout x:Name="ElementsContainer" Spacing="0"/>
                            
                            <!-- Table Footer -->
                            <Grid ColumnDefinitions="2*,0.8*,0.8*,0.6*,1.2*,1.5*" ColumnSpacing="8" Padding="20,12" BackgroundColor="#E8F5E9">
                                <Label Grid.Column="0" Text="TOTAL" FontSize="11" FontAttributes="Bold" TextColor="#5EAA8D"/>
                                <Label Grid.Column="1" x:Name="TotalQteFooter" Text="0" FontSize="12" FontAttributes="Bold" TextColor="#5EAA8D" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="2" x:Name="TotalHTFooter" Text="0.00" FontSize="11" FontAttributes="Bold" TextColor="#5EAA8D" HorizontalTextAlignment="End"/>
                                <Label Grid.Column="3" x:Name="TotalTVAFooter" Text="0.00" FontSize="11" FontAttributes="Bold" TextColor="#5EAA8D" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="4" Text="" FontSize="11"/>
                                <Label Grid.Column="5" x:Name="TotalMontantFooter" Text="0.00 MAD" FontSize="12" FontAttributes="Bold" TextColor="#5EAA8D" HorizontalTextAlignment="End"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Signature Section -->
                    <Grid ColumnDefinitions="*,50,*" Margin="0,20,0,0">
                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="Signature Client:" FontSize="10" TextColor="#666"/>
                            <BoxView Color="#999" HeightRequest="1"/>
                            <BoxView HeightRequest="40" Color="Transparent"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="5">
                            <Label Text="Cachet et Signature:" FontSize="10" TextColor="#666"/>
                            <BoxView Color="#999" HeightRequest="1"/>
                            <BoxView HeightRequest="40" Color="Transparent"/>
                        </VerticalStackLayout>
                    </Grid>
                    
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Border>
</toolkit:Popup>
