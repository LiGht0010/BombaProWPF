<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.FactureViews.BLDetails">

    <Border BackgroundColor="#F5F5F5" Padding="0" WidthRequest="1000" HeightRequest="700" StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="16"/>
        </Border.StrokeShape>
        
        <Grid RowDefinitions="Auto,*">
            
            <!-- HEADER -->
            <Border Grid.Row="0" BackgroundColor="#4A8FBF" Padding="25,18" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label x:Name="HeaderLabel" Text="Bon de Livraison" FontSize="22" FontAttributes="Bold" TextColor="White"/>
                        <HorizontalStackLayout Spacing="25">
                            <Label x:Name="NumeroLabel" Text="BL-2025-00001" FontSize="13" TextColor="#B3D9F2"/>
                            <Label x:Name="DateLabel" Text="01/01/2025" FontSize="13" TextColor="#B3D9F2"/>
                            <Label x:Name="ClientLabel" Text="Client: Non assigne" FontSize="13" TextColor="#B3D9F2"/>
                            <Label x:Name="StatutLabel" Text="Non Facture" FontSize="13" TextColor="#B3D9F2"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                    
                    <!-- PDF Button -->
                    <Button Grid.Column="1" 
                            x:Name="PdfButton"
                            Text="📄 Enregistrer PDF" 
                            BackgroundColor="#2E7D32" 
                            TextColor="White" 
                            FontSize="13"
                            FontAttributes="Bold"
                            Padding="16,10"
                            CornerRadius="8" 
                            Margin="0,0,12,0"
                            Clicked="OnEnregistrerPdfClicked"/>
                    
                    <!-- Close Button -->
                    <Button Grid.Column="2" Text="✕" BackgroundColor="#3A7CA5" TextColor="White" FontSize="16" WidthRequest="36" HeightRequest="36" CornerRadius="18" Clicked="OnCloseClicked"/>
                </Grid>
            </Border>
            
            <!-- CONTENT -->
            <ScrollView Grid.Row="1" Padding="25,20">
                <VerticalStackLayout Spacing="20">
                    
                    <!-- ROW 1: Client Info + Financial Summary -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                        
                        <!-- Client Info Card -->
                        <Border Grid.Column="0" BackgroundColor="White" Padding="20" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="INFORMATIONS CLIENT" FontSize="12" FontAttributes="Bold" TextColor="#4A8FBF"/>
                                <BoxView Color="#E0E0E0" HeightRequest="1" Margin="0,4"/>
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="6">
                                    <Label Grid.Row="0" Grid.Column="0" Text="Client:" FontSize="12" TextColor="#666"/>
                                    <Label Grid.Row="0" Grid.Column="1" x:Name="ClientNomLabel" Text="-" FontSize="12" FontAttributes="Bold" TextColor="#333"/>
                                    <Label Grid.Row="1" Grid.Column="0" Text="N° Client:" FontSize="12" TextColor="#666"/>
                                    <Label Grid.Row="1" Grid.Column="1" x:Name="ClientNumeroLabel" Text="-" FontSize="12" TextColor="#333"/>
                                    <Label Grid.Row="2" Grid.Column="0" Text="Contact:" FontSize="12" TextColor="#666"/>
                                    <Label Grid.Row="2" Grid.Column="1" x:Name="ClientContactLabel" Text="-" FontSize="12" TextColor="#333"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Financial Summary Card -->
                        <Border Grid.Column="1" BackgroundColor="White" Padding="20" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="RESUME FINANCIER" FontSize="12" FontAttributes="Bold" TextColor="#4A8FBF"/>
                                <BoxView Color="#E0E0E0" HeightRequest="1" Margin="0,4"/>
                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="20" RowSpacing="12">
                                    <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="2">
                                        <Label Text="Nombre de lignes" FontSize="11" TextColor="#666"/>
                                        <Label x:Name="NbLignesLabel" Text="0" FontSize="18" FontAttributes="Bold" TextColor="#333"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="2">
                                        <Label Text="Quantite totale" FontSize="11" TextColor="#666"/>
                                        <Label x:Name="QteToTaleLabel" Text="0" FontSize="18" FontAttributes="Bold" TextColor="#333"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="2">
                                        <Label Text="Montant Total" FontSize="11" TextColor="#666"/>
                                        <Label x:Name="MontantTotalLabel" Text="0.00 MAD" FontSize="24" FontAttributes="Bold" TextColor="#4A8FBF"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                    
                    <!-- ROW 2: Totaux par Produit -->
                    <Border BackgroundColor="White" Padding="20" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="TOTAUX PAR PRODUIT" FontSize="12" FontAttributes="Bold" TextColor="#4A8FBF"/>
                            <VerticalStackLayout x:Name="ProduitsContainer" Spacing="8"/>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- ROW 3: DETAILS TABLE -->
                    <Border BackgroundColor="White" Padding="0" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="0">
                            <Label Text="DETAILS DU BON DE LIVRAISON" FontSize="12" FontAttributes="Bold" TextColor="#4A8FBF" Margin="20,15,20,10"/>
                            
                            <!-- Table Header -->
                            <Grid ColumnDefinitions="2*,*,*,1.5*" ColumnSpacing="10" Padding="20,10" BackgroundColor="#F8F9FA">
                                <Label Grid.Column="0" Text="DESIGNATION" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Column="1" Text="QUANTITE" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="2" Text="PRIX UNIT." FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                                <Label Grid.Column="3" Text="MONTANT" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                            </Grid>
                            
                            <!-- Table Body -->
                            <VerticalStackLayout x:Name="DetailsContainer" Spacing="0"/>
                            
                            <!-- Table Footer -->
                            <Grid ColumnDefinitions="2*,*,*,1.5*" ColumnSpacing="10" Padding="20,12" BackgroundColor="#E3F2FD">
                                <Label Grid.Column="0" Text="TOTAL" FontSize="11" FontAttributes="Bold" TextColor="#4A8FBF"/>
                                <Label Grid.Column="1" x:Name="TotalQteFooter" Text="0" FontSize="12" FontAttributes="Bold" TextColor="#4A8FBF" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="2" Text="" FontSize="12"/>
                                <Label Grid.Column="3" x:Name="TotalMontantFooter" Text="0.00 MAD" FontSize="12" FontAttributes="Bold" TextColor="#4A8FBF" HorizontalTextAlignment="End"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Notes Section (if any) -->
                    <Border x:Name="NotesSection" BackgroundColor="White" Padding="20" StrokeThickness="0" IsVisible="False">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="NOTES" FontSize="12" FontAttributes="Bold" TextColor="#4A8FBF"/>
                            <Label x:Name="NotesLabel" Text="" FontSize="12" TextColor="#666"/>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Signature Section -->
                    <Grid ColumnDefinitions="*,50,*" Margin="0,20,0,0">
                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="Signature Client:" FontSize="10" TextColor="#666"/>
                            <BoxView Color="#999" HeightRequest="1"/>
                            <BoxView HeightRequest="40" Color="Transparent"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="5">
                            <Label Text="Signature Livreur:" FontSize="10" TextColor="#666"/>
                            <BoxView Color="#999" HeightRequest="1"/>
                            <BoxView HeightRequest="40" Color="Transparent"/>
                        </VerticalStackLayout>
                    </Grid>
                    
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Border>
</toolkit:Popup>
