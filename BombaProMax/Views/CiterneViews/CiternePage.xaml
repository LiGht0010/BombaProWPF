<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BombaProMax.Models"
             xmlns:viewmodels="clr-namespace:BombaProMax.ViewModels"
             x:Class="BombaProMax.Views.CiterneViews.CiternePage"
             x:DataType="viewmodels:CiterneViewModel"
             Style="{StaticResource CiternePageStyle}">

    <ScrollView Style="{StaticResource CiternePageScrollView}">
        <VerticalStackLayout Style="{StaticResource CiternePageMainStack}">

            <!-- ========================================= -->
            <!-- HEADER SECTION with Action Button         -->
            <!-- ========================================= -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                <VerticalStackLayout Style="{StaticResource CiternePageHeaderStack}">
                    <Label Text="Gestion des Citernes" 
                           Style="{StaticResource CiternePageTitleLabel}"/>
                    <Label Text="{Binding Citernes.Count, StringFormat='{0} citernes enregistrées'}" 
                           Style="{StaticResource CiternePageSubtitleLabel}"/>
                </VerticalStackLayout>
                
                <!-- Add Button -->
                <Button Grid.Column="1"
                        Text="+ Nouvelle Citerne"
                        Style="{StaticResource CiterneAddButton}"
                        Command="{Binding AddCiterneCommand}"
                        VerticalOptions="Center"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"/>
            </Grid>

            <!-- ========================================= -->
            <!-- STATS CARDS ROW - Neumorphic Raised       -->
            <!-- ========================================= -->
            <Grid ColumnDefinitions="*,*,*,*" 
                  ColumnSpacing="16"
                  IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                
                <!-- Total Citernes -->
                <Border Grid.Column="0" Style="{StaticResource CiterneStatCard}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding Citernes.Count}" 
                               Style="{StaticResource CiterneStatNumber}"/>
                        <Label Text="Total Citernes" 
                               Style="{StaticResource CiterneStatLabel}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Total Capacity -->
                <Border Grid.Column="1" Style="{StaticResource CiterneStatCard}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="—" 
                               Style="{StaticResource CiterneStatNumber}"
                               TextColor="#5EAA8D"/>
                        <Label Text="Capacité (L)" 
                               Style="{StaticResource CiterneStatLabel}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- With Camion -->
                <Border Grid.Column="2" Style="{StaticResource CiterneStatCard}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="—" 
                               Style="{StaticResource CiterneStatNumber}"
                               TextColor="#E8A84C"/>
                        <Label Text="Avec Camion" 
                               Style="{StaticResource CiterneStatLabel}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Available -->
                <Border Grid.Column="3" Style="{StaticResource CiterneStatCard}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="—" 
                               Style="{StaticResource CiterneStatNumber}"
                               TextColor="#8FA3B8"/>
                        <Label Text="Disponibles" 
                               Style="{StaticResource CiterneStatLabel}"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- ========================================= -->
            <!-- SEARCH BAR - Neumorphic Inset             -->
            <!-- ========================================= -->
            <Border Style="{StaticResource CiterneSearchContainer}"
                    IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Image Source="search.png"
                           WidthRequest="24"
                           HeightRequest="24"/>

                    <Entry Grid.Column="1"
                           Placeholder="Rechercher par matricule, capacité, fournisseur..."
                           Text="{Binding SearchText}"
                           Style="{StaticResource CiterneSearchEntry}"/>
                    <Button Grid.Column="2"
                            Text="Rechercher"
                            Command="{Binding SearchCiternesCommand}"
                            BackgroundColor="#E8ECF1"
                            TextColor="#5A6068"
                            FontSize="13"
                            FontAttributes="Bold"
                            Padding="16,10"
                            CornerRadius="10"/>
                </Grid>
            </Border>

            <!-- Loading Indicator -->
            <ActivityIndicator Style="{StaticResource CiternePageLoadingIndicator}"
                              IsRunning="{Binding IsLoading}"
                              IsVisible="{Binding IsLoading}"/>

            <!-- ========================================= -->
            <!-- TABLE CARD - Neumorphic Raised Container  -->
            <!-- ========================================= -->
            <Border Style="{StaticResource CiterneTableCard}"
                    IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                <VerticalStackLayout Style="{StaticResource CiterneTableContainer}">

                    <!-- Table Header -->
                    <Grid Style="{StaticResource CiterneTableHeaderGrid}">
                        <Label Grid.Column="0" 
                               Text="ID" 
                               Style="{StaticResource CiterneTableHeaderLabel}"/>
                        <Label Grid.Column="1" 
                               Text="Capacité" 
                               Style="{StaticResource CiterneTableHeaderLabel}"/>
                        <Label Grid.Column="2" 
                               Text="Matricule" 
                               Style="{StaticResource CiterneTableHeaderLabel}"/>
                        <Label Grid.Column="3" 
                               Text="Fournisseur" 
                               Style="{StaticResource CiterneTableHeaderLabel}"/>
                        <Label Grid.Column="4" 
                               Text="Partitions" 
                               Style="{StaticResource CiterneTableHeaderLabel}"/>
                        <Label Grid.Column="5" 
                               Text="Actions" 
                               Style="{StaticResource CiterneTableHeaderLabel}"/>
                    </Grid>

                    <!-- Table Rows with SwipeView -->
                    <CollectionView ItemsSource="{Binding Citernes}"
                                    Style="{StaticResource CiterneTableCollectionView}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:CiterneDto">
                                <SwipeView BackgroundColor="Transparent">
                                    <!-- Left Swipe Actions -->
                                    <SwipeView.LeftItems>
                                        <SwipeItems Mode="Reveal">
                                            <SwipeItem Text="Détails"
                                                       BackgroundColor="#8FA3B8"
                                                       Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CiterneViewModel}}, Path=ShowDetailsCommand}"
                                                       CommandParameter="{Binding .}"/>
                                            <SwipeItem Text="Modifier"
                                                       BackgroundColor="#4A8FBF"
                                                       Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CiterneViewModel}}, Path=EditCiterneCommand}"
                                                       CommandParameter="{Binding .}"/>
                                        </SwipeItems>
                                    </SwipeView.LeftItems>

                                    <!-- Right Swipe Actions -->
                                    <SwipeView.RightItems>
                                        <SwipeItems Mode="Reveal">
                                            <SwipeItem Text="Supprimer"
                                                       BackgroundColor="#E16C6C"
                                                       Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CiterneViewModel}}, Path=DeleteCiterneCommand}"
                                                       CommandParameter="{Binding .}"/>
                                        </SwipeItems>
                                    </SwipeView.RightItems>

                                    <!-- Row Content -->
                                    <VerticalStackLayout BackgroundColor="Transparent">
                                        <Grid Style="{StaticResource CiterneTableRowGrid}">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer 
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CiterneViewModel}}, Path=ShowCiterneRowDetailsCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Grid.GestureRecognizers>

                                            <!-- ID - Neumorphic Pill -->
                                            <Border Grid.Column="0" 
                                                    Style="{StaticResource CiterneIdCell}">
                                                <Label Text="{Binding ID}" 
                                                       Style="{StaticResource CiterneIdLabel}"/>
                                            </Border>

                                            <!-- Capacity Badge - Neumorphic -->
                                            <Border Grid.Column="1" 
                                                    Style="{StaticResource CiterneCapacityBadge}">
                                                <Label Text="{Binding Capacite, StringFormat='{0:N0}L'}" 
                                                       Style="{StaticResource CiterneCapacityLabel}"/>
                                            </Border>

                                            <!-- Matricule -->
                                            <Label Grid.Column="2" 
                                                   Text="{Binding MatriculeCiterne, FallbackValue='N/A'}" 
                                                   Style="{StaticResource CiterneProduitLabel}"/>

                                            <!-- Fournisseur -->
                                            <Label Grid.Column="3" 
                                                   Text="{Binding FournisseurNom, FallbackValue='N/A'}"
                                                   Style="{StaticResource CiterneFournisseurLabel}"/>

                                            <!-- Partitions Badge -->
                                            <Border Grid.Column="4" 
                                                    Style="{StaticResource CiterneCamionStatusBadge}"
                                                    BackgroundColor="#8FA3B8">
                                                <Label Text="{Binding PartitionsNumber, StringFormat='{0} part.'}"
                                                       Style="{StaticResource CiterneCamionStatusLabel}"/>
                                            </Border>

                                            <!-- Actions -->
                                            <HorizontalStackLayout Grid.Column="5" 
                                                                   Style="{StaticResource CiterneActionsCell}">
                                                <Button Text="Détails"
                                                        Style="{StaticResource CiterneDetailsButton}"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CiterneViewModel}}, Path=ShowDetailsCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                <Button Text="Modifier"
                                                        Style="{StaticResource CiterneModifierButton}"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CiterneViewModel}}, Path=EditCiterneCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                <Button Text="Supprimer"
                                                        Style="{StaticResource CiterneSupprimerButton}"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CiterneViewModel}}, Path=DeleteCiterneCommand}"
                                                        CommandParameter="{Binding .}"/>
                                            </HorizontalStackLayout>
                                        </Grid>

                                        <!-- Row Divider -->
                                        <BoxView Style="{StaticResource CiterneRowDivider}"/>
                                    </VerticalStackLayout>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                        <!-- Modern Empty View - Neumorphic Style -->
                        <CollectionView.EmptyView>
                            <VerticalStackLayout Style="{StaticResource CiterneEmptyView}">
                                <!-- Neumorphic Icon Container -->
                                <Border BackgroundColor="#EEF1F5"
                                        WidthRequest="100"
                                        HeightRequest="100"
                                        StrokeThickness="0"
                                        Margin="0,0,0,16">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="50"/>
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="#C5CAD1"
                                                Offset="6,6"
                                                Radius="12"
                                                Opacity="0.25"/>
                                    </Border.Shadow>
                                    <Label Text="🛢️"
                                           FontSize="48"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <Label Text="Aucune citerne disponible" 
                                       Style="{StaticResource CiterneEmptyTitle}"/>
                                <Label Text="Commencez par ajouter votre première citerne pour gérer votre stock" 
                                       Style="{StaticResource CiterneEmptySubtitle}"/>
                                <Button Text="+ Ajouter une Citerne"
                                        Style="{StaticResource CiterneEmptyButton}"
                                        Command="{Binding AddCiterneCommand}"/>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
