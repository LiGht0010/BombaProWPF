<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.CiterneViews.CiterneCreatePopup"
               Color="Transparent">

    <Border BackgroundColor="#F5F5F5" Padding="0" WidthRequest="600" HeightRequest="580" StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="12"/>
        </Border.StrokeShape>
        
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- ========================================= -->
            <!-- HEADER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="0" BackgroundColor="#795548" Padding="20,18" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="🛢️ Nouvelle Citerne" 
                               FontSize="20" 
                               FontAttributes="Bold" 
                               TextColor="White"/>
                        <Label Text="Créer une nouvelle citerne de transport" 
                               FontSize="12" 
                               TextColor="#D7CCC8"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" 
                            Text="✕" 
                            BackgroundColor="#6D4C41" 
                            TextColor="White" 
                            FontSize="16" 
                            WidthRequest="36" 
                            HeightRequest="36" 
                            CornerRadius="18" 
                            Clicked="OnCancelClicked"/>
                </Grid>
            </Border>

            <!-- ========================================= -->
            <!-- CONTENT                                   -->
            <!-- ========================================= -->
            <ScrollView Grid.Row="1" Padding="20,15">
                <VerticalStackLayout Spacing="15">
                    
                    <!-- Basic Info Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="ℹ️ INFORMATIONS DE BASE" FontSize="11" FontAttributes="Bold" TextColor="#795548"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                                <VerticalStackLayout Grid.Column="0" Spacing="5">
                                    <Label Text="📏 Capacité (Litres) *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="CapaciteEntry"
                                           Placeholder="Ex: 5000"
                                           Keyboard="Numeric"
                                           FontSize="14"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="5">
                                    <Label Text="🔢 Matricule Citerne" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="MatriculeEntry"
                                           Placeholder="Ex: CIT-001"
                                           FontSize="14"/>
                                </VerticalStackLayout>
                            </Grid>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="📊 Nombre de Partitions" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                <Entry x:Name="PartitionsEntry"
                                       Placeholder="Ex: 2"
                                       Keyboard="Numeric"
                                       FontSize="14"/>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Assignment Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="🔗 AFFECTATION" FontSize="11" FontAttributes="Bold" TextColor="#795548"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="🏭 Fournisseur *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                <Picker x:Name="FournisseurPicker"
                                        Title="Sélectionnez un fournisseur"
                                        ItemDisplayBinding="{Binding Societe}"
                                        FontSize="14"/>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ========================================= -->
            <!-- FOOTER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="2" BackgroundColor="White" Padding="20,15" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,-2" Radius="6" Opacity="0.06"/>
                </Border.Shadow>
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                    <Label x:Name="ErrorLabel" 
                           TextColor="#F44336" 
                           FontSize="12" 
                           IsVisible="False" 
                           VerticalOptions="Center"/>
                    <Button Grid.Column="1" 
                            Text="Annuler" 
                            BackgroundColor="#9E9E9E" 
                            TextColor="White" 
                            Padding="25,12" 
                            CornerRadius="8" 
                            Clicked="OnCancelClicked"/>
                    <Button Grid.Column="2" 
                            Text="✓ Créer la citerne" 
                            BackgroundColor="#4CAF50" 
                            TextColor="White" 
                            Padding="25,12" 
                            CornerRadius="8" 
                            FontAttributes="Bold" 
                            Clicked="OnCreateClicked"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>
