<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.CiterneViews.CiterneCreatePopup">

    <Border Style="{StaticResource CiternePopupContainer}">
        <ScrollView>
            <VerticalStackLayout Spacing="20">
                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="🛢️ Creer une nouvelle citerne" 
                           Style="{StaticResource CiternePopupTitle}"/>
                    <Button Grid.Column="1" 
                            Text="✕" 
                            Style="{StaticResource CiternePopupCloseButton}"
                            Clicked="OnCancelClicked"/>
                </Grid>

                <BoxView Style="{StaticResource CiternePopupDivider}"/>

                <!-- Citerne Form -->
                <VerticalStackLayout Spacing="18">

                    <!-- Basic Information Section -->
                    <Border Style="{StaticResource CiternePopupSectionCard}">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="ℹ️ Informations de Base" 
                                   Style="{StaticResource CiternePopupSectionTitle}"/>

                            <BoxView Style="{StaticResource CiternePopupDivider}"/>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                                <!-- Capacite -->
                                <VerticalStackLayout Grid.Column="0" Spacing="8">
                                    <Label Text="Capacite (Litres) *" 
                                           Style="{StaticResource CiternePopupFieldLabel}"/>
                                    <Border Style="{StaticResource CiternePopupInputContainer}">
                                        <Entry x:Name="CapaciteEntry"
                                               Placeholder="Ex: 5000"
                                               Keyboard="Numeric"
                                               Style="{StaticResource CiternePopupEntry}"/>
                                    </Border>
                                </VerticalStackLayout>

                                <!-- Matricule -->
                                <VerticalStackLayout Grid.Column="1" Spacing="8">
                                    <Label Text="Matricule Citerne" 
                                           Style="{StaticResource CiternePopupFieldLabel}"/>
                                    <Border Style="{StaticResource CiternePopupInputContainer}">
                                        <Entry x:Name="MatriculeEntry"
                                               Placeholder="Ex: CIT-001"
                                               Style="{StaticResource CiternePopupEntry}"/>
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Nombre de Partitions -->
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Nombre de Partitions" 
                                       Style="{StaticResource CiternePopupFieldLabel}"/>
                                <Border Style="{StaticResource CiternePopupInputContainer}">
                                    <Entry x:Name="PartitionsEntry"
                                           Placeholder="Ex: 2"
                                           Keyboard="Numeric"
                                           Style="{StaticResource CiternePopupEntry}"/>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Assignment Section -->
                    <Border Style="{StaticResource CiternePopupSectionCard}">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="🔗 Affectation" 
                                   Style="{StaticResource CiternePopupSectionTitle}"/>

                            <BoxView Style="{StaticResource CiternePopupDivider}"/>

                            <!-- Fournisseur Picker -->
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Fournisseur *" 
                                       Style="{StaticResource CiternePopupFieldLabel}"/>
                                <Border Style="{StaticResource CiternePopupInputContainer}">
                                    <Picker x:Name="FournisseurPicker"
                                            Title="Selectionnez un fournisseur"
                                            Style="{StaticResource CiternePopupPicker}"/>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Error Message -->
                    <Label x:Name="ErrorLabel"
                           Style="{StaticResource CiternePopupErrorLabel}"
                           IsVisible="False"/>

                    <!-- Action Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,10,0,0">
                        <!-- Cancel Button -->
                        <Button Grid.Column="0"
                                Text="Annuler"
                                Style="{StaticResource CiternePopupCancelButton}"
                                Clicked="OnCancelClicked"/>

                        <!-- Create Button -->
                        <Button Grid.Column="1"
                                Text="✓ Creer la citerne"
                                Style="{StaticResource CiternePopupCreateButton}"
                                Clicked="OnCreateClicked"/>
                    </Grid>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Border>
</toolkit:Popup>
