<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.JaugeageViews.JaugeageEditPopup"
               Color="Transparent">

    <Border BackgroundColor="White" Padding="0" WidthRequest="750" HeightRequest="650" StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="12"/>
        </Border.StrokeShape>
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- HEADER -->
            <Border Grid.Row="0" BackgroundColor="#1976D2" Padding="20" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout>
                        <Label x:Name="HeaderLabel" 
                               Text="Modifier le Jaugeage" 
                               FontSize="20" 
                               FontAttributes="Bold"
                               TextColor="White"/>
                        <Label x:Name="SubHeaderLabel"
                               Text="Modifier les mesures du jaugeage" 
                               FontSize="12"
                               TextColor="#BBDEFB"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" 
                            Text="X" 
                            BackgroundColor="#1565C0"
                            TextColor="White"
                            FontSize="16"
                            WidthRequest="36"
                            HeightRequest="36"
                            CornerRadius="18"
                            Clicked="OnCancelClicked"/>
                </Grid>
            </Border>

            <!-- CONTENT -->
            <ScrollView Grid.Row="1" Padding="20">
                <VerticalStackLayout Spacing="16">
                    
                    <!-- Date and Temoin Row -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="15">
                        <!-- Date -->
                        <Border BackgroundColor="#F8F8F8" Padding="12" Stroke="#E0E0E0" StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="DATE DU JAUGEAGE *" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                                <DatePicker x:Name="JaugeageDatePicker" FontSize="14"/>
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Temoin (Employe) -->
                        <Border Grid.Column="1" BackgroundColor="#E3F2FD" Padding="12" Stroke="#1976D2" StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="TEMOIN (EMPLOYE) *" FontSize="10" FontAttributes="Bold" TextColor="#1565C0"/>
                                <Picker x:Name="TemoinPicker" 
                                        Title="Selectionnez..."
                                        FontSize="14"/>
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Numero -->
                        <Border Grid.Column="2" BackgroundColor="#F8F8F8" Padding="12" Stroke="#E0E0E0" StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="NUMERO" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                                <Entry x:Name="NumeroEntry" 
                                       IsReadOnly="True" 
                                       BackgroundColor="#EEEEEE" 
                                       FontSize="14"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Observations -->
                    <Border BackgroundColor="#F8F8F8" Padding="12" Stroke="#E0E0E0" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="5">
                            <Label Text="OBSERVATIONS (OPTIONNEL)" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                            <Entry x:Name="ObservationsEntry" 
                                   Placeholder="Notes ou remarques..." 
                                   FontSize="14"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Reservoirs Section Header -->
                    <Border BackgroundColor="#E8F5E9" Padding="12" Stroke="#4CAF50" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout>
                                <Label Text="MESURES DES RESERVOIRS" FontSize="12" FontAttributes="Bold" TextColor="#2E7D32"/>
                                <Label Text="Modifiez la hauteur mesuree (cm) pour chaque reservoir" FontSize="11" TextColor="#666"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="End">
                                <Label Text="Volume Total" FontSize="10" TextColor="#666"/>
                                <Label x:Name="TotalVolumeLabel" Text="0 L" FontSize="18" FontAttributes="Bold" TextColor="#2E7D32"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Reservoirs Table Header -->
                    <Grid ColumnDefinitions="1.2*,1*,1*,1*,0.8*" 
                          ColumnSpacing="8" 
                          Padding="12,8"
                          BackgroundColor="#ECEFF1">
                        <Label Grid.Column="0" Text="RESERVOIR" FontSize="10" FontAttributes="Bold" TextColor="#546E7A"/>
                        <Label Grid.Column="1" Text="PRODUIT" FontSize="10" FontAttributes="Bold" TextColor="#546E7A"/>
                        <Label Grid.Column="2" Text="HAUTEUR (CM)" FontSize="10" FontAttributes="Bold" TextColor="#546E7A" HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="3" Text="VOLUME (L)" FontSize="10" FontAttributes="Bold" TextColor="#546E7A" HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="4" Text="STATUT" FontSize="10" FontAttributes="Bold" TextColor="#546E7A" HorizontalTextAlignment="Center"/>
                    </Grid>

                    <!-- Reservoirs List -->
                    <VerticalStackLayout x:Name="ReservoirsContainer" Spacing="4">
                        <!-- Populated dynamically -->
                    </VerticalStackLayout>

                    <!-- Summary Card -->
                    <Border BackgroundColor="#E3F2FD" Padding="16" Stroke="#1976D2" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="20">
                            <VerticalStackLayout HorizontalOptions="Center">
                                <Label Text="Reservoirs" FontSize="11" TextColor="#666"/>
                                <Label x:Name="TotalReservoirsLabel" Text="0" FontSize="20" FontAttributes="Bold" TextColor="#1976D2"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                                <Label Text="Mesures" FontSize="11" TextColor="#666"/>
                                <Label x:Name="MeasuredCountLabel" Text="0" FontSize="20" FontAttributes="Bold" TextColor="#2E7D32"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                                <Label Text="Volume Total" FontSize="11" TextColor="#666"/>
                                <Label x:Name="SummaryVolumeLabel" Text="0 L" FontSize="20" FontAttributes="Bold" TextColor="#1976D2"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- FOOTER -->
            <Border Grid.Row="2" BackgroundColor="#F5F5F5" Padding="15" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="15">
                    <Label x:Name="ErrorLabel" 
                           TextColor="#F44336" 
                           FontSize="12" 
                           IsVisible="False" 
                           VerticalOptions="Center"/>
                    <Button Grid.Column="1"
                            Text="Annuler" 
                            BackgroundColor="#9E9E9E"
                            TextColor="White"
                            Padding="20,10"
                            CornerRadius="8"
                            Clicked="OnCancelClicked"/>
                    <Button x:Name="SaveButton"
                            Grid.Column="2"
                            Text="Mettre a jour" 
                            BackgroundColor="#1976D2"
                            TextColor="White"
                            Padding="20,10"
                            CornerRadius="8"
                            FontAttributes="Bold"
                            Clicked="OnSaveClicked"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>
