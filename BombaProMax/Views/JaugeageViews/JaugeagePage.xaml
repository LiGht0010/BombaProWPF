<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:BombaProMax.ViewModels"
             xmlns:models="clr-namespace:BombaProMax.Models"
             x:Class="BombaProMax.Views.JaugeageViews.JaugeagePage"
             x:DataType="viewmodels:JaugeageViewModel"
             Style="{StaticResource CalibPageStyle}">

    <Grid RowDefinitions="*,Auto">
        
        <ScrollView Grid.Row="0" Style="{StaticResource CalibPageScrollView}">
            <VerticalStackLayout Style="{StaticResource CalibPageMainStack}">

                <!-- JOURNEE PROGRESS BAR -->
                <Border BackgroundColor="#E0F2F1" 
                        Padding="15" 
                        Margin="0,0,0,10"
                        IsVisible="{Binding IsJourneeActive}" 
                        StrokeShape="RoundRectangle 10" 
                        Stroke="#00796B">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Text="[M]" FontSize="24" VerticalOptions="Center" TextColor="#00796B"/>
                        <VerticalStackLayout Grid.Column="1" Margin="10,0">
                            <Label Text="{Binding JourneeStepInfo}" 
                                   FontAttributes="Bold" 
                                   TextColor="#00796B" 
                                   FontSize="14"/>
                            <Label Text="Mesurez les niveaux de carburant" 
                                   TextColor="#5A6068" 
                                   FontSize="11"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- HEADER -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <VerticalStackLayout Style="{StaticResource CalibPageHeaderStack}">
                        <Label Text="Jaugeage des Reservoirs" 
                               Style="{StaticResource CalibPageTitleLabel}"/>
                        <Label Text="Gerez les jaugeages et les calibrations des reservoirs" 
                               Style="{StaticResource CalibPageSubtitleLabel}"/>
                    </VerticalStackLayout>
                    
                    <Button Grid.Column="1"
                            Text="Rafraichir"
                            Style="{StaticResource CalibResetButton}"
                            Command="{Binding InitializeCommand}"
                            VerticalOptions="Center"/>
                </Grid>

                <!-- STATS CARDS -->
                <Grid ColumnDefinitions="*,*,*,*" 
                      ColumnSpacing="16"
                      IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                    
                    <Border Grid.Column="0" Style="{StaticResource CalibStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding TotalJaugeages}" 
                                   Style="{StaticResource CalibStatNumber}"
                                   TextColor="#00796B"/>
                            <Label Text="Jaugeages" 
                                   Style="{StaticResource CalibStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CalibStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding TotalReservoirs}" 
                                   Style="{StaticResource CalibStatNumber}"
                                   TextColor="#2E7D32"/>
                            <Label Text="Reservoirs" 
                                   Style="{StaticResource CalibStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CalibStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding TotalVolumeJaugeages, StringFormat='{0:N0}'}" 
                                   Style="{StaticResource CalibStatNumber}"
                                   TextColor="#1976D2"/>
                            <Label Text="Litres Total" 
                                   Style="{StaticResource CalibStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource CalibStatCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding MeasuredCount}" 
                                   Style="{StaticResource CalibStatNumber}"
                                   TextColor="#7B1FA2"/>
                            <Label Text="Mesures" 
                                   Style="{StaticResource CalibStatLabel}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Loading -->
                <ActivityIndicator Style="{StaticResource CalibLoadingIndicator}"
                                   IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"/>

                <!-- TABS CARD -->
                <Border Style="{StaticResource CalibTableCard}"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                    <VerticalStackLayout Style="{StaticResource CalibTableContainer}">
                        
                        <!-- Tab Headers -->
                        <Grid ColumnDefinitions="*,*" 
                              BackgroundColor="{StaticResource CalibNeuPrimary}"
                              Padding="0">
                            <Button x:Name="JaugeagesTabButton"
                                    Grid.Column="0"
                                    Text="Jaugeages"
                                    BackgroundColor="#00796B"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    CornerRadius="0"
                                    Padding="20,14"
                                    Clicked="OnJaugeagesTabClicked"/>
                            <Button x:Name="CalibrationTabButton"
                                    Grid.Column="1"
                                    Text="Calibration"
                                    BackgroundColor="#00695C"
                                    TextColor="#B2DFDB"
                                    FontSize="14"
                                    CornerRadius="0"
                                    Padding="20,14"
                                    Clicked="OnCalibrationTabClicked"/>
                        </Grid>

                        <!-- TAB 1: JAUGEAGES -->
                        <VerticalStackLayout x:Name="JaugeagesTab" 
                                             Spacing="0"
                                             Padding="0">
                            
                            <!-- Filters & Add Button Row -->
                            <Border BackgroundColor="{StaticResource CalibNeuCardBg}" 
                                    Padding="20"
                                    StrokeThickness="0">
                                <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,Auto,Auto" ColumnSpacing="12">
                                    <Label Text="Du:" Style="{StaticResource CalibFilterLabel}"/>
                                    <DatePicker Grid.Column="1"
                                                Date="{Binding FilterStartDate}"
                                                MaximumDate="{Binding FilterMaxDate}"
                                                Style="{StaticResource CalibFilterDatePicker}"/>
                                    <Label Grid.Column="2" Text="Au:" Style="{StaticResource CalibFilterLabel}"/>
                                    <DatePicker Grid.Column="3"
                                                Date="{Binding FilterEndDate}"
                                                MaximumDate="{Binding FilterMaxDate}"
                                                Style="{StaticResource CalibFilterDatePicker}"/>
                                    <Button Grid.Column="4"
                                            Text="Filtrer"
                                            Command="{Binding LoadJaugeagesByDateRangeCommand}"
                                            Style="{StaticResource CalibFilterButton}"/>
                                    <Button Grid.Column="5"
                                            Text="Reset"
                                            Command="{Binding LoadHistoryCommand}"
                                            Style="{StaticResource CalibResetButton}"/>
                                    <Button Grid.Column="6"
                                            Text="+ Nouveau Jaugeage"
                                            Style="{StaticResource CalibAddButton}"
                                            Clicked="OnAddJaugeageClicked"/>
                                </Grid>
                            </Border>

                            <!-- Jaugeages Table Header -->
                            <Grid Style="{StaticResource CalibTableHeaderGrid}">
                                <Label Grid.Column="0" Text="N Jaugeage" Style="{StaticResource CalibTableHeaderLabelLeft}"/>
                                <Label Grid.Column="1" Text="Date" Style="{StaticResource CalibTableHeaderLabel}"/>
                                <Label Grid.Column="2" Text="Citernes Inclues" Style="{StaticResource CalibTableHeaderLabelLeft}"/>
                                <Label Grid.Column="3" Text="Volume Total" Style="{StaticResource CalibTableHeaderLabel}"/>
                                <Label Grid.Column="4" Text="Temoin" Style="{StaticResource CalibTableHeaderLabelLeft}"/>
                                <Label Grid.Column="5" Text="Actions" Style="{StaticResource CalibTableHeaderLabel}"/>
                            </Grid>

                            <!-- Jaugeages Rows -->
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding JaugeageHistory}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:JaugeageDto">
                                        <VerticalStackLayout BackgroundColor="Transparent">
                                            <Grid Style="{StaticResource CalibTableRowGrid}">
                                                <Grid.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnRowTapped" CommandParameter="{Binding .}"/>
                                                </Grid.GestureRecognizers>
                                                
                                                <!-- N Jaugeage -->
                                                <Border Grid.Column="0" Style="{StaticResource CalibNumeroCell}">
                                                    <Label Text="{Binding NumeroJaugeage}" 
                                                           Style="{StaticResource CalibNumeroLabel}"/>
                                                </Border>

                                                <!-- Date -->
                                                <Label Grid.Column="1" 
                                                       Text="{Binding DateJaugeage, StringFormat='{0:dd/MM/yyyy}'}" 
                                                       Style="{StaticResource CalibDateLabel}"
                                                       HorizontalTextAlignment="Center"/>

                                                <!-- Citernes Inclues -->
                                                <Label Grid.Column="2" 
                                                       Text="{Binding CiternesInclues, TargetNullValue='-'}" 
                                                       TextColor="{StaticResource CalibNeuInfo}"
                                                       FontSize="11"
                                                       VerticalTextAlignment="Center"
                                                       LineBreakMode="TailTruncation"/>

                                                <!-- Volume Total -->
                                                <Border Grid.Column="3" Style="{StaticResource CalibVolumeBadge}">
                                                    <Label Text="{Binding TotalVolume, StringFormat='{0:N0} L'}" 
                                                           Style="{StaticResource CalibVolumeBadgeLabel}"/>
                                                </Border>

                                                <!-- Temoin -->
                                                <Label Grid.Column="4" 
                                                       Text="{Binding TemoinNom, TargetNullValue='-'}" 
                                                       Style="{StaticResource CalibTemoinLabel}"/>

                                                <!-- Actions -->
                                                <HorizontalStackLayout Grid.Column="5" Style="{StaticResource CalibActionsCell}">
                                                    <Button Text="Details"
                                                            Style="{StaticResource CalibDetailsButton}"
                                                            Clicked="OnDetailsJaugeageClicked"
                                                            CommandParameter="{Binding .}"/>
                                                    <Button Text="Modifier"
                                                            Style="{StaticResource CalibModifierButton}"
                                                            Clicked="OnEditJaugeageClicked"
                                                            CommandParameter="{Binding .}"/>
                                                    <Button Text="Supprimer"
                                                            Style="{StaticResource CalibSupprimerButton}"
                                                            Clicked="OnDeleteJaugeageClicked"
                                                            CommandParameter="{Binding .}"/>
                                                </HorizontalStackLayout>
                                            </Grid>
                                            <BoxView Style="{StaticResource CalibRowDivider}"/>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                                
                                <BindableLayout.EmptyView>
                                    <VerticalStackLayout Style="{StaticResource CalibEmptyView}">
                                        <Border BackgroundColor="#EEF1F5"
                                                WidthRequest="100"
                                                HeightRequest="100"
                                                StrokeThickness="0"
                                                Margin="0,0,0,16">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="50"/>
                                            </Border.StrokeShape>
                                            <Border.Shadow>
                                                <Shadow Brush="#C5CAD1" Offset="6,6" Radius="12" Opacity="0.25"/>
                                            </Border.Shadow>
                                            <Label Text="J" FontSize="48" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#00796B"/>
                                        </Border>
                                        <Label Text="Aucun jaugeage trouve" Style="{StaticResource CalibEmptyTitle}"/>
                                        <Label Text="Commencez par ajouter un nouveau jaugeage de reservoirs" 
                                               Style="{StaticResource CalibEmptySubtitle}"/>
                                        <Button Text="+ Nouveau Jaugeage"
                                                Style="{StaticResource CalibEmptyButton}"
                                                Clicked="OnAddJaugeageClicked"/>
                                    </VerticalStackLayout>
                                </BindableLayout.EmptyView>
                            </VerticalStackLayout>
                        </VerticalStackLayout>

                        <!-- TAB 2: CALIBRATION -->
                        <VerticalStackLayout x:Name="CalibrationTab" 
                                             Spacing="0"
                                             Padding="0"
                                             IsVisible="False">
                            
                            <!-- Summary Stats -->
                            <Grid ColumnDefinitions="*,*,*" 
                                  ColumnSpacing="12"
                                  Padding="20,16"
                                  BackgroundColor="#F8F9FA">
                                
                                <Border Grid.Column="0" Style="{StaticResource CalibStatCard}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding CalibrationReservoirs.Count}" 
                                               Style="{StaticResource CalibStatNumber}"
                                               TextColor="#1976D2"/>
                                        <Label Text="Total Reservoirs" Style="{StaticResource CalibStatLabel}"/>
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource CalibStatCard}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding CalibratedReservoirsCount}" 
                                               Style="{StaticResource CalibStatNumber}"
                                               TextColor="#2E7D32"/>
                                        <Label Text="Calibres" Style="{StaticResource CalibStatLabel}"/>
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource CalibStatCard}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding NotCalibratedReservoirsCount}" 
                                               Style="{StaticResource CalibStatNumber}"
                                               TextColor="#F57C00"/>
                                        <Label Text="Non Calibres" Style="{StaticResource CalibStatLabel}"/>
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <!-- Reservoirs Table Header -->
                            <Grid ColumnDefinitions="1.2*,1*,1*,1*,1.5*" 
                                  ColumnSpacing="8"
                                  Padding="20,12"
                                  BackgroundColor="#00796B">
                                <Label Grid.Column="0" Text="RESERVOIR" FontSize="11" FontAttributes="Bold" TextColor="White"/>
                                <Label Grid.Column="1" Text="PRODUIT" FontSize="11" FontAttributes="Bold" TextColor="White"/>
                                <Label Grid.Column="2" Text="CAPACITE" FontSize="11" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="3" Text="ETAT CALIBRATION" FontSize="11" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="4" Text="ACTIONS" FontSize="11" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"/>
                            </Grid>

                            <!-- Reservoirs Rows -->
                            <ScrollView HeightRequest="400">
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding CalibrationReservoirs}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:ReservoirDto">
                                            <VerticalStackLayout>
                                                <Grid ColumnDefinitions="1.2*,1*,1*,1*,1.5*" 
                                                      ColumnSpacing="8"
                                                      Padding="20,12">
                                                    <Grid.Triggers>
                                                        <DataTrigger TargetType="Grid" Binding="{Binding HasCalibration}" Value="True">
                                                            <Setter Property="BackgroundColor" Value="#F1F8E9"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Grid" Binding="{Binding HasCalibration}" Value="False">
                                                            <Setter Property="BackgroundColor" Value="#FFF8E1"/>
                                                        </DataTrigger>
                                                    </Grid.Triggers>
                                                    
                                                    <!-- Reservoir Numero -->
                                                    <HorizontalStackLayout Grid.Column="0" Spacing="8">
                                                        <Border WidthRequest="8"
                                                                HeightRequest="36"
                                                                StrokeThickness="0">
                                                            <Border.StrokeShape>
                                                                <RoundRectangle CornerRadius="4"/>
                                                            </Border.StrokeShape>
                                                            <Border.Triggers>
                                                                <DataTrigger TargetType="Border" Binding="{Binding HasCalibration}" Value="True">
                                                                    <Setter Property="BackgroundColor" Value="#C8E6C9"/>
                                                                </DataTrigger>
                                                                <DataTrigger TargetType="Border" Binding="{Binding HasCalibration}" Value="False">
                                                                    <Setter Property="BackgroundColor" Value="#FFE0B2"/>
                                                                </DataTrigger>
                                                            </Border.Triggers>
                                                        </Border>
                                                        <VerticalStackLayout VerticalOptions="Center">
                                                            <Label Text="{Binding Numero}" 
                                                                   FontSize="14" 
                                                                   FontAttributes="Bold" 
                                                                   TextColor="#2E2E2E"/>
                                                        </VerticalStackLayout>
                                                    </HorizontalStackLayout>

                                                    <!-- Produit -->
                                                    <Label Grid.Column="1" 
                                                           Text="{Binding ProduitNom, TargetNullValue='Non assigne'}" 
                                                           FontSize="12"
                                                           TextColor="#5A6068"
                                                           VerticalTextAlignment="Center"/>

                                                    <!-- Capacite -->
                                                    <Label Grid.Column="2" 
                                                           Text="{Binding Capacite, StringFormat='{0:N0} L'}" 
                                                           FontSize="12"
                                                           FontAttributes="Bold"
                                                           TextColor="#00796B"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalTextAlignment="Center"/>

                                                    <!-- Etat Calibration -->
                                                    <Border Grid.Column="3"
                                                            Padding="10,6"
                                                            HorizontalOptions="Center"
                                                            VerticalOptions="Center"
                                                            StrokeThickness="0">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="12"/>
                                                        </Border.StrokeShape>
                                                        <Border.Triggers>
                                                            <DataTrigger TargetType="Border" 
                                                                         Binding="{Binding HasCalibration}" 
                                                                         Value="True">
                                                                <Setter Property="BackgroundColor" Value="#C8E6C9"/>
                                                            </DataTrigger>
                                                            <DataTrigger TargetType="Border" 
                                                                         Binding="{Binding HasCalibration}" 
                                                                         Value="False">
                                                                <Setter Property="BackgroundColor" Value="#FFE0B2"/>
                                                            </DataTrigger>
                                                        </Border.Triggers>
                                                        <Label FontSize="11" FontAttributes="Bold" HorizontalTextAlignment="Center">
                                                            <Label.Triggers>
                                                                <DataTrigger TargetType="Label" 
                                                                             Binding="{Binding HasCalibration}" 
                                                                             Value="True">
                                                                    <Setter Property="Text" Value="✓ Calibre"/>
                                                                    <Setter Property="TextColor" Value="#2E7D32"/>
                                                                </DataTrigger>
                                                                <DataTrigger TargetType="Label" 
                                                                             Binding="{Binding HasCalibration}" 
                                                                             Value="False">
                                                                    <Setter Property="Text" Value="⚠ Non calibre"/>
                                                                    <Setter Property="TextColor" Value="#E65100"/>
                                                                </DataTrigger>
                                                            </Label.Triggers>
                                                        </Label>
                                                    </Border>

                                                    <!-- Actions -->
                                                    <HorizontalStackLayout Grid.Column="4" 
                                                                           Spacing="8" 
                                                                           HorizontalOptions="Center"
                                                                           VerticalOptions="Center">
                                                        <Button Text="Importer CSV"
                                                                BackgroundColor="#1976D2"
                                                                TextColor="White"
                                                                FontSize="11"
                                                                Padding="12,8"
                                                                CornerRadius="6"
                                                                Clicked="OnImportCsvForReservoirClicked"
                                                                CommandParameter="{Binding .}"/>
                                                        <Button Text="Voir"
                                                                BackgroundColor="#00796B"
                                                                TextColor="White"
                                                                FontSize="11"
                                                                Padding="12,8"
                                                                CornerRadius="6"
                                                                IsVisible="{Binding HasCalibration}"
                                                                Clicked="OnViewCalibrationClicked"
                                                                CommandParameter="{Binding .}"/>
                                                        <Button Text="Supprimer"
                                                                BackgroundColor="#E53935"
                                                                TextColor="White"
                                                                FontSize="11"
                                                                Padding="12,8"
                                                                CornerRadius="6"
                                                                IsVisible="{Binding HasCalibration}"
                                                                Clicked="OnDeleteCalibrationForReservoirClicked"
                                                                CommandParameter="{Binding .}"/>
                                                    </HorizontalStackLayout>
                                                </Grid>
                                                <BoxView HeightRequest="1" Color="#E0E0E0" Margin="20,0"/>
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                    
                                    <BindableLayout.EmptyView>
                                        <VerticalStackLayout Style="{StaticResource CalibEmptyView}" Padding="40,60">
                                            <Border BackgroundColor="#EEF1F5"
                                                    WidthRequest="80"
                                                    HeightRequest="80"
                                                    StrokeThickness="0"
                                                    Margin="0,0,0,16">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="40"/>
                                                </Border.StrokeShape>
                                                <Label Text="🛢️" FontSize="36" HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>
                                            <Label Text="Aucun reservoir trouve" Style="{StaticResource CalibEmptyTitle}"/>
                                            <Label Text="Ajoutez des reservoirs pour pouvoir les calibrer" 
                                                   Style="{StaticResource CalibEmptySubtitle}"/>
                                        </VerticalStackLayout>
                                    </BindableLayout.EmptyView>
                                </VerticalStackLayout>
                            </ScrollView>

                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- JOURNEE NAVIGATION BAR -->
        <Border Grid.Row="1" 
                BackgroundColor="#F5F5F5" 
                Padding="15" 
                IsVisible="{Binding IsJourneeActive}" 
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="#000" Offset="0,-2" Radius="8" Opacity="0.1"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                <Button Text="Precedent" 
                        Command="{Binding JourneePrecedentCommand}"
                        BackgroundColor="#757575" 
                        TextColor="White" 
                        Padding="20,12" 
                        CornerRadius="8"
                        IsVisible="{Binding IsFirstStep, Converter={StaticResource InvertedBoolConverter}}"/>
                <BoxView Grid.Column="1" Color="Transparent"/>
                <Button Grid.Column="2" 
                        Text="Passer" 
                        Command="{Binding JourneePasserCommand}"
                        BackgroundColor="#FFA726" 
                        TextColor="White" 
                        Padding="20,12" 
                        CornerRadius="8"/>
                <Button Grid.Column="3" 
                        Text="Suivant"
                        Command="{Binding JourneeSuivantCommand}" 
                        BackgroundColor="#4CAF50" 
                        TextColor="White"
                        Padding="20,12" 
                        CornerRadius="8" 
                        FontAttributes="Bold"/>
            </Grid>
        </Border>

    </Grid>
</ContentPage>
