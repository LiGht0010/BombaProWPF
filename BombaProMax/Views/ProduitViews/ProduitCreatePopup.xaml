<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.ProduitViews.ProduitCreatePopup"
               Color="Transparent">

    <Border BackgroundColor="White"       
            Padding="0"
            WidthRequest="550"
            HeightRequest="650"
            StrokeShape="RoundRectangle 12">
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- HEADER -->
            <Border Grid.Row="0" 
                    BackgroundColor="#FF9800" 
                    Padding="20">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout>
                        <Label x:Name="HeaderLabel"
                               Text="📦 Nouveau Produit" 
                               FontSize="20" 
                               FontAttributes="Bold"
                               TextColor="White"/>
                        <Label Text="Enregistrer un nouveau produit" 
                               FontSize="12"
                               TextColor="#FFE0B2"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" 
                            Text="✕" 
                            BackgroundColor="Transparent"
                            TextColor="White"
                            FontSize="20"
                            Clicked="OnCancelClicked"/>
                </Grid>
            </Border>

            <!-- FORM CONTENT -->
            <ScrollView Grid.Row="1" Padding="20">
                <VerticalStackLayout Spacing="15">
                    
                    <!-- Numero & Categorie -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <Border BackgroundColor="#F8F8F8" 
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#E0E0E0">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="🔢 Numéro (auto)" 
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#666"/>
                                <Entry x:Name="NumeroEntry"
                                       Placeholder="Généré automatiquement"
                                       IsReadOnly="True"
                                       BackgroundColor="#EEEEEE"
                                       FontSize="14"/>
                            </VerticalStackLayout>
                        </Border>
                        
                        <Border Grid.Column="1"
                                BackgroundColor="#FFF3E0" 
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#FF9800">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="📁 Catégorie *" 
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#E65100"/>
                                <Picker x:Name="CategoriePicker"
                                        Title="Sélectionner..."
                                        FontSize="14"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Description -->
                    <Border BackgroundColor="#E3F2FD" 
                            Padding="12"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#2196F3">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="📝 Description *" 
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#1565C0"/>
                            <Entry x:Name="DescriptionEntry"
                                   Placeholder="Ex: Huile moteur 5W30, Filtre à air..."
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#1565C0"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Prix d'Achat & Prix HT -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <Border BackgroundColor="#F8F8F8" 
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#E0E0E0">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="💵 Prix d'Achat (DH)" 
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#666"/>
                                <Entry x:Name="PrixAchatEntry"
                                       Placeholder="0.00"
                                       Keyboard="Numeric"
                                       FontSize="14"
                                       TextChanged="OnPrixAchatChanged"/>
                            </VerticalStackLayout>
                        </Border>
                        
                        <Border Grid.Column="1"
                                BackgroundColor="#E8F5E9" 
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#4CAF50">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="💰 Prix HT (DH) *" 
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#2E7D32"/>
                                <Entry x:Name="PrixHTEntry"
                                       Placeholder="0.00"
                                       Keyboard="Numeric"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#2E7D32"
                                       TextChanged="OnPrixHTChanged"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- TVA & Prix TTC -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <Border BackgroundColor="#F8F8F8" 
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#E0E0E0">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="📊 TVA (%)" 
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#666"/>
                                <Entry x:Name="TVAEntry"
                                       Placeholder="20"
                                       Keyboard="Numeric"
                                       Text="20"
                                       FontSize="14"
                                       TextChanged="OnTVAChanged"/>
                            </VerticalStackLayout>
                        </Border>
                        
                        <Border Grid.Column="1"
                                BackgroundColor="#E8F5E9" 
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#4CAF50">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="🏷️ Prix TTC (calculé)" 
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#2E7D32"/>
                                <Label x:Name="PrixTTCLabel"
                                       Text="0.00 DH"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#2E7D32"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Marge Summary -->
                    <Border BackgroundColor="#F5F5F5" 
                            Padding="12"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#E0E0E0">
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="💹 Marge Bénéficiaire" 
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#666"/>
                                <Label x:Name="MargeBeneficiaireLabel"
                                       Text="0.00 DH"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#4CAF50"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="📈 Marge (%)" 
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#666"/>
                                <Label x:Name="MargePourcentageLabel"
                                       Text="0.00%"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#4CAF50"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Stock Section -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="15">
                        <Border BackgroundColor="#E1F5FE" 
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#03A9F4">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="📦 Stock Initial" 
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#0277BD"/>
                                <Entry x:Name="StockEntry"
                                       Placeholder="0"
                                       Keyboard="Numeric"
                                       Text="0"
                                       FontSize="14"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        
                        <Border Grid.Column="1"
                                BackgroundColor="#FFEBEE" 
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#F44336">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="⚠️ Stock Min" 
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#C62828"/>
                                <Entry x:Name="StockMinimumEntry"
                                       Placeholder="0"
                                       Keyboard="Numeric"
                                       Text="0"
                                       FontSize="14"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="2"
                                BackgroundColor="#F8F8F8" 
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#E0E0E0">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="🚚 Délai (jours)" 
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#666"/>
                                <Entry x:Name="DelaiLivraisonEntry"
                                       Placeholder="7"
                                       Keyboard="Numeric"
                                       FontSize="14"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </ScrollView>

            <!-- FOOTER -->
            <Border Grid.Row="2" 
                    BackgroundColor="#F5F5F5" 
                    Padding="15">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="15">
                    <Label x:Name="ErrorLabel"
                           TextColor="#F44336"
                           FontSize="12"
                           IsVisible="False"
                           VerticalOptions="Center"/>

                    <Button Grid.Column="1"
                            Text="Annuler" 
                            BackgroundColor="#9E9E9E"
                            TextColor="White"
                            Padding="20,10"
                            CornerRadius="8"
                            Clicked="OnCancelClicked"/>

                    <Button x:Name="SaveButton"
                            Grid.Column="2"
                            Text="✓ Créer le produit" 
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            Padding="20,10"
                            CornerRadius="8"
                            FontAttributes="Bold"
                            Clicked="OnCreateClicked"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>