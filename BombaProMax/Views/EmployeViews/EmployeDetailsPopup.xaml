<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.EmployeViews.EmployeDetailsPopup"
               Color="Transparent">

    <Border BackgroundColor="#F5F5F5" Padding="0" WidthRequest="700" HeightRequest="850" StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="12"/>
        </Border.StrokeShape>
        
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- ========================================= -->
            <!-- HEADER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="0" BackgroundColor="#3F51B5" Padding="20,18" StrokeThickness="0">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                    <Border Grid.Column="0"
                            BackgroundColor="White"
                            WidthRequest="50"
                            HeightRequest="50"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="25"/>
                        </Border.StrokeShape>
                        <Label Text="👤" 
                               FontSize="24"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                        <Label x:Name="EmployeNameLabel"
                               FontSize="20" 
                               FontAttributes="Bold"
                               TextColor="White"/>
                        <HorizontalStackLayout Spacing="8">
                            <Border BackgroundColor="#27AE60" Padding="8,3" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label x:Name="EmployePosteLabel" FontSize="10" FontAttributes="Bold" TextColor="White"/>
                            </Border>
                            <Label x:Name="EmployeIdLabel" FontSize="10" TextColor="#C5CAE9" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                    <Button Grid.Column="2" 
                            Text="✕" 
                            BackgroundColor="#303F9F" 
                            TextColor="White" 
                            FontSize="16" 
                            WidthRequest="36" 
                            HeightRequest="36" 
                            CornerRadius="18" 
                            Clicked="OnCloseClicked"/>
                </Grid>
            </Border>

            <!-- ========================================= -->
            <!-- CONTENT                                   -->
            <!-- ========================================= -->
            <ScrollView Grid.Row="1" Padding="20,15">
                <VerticalStackLayout Spacing="15">
                    
                    <!-- Stats Cards Row -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                        <!-- Jaugeages Card -->
                        <Border Grid.Column="0" BackgroundColor="White" Padding="15" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Label Text="📊" FontSize="26" HorizontalOptions="Center"/>
                                <Label x:Name="JaugeagesCountLabel"
                                       Text="0"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       TextColor="#1565C0"/>
                                <Label Text="Jaugeages"
                                       FontSize="11"
                                       HorizontalOptions="Center"
                                       TextColor="#666"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Credit Transactions Card -->
                        <Border Grid.Column="1" BackgroundColor="White" Padding="15" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Label Text="💳" FontSize="26" HorizontalOptions="Center"/>
                                <Label x:Name="CreditTransactionsCountLabel"
                                       Text="0"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       TextColor="#E65100"/>
                                <Label Text="Transactions"
                                       FontSize="11"
                                       HorizontalOptions="Center"
                                       TextColor="#666"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Credit Balance Card -->
                        <Border Grid.Column="2" BackgroundColor="White" Padding="15" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Label Text="💰" FontSize="26" HorizontalOptions="Center"/>
                                <Label x:Name="CreditBalanceLabel"
                                       Text="0,00 MAD"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       TextColor="#2E7D32"/>
                                <Label Text="Solde Crédit"
                                       FontSize="11"
                                       HorizontalOptions="Center"
                                       TextColor="#666"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Personal Info Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="ℹ️ INFORMATIONS PERSONNELLES" FontSize="11" FontAttributes="Bold" TextColor="#3F51B5"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" 
                                  ColumnDefinitions="150,*"
                                  RowSpacing="10">
                                <Label Grid.Row="0" Grid.Column="0" Text="CIN:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="0" Grid.Column="1" x:Name="CINLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="1" Grid.Column="0" Text="Téléphone:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="1" Grid.Column="1" x:Name="TelephoneLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="2" Grid.Column="0" Text="Adresse:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="2" Grid.Column="1" x:Name="AddressLabel" FontSize="12" TextColor="#333" LineBreakMode="WordWrap"/>
                                <Label Grid.Row="3" Grid.Column="0" Text="Salaire:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Border Grid.Row="3" Grid.Column="1" BackgroundColor="#27AE60" Padding="10,5" HorizontalOptions="Start" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="6"/>
                                    </Border.StrokeShape>
                                    <Label x:Name="SalaireLabel" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Employment Info Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="💼 INFORMATIONS D'EMPLOI" FontSize="11" FontAttributes="Bold" TextColor="#3F51B5"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" 
                                  ColumnDefinitions="150,*"
                                  RowSpacing="10">
                                <Label Grid.Row="0" Grid.Column="0" Text="Poste:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="0" Grid.Column="1" x:Name="PosteDetailLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="1" Grid.Column="0" Text="Créé le:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="1" Grid.Column="1" x:Name="DateCreationLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="2" Grid.Column="0" Text="Ajouté par:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="2" Grid.Column="1" x:Name="AjouteParLabel" Text="Chargement..." FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="3" Grid.Column="0" Text="Modifié le:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="3" Grid.Column="1" x:Name="DateModificationLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="4" Grid.Column="0" Text="Modifié par:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="4" Grid.Column="1" x:Name="ModifieParLabel" Text="Chargement..." FontSize="12" TextColor="#333"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Activity Summary Card -->
                    <Border BackgroundColor="#E3F2FD" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="📈" FontSize="18" VerticalOptions="Center"/>
                            <Label Text="Résumé d'Activité:"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#1565C0"
                                   VerticalOptions="Center"/>
                            <Label x:Name="ActivitySummaryLabel"
                                   FontSize="13"
                                   TextColor="#333"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ========================================= -->
            <!-- FOOTER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="2" BackgroundColor="White" Padding="20,15" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,-2" Radius="6" Opacity="0.06"/>
                </Border.Shadow>
                <Button Text="✓ Fermer" 
                        BackgroundColor="#3F51B5" 
                        TextColor="White" 
                        Padding="30,12" 
                        CornerRadius="8"
                        FontAttributes="Bold"
                        HorizontalOptions="End"
                        Clicked="OnCloseClicked"/>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>
