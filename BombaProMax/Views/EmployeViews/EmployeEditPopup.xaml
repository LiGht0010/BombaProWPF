<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.EmployeViews.EmployeEditPopup">

    <Border Style="{StaticResource EmployePopupContainer}">
        <ScrollView>
            <VerticalStackLayout Spacing="20">
                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="✏️ Modifier l'employé" 
                           Style="{StaticResource EmployePopupTitle}"/>
                    <Button Grid.Column="1" 
                            Text="✕" 
                            Style="{StaticResource EmployePopupCloseButton}"
                            Clicked="OnCancelClicked"/>
                </Grid>

                <BoxView Style="{StaticResource EmployePopupDivider}"/>

                <!-- Employe Form -->
                <VerticalStackLayout Spacing="18">

                    <!-- Personal Information Section -->
                    <Border Style="{StaticResource EmployePopupSectionCard}">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="ℹ️ Informations Personnelles" 
                                   Style="{StaticResource EmployePopupSectionTitle}"/>

                            <BoxView Style="{StaticResource EmployePopupDivider}"/>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                                <!-- Nom -->
                                <VerticalStackLayout Grid.Column="0" Spacing="8">
                                    <Label Text="Nom *" 
                                           Style="{StaticResource EmployePopupFieldLabel}"/>
                                    <Border Style="{StaticResource EmployePopupInputContainer}">
                                        <Entry x:Name="NomEntry"
                                               Placeholder="Ex: Alami"
                                               Style="{StaticResource EmployePopupEntry}"/>
                                    </Border>
                                </VerticalStackLayout>

                                <!-- Prenom -->
                                <VerticalStackLayout Grid.Column="1" Spacing="8">
                                    <Label Text="Prénom *" 
                                           Style="{StaticResource EmployePopupFieldLabel}"/>
                                    <Border Style="{StaticResource EmployePopupInputContainer}">
                                        <Entry x:Name="PrenomEntry"
                                               Placeholder="Ex: Mohammed"
                                               Style="{StaticResource EmployePopupEntry}"/>
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                                <!-- CIN -->
                                <VerticalStackLayout Grid.Column="0" Spacing="8">
                                    <Label Text="CIN *" 
                                           Style="{StaticResource EmployePopupFieldLabel}"/>
                                    <Border Style="{StaticResource EmployePopupInputContainer}">
                                        <Entry x:Name="CINEntry"
                                               Placeholder="Ex: AB123456"
                                               Style="{StaticResource EmployePopupEntry}"/>
                                    </Border>
                                </VerticalStackLayout>

                                <!-- Telephone -->
                                <VerticalStackLayout Grid.Column="1" Spacing="8">
                                    <Label Text="Téléphone" 
                                           Style="{StaticResource EmployePopupFieldLabel}"/>
                                    <Border Style="{StaticResource EmployePopupInputContainer}">
                                        <Entry x:Name="TelephoneEntry"
                                               Placeholder="Ex: 0612345678"
                                               Keyboard="Telephone"
                                               Style="{StaticResource EmployePopupEntry}"/>
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Address -->
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Adresse *" 
                                       Style="{StaticResource EmployePopupFieldLabel}"/>
                                <Border Style="{StaticResource EmployePopupInputContainer}">
                                    <Entry x:Name="AddressEntry"
                                           Placeholder="Ex: 123 Rue Mohammed V, Casablanca"
                                           Style="{StaticResource EmployePopupEntry}"/>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Employment Information Section -->
                    <Border Style="{StaticResource EmployePopupSectionCard}">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="💼 Informations d'Emploi" 
                                   Style="{StaticResource EmployePopupSectionTitle}"/>

                            <BoxView Style="{StaticResource EmployePopupDivider}"/>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                                <!-- Poste -->
                                <VerticalStackLayout Grid.Column="0" Spacing="8">
                                    <Label Text="Poste" 
                                           Style="{StaticResource EmployePopupFieldLabel}"/>
                                    <Border Style="{StaticResource EmployePopupInputContainer}">
                                        <Picker x:Name="PostePicker"
                                                Title="Sélectionnez un poste"
                                                Style="{StaticResource EmployePopupPicker}"/>
                                    </Border>
                                </VerticalStackLayout>

                                <!-- Salaire -->
                                <VerticalStackLayout Grid.Column="1" Spacing="8">
                                    <Label Text="Salaire (MAD)" 
                                           Style="{StaticResource EmployePopupFieldLabel}"/>
                                    <Border Style="{StaticResource EmployePopupInputContainer}">
                                        <Entry x:Name="SalaireEntry"
                                               Placeholder="Ex: 5000.00"
                                               Keyboard="Numeric"
                                               Style="{StaticResource EmployePopupEntry}"/>
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Error Message -->
                    <Label x:Name="ErrorLabel"
                           Style="{StaticResource EmployePopupErrorLabel}"
                           IsVisible="False"/>

                    <!-- Action Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,10,0,0">
                        <!-- Cancel Button -->
                        <Button Grid.Column="0"
                                Text="Annuler"
                                Style="{StaticResource EmployePopupCancelButton}"
                                Clicked="OnCancelClicked"/>

                        <!-- Update Button -->
                        <Button Grid.Column="1"
                                Text="✓ Modifier l'employé"
                                Style="{StaticResource EmployePopupCreateButton}"
                                Clicked="OnUpdateClicked"/>
                    </Grid>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Border>
</toolkit:Popup>
