<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BombaProMax.Models"
             x:Class="BombaProMax.Views.EmployeViews.EmployePage"
             Style="{StaticResource EmployePageStyle}">

    <ScrollView Style="{StaticResource EmployePageScrollView}">
        <VerticalStackLayout Style="{StaticResource EmployePageMainStack}">

            <!-- ========================================= -->
            <!-- HEADER SECTION with Action Button         -->
            <!-- ========================================= -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                <VerticalStackLayout Style="{StaticResource EmployePageHeaderStack}">
                    <Label Text="Gestion des Employés" 
                           Style="{StaticResource EmployePageTitleLabel}"/>
                    <Label Text="{Binding Employes.Count, StringFormat='{0} employés enregistrés'}" 
                           Style="{StaticResource EmployePageSubtitleLabel}"/>
                </VerticalStackLayout>
                
                <!-- Add Button -->
                <Button Grid.Column="1"
                        Text="+ Nouvel Employé"
                        Style="{StaticResource EmployeAddButton}"
                        Clicked="OnAddEmployeClicked"
                        VerticalOptions="Center"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"/>
            </Grid>

            <!-- ========================================= -->
            <!-- STATS CARDS ROW - Neumorphic Raised       -->
            <!-- ========================================= -->
            <Grid ColumnDefinitions="*,*,*,*" 
                  ColumnSpacing="16"
                  IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                
                <!-- Total Employees -->
                <Border Grid.Column="0" Style="{StaticResource EmployeStatCard}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding Employes.Count}" 
                               Style="{StaticResource EmployeStatNumber}"/>
                        <Label Text="Total Employés" 
                               Style="{StaticResource EmployeStatLabel}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- By Position -->
                <Border Grid.Column="1" Style="{StaticResource EmployeStatCard}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="—" 
                               Style="{StaticResource EmployeStatNumber}"
                               TextColor="#5EAA8D"/>
                        <Label Text="Chauffeurs" 
                               Style="{StaticResource EmployeStatLabel}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Active -->
                <Border Grid.Column="2" Style="{StaticResource EmployeStatCard}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="—" 
                               Style="{StaticResource EmployeStatNumber}"
                               TextColor="#E8A84C"/>
                        <Label Text="Pompistes" 
                               Style="{StaticResource EmployeStatLabel}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- New This Month -->
                <Border Grid.Column="3" Style="{StaticResource EmployeStatCard}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="—" 
                               Style="{StaticResource EmployeStatNumber}"
                               TextColor="#8FA3B8"/>
                        <Label Text="Ce Mois" 
                               Style="{StaticResource EmployeStatLabel}"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- ========================================= -->
            <!-- SEARCH BAR - Neumorphic Inset             -->
            <!-- ========================================= -->
            <Border Style="{StaticResource EmployeSearchContainer}"
                    IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Image Source="search.png"
                           WidthRequest="24"
                           HeightRequest="24"/>

                    <Entry Grid.Column="1"
                           Placeholder="Rechercher par nom, CIN, poste..."
                           Style="{StaticResource EmployeSearchEntry}"/>
                    <Button Grid.Column="2"
                            Text="Filtres"
                            BackgroundColor="#E8ECF1"
                            TextColor="#5A6068"
                            FontSize="13"
                            FontAttributes="Bold"
                            Padding="16,10"
                            CornerRadius="10"/>
                </Grid>
            </Border>

            <!-- Loading Indicator -->
            <ActivityIndicator Style="{StaticResource EmployePageLoadingIndicator}"
                              IsRunning="{Binding IsLoading}"
                              IsVisible="{Binding IsLoading}"/>

            <!-- ========================================= -->
            <!-- TABLE CARD - Neumorphic Raised Container  -->
            <!-- ========================================= -->
            <Border Style="{StaticResource EmployeTableCard}"
                    IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                <VerticalStackLayout Style="{StaticResource EmployeTableContainer}">

                    <!-- Table Header -->
                    <Grid Style="{StaticResource EmployeTableHeaderGrid}">
                        <Label Grid.Column="0" 
                               Text="ID" 
                               Style="{StaticResource EmployeTableHeaderLabel}"/>
                        <Label Grid.Column="1" 
                               Text="Nom" 
                               Style="{StaticResource EmployeTableHeaderLabelLeft}"/>
                        <Label Grid.Column="2" 
                               Text="Prénom" 
                               Style="{StaticResource EmployeTableHeaderLabelLeft}"/>
                        <Label Grid.Column="3" 
                               Text="CIN" 
                               Style="{StaticResource EmployeTableHeaderLabel}"/>
                        <Label Grid.Column="4" 
                               Text="Téléphone" 
                               Style="{StaticResource EmployeTableHeaderLabel}"/>
                        <Label Grid.Column="5" 
                               Text="Poste" 
                               Style="{StaticResource EmployeTableHeaderLabel}"/>
                        <Label Grid.Column="6" 
                               Text="Actions" 
                               Style="{StaticResource EmployeTableHeaderLabel}"/>
                    </Grid>

                    <!-- Table Rows with SwipeView -->
                    <CollectionView ItemsSource="{Binding Employes}"
                                    Style="{StaticResource EmployeTableCollectionView}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:EmployeDto">
                                <SwipeView BackgroundColor="Transparent">
                                    <!-- Left Swipe Actions -->
                                    <SwipeView.LeftItems>
                                        <SwipeItems Mode="Reveal">
                                            <SwipeItem Text="Détails"
                                                       BackgroundColor="#8FA3B8"
                                                       CommandParameter="{Binding .}"
                                                       Invoked="OnDetailsSwipeInvoked"/>
                                            <SwipeItem Text="Modifier"
                                                       BackgroundColor="#4A8FBF"
                                                       CommandParameter="{Binding .}"
                                                       Invoked="OnEditSwipeInvoked"/>
                                        </SwipeItems>
                                    </SwipeView.LeftItems>

                                    <!-- Right Swipe Actions -->
                                    <SwipeView.RightItems>
                                        <SwipeItems Mode="Reveal">
                                            <SwipeItem Text="Supprimer"
                                                       BackgroundColor="#E16C6C"
                                                       CommandParameter="{Binding .}"
                                                       Invoked="OnDeleteSwipeInvoked"/>
                                        </SwipeItems>
                                    </SwipeView.RightItems>

                                    <!-- Row Content -->
                                    <VerticalStackLayout BackgroundColor="Transparent">
                                        <Grid Style="{StaticResource EmployeTableRowGrid}">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer 
                                                    CommandParameter="{Binding .}"
                                                    Tapped="OnRowTapped"/>
                                            </Grid.GestureRecognizers>

                                            <!-- ID - Neumorphic Pill -->
                                            <Border Grid.Column="0" 
                                                    Style="{StaticResource EmployeIdCell}">
                                                <Label Text="{Binding ID}" 
                                                       Style="{StaticResource EmployeIdLabel}"/>
                                            </Border>

                                            <!-- Nom -->
                                            <Label Grid.Column="1" 
                                                   Text="{Binding Nom, FallbackValue='N/A'}" 
                                                   Style="{StaticResource EmployeNameLabel}"/>

                                            <!-- Prenom -->
                                            <Label Grid.Column="2" 
                                                   Text="{Binding Prenom, FallbackValue='N/A'}" 
                                                   Style="{StaticResource EmployeNameLabel}"/>

                                            <!-- CIN Badge - Neumorphic -->
                                            <Border Grid.Column="3" 
                                                    Style="{StaticResource EmployeCINBadge}">
                                                <Label Text="{Binding CIN, FallbackValue='N/A'}" 
                                                       Style="{StaticResource EmployeCINLabel}"/>
                                            </Border>

                                            <!-- Telephone -->
                                            <Label Grid.Column="4" 
                                                   Text="{Binding Telephone, FallbackValue='N/A'}" 
                                                   Style="{StaticResource EmployeTelephoneLabel}"/>

                                            <!-- Poste -->
                                            <Label Grid.Column="5" 
                                                   Text="{Binding Poste, FallbackValue='N/A'}" 
                                                   Style="{StaticResource EmployePosteLabel}"/>

                                            <!-- Actions -->
                                            <HorizontalStackLayout Grid.Column="6" 
                                                                   Style="{StaticResource EmployeActionsCell}">
                                                <Button Text="Détails"
                                                        Style="{StaticResource EmployeDetailsButton}"
                                                        CommandParameter="{Binding .}"
                                                        Clicked="OnDetailsClicked"/>
                                                <Button Text="Modifier"
                                                        Style="{StaticResource EmployeModifierButton}"
                                                        CommandParameter="{Binding .}"
                                                        Clicked="OnEditEmployeClicked"/>
                                                <Button Text="Supprimer"
                                                        Style="{StaticResource EmployeSupprimerButton}"
                                                        CommandParameter="{Binding .}"
                                                        Clicked="OnDeleteEmployeClicked"/>
                                            </HorizontalStackLayout>
                                        </Grid>

                                        <!-- Row Divider -->
                                        <BoxView Style="{StaticResource EmployeRowDivider}"/>
                                    </VerticalStackLayout>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                        <!-- Modern Empty View - Neumorphic Style -->
                        <CollectionView.EmptyView>
                            <VerticalStackLayout Style="{StaticResource EmployeEmptyView}">
                                <!-- Neumorphic Icon Container -->
                                <Border BackgroundColor="#EEF1F5"
                                        WidthRequest="100"
                                        HeightRequest="100"
                                        StrokeThickness="0"
                                        Margin="0,0,0,16">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="50"/>
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="#C5CAD1"
                                                Offset="6,6"
                                                Radius="12"
                                                Opacity="0.25"/>
                                    </Border.Shadow>
                                    <Label Text="👥"
                                           FontSize="48"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <Label Text="Aucun employé disponible" 
                                       Style="{StaticResource EmployeEmptyTitle}"/>
                                <Label Text="Commencez par ajouter votre premier employé pour gérer votre équipe" 
                                       Style="{StaticResource EmployeEmptySubtitle}"/>
                                <Button Text="+ Ajouter un Employé"
                                        Style="{StaticResource EmployeEmptyButton}"
                                        Clicked="OnAddEmployeClicked"/>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>