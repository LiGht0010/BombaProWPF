<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BombaProMax.Models"
             xmlns:viewmodels="clr-namespace:BombaProMax.ViewModels"
             x:Class="BombaProMax.Views.ClientViews.ClientCreditManagement"
             x:DataType="viewmodels:ClientCreditManagementViewModel"
             Style="{StaticResource CreditPageStyle}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior TextOverride="← Clients"
                            IsVisible="True"
                            IsEnabled="True"/>
    </Shell.BackButtonBehavior>

    <ScrollView Style="{StaticResource CreditPageScrollView}">
        <VerticalStackLayout Style="{StaticResource CreditPageMainStack}">

            <!-- ========================================= -->
            <!-- HEADER with Back Navigation               -->
            <!-- ========================================= -->
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Margin="0,0,0,8">
                <Button Grid.Column="0"
                        Text="← Retour Clients"
                        Style="{StaticResource CreditBackButton}"
                        Clicked="OnBackToClientsClicked"/>

                <VerticalStackLayout Grid.Column="1" 
                                     Style="{StaticResource CreditHeaderStack}">
                    <Label Text="Gestion Complète Client" 
                           Style="{StaticResource CreditTitleLabel}"/>
                    <Label Text="Transactions, Règlements, Factures et Bons de Livraison" 
                           Style="{StaticResource CreditSubtitleLabel}"/>
                </VerticalStackLayout>
                
                <Button Grid.Column="2"
                        Text="⟳ Rafraîchir"
                        Command="{Binding RefreshBilanCommand}"
                        Style="{StaticResource CreditRefreshButton}"
                        IsEnabled="{Binding CurrentClient, Converter={StaticResource IsNotNullConverter}}"/>
            </Grid>

            <!-- Client Header Banner - Shows selected client info + Balance -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16"
                  IsVisible="{Binding CurrentClient, Converter={StaticResource IsNotNullConverter}}">
                
                <!-- Client Info Card -->
                <Border Grid.Column="0" Style="{StaticResource CreditClientSelectorCard}">
                    <Grid Style="{StaticResource CreditClientSelectorGrid}">
                        <Label Text="👤" 
                               Style="{StaticResource CreditClientIconLabel}"/>
                        <VerticalStackLayout Grid.Column="1" 
                                             Style="{StaticResource CreditClientSelectorStack}">
                            <Label Text="{Binding CurrentClient.Nom}" 
                                   Style="{StaticResource CreditClientSelectorLabel}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource GREY}"/>
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="{Binding CurrentClient.NomSociete, StringFormat='Société: {0}'}" 
                                       Style="{StaticResource CreditClientSelectorLabel}"
                                       IsVisible="{Binding CurrentClient.NomSociete, Converter={StaticResource IsNotNullConverter}}"/>
                                <Label Text="•" 
                                       Style="{StaticResource CreditClientSelectorLabel}"
                                       IsVisible="{Binding CurrentClient.Contact, Converter={StaticResource IsNotNullConverter}}"/>
                                <Label Text="{Binding CurrentClient.Contact, StringFormat='Tél: {0}'}" 
                                       Style="{StaticResource CreditClientSelectorLabel}"
                                       IsVisible="{Binding CurrentClient.Contact, Converter={StaticResource IsNotNullConverter}}"/>
                            </HorizontalStackLayout>
                            <Label Text="{Binding CurrentClient.NumeroClient, StringFormat='ID: {0}'}" 
                                   Style="{StaticResource CreditClientSelectorLabel}"
                                   FontSize="12"
                                   TextColor="{StaticResource ClientNeuTextMuted}"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>
                
                <!-- Balance Card - Styled like other bilan cards -->
                <Border Grid.Column="1" 
                        BackgroundColor="{StaticResource ClientNeuCardBg}"
                        Padding="40,24"
                        WidthRequest="390"
                        HeightRequest="110"
                        StrokeThickness="0">

                    <Border.Shadow>
                        <Shadow Brush="{StaticResource ClientNeuShadowDark}"
                                Offset="6,6"
                                Radius="12"
                                Opacity="0.2"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="8" VerticalOptions="Center" HorizontalOptions="Center">
                        <Label Text="{Binding Bilan.Balance, Converter={StaticResource BalanceToTextConverter}}" 
                               FontSize="26"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{Binding Bilan.Balance, Converter={StaticResource BalanceToColorConverter}}"/>
                        <Label Text="BALANCE" 
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource ClientNeuTextMuted}"
                               HorizontalOptions="Center"
                               CharacterSpacing="2"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                              IsVisible="{Binding IsLoading}"
                              Style="{StaticResource CreditLoadingIndicator}"/>

            <!-- ========================================= -->
            <!-- BILAN CARDS - Neumorphic Stats Row        -->
            <!-- ========================================= -->
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="16"
                  IsVisible="{Binding CurrentClient, Converter={StaticResource IsNotNullConverter}}"
                  Margin="0,8,0,0">
                
                <!-- Total Credit -->
                <Border Grid.Column="0" Style="{StaticResource CreditBilanCardOrange}">
                    <VerticalStackLayout Style="{StaticResource CreditBilanStack}">
                        <Label Text="{Binding Bilan.TotalCredit, StringFormat='{0:N2} MAD'}" 
                               Style="{StaticResource CreditBilanValueOrange}"/>
                        <Label Text="Total Crédit" 
                               Style="{StaticResource CreditBilanLabel}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Total Paid -->
                <Border Grid.Column="1" Style="{StaticResource CreditBilanCardGreen}">
                    <VerticalStackLayout Style="{StaticResource CreditBilanStack}">
                        <Label Text="{Binding Bilan.TotalPaye, StringFormat='{0:N2} MAD'}" 
                               Style="{StaticResource CreditBilanValueGreen}"/>
                        <Label Text="Total Payé" 
                               Style="{StaticResource CreditBilanLabel}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Credit Facturé -->
                <Border Grid.Column="2" Style="{StaticResource CreditBilanCardBlue}">
                    <VerticalStackLayout Style="{StaticResource CreditBilanStack}">
                        <Label Text="{Binding Bilan.CreditFacture, StringFormat='{0:N2} MAD'}" 
                               Style="{StaticResource CreditBilanValueBlue}"/>
                        <Label Text="Facturé" 
                               Style="{StaticResource CreditBilanLabel}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Credit Non Facturé -->
                <Border Grid.Column="3" Style="{StaticResource CreditBilanCardPurple}">
                    <VerticalStackLayout Style="{StaticResource CreditBilanStack}">
                        <Label Text="{Binding Bilan.CreditNonFacture, StringFormat='{0:N2} MAD'}" 
                               Style="{StaticResource CreditBilanValuePurple}"/>
                        <Label Text="Non Facturé" 
                               Style="{StaticResource CreditBilanLabel}"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- ========================================= -->
            <!-- TABS CARD - 4 Tabs Now                    -->
            <!-- ========================================= -->
            <Border Style="{StaticResource CreditTabsCard}"
                    IsVisible="{Binding CurrentClient, Converter={StaticResource IsNotNullConverter}}">
                <VerticalStackLayout Style="{StaticResource ClientTableContainer}">
                    
                    <!-- Tab Headers - 4 Columns Now -->
                    <Grid ColumnDefinitions="*,*,*,*" BackgroundColor="{StaticResource ClientNeuPrimary}">
                        <Button x:Name="TransactionsTabButton"
                                Grid.Column="0"
                                Text="📦 Transactions"
                                Style="{StaticResource CreditTabButtonActive}"
                                Clicked="OnTransactionsTabClicked"/>
                        <Button x:Name="ReglementsTabButton"
                                Grid.Column="1"
                                Text="💵 Règlements"
                                Style="{StaticResource CreditTabButtonInactive}"
                                Clicked="OnReglementsTabClicked"/>
                        <Button x:Name="FacturesTabButton"
                                Grid.Column="2"
                                Text="📄 Factures"
                                Style="{StaticResource CreditTabButtonInactive}"
                                Clicked="OnFacturesTabClicked"/>
                        <Button x:Name="BLTabButton"
                                Grid.Column="3"
                                Text="🚚 Bons Livraison"
                                Style="{StaticResource CreditTabButtonInactive}"
                                Clicked="OnBLTabClicked"/>
                    </Grid>

                    <!-- ========================================= -->
                    <!-- TAB 1: TRANSACTIONS                       -->
                    <!-- ========================================= -->
                    <VerticalStackLayout x:Name="TransactionsTab" 
                                         Style="{StaticResource CreditTabContent}">
                        
                        <!-- Filter Buttons Row -->
                        <HorizontalStackLayout Style="{StaticResource CreditAddButtonStack}" Spacing="10">
                            <Button x:Name="CTFilterAvailableBtn"
                                    Text="Disponibles"
                                    Command="{Binding SetCTFilterAvailableCommand}"
                                    Style="{StaticResource CreditAddButton}"/>
                            <Button x:Name="CTFilterInBLBtn"
                                    Text="En BL"
                                    Command="{Binding SetCTFilterInBLCommand}"
                                    Style="{StaticResource CreditAddButton}"
                                    BackgroundColor="#E8ECF1"
                                    TextColor="#5A6068"/>
                            <Button x:Name="CTFilterInvoicedBtn"
                                    Text="Facturés"
                                    Command="{Binding SetCTFilterInvoicedCommand}"
                                    Style="{StaticResource CreditAddButton}"
                                    BackgroundColor="#E8ECF1"
                                    TextColor="#5A6068"/>
                            <BoxView WidthRequest="20" BackgroundColor="Transparent"/>
                            <Button Text="Tout Sélectionner"
                                    Command="{Binding SelectAllCTsCommand}"
                                    Style="{StaticResource CreditAddButton}"
                                    BackgroundColor="#E8ECF1"
                                    TextColor="#5A6068"/>
                            <Button Text="Désélectionner"
                                    Command="{Binding DeselectAllCTsCommand}"
                                    Style="{StaticResource CreditAddButton}"
                                    BackgroundColor="#E8ECF1"
                                    TextColor="#5A6068"/>
                            <BoxView WidthRequest="20" BackgroundColor="Transparent"/>
                            <Button Text="+ Nouvelle Transaction"
                                    Style="{StaticResource CreditAddButton}"
                                    Clicked="OnAddTransactionClicked"/>
                        </HorizontalStackLayout>

                        <!-- Transactions Table Header (with checkbox column) -->
                        <Grid ColumnDefinitions="0.4*,0.9*,1.2*,1.4*,0.6*,1*,0.8*,1.1*" 
                              ColumnSpacing="8" 
                              Padding="20,18" 
                              BackgroundColor="{StaticResource ClientNeuCardBg}">
                            <Label Grid.Column="0" Text="✓" Style="{StaticResource CreditTableHeaderLabelCenter}"/>
                            <Label Grid.Column="1" Text="Date" Style="{StaticResource CreditTableHeaderLabel}"/>
                            <Label Grid.Column="2" Text="Numéro" Style="{StaticResource CreditTableHeaderLabel}"/>
                            <Label Grid.Column="3" Text="Article" Style="{StaticResource CreditTableHeaderLabel}"/>
                            <Label Grid.Column="4" Text="Qté" Style="{StaticResource CreditTableHeaderLabelCenter}"/>
                            <Label Grid.Column="5" Text="Montant" Style="{StaticResource CreditTableHeaderLabelEnd}"/>
                            <Label Grid.Column="6" Text="Statut" Style="{StaticResource CreditTableHeaderLabelCenter}"/>
                            <Label Grid.Column="7" Text="Actions" Style="{StaticResource CreditTableHeaderLabelCenter}"/>
                        </Grid>

                        <!-- Transactions List -->
                        <CollectionView ItemsSource="{Binding Transactions}"
                                       Style="{StaticResource CreditTransactionCollectionView}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:CreditTransactionDto">
                                    <VerticalStackLayout>
                                        <Border BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToSelectionColorConverter}}"
                                                Padding="0" StrokeThickness="0">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer 
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ClientCreditManagementViewModel}}, Path=ToggleCTSelectionCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Grid ColumnDefinitions="0.4*,0.9*,1.2*,1.4*,0.6*,1*,0.8*,1.1*" 
                                                  ColumnSpacing="8" 
                                                  Padding="20,12">
                                                
                                                <!-- CheckBox for selection (disabled for invoiced) -->
                                                <CheckBox Grid.Column="0" 
                                                          IsChecked="{Binding IsSelected}"
                                                          IsEnabled="{Binding Facture, Converter={StaticResource InverseBoolConverter}}"
                                                          CheckedChanged="OnCTCheckBoxChanged"
                                                          VerticalOptions="Center"
                                                          HorizontalOptions="Center"/>
                                                
                                                <!-- Date -->
                                                <Label Grid.Column="1" 
                                                       Text="{Binding DateCredit, StringFormat='{0:dd/MM/yyyy}'}"
                                                       Style="{StaticResource CreditTableCellText}"/>
                                                
                                                <!-- Numéro - Pill Style -->
                                                <Border Grid.Column="2" Style="{StaticResource ClientNumberCell}"
                                                        HorizontalOptions="Start">
                                                    <Label Text="{Binding NumeroTransaction}" 
                                                           Style="{StaticResource ClientNumberLabel}"/>
                                                </Border>
                                                
                                                <!-- Article -->
                                                <VerticalStackLayout Grid.Column="3" VerticalOptions="Center"
                                                                 HorizontalOptions="Start">
                                                    <Label Text="{Binding ProduitNom}" 
                                                           Style="{StaticResource ClientNameCell}"
                                                           IsVisible="{Binding ProduitNom, Converter={StaticResource IsNotNullConverter}}"/>
                                                    <Label Text="{Binding ServiceNom}" 
                                                           Style="{StaticResource ClientNameCell}"
                                                           IsVisible="{Binding ServiceNom, Converter={StaticResource IsNotNullConverter}}"/>
                                                </VerticalStackLayout>
                                                
                                                <!-- Quantity -->
                                                <Label Grid.Column="4" 
                                                       Text="{Binding Quantite}"
                                                       Style="{StaticResource CreditTableCellTextCenter}"/>
                                                
                                                <!-- Amount -->
                                                <Label Grid.Column="5" 
                                                       Text="{Binding MontantTotal, StringFormat='{0:N2} MAD'}"
                                                       Style="{StaticResource CreditTableCellAmountOrange}"/>
                                                
                                                <!-- Status Badge -->
                                                <Border Grid.Column="6"
                                                        BackgroundColor="{Binding Facture, Converter={StaticResource BoolToColorConverter}}"
                                                        Style="{StaticResource CreditStatusBadge}">
                                                    <Label Text="{Binding Facture, Converter={StaticResource BoolToFactureStatusConverter}}"
                                                           Style="{StaticResource CreditStatusBadgeLabel}"/>
                                                </Border>
                                                
                                                <!-- Actions -->
                                                <HorizontalStackLayout Grid.Column="7" 
                                                                       Style="{StaticResource CreditRowActionsStack}">
                                                    <Button Text="✏️"
                                                            Style="{StaticResource CreditEditButton}"
                                                            Clicked="OnEditTransactionClicked"
                                                            CommandParameter="{Binding .}"/>
                                                    <Button Text="🗑️"
                                                            Style="{StaticResource CreditDeleteButton}"
                                                            Clicked="OnDeleteTransactionClicked"
                                                            CommandParameter="{Binding .}"/>
                                                </HorizontalStackLayout>
                                            </Grid>
                                        </Border>
                                        
                                        <!-- Row Divider -->
                                        <BoxView Style="{StaticResource CreditRowDivider}"/>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            
                            <!-- Empty View -->
                            <CollectionView.EmptyView>
                                <VerticalStackLayout Style="{StaticResource ClientEmptyView}">
                                    <Border BackgroundColor="{StaticResource ClientNeuCardBg}"
                                            WidthRequest="100"
                                            HeightRequest="100"
                                            StrokeThickness="0"
                                            Margin="0,0,0,16">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="50"/>
                                        </Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="{StaticResource ClientNeuShadowDark}"
                                                    Offset="6,6"
                                                    Radius="12"
                                                    Opacity="0.25"/>
                                        </Border.Shadow>
                                        <Label Text="📦"
                                               FontSize="48"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>
                                    <Label Text="Aucune transaction" 
                                           Style="{StaticResource ClientEmptyTitle}"/>
                                    <Label Text="Ce client n'a pas encore de transactions de crédit enregistrées" 
                                           Style="{StaticResource ClientEmptySubtitle}"/>
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>
                        </CollectionView>

                        <!-- CT Selection Summary & Action Buttons -->
                        <Border BackgroundColor="{StaticResource ClientNeuCardBg}"
                                Padding="0" StrokeThickness="0"
                                IsVisible="{Binding SelectedCTCount, Converter={StaticResource IntToVisibilityConverter}}">
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12" Padding="16,12">
                                <VerticalStackLayout>
                                    <Label Text="{Binding SelectedCTCount, StringFormat='{0} transaction(s) sélectionnée(s)'}" 
                                           FontSize="14" FontAttributes="Bold" TextColor="{StaticResource GREY}"/>
                                    <Label Text="{Binding SelectedCTTotal, StringFormat='Total: {0:N2} MAD'}" 
                                           FontSize="13" TextColor="{StaticResource ClientNeuTextMuted}"/>
                                </VerticalStackLayout>
                                <Button Grid.Column="1"
                                        Text="🚚 Créer BL"
                                        Command="{Binding CreateBLFromSelectedCTsCommand}"
                                        IsEnabled="{Binding CanCreateBLFromCTs}"
                                        BackgroundColor="#E8833A"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        Padding="16,10"
                                        CornerRadius="8"/>
                                <Button Grid.Column="2"
                                        Text="📄 Facturer Directement"
                                        Command="{Binding CreateFactureFromSelectedCTsCommand}"
                                        IsEnabled="{Binding CanCreateFactureFromCTs}"
                                        BackgroundColor="#4A8FBF"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        Padding="16,10"
                                        CornerRadius="8"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- ========================================= -->
                    <!-- TAB 2: RÈGLEMENTS                         -->
                    <!-- ========================================= -->
                    <VerticalStackLayout x:Name="ReglementsTab" 
                                         Style="{StaticResource CreditTabContent}" 
                                         IsVisible="False">
                        
                        <!-- Add Button Row -->
                        <HorizontalStackLayout Style="{StaticResource CreditAddButtonStack}">
                            <Button Text="+ Nouveau Règlement"
                                    Style="{StaticResource CreditAddButton}"
                                    Clicked="OnAddReglementClicked"/>
                        </HorizontalStackLayout>

                        <!-- Reglements Table Header -->
                        <Grid Style="{StaticResource CreditReglementHeaderGrid}">
                            <Label Grid.Column="0" Text="Date" Style="{StaticResource CreditTableHeaderLabel}"/>
                            <Label Grid.Column="1" Text="Montant" Style="{StaticResource CreditTableHeaderLabel}"/>
                            <Label Grid.Column="2" Text="Mode" Style="{StaticResource CreditTableHeaderLabel}"/>
                            <Label Grid.Column="3" Text="Référence" Style="{StaticResource CreditTableHeaderLabel}"/>
                            <Label Grid.Column="4" Text="Validé Par" Style="{StaticResource CreditTableHeaderLabel}"/>
                            <Label Grid.Column="5" Text="Actions" Style="{StaticResource CreditTableHeaderLabelCenter}"/>
                        </Grid>

                        <!-- Reglements List -->
                        <CollectionView ItemsSource="{Binding Reglements}"
                                       Style="{StaticResource CreditTransactionCollectionView}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:ReglementCreditDto">
                                    <VerticalStackLayout>
                                        <Grid Style="{StaticResource CreditReglementRowGrid}">
                                            <!-- Date -->
                                            <Label Grid.Column="0" 
                                                   Text="{Binding DateReglement, StringFormat='{0:dd/MM/yyyy}'}"
                                                   Style="{StaticResource CreditTableCellText}"/>
                                            
                                            <!-- Montant -->
                                            <Label Grid.Column="1" 
                                                   Text="{Binding MontantPaye, StringFormat='{0:N2} MAD'}"
                                                   Style="{StaticResource CreditTableCellAmountGreen}"/>
                                            
                                            <!-- Mode Badge -->
                                            <Border Grid.Column="2" Style="{StaticResource CreditModeBadge}">
                                                <Label Text="{Binding ModePaiementNom}"
                                                       Style="{StaticResource CreditModeBadgeLabel}"/>
                                            </Border>
                                            
                                            <!-- Reference -->
                                            <Label Grid.Column="3" 
                                                   Text="{Binding ReferenceTransaction}"
                                                   Style="{StaticResource CreditTableCellTextMuted}"/>
                                            
                                            <!-- Validated By -->
                                            <Label Grid.Column="4" 
                                                   Text="{Binding ValidePar}"
                                                   Style="{StaticResource CreditTableCellTextMuted}"/>
                                            
                                            <!-- Actions -->
                                            <HorizontalStackLayout Grid.Column="5" 
                                                                   Style="{StaticResource CreditRowActionsStack}">
                                                <Button Text="✏️"
                                                        Style="{StaticResource CreditEditButton}"
                                                        Clicked="OnEditReglementClicked"
                                                        CommandParameter="{Binding .}"/>
                                                <Button Text="🗑️"
                                                        Style="{StaticResource CreditDeleteButton}"
                                                        Clicked="OnDeleteReglementClicked"
                                                        CommandParameter="{Binding .}"/>
                                            </HorizontalStackLayout>
                                        </Grid>
                                        
                                        <!-- Row Divider -->
                                        <BoxView Style="{StaticResource CreditRowDivider}"/>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            
                            <!-- Empty View -->
                            <CollectionView.EmptyView>
                                <VerticalStackLayout Style="{StaticResource ClientEmptyView}">
                                    <Border BackgroundColor="{StaticResource ClientNeuCardBg}"
                                            WidthRequest="100"
                                            HeightRequest="100"
                                            StrokeThickness="0"
                                            Margin="0,0,0,16">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="50"/>
                                        </Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="{StaticResource ClientNeuShadowDark}"
                                                    Offset="6,6"
                                                    Radius="12"
                                                    Opacity="0.25"/>
                                        </Border.Shadow>
                                        <Label Text="💵"
                                               FontSize="48"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>
                                    <Label Text="Aucun règlement" 
                                           Style="{StaticResource ClientEmptyTitle}"/>
                                    <Label Text="Ce client n'a pas encore de règlements enregistrés" 
                                           Style="{StaticResource ClientEmptySubtitle}"/>
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>

                    <!-- ========================================= -->
                    <!-- TAB 3: FACTURES                           -->
                    <!-- ========================================= -->
                    <VerticalStackLayout x:Name="FacturesTab" 
                                         Style="{StaticResource CreditTabContent}" 
                                         IsVisible="False">
                        
                        <!-- Filter/Selection Buttons Row -->
                        <HorizontalStackLayout Style="{StaticResource CreditAddButtonStack}" Spacing="10">
                            <Button Text="Tout Sélectionner"
                                    Command="{Binding SelectAllFacturesCommand}"
                                    Style="{StaticResource CreditAddButton}"
                                    BackgroundColor="#E8ECF1"
                                    TextColor="#5A6068"/>
                            <Button Text="Désélectionner"
                                    Command="{Binding DeselectAllFacturesCommand}"
                                    Style="{StaticResource CreditAddButton}"
                                    BackgroundColor="#E8ECF1"
                                    TextColor="#5A6068"/>
                        </HorizontalStackLayout>

                        <!-- Factures Table Header -->
                        <Grid ColumnDefinitions="0.5*,1*,1.4*,1.5*,1.2*,1.3*" 
                              ColumnSpacing="12" 
                              Padding="28,18" 
                              BackgroundColor="{StaticResource ClientNeuCardBg}">
                            <Label Grid.Column="0" Text="✓" Style="{StaticResource CreditTableHeaderLabelCenter}"/>
                            <Label Grid.Column="1" Text="Date" Style="{StaticResource CreditTableHeaderLabel}"/>
                            <Label Grid.Column="2" Text="Numéro" Style="{StaticResource CreditTableHeaderLabel}"/>
                            <Label Grid.Column="3" Text="Client" Style="{StaticResource CreditTableHeaderLabel}"/>
                            <Label Grid.Column="4" Text="Montant" Style="{StaticResource CreditTableHeaderLabelEnd}"/>
                            <Label Grid.Column="5" Text="Actions" Style="{StaticResource CreditTableHeaderLabelCenter}"/>
                        </Grid>

                        <!-- Factures List -->
                        <CollectionView ItemsSource="{Binding Factures}"
                                       Style="{StaticResource CreditTransactionCollectionView}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:FactureDto">
                                    <VerticalStackLayout>
                                        <Border BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToSelectionColorConverter}}"
                                                Padding="0" StrokeThickness="0">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer 
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ClientCreditManagementViewModel}}, Path=ToggleFactureSelectionCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Grid ColumnDefinitions="0.5*,1*,1.4*,1.5*,1.2*,1.3*" 
                                                  ColumnSpacing="12" 
                                                  Padding="28,14">
                                                
                                                <!-- CheckBox for selection -->
                                                <CheckBox Grid.Column="0" 
                                                          IsChecked="{Binding IsSelected}"
                                                          CheckedChanged="OnFactureCheckBoxChanged"
                                                          VerticalOptions="Center"
                                                          HorizontalOptions="Center"/>
                                                
                                                <!-- Date -->
                                                <Label Grid.Column="1" 
                                                       Text="{Binding DateFacture, StringFormat='{0:dd/MM/yyyy}'}"
                                                       Style="{StaticResource CreditTableCellText}"/>
                                                
                                                <!-- Numéro - Pill Style -->
                                                <Border Grid.Column="2" Style="{StaticResource ClientNumberCell}"
                                                        HorizontalOptions="Start">
                                                    <Label Text="{Binding NumeroFacture}" 
                                                           Style="{StaticResource ClientNumberLabel}"/>
                                                </Border>
                                                
                                                <!-- Client -->
                                                <Label Grid.Column="3" 
                                                       Text="{Binding ClientNom}"
                                                       Style="{StaticResource CreditTableCellText}"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1"/>
                                                
                                                <!-- Montant -->
                                                <Label Grid.Column="4" 
                                                       Text="{Binding MontantTotal, StringFormat='{0:N2} MAD'}"
                                                       Style="{StaticResource CreditTableCellAmountGreen}"/>
                                                
                                                <!-- Actions -->
                                                <HorizontalStackLayout Grid.Column="5" 
                                                                       Style="{StaticResource CreditRowActionsStack}">
                                                    <Button Text="Détails"
                                                            Style="{StaticResource CreditEditButton}"
                                                            Clicked="OnFactureDetailsClicked"
                                                            CommandParameter="{Binding .}"/>
                                                    <Button Text="🗑️"
                                                            Style="{StaticResource CreditDeleteButton}"
                                                            Clicked="OnDeleteFactureClicked"
                                                            CommandParameter="{Binding .}"/>
                                                </HorizontalStackLayout>
                                            </Grid>
                                        </Border>
                                        
                                        <!-- Row Divider -->
                                        <BoxView Style="{StaticResource CreditRowDivider}"/>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            
                            <!-- Empty View -->
                            <CollectionView.EmptyView>
                                <VerticalStackLayout Style="{StaticResource ClientEmptyView}">
                                    <Border BackgroundColor="{StaticResource ClientNeuCardBg}"
                                            WidthRequest="100"
                                            HeightRequest="100"
                                            StrokeThickness="0"
                                            Margin="0,0,0,16">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="50"/>
                                        </Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="{StaticResource ClientNeuShadowDark}"
                                                    Offset="6,6"
                                                    Radius="12"
                                                    Opacity="0.25"/>
                                        </Border.Shadow>
                                        <Label Text="📄"
                                               FontSize="48"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>
                                    <Label Text="Aucune facture" 
                                           Style="{StaticResource ClientEmptyTitle}"/>
                                    <Label Text="Ce client n'a pas de factures enregistrées" 
                                           Style="{StaticResource ClientEmptySubtitle}"/>
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>
                        </CollectionView>

                        <!-- Facture Selection Summary & Merge Button -->
                        <Border BackgroundColor="{StaticResource ClientNeuCardBg}"
                                Padding="0" StrokeThickness="0"
                                IsVisible="{Binding SelectedFactureCount, Converter={StaticResource IntToVisibilityConverter}}">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Padding="16,12">
                                <VerticalStackLayout>
                                    <Label Text="{Binding SelectedFactureCount, StringFormat='{0} facture(s) sélectionnée(s)'}" 
                                           FontSize="14" FontAttributes="Bold" TextColor="{StaticResource GREY}"/>
                                    <Label Text="{Binding SelectedFactureTotal, StringFormat='Total: {0:N2} MAD'}" 
                                           FontSize="13" TextColor="{StaticResource ClientNeuTextMuted}"/>
                                </VerticalStackLayout>
                                <Button Grid.Column="1"
                                        Text="🧾 Fusionner Factures"
                                        Command="{Binding MergeFacturesCommand}"
                                        IsEnabled="{Binding CanMergeFactures}"
                                        BackgroundColor="#5EAA8D"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        Padding="16,10"
                                        CornerRadius="8"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- ========================================= -->
                    <!-- TAB 4: BONS DE LIVRAISON                  -->
                    <!-- ========================================= -->
                    <VerticalStackLayout x:Name="BLTab" 
                                         Style="{StaticResource CreditTabContent}" 
                                         IsVisible="False">
                        
                        <!-- Filter Buttons Row -->
                        <HorizontalStackLayout Style="{StaticResource CreditAddButtonStack}" Spacing="10">
                            <Button x:Name="BLFilterAllBtn"
                                    Text="Tous"
                                    Command="{Binding SetBLFilterAllCommand}"
                                    Style="{StaticResource CreditAddButton}"/>
                            <Button x:Name="BLFilterInvoicedBtn"
                                    Text="Facturés"
                                    Command="{Binding SetBLFilterInvoicedCommand}"
                                    Style="{StaticResource CreditAddButton}"
                                    BackgroundColor="#E8ECF1"
                                    TextColor="#5A6068"/>
                            <Button x:Name="BLFilterNotInvoicedBtn"
                                    Text="Non Facturés"
                                    Command="{Binding SetBLFilterNotInvoicedCommand}"
                                    Style="{StaticResource CreditAddButton}"
                                    BackgroundColor="#E8ECF1"
                                    TextColor="#5A6068"/>
                            <Button Text="Tout Sélectionner"
                                    Command="{Binding SelectAllBLsCommand}"
                                    Style="{StaticResource CreditAddButton}"
                                    BackgroundColor="#E8ECF1"
                                    TextColor="#5A6068"/>
                            <Button Text="Désélectionner"
                                    Command="{Binding DeselectAllBLsCommand}"
                                    Style="{StaticResource CreditAddButton}"
                                    BackgroundColor="#E8ECF1"
                                    TextColor="#5A6068"/>
                        </HorizontalStackLayout>

                        <!-- BL Table Header -->
                        <Grid ColumnDefinitions="0.5*,1*,1.4*,1.5*,1.2*,0.8*,1.3*" 
                              ColumnSpacing="12" 
                              Padding="28,18" 
                              BackgroundColor="{StaticResource ClientNeuCardBg}">
                            <Label Grid.Column="0" Text="✓" Style="{StaticResource CreditTableHeaderLabelCenter}"/>
                            <Label Grid.Column="1" Text="Date" Style="{StaticResource CreditTableHeaderLabel}"/>
                            <Label Grid.Column="2" Text="Numéro" Style="{StaticResource CreditTableHeaderLabel}"/>
                            <Label Grid.Column="3" Text="Client" Style="{StaticResource CreditTableHeaderLabel}"/>
                            <Label Grid.Column="4" Text="Montant" Style="{StaticResource CreditTableHeaderLabelEnd}"/>
                            <Label Grid.Column="5" Text="Statut" Style="{StaticResource CreditTableHeaderLabelCenter}"/>
                            <Label Grid.Column="6" Text="Actions" Style="{StaticResource CreditTableHeaderLabelCenter}"/>
                        </Grid>

                        <!-- BL List -->
                        <CollectionView ItemsSource="{Binding BonsLivraison}"
                                       Style="{StaticResource CreditTransactionCollectionView}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:BonLivraisonDto">
                                    <VerticalStackLayout>
                                        <Border BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToSelectionColorConverter}}"
                                                Padding="0" StrokeThickness="0">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer 
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ClientCreditManagementViewModel}}, Path=ToggleBLSelectionCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Grid ColumnDefinitions="0.5*,1*,1.4*,1.5*,1.2*,0.8*,1.3*" 
                                                  ColumnSpacing="12" 
                                                  Padding="28,14">
                                                
                                                <!-- CheckBox for selection (only for non-invoiced) -->
                                                <CheckBox Grid.Column="0" 
                                                          IsChecked="{Binding IsSelected}"
                                                          IsEnabled="{Binding EstFacture, Converter={StaticResource InverseBoolConverter}}"
                                                          CheckedChanged="OnBLCheckBoxChanged"
                                                          VerticalOptions="Center"
                                                          HorizontalOptions="Center"/>
                                                
                                                <!-- Date -->
                                                <Label Grid.Column="1" 
                                                       Text="{Binding DateBL, StringFormat='{0:dd/MM/yyyy}'}"
                                                       Style="{StaticResource CreditTableCellText}"/>
                                                
                                                <!-- Numéro - Pill Style -->
                                                <Border Grid.Column="2" Style="{StaticResource ClientNumberCell}"
                                                        HorizontalOptions="Start">
                                                    <Label Text="{Binding NumeroBL}" 
                                                           Style="{StaticResource ClientNumberLabel}"/>
                                                </Border>
                                                
                                                <!-- Client -->
                                                <Label Grid.Column="3" 
                                                       Text="{Binding ClientNom}"
                                                       Style="{StaticResource CreditTableCellText}"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1"/>
                                                
                                                <!-- Montant -->
                                                <Label Grid.Column="4" 
                                                       Text="{Binding MontantTotal, StringFormat='{0:N2} MAD'}"
                                                       Style="{StaticResource CreditTableCellAmountOrange}"/>
                                                
                                                <!-- Status Badge -->
                                                <Border Grid.Column="5"
                                                        BackgroundColor="{Binding EstFacture, Converter={StaticResource BoolToColorConverter}}"
                                                        Style="{StaticResource CreditStatusBadge}">
                                                    <Label Text="{Binding EstFacture, Converter={StaticResource BoolToFactureStatusConverter}}"
                                                           Style="{StaticResource CreditStatusBadgeLabel}"/>
                                                </Border>
                                                
                                                <!-- Actions -->
                                                <HorizontalStackLayout Grid.Column="6" 
                                                                       Style="{StaticResource CreditRowActionsStack}">
                                                    <Button Text="Détails"
                                                            Style="{StaticResource CreditEditButton}"
                                                            Clicked="OnBLDetailsClicked"
                                                            CommandParameter="{Binding .}"/>
                                                    <Button Text="🗑️"
                                                            Style="{StaticResource CreditDeleteButton}"
                                                            Clicked="OnDeleteBLClicked"
                                                            CommandParameter="{Binding .}"/>
                                                </HorizontalStackLayout>
                                            </Grid>
                                        </Border>
                                        
                                        <!-- Row Divider -->
                                        <BoxView Style="{StaticResource CreditRowDivider}"/>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            
                            <!-- Empty View -->
                            <CollectionView.EmptyView>
                                <VerticalStackLayout Style="{StaticResource ClientEmptyView}">
                                    <Border BackgroundColor="{StaticResource ClientNeuCardBg}"
                                            WidthRequest="100"
                                            HeightRequest="100"
                                            StrokeThickness="0"
                                            Margin="0,0,0,16">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="50"/>
                                        </Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="{StaticResource ClientNeuShadowDark}"
                                                    Offset="6,6"
                                                    Radius="12"
                                                    Opacity="0.25"/>
                                        </Border.Shadow>
                                        <Label Text="🚚"
                                               FontSize="48"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>
                                    <Label Text="Aucun bon de livraison" 
                                           Style="{StaticResource ClientEmptyTitle}"/>
                                    <Label Text="Ce client n'a pas de bons de livraison enregistrés" 
                                           Style="{StaticResource ClientEmptySubtitle}"/>
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>
                        </CollectionView>

                        <!-- BL Selection Summary & Action Buttons -->
                        <Border BackgroundColor="{StaticResource ClientNeuCardBg}"
                                Padding="0" StrokeThickness="0"
                                IsVisible="{Binding SelectedBLCount, Converter={StaticResource IntToVisibilityConverter}}">
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12" Padding="16,12">
                                <VerticalStackLayout>
                                    <Label Text="{Binding SelectedBLCount, StringFormat='{0} BL(s) sélectionné(s)'}" 
                                           FontSize="14" FontAttributes="Bold" TextColor="{StaticResource GREY}"/>
                                    <Label Text="{Binding SelectedBLTotal, StringFormat='Total: {0:N2} MAD'}" 
                                           FontSize="13" TextColor="{StaticResource ClientNeuTextMuted}"/>
                                </VerticalStackLayout>
                                <Button Grid.Column="1"
                                        Text="📄 Créer Facture"
                                        Command="{Binding CreateFactureFromBLsCommand}"
                                        IsEnabled="{Binding CanCreateFactureFromBLs}"
                                        BackgroundColor="#4A8FBF"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        Padding="16,10"
                                        CornerRadius="8"/>
                                <Button Grid.Column="2"
                                        Text="🔗 Fusionner BLs"
                                        Command="{Binding MergeBLsCommand}"
                                        IsEnabled="{Binding CanMergeBLs}"
                                        BackgroundColor="#5EAA8D"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        Padding="16,10"
                                        CornerRadius="8"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Empty State when no client (fallback for direct navigation) -->
            <Border Style="{StaticResource CreditEmptyStateCard}"
                    IsVisible="{Binding CurrentClient, Converter={StaticResource IsNullConverter}}">
                <VerticalStackLayout Style="{StaticResource CreditEmptyStateStack}">
                    <!-- Neumorphic Icon Container -->
                    <Border BackgroundColor="{StaticResource ClientNeuCardBg}"
                            WidthRequest="100"
                            HeightRequest="100"
                            StrokeThickness="0"
                            Margin="0,0,0,16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="50"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="{StaticResource ClientNeuShadowDark}"
                                    Offset="6,6"
                                    Radius="12"
                                    Opacity="0.25"/>
                        </Border.Shadow>
                        <Label Text="👆"
                               FontSize="48"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Aucun client sélectionné" 
                           Style="{StaticResource CreditEmptyStateTitle}"/>
                    <Label Text="Veuillez sélectionner un client depuis la liste des clients pour afficher ses transactions de crédit."
                           Style="{StaticResource CreditEmptyStateSubtitle}"/>
                    <Button Text="← Retour à la liste des clients"
                            Style="{StaticResource CreditBackButton}"
                            Clicked="OnBackToClientsClicked"
                            Margin="0,16,0,0"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
