<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:sys="clr-namespace:System;assembly=netstandard"
               x:Class="BombaProMax.Views.ClientViews.CreditTransactionPopup"
               Color="Transparent">

    <Border BackgroundColor="#F5F5F5" Padding="0" WidthRequest="600" HeightRequest="720" StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="12"/>
        </Border.StrokeShape>
        
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- ========================================= -->
            <!-- HEADER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="0" BackgroundColor="#FF9800" Padding="20,18" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label x:Name="HeaderLabel"
                               Text="📦 Nouvelle Transaction Crédit" 
                               FontSize="20" 
                               FontAttributes="Bold" 
                               TextColor="White"/>
                        <Label Text="Enregistrer un crédit client" 
                               FontSize="12" 
                               TextColor="#FFE0B2"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" 
                            Text="✕" 
                            BackgroundColor="#F57C00" 
                            TextColor="White" 
                            FontSize="16" 
                            WidthRequest="36" 
                            HeightRequest="36" 
                            CornerRadius="18" 
                            Clicked="OnCancelClicked"/>
                </Grid>
            </Border>

            <!-- ========================================= -->
            <!-- CONTENT                                   -->
            <!-- ========================================= -->
            <ScrollView Grid.Row="1" Padding="20,15">
                <VerticalStackLayout Spacing="15">
                    
                    <!-- Client Info Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <HorizontalStackLayout Spacing="12">
                            <Label Text="👤" FontSize="28" VerticalOptions="Center"/>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Client" FontSize="11" TextColor="#666"/>
                                <Label x:Name="ClientNameLabel"
                                       Text="Nom du client" 
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#1976D2"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Date & Numéro Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="INFORMATIONS GÉNÉRALES" FontSize="11" FontAttributes="Bold" TextColor="#FF9800"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                                <VerticalStackLayout Grid.Column="0" Spacing="5">
                                    <Label Text="📅 Date du Crédit *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <DatePicker x:Name="DateCreditPicker"
                                                FontSize="14"
                                                MaximumDate="{x:Static sys:DateTime.Today}"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="5">
                                    <Label Text="🔢 Numéro Transaction" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="NumeroEntry"
                                           Placeholder="Auto-généré"
                                           IsReadOnly="True"
                                           BackgroundColor="#EEEEEE"
                                           FontSize="14"/>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Type Selection Card -->
                    <Border BackgroundColor="#FFF3E0" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="📦 Type d'article" 
                                   FontAttributes="Bold" 
                                   TextColor="#E65100"
                                   FontSize="12"/>
                            <HorizontalStackLayout Spacing="20">
                                <RadioButton x:Name="ProduitRadio" 
                                            Content="Produit" 
                                            IsChecked="True"
                                            GroupName="ArticleType"
                                            CheckedChanged="OnArticleTypeChanged"/>
                                <RadioButton x:Name="ServiceRadio" 
                                            Content="Service" 
                                            GroupName="ArticleType"
                                            CheckedChanged="OnArticleTypeChanged"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Produit/Service Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="ARTICLE &amp; QUANTITÉ" FontSize="11" FontAttributes="Bold" TextColor="#FF9800"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            
                            <!-- Produit Picker -->
                            <VerticalStackLayout x:Name="ProduitSection" Spacing="5">
                                <Label Text="🛢️ Produit *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                <Picker x:Name="ProduitPicker"
                                        Title="Sélectionner un produit"
                                        FontSize="14"
                                        ItemDisplayBinding="{Binding Description}"
                                        SelectedIndexChanged="OnProduitSelected"/>
                            </VerticalStackLayout>

                            <!-- Service Picker -->
                            <VerticalStackLayout x:Name="ServiceSection" Spacing="5" IsVisible="False">
                                <Label Text="🔧 Service *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                <Picker x:Name="ServicePicker"
                                        Title="Sélectionner un service"
                                        FontSize="14"
                                        ItemDisplayBinding="{Binding Description}"
                                        SelectedIndexChanged="OnServiceSelected"/>
                            </VerticalStackLayout>

                            <!-- Quantity and Price Row -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                                <VerticalStackLayout Grid.Column="0" Spacing="5">
                                    <Label Text="📊 Quantité *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="QuantiteEntry"
                                           Placeholder="1"
                                           Keyboard="Numeric"
                                           FontSize="14"
                                           TextChanged="OnQuantityOrPriceChanged"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="5">
                                    <Label Text="💲 Prix TTC (MAD) *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="PrixTTCEntry"
                                           Placeholder="0.00"
                                           Keyboard="Numeric"
                                           FontSize="14"
                                           TextChanged="OnQuantityOrPriceChanged"/>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Montant Total Card -->
                    <Border BackgroundColor="#E8F5E9" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout>
                                <Label Text="💰 Montant Total" 
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#2E7D32"/>
                                <Label Text="Quantité × Prix TTC" 
                                       FontSize="11"
                                       TextColor="#666"/>
                            </VerticalStackLayout>
                            <Label x:Name="MontantTotalLabel"
                                   Grid.Column="1"
                                   Text="0.00 MAD" 
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="#2E7D32"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <!-- Facture Status Card -->
                    <Border BackgroundColor="#F3E5F5" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="📄 Statut Facture" 
                                       FontAttributes="Bold" 
                                       TextColor="#7B1FA2"
                                       FontSize="13"/>
                                <Label Text="Cette transaction est-elle facturée?" 
                                       TextColor="#999"
                                       FontSize="11"/>
                            </VerticalStackLayout>
                            <Switch x:Name="FactureSwitch"
                                    Grid.Column="1"
                                    IsToggled="False"
                                    OnColor="#9C27B0"/>
                        </Grid>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ========================================= -->
            <!-- FOOTER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="2" BackgroundColor="White" Padding="20,15" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,-2" Radius="6" Opacity="0.06"/>
                </Border.Shadow>
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                    <Label x:Name="ErrorLabel" 
                           TextColor="#F44336" 
                           FontSize="12" 
                           IsVisible="False" 
                           VerticalOptions="Center"/>
                    <Button Grid.Column="1" 
                            Text="Annuler" 
                            BackgroundColor="#9E9E9E" 
                            TextColor="White" 
                            Padding="25,12" 
                            CornerRadius="8" 
                            Clicked="OnCancelClicked"/>
                    <Button x:Name="SaveButton"
                            Grid.Column="2" 
                            Text="✓ Enregistrer" 
                            BackgroundColor="#4CAF50" 
                            TextColor="White" 
                            Padding="25,12" 
                            CornerRadius="8" 
                            FontAttributes="Bold" 
                            Clicked="OnSaveClicked"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>
