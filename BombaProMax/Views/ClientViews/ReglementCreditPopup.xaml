<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:sys="clr-namespace:System;assembly=netstandard"
               x:Class="BombaProMax.Views.ClientViews.ReglementCreditPopup"
               Color="Transparent">

    <Border BackgroundColor="#F5F5F5" Padding="0" WidthRequest="550" HeightRequest="650" StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="12"/>
        </Border.StrokeShape>
        
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- ========================================= -->
            <!-- HEADER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="0" BackgroundColor="#4CAF50" Padding="20,18" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label x:Name="HeaderLabel"
                               Text="💵 Nouveau Règlement" 
                               FontSize="20" 
                               FontAttributes="Bold" 
                               TextColor="White"/>
                        <Label Text="Enregistrer un paiement client" 
                               FontSize="12" 
                               TextColor="#C8E6C9"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" 
                            Text="✕" 
                            BackgroundColor="#388E3C" 
                            TextColor="White" 
                            FontSize="16" 
                            WidthRequest="36" 
                            HeightRequest="36" 
                            CornerRadius="18" 
                            Clicked="OnCancelClicked"/>
                </Grid>
            </Border>

            <!-- ========================================= -->
            <!-- CONTENT                                   -->
            <!-- ========================================= -->
            <ScrollView Grid.Row="1" Padding="20,15">
                <VerticalStackLayout Spacing="15">
                    
                    <!-- Client Info Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Label Text="👤" FontSize="28" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Client" FontSize="11" TextColor="#666"/>
                                <Label x:Name="ClientNameLabel"
                                       Text="Nom du client" 
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#2E7D32"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="2">
                                <Label Text="Balance actuelle" FontSize="11" TextColor="#666" HorizontalTextAlignment="End"/>
                                <Label x:Name="BalanceLabel"
                                       Text="0.00 MAD" 
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#F44336"
                                       HorizontalTextAlignment="End"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Date & Montant Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="INFORMATIONS DU RÈGLEMENT" FontSize="11" FontAttributes="Bold" TextColor="#4CAF50"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                                <VerticalStackLayout Grid.Column="0" Spacing="5">
                                    <Label Text="📅 Date du Règlement *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <DatePicker x:Name="DateReglementPicker"
                                                FontSize="14"
                                                MaximumDate="{x:Static sys:DateTime.Today}"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="5">
                                    <Label Text="💰 Montant Payé (MAD) *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="MontantEntry"
                                           Placeholder="0.00"
                                           Keyboard="Numeric"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#2E7D32"
                                           HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Mode de Paiement Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="MODE DE PAIEMENT" FontSize="11" FontAttributes="Bold" TextColor="#4CAF50"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                                <VerticalStackLayout Grid.Column="0" Spacing="5">
                                    <Label Text="💳 Mode de Paiement *" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Picker x:Name="ModePaiementPicker"
                                            Title="Sélectionner un mode"
                                            FontSize="14"
                                            ItemDisplayBinding="{Binding Nom}"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="5">
                                    <Label Text="🔢 Référence Transaction" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                                    <Entry x:Name="ReferenceEntry"
                                           Placeholder="Ex: CHQ-12345, VIR-001..."
                                           FontSize="14"/>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Remarques Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="5">
                            <Label Text="📝 Remarques (optionnel)" FontSize="11" FontAttributes="Bold" TextColor="#666"/>
                            <Editor x:Name="RemarquesEditor"
                                    Placeholder="Notes ou commentaires..."
                                    HeightRequest="70"
                                    FontSize="14"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Validator Info Card -->
                    <Border BackgroundColor="#E3F2FD" Padding="12" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="✓" FontSize="18" TextColor="#1976D2" VerticalOptions="Center"/>
                            <VerticalStackLayout>
                                <Label Text="Validé par" FontSize="11" TextColor="#666"/>
                                <Label x:Name="ValidateurLabel"
                                       Text="Utilisateur actuel" 
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#1976D2"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ========================================= -->
            <!-- FOOTER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="2" BackgroundColor="White" Padding="20,15" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,-2" Radius="6" Opacity="0.06"/>
                </Border.Shadow>
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                    <Label x:Name="ErrorLabel" 
                           TextColor="#F44336" 
                           FontSize="12" 
                           IsVisible="False" 
                           VerticalOptions="Center"/>
                    <Button Grid.Column="1" 
                            Text="Annuler" 
                            BackgroundColor="#9E9E9E" 
                            TextColor="White" 
                            Padding="25,12" 
                            CornerRadius="8" 
                            Clicked="OnCancelClicked"/>
                    <Button x:Name="SaveButton"
                            Grid.Column="2" 
                            Text="✓ Enregistrer" 
                            BackgroundColor="#4CAF50" 
                            TextColor="White" 
                            Padding="25,12" 
                            CornerRadius="8" 
                            FontAttributes="Bold" 
                            Clicked="OnSaveClicked"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>
