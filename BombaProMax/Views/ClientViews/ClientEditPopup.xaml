<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.ClientViews.ClientEditPopup">

    <Border BackgroundColor="White"       
           Padding="20"
           WidthRequest="550">
        <ScrollView>
            <VerticalStackLayout Spacing="15">
                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="✏️ Modifier le client" 
                           FontSize="20" 
                           FontAttributes="Bold"
                           TextColor="#2C3E50"/>
                    <Button Grid.Column="1" 
                            Text="✕" 
                            BackgroundColor="Transparent"
                            TextColor="#666"
                            FontSize="20"
                            Clicked="OnCancelClicked"/>
                </Grid>

                <BoxView Color="#E0E0E0" HeightRequest="1"/>

                <!-- Client Info Badge -->
                <Border BackgroundColor="#E3F2FD" 
                       Padding="12"
                       StrokeShape="RoundRectangle 8">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" 
                               Text="👤" 
                               FontSize="24"
                               Margin="0,0,10,0"/>
                        <VerticalStackLayout Grid.Column="1">
                            <Label x:Name="ClientBadgeLabel" 
                                   FontAttributes="Bold"
                                   TextColor="#1976D2"
                                   FontSize="16"/>
                            <Label x:Name="ClientNumberLabel" 
                                   TextColor="#666"
                                   FontSize="12"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Edit Form -->
                <VerticalStackLayout Spacing="15">
                    <!-- Numero Client Field (Read-only) -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Numéro Client" 
                               FontAttributes="Bold" 
                               TextColor="#666"
                               FontSize="14"/>
                        <Entry Text="{Binding NumeroClient}"
                               IsReadOnly="True"
                               BackgroundColor="#F0F0F0"
                               TextColor="#666"/>
                    </VerticalStackLayout>

                    <!-- Name Field -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Nom du client *" 
                               FontAttributes="Bold" 
                               TextColor="#666"
                               FontSize="14"/>
                        <Entry Text="{Binding Nom}"
                               Placeholder="Entrez le nom complet"
                               BackgroundColor="#F8F8F8"
                               TextColor="#333"
                               PlaceholderColor="#999"/>
                    </VerticalStackLayout>

                    <!-- Contact Field -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Contact (Téléphone) *" 
                               FontAttributes="Bold" 
                               TextColor="#666"
                               FontSize="14"/>
                        <Entry Text="{Binding Contact}"
                               Placeholder="Ex: +212 6XX XXX XXX"
                               Keyboard="Telephone"
                               BackgroundColor="#F8F8F8"
                               TextColor="#333"
                               PlaceholderColor="#999"/>
                    </VerticalStackLayout>

                    <!-- CIN Field -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="CIN *" 
                               FontAttributes="Bold" 
                               TextColor="#666"
                               FontSize="14"/>
                        <Entry Text="{Binding CIN}"
                               Placeholder="Carte d'identité nationale"
                               BackgroundColor="#F8F8F8"
                               TextColor="#333"
                               PlaceholderColor="#999"/>
                    </VerticalStackLayout>

                    <!-- Company Name Field -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Nom de la société *" 
                               FontAttributes="Bold" 
                               TextColor="#666"
                               FontSize="14"/>
                        <Entry Text="{Binding NomSociete}"
                               Placeholder="Nom de l'entreprise"
                               BackgroundColor="#F8F8F8"
                               TextColor="#333"
                               PlaceholderColor="#999"/>
                    </VerticalStackLayout>

                    <!-- Transaction Summary -->
                    <Border BackgroundColor="#F5F5F5" 
                           Padding="15"
                           StrokeShape="RoundRectangle 8">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8">
                            <Label Grid.Row="0" Grid.ColumnSpan="2" 
                                   Text="📊 Résumé des transactions" 
                                   FontAttributes="Bold" 
                                   TextColor="#333"
                                   FontSize="14"
                                   Margin="0,0,0,8"/>

                            <Label Grid.Row="1" Grid.Column="0" 
                                   Text="Factures:" 
                                   TextColor="#666"/>
                            <Label Grid.Row="1" Grid.Column="1" 
                                   Text="{Binding FacturesCount}" 
                                   TextColor="#1976D2" 
                                   FontAttributes="Bold"/>

                            <Label Grid.Row="2" Grid.Column="0" 
                                   Text="Crédits en cours:" 
                                   TextColor="#666"/>
                            <Label Grid.Row="2" Grid.Column="1" 
                                   Text="{Binding CreditsCount}" 
                                   TextColor="#FF9800" 
                                   FontAttributes="Bold"/>
                        </Grid>
                    </Border>

                    <!-- Error Message -->
                    <Label x:Name="ErrorLabel"
                           TextColor="#F44336"
                           FontSize="14"
                           IsVisible="False"
                           HorizontalTextAlignment="Center"/>

                    <!-- Action Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,0">
                        <Button Grid.Column="0"
                                Text="Annuler" 
                                BackgroundColor="#9E9E9E"
                                TextColor="White"
                                CornerRadius="8"
                                Clicked="OnCancelClicked"/>

                        <Button Grid.Column="1"
                                Text="💾 Enregistrer les modifications" 
                                BackgroundColor="#FF9800"
                                TextColor="White"
                                CornerRadius="8"
                                FontAttributes="Bold"
                                Clicked="OnSaveClicked"/>
                    </Grid>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Border>
</toolkit:Popup>