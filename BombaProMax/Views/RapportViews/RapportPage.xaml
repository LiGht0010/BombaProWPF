<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BombaProMax.ViewModels"
             xmlns:models="clr-namespace:BombaProMax.Models"
             xmlns:styles="clr-namespace:BombaProMax.Styles"
             x:Class="BombaProMax.Views.RapportViews.RapportPage"
             x:DataType="vm:RapportViewModel"
             Title="Rapports"
             BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <styles:RapportStyles/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView Padding="25,20">
        <VerticalStackLayout Spacing="20">

            <!-- HEADER -->
            <Border BackgroundColor="#1976D2" Padding="25,18" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Rapports" FontSize="22" FontAttributes="Bold" TextColor="White"/>
                        <Label Text="{Binding PeriodeLabel, StringFormat='Periode: {0}'}" 
                               FontSize="13" TextColor="#B3E5FC"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" 
                            Text="Imprimer PDF" 
                            BackgroundColor="#2E7D32" 
                            TextColor="White"
                            FontSize="13"
                            FontAttributes="Bold"
                            Padding="16,10"
                            CornerRadius="8"
                            Command="{Binding PrintRapportCommand}"/>
                </Grid>
            </Border>

            <!-- FILTER SECTION -->
            <Border BackgroundColor="White" Padding="20" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                </Border.Shadow>
                <Grid ColumnDefinitions="*,*,*,Auto,Auto,Auto" ColumnSpacing="16">
                    <!-- Mois -->
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Mois:" FontSize="12" TextColor="#666"/>
                        <Picker x:Name="MoisPicker"
                                ItemsSource="{Binding MoisNomsAvecVide}"
                                SelectedIndex="{Binding SelectedMoisIndex}"
                                BackgroundColor="#F8F9FA"
                                SelectedIndexChanged="OnMoisPickerSelectedIndexChanged"/>
                    </VerticalStackLayout>
                    <!-- Annee -->
                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="Annee:" FontSize="12" TextColor="#666"/>
                        <Picker x:Name="AnneePicker"
                                ItemsSource="{Binding AnneeList}"
                                SelectedItem="{Binding SelectedAnnee}"
                                BackgroundColor="#F8F9FA"
                                SelectedIndexChanged="OnAnneePickerSelectedIndexChanged">
                            <Picker.ItemDisplayBinding>
                                <Binding StringFormat="{}{0}" FallbackValue="-- Tous --"/>
                            </Picker.ItemDisplayBinding>
                        </Picker>
                    </VerticalStackLayout>
                    <!-- Date Specifique -->
                    <VerticalStackLayout Grid.Column="2">
                        <Label Text="Ou Date Specifique:" FontSize="12" TextColor="#666"/>
                        <DatePicker x:Name="DateSpecifiquePicker"
                                    BackgroundColor="#F8F9FA"
                                    DateSelected="OnDateSpecifiqueSelected"/>
                    </VerticalStackLayout>
                    <!-- Filtrer -->
                    <Button Grid.Column="3"
                            Text="Filtrer"
                            BackgroundColor="#1976D2"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="13"
                            Padding="16,10"
                            CornerRadius="8"
                            VerticalOptions="End"
                            Command="{Binding ApplyFilterCommand}"/>
                    <!-- Effacer -->
                    <Button Grid.Column="4"
                            Text="Effacer"
                            BackgroundColor="#F8F9FA"
                            TextColor="#666"
                            FontSize="13"
                            Padding="16,10"
                            CornerRadius="8"
                            VerticalOptions="End"
                            Command="{Binding ClearFilterCommand}"/>
                    <!-- Rafraichir -->
                    <Button Grid.Column="5"
                            Text="Rafraichir"
                            BackgroundColor="#FF9800"
                            TextColor="White"
                            FontSize="13"
                            Padding="16,10"
                            CornerRadius="8"
                            VerticalOptions="End"
                            Command="{Binding LoadRapportsCommand}"/>
                </Grid>
            </Border>

            <!-- LOADING -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="#1976D2"
                               HeightRequest="50"/>

            <!-- TABS -->
            <Border x:Name="TabsContainer" BackgroundColor="White" Padding="0" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="0">
                    
                    <!-- Tab Headers -->
                    <Grid ColumnDefinitions="*,*,*" BackgroundColor="#1976D2">
                        <Button x:Name="VentesTabButton"
                                Grid.Column="0"
                                Text="Ventes"
                                BackgroundColor="#1976D2"
                                TextColor="White"
                                FontAttributes="Bold"
                                FontSize="14"
                                CornerRadius="0"
                                Padding="20,14"
                                Clicked="OnVentesTabClicked"/>
                        <Button x:Name="DepensesTabButton"
                                Grid.Column="1"
                                Text="Depenses"
                                BackgroundColor="#1565C0"
                                TextColor="#B3E5FC"
                                FontSize="14"
                                CornerRadius="0"
                                Padding="20,14"
                                Clicked="OnDepensesTabClicked"/>
                        <Button x:Name="StockTabButton"
                                Grid.Column="2"
                                Text="Stock"
                                BackgroundColor="#1565C0"
                                TextColor="#B3E5FC"
                                FontSize="14"
                                CornerRadius="0"
                                Padding="20,14"
                                Clicked="OnStockTabClicked"/>
                    </Grid>

                    <!-- TAB 1: VENTES -->
                    <VerticalStackLayout x:Name="VentesTab" Spacing="20" Padding="20">
                        
                        <!-- Ventes Summary -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="20">
                            <Border Grid.Column="0" BackgroundColor="#E8F5E9" Padding="16" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Total Ventes" FontSize="12" TextColor="#666"/>
                                    <Label Text="{Binding TotalVentes, StringFormat='{0:N2} MAD'}" 
                                           FontSize="20" FontAttributes="Bold" TextColor="#2E7D32"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" BackgroundColor="#E3F2FD" Padding="16" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Carburant" FontSize="12" TextColor="#666"/>
                                    <Label Text="{Binding TotalVentesCarburant, StringFormat='{0:N2} MAD'}" 
                                           FontSize="18" FontAttributes="Bold" TextColor="#1976D2"/>
                                    <Label Text="{Binding TotalQuantiteCarburant, StringFormat='{0:N0} L'}" 
                                           FontSize="11" TextColor="#999"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="2" BackgroundColor="#FFF3E0" Padding="16" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Lub/Articles" FontSize="12" TextColor="#666"/>
                                    <Label Text="{Binding TotalVentesLubArticles, StringFormat='{0:N2} MAD'}" 
                                           FontSize="18" FontAttributes="Bold" TextColor="#E65100"/>
                                    <Label Text="{Binding TotalQuantiteLubArticles, StringFormat='{0} unites'}" 
                                           FontSize="11" TextColor="#999"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <!-- Ventes Carburant Table -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Ventes Carburant par Produit" FontSize="14" FontAttributes="Bold" TextColor="#333"/>
                            <Grid ColumnDefinitions="2*,*,*,*" Padding="12,8" BackgroundColor="#F8F9FA">
                                <Label Grid.Column="0" Text="PRODUIT" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Column="1" Text="QUANTITE" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                                <Label Grid.Column="2" Text="MONTANT" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                                <Label Grid.Column="3" Text="PERIODES" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                            </Grid>
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding VentesCarburantParProduit}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:RapportVenteCarburantProduitDto">
                                        <Grid ColumnDefinitions="2*,*,*,*" Padding="12,10">
                                            <Label Grid.Column="0" Text="{Binding ProduitNom}" FontSize="13" TextColor="#333"/>
                                            <Label Grid.Column="1" Text="{Binding TotalQuantite, StringFormat='{0:N0} L'}" FontSize="13" TextColor="#1976D2" HorizontalTextAlignment="End"/>
                                            <Label Grid.Column="2" Text="{Binding TotalMontant, StringFormat='{0:N2}'}" FontSize="13" FontAttributes="Bold" TextColor="#333" HorizontalTextAlignment="End"/>
                                            <Label Grid.Column="3" Text="{Binding NombrePeriodes}" FontSize="13" TextColor="#999" HorizontalTextAlignment="End"/>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                                <BindableLayout.EmptyView>
                                    <Label Text="Aucune vente carburant" TextColor="#999" Padding="20" HorizontalTextAlignment="Center"/>
                                </BindableLayout.EmptyView>
                            </VerticalStackLayout>
                        </VerticalStackLayout>

                        <!-- Ventes Lub/Articles Table -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Ventes Lubrifiants et Articles par Produit" FontSize="14" FontAttributes="Bold" TextColor="#333"/>
                            <Grid ColumnDefinitions="2*,*,*,*" Padding="12,8" BackgroundColor="#F8F9FA">
                                <Label Grid.Column="0" Text="PRODUIT" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Column="1" Text="QUANTITE" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                                <Label Grid.Column="2" Text="MONTANT" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                                <Label Grid.Column="3" Text="VENTES" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                            </Grid>
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding VentesLubArticlesParProduit}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:RapportVenteLubArticleProduitDto">
                                        <Grid ColumnDefinitions="2*,*,*,*" Padding="12,10">
                                            <Label Grid.Column="0" Text="{Binding ProduitNom}" FontSize="13" TextColor="#333"/>
                                            <Label Grid.Column="1" Text="{Binding TotalQuantite}" FontSize="13" TextColor="#E65100" HorizontalTextAlignment="End"/>
                                            <Label Grid.Column="2" Text="{Binding TotalMontant, StringFormat='{0:N2}'}" FontSize="13" FontAttributes="Bold" TextColor="#333" HorizontalTextAlignment="End"/>
                                            <Label Grid.Column="3" Text="{Binding NombreVentes}" FontSize="13" TextColor="#999" HorizontalTextAlignment="End"/>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                                <BindableLayout.EmptyView>
                                    <Label Text="Aucune vente" TextColor="#999" Padding="20" HorizontalTextAlignment="Center"/>
                                </BindableLayout.EmptyView>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- TAB 2: DEPENSES -->
                    <VerticalStackLayout x:Name="DepensesTab" Spacing="20" Padding="20" IsVisible="False">
                        
                        <!-- Depenses Summary -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                            <Border Grid.Column="0" BackgroundColor="#FFEBEE" Padding="16" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Total Depenses" FontSize="12" TextColor="#666"/>
                                    <Label Text="{Binding TotalDepenses, StringFormat='{0:N2} MAD'}" 
                                           FontSize="26" FontAttributes="Bold" TextColor="#C62828"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" BackgroundColor="#F5F5F5" Padding="16" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Nombre de Depenses" FontSize="12" TextColor="#666"/>
                                    <Label Text="{Binding NombreDepenses}" 
                                           FontSize="26" FontAttributes="Bold" TextColor="#333"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <!-- Depenses par Categorie -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Depenses par Categorie" FontSize="14" FontAttributes="Bold" TextColor="#333"/>
                            <FlexLayout Wrap="Wrap" JustifyContent="Start" BindableLayout.ItemsSource="{Binding DepensesParCategorie}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:RapportDepenseCategorieDto">
                                        <Border BackgroundColor="#FFF8F8" Padding="16" Margin="4" MinimumWidthRequest="150" StrokeThickness="1" Stroke="#FFCDD2">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="10"/>
                                            </Border.StrokeShape>
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="{Binding CategorieNom}" FontSize="12" TextColor="#666"/>
                                                <Label Text="{Binding TotalMontant, StringFormat='{0:N2} MAD'}" FontSize="16" FontAttributes="Bold" TextColor="#C62828"/>
                                                <Label Text="{Binding NombreDepenses, StringFormat='{0} depenses'}" FontSize="10" TextColor="#999"/>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                        </VerticalStackLayout>

                        <!-- Depenses Details Table -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Liste des Depenses" FontSize="14" FontAttributes="Bold" TextColor="#333"/>
                            <Grid ColumnDefinitions="1.8*,0.8*,1.2*,0.8*,2*" ColumnSpacing="35" Padding="12,8" BackgroundColor="#F8F9FA">
                                <Label Grid.Column="0" Text="NUMERO" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Column="1" Text="DATE" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Column="2" Text="CATEGORIE" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Column="3" Text="MONTANT" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                                <Label Grid.Column="4" Text="DESCRIPTION" FontSize="10" FontAttributes="Bold" TextColor="#666" Margin="20,0,0,0"/>
                            </Grid>
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding DepensesDetails}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:RapportDepenseDetailDto">
                                        <VerticalStackLayout>
                                            <Grid ColumnDefinitions="1.8*,0.8*,1.2*,0.8*,2*" ColumnSpacing="36" Padding="12,10">
                                                <Label Grid.Column="0" Text="{Binding Numero}" FontSize="12" TextColor="#1976D2"/>
                                                <Label Grid.Column="1" Text="{Binding DateDisplay}" FontSize="12" TextColor="#666"/>
                                                <Label Grid.Column="2" Text="{Binding Categorie}" FontSize="12" TextColor="#333"/>
                                                <Label Grid.Column="3" Text="{Binding Montant, StringFormat='{0:N2}'}" FontSize="12" FontAttributes="Bold" TextColor="#C62828" HorizontalTextAlignment="End"/>
                                                <Label Grid.Column="4" Text="{Binding Description}" FontSize="12" TextColor="#999" LineBreakMode="TailTruncation" Margin="20,0,0,0"/>
                                            </Grid>
                                            <BoxView HeightRequest="1" Color="#E0E0E0"/>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                                <BindableLayout.EmptyView>
                                    <Label Text="Aucune depense" TextColor="#999" Padding="20" HorizontalTextAlignment="Center"/>
                                </BindableLayout.EmptyView>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- TAB 3: STOCK -->
                    <VerticalStackLayout x:Name="StockTab" Spacing="20" Padding="20" IsVisible="False">
                        
                        <!-- Stock Summary -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="20">
                            <Border Grid.Column="0" BackgroundColor="#E3F2FD" Padding="16" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Stock Carburant" FontSize="12" TextColor="#666"/>
                                    <Label Text="{Binding TotalStockCarburantLitres, StringFormat='{0:N0} L'}" 
                                           FontSize="20" FontAttributes="Bold" TextColor="#1976D2"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" BackgroundColor="#F3E5F5" Padding="16" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Stock Produits" FontSize="12" TextColor="#666"/>
                                    <Label Text="{Binding TotalStockProduits, StringFormat='{0} unites'}" 
                                           FontSize="20" FontAttributes="Bold" TextColor="#7B1FA2"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="2" BackgroundColor="#FFF3E0" Padding="16" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Achats Periode" FontSize="12" TextColor="#666"/>
                                    <Label Text="{Binding TotalAchatsPeriode, StringFormat='{0:N2} MAD'}" 
                                           FontSize="20" FontAttributes="Bold" TextColor="#E65100"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <!-- ═══════════════════════════════════════════════════════════════ -->
                        <!-- JAUGEAGE vs VENTES ANALYSIS -->
                        <!-- ═══════════════════════════════════════════════════════════════ -->
                        <Border BackgroundColor="#ECEFF1" Padding="16" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="12">
                                <!-- Header -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="Analyse Jaugeage vs Ventes" FontSize="16" FontAttributes="Bold" TextColor="#37474F"/>
                                        <Label Text="{Binding JaugeagePeriodeAnalyse, StringFormat='Periode: {0}'}" 
                                               FontSize="11" TextColor="#78909C"
                                               IsVisible="{Binding HasJaugeageData}"/>
                                    </VerticalStackLayout>
                                    <Border Grid.Column="1" BackgroundColor="#546E7A" Padding="8,4" StrokeThickness="0"
                                            IsVisible="{Binding HasJaugeageData}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="4"/>
                                        </Border.StrokeShape>
                                        <Label Text="Detection Remise au Cuve" FontSize="10" TextColor="White"/>
                                    </Border>
                                </Grid>

                                <!-- Jaugeage Info (if has data) -->
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="15" IsVisible="{Binding HasJaugeageData}">
                                    <Border Grid.Column="0" BackgroundColor="White" Padding="12" StrokeThickness="1" Stroke="#CFD8DC">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="6"/>
                                        </Border.StrokeShape>
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="Jaugeage Precedent (n-1)" FontSize="10" TextColor="#78909C"/>
                                            <Label Text="{Binding JaugeagePrecedentInfo}" FontSize="12" FontAttributes="Bold" TextColor="#455A64"/>
                                        </VerticalStackLayout>
                                    </Border>
                                    <Border Grid.Column="1" BackgroundColor="White" Padding="12" StrokeThickness="1" Stroke="#CFD8DC">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="6"/>
                                        </Border.StrokeShape>
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="Jaugeage Actuel (n)" FontSize="10" TextColor="#78909C"/>
                                            <Label Text="{Binding JaugeageActuelInfo}" FontSize="12" FontAttributes="Bold" TextColor="#455A64"/>
                                        </VerticalStackLayout>
                                    </Border>
                                </Grid>

                                <!-- No Data Message - Show when HasJaugeageData is false -->
                                <Label x:Name="NoJaugeageDataLabel"
                                       Text="{Binding JaugeageAnalyseMessage}" 
                                       TextColor="#78909C" 
                                       FontSize="13" 
                                       HorizontalTextAlignment="Center"
                                       Padding="20"
                                       IsVisible="{Binding HasNoJaugeageData}"/>

                                <!-- Comparison Table (if has data) -->
                                <VerticalStackLayout Spacing="0" IsVisible="{Binding HasJaugeageData}">
                                    <!-- Table Header -->
                                    <Grid ColumnDefinitions="1.2*,1.2*,*,*,*,*,*,1.2*" ColumnSpacing="8" Padding="12,10" BackgroundColor="#546E7A">
                                        <Label Grid.Column="0" Text="RESERVOIR" FontSize="9" FontAttributes="Bold" TextColor="White"/>
                                        <Label Grid.Column="1" Text="PRODUIT" FontSize="9" FontAttributes="Bold" TextColor="White"/>
                                        <Label Grid.Column="2" Text="VOL. (n-1)" FontSize="9" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="End"/>
                                        <Label Grid.Column="3" Text="VOL. (n)" FontSize="9" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="End"/>
                                        <Label Grid.Column="4" Text="CONSOMME" FontSize="9" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="End"/>
                                        <Label Grid.Column="5" Text="VENDU" FontSize="9" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="End"/>
                                        <Label Grid.Column="6" Text="ECART" FontSize="9" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="End"/>
                                        <Label Grid.Column="7" Text="STATUT" FontSize="9" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"/>
                                    </Grid>

                                    <!-- Table Body -->
                                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding JaugeageComparaisons}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="models:RapportJaugeageReservoirComparisonDto">
                                                <Grid ColumnDefinitions="1.2*,1.2*,*,*,*,*,*,1.2*" ColumnSpacing="8" Padding="12,10" BackgroundColor="White">
                                                    <Label Grid.Column="0" Text="{Binding ReservoirNumero}" FontSize="12" TextColor="#1976D2" FontAttributes="Bold" VerticalTextAlignment="Center"/>
                                                    <Label Grid.Column="1" Text="{Binding ProduitNom}" FontSize="11" TextColor="#455A64" VerticalTextAlignment="Center" LineBreakMode="TailTruncation"/>
                                                    <Label Grid.Column="2" Text="{Binding VolumePrecedent, StringFormat='{0:N0}'}" FontSize="11" TextColor="#666" HorizontalTextAlignment="End" VerticalTextAlignment="Center"/>
                                                    <Label Grid.Column="3" Text="{Binding VolumeActuel, StringFormat='{0:N0}'}" FontSize="11" TextColor="#666" HorizontalTextAlignment="End" VerticalTextAlignment="Center"/>
                                                    <Label Grid.Column="4" Text="{Binding StockConsomme, StringFormat='{0:N0} L'}" FontSize="11" FontAttributes="Bold" TextColor="#37474F" HorizontalTextAlignment="End" VerticalTextAlignment="Center"/>
                                                    <Label Grid.Column="5" Text="{Binding QuantiteVendue, StringFormat='{0:N0} L'}" FontSize="11" TextColor="#1976D2" HorizontalTextAlignment="End" VerticalTextAlignment="Center"/>
                                                    <Label Grid.Column="6" Text="{Binding Ecart, StringFormat='{0:N0} L'}" FontSize="11" FontAttributes="Bold" TextColor="{Binding StatutColor}" HorizontalTextAlignment="End" VerticalTextAlignment="Center"/>
                                                    <Border Grid.Column="7" BackgroundColor="{Binding StatutBackgroundColor}" Padding="8,4" StrokeThickness="0" HorizontalOptions="Center" VerticalOptions="Center">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="4"/>
                                                        </Border.StrokeShape>
                                                        <Label Text="{Binding Statut}" FontSize="9" FontAttributes="Bold" TextColor="{Binding StatutColor}" HorizontalTextAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                        <BindableLayout.EmptyView>
                                            <Label Text="Aucune donnee de comparaison" TextColor="#78909C" Padding="20" HorizontalTextAlignment="Center"/>
                                        </BindableLayout.EmptyView>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>

                                <!-- Legend -->
                                <HorizontalStackLayout Spacing="20" HorizontalOptions="Center" IsVisible="{Binding HasJaugeageData}">
                                    <HorizontalStackLayout Spacing="5">
                                        <BoxView WidthRequest="12" HeightRequest="12" Color="#2E7D32" CornerRadius="2"/>
                                        <Label Text="Normal" FontSize="10" TextColor="#666"/>
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="5">
                                        <BoxView WidthRequest="12" HeightRequest="12" Color="#FF9800" CornerRadius="2"/>
                                        <Label Text="Remise au cuve" FontSize="10" TextColor="#666"/>
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="5">
                                        <BoxView WidthRequest="12" HeightRequest="12" Color="#C62828" CornerRadius="2"/>
                                        <Label Text="Manquant" FontSize="10" TextColor="#666"/>
                                    </HorizontalStackLayout>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Stock Carburant (Reservoirs) -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Stock Carburant (Reservoirs)" FontSize="14" FontAttributes="Bold" TextColor="#333"/>
                            <Grid ColumnDefinitions="1.5*,1.5*,*,*,*" Padding="12,8" BackgroundColor="#F8F9FA">
                                <Label Grid.Column="0" Text="RESERVOIR" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Column="1" Text="PRODUIT" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Column="2" Text="CAPACITE" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                                <Label Grid.Column="3" Text="NIVEAU" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                                <Label Grid.Column="4" Text="%" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                            </Grid>
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding StockCarburant}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:RapportStockReservoirDto">
                                        <Grid ColumnDefinitions="1.5*,1.5*,*,*,*" Padding="12,10">
                                            <Label Grid.Column="0" Text="{Binding ReservoirNumero}" FontSize="13" TextColor="#1976D2" FontAttributes="Bold"/>
                                            <Label Grid.Column="1" Text="{Binding ProduitNom}" FontSize="13" TextColor="#333"/>
                                            <Label Grid.Column="2" Text="{Binding Capacite, StringFormat='{0:N0} L'}" FontSize="13" TextColor="#999" HorizontalTextAlignment="End"/>
                                            <Label Grid.Column="3" Text="{Binding NiveauActuel, StringFormat='{0:N0} L'}" FontSize="13" FontAttributes="Bold" TextColor="#333" HorizontalTextAlignment="End"/>
                                            <Label Grid.Column="4" Text="{Binding PourcentageRemplissage, StringFormat='{0:N0}%'}" FontSize="13" TextColor="#2E7D32" HorizontalTextAlignment="End"/>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                                <BindableLayout.EmptyView>
                                    <Label Text="Aucun reservoir" TextColor="#999" Padding="20" HorizontalTextAlignment="Center"/>
                                </BindableLayout.EmptyView>
                            </VerticalStackLayout>
                        </VerticalStackLayout>

                        <!-- Stock Produits -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Stock Produits (Non-Carburant)" FontSize="14" FontAttributes="Bold" TextColor="#333"/>
                            <Grid ColumnDefinitions="2*,1.5*,*,*" Padding="12,8" BackgroundColor="#F8F9FA">
                                <Label Grid.Column="0" Text="PRODUIT" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Column="1" Text="CATEGORIE" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Column="2" Text="STOCK" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                                <Label Grid.Column="3" Text="MIN" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                            </Grid>
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding StockProduits}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:RapportStockProduitDto">
                                        <Grid ColumnDefinitions="2*,1.5*,*,*" Padding="12,10">
                                            <Label Grid.Column="0" Text="{Binding ProduitNom}" FontSize="13" TextColor="#333"/>
                                            <Label Grid.Column="1" Text="{Binding CategorieNom}" FontSize="12" TextColor="#999"/>
                                            <Label Grid.Column="2" Text="{Binding StockActuel}" FontSize="13" FontAttributes="Bold" TextColor="#333" HorizontalTextAlignment="End"/>
                                            <Label Grid.Column="3" Text="{Binding StockMinimum}" FontSize="12" TextColor="#999" HorizontalTextAlignment="End"/>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                                <BindableLayout.EmptyView>
                                    <Label Text="Aucun produit" TextColor="#999" Padding="20" HorizontalTextAlignment="Center"/>
                                </BindableLayout.EmptyView>
                            </VerticalStackLayout>
                        </VerticalStackLayout>

                        <!-- Achats Periode -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Achats de la Periode" FontSize="14" FontAttributes="Bold" TextColor="#333"/>
                            <Grid ColumnDefinitions="2*,*,*,*" Padding="12,8" BackgroundColor="#F8F9FA">
                                <Label Grid.Column="0" Text="PRODUIT" FontSize="10" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Column="1" Text="QUANTITE" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                                <Label Grid.Column="2" Text="MONTANT" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                                <Label Grid.Column="3" Text="ACHATS" FontSize="10" FontAttributes="Bold" TextColor="#666" HorizontalTextAlignment="End"/>
                            </Grid>
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding AchatsParProduit}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:RapportAchatProduitDto">
                                        <Grid ColumnDefinitions="2*,*,*,*" Padding="12,10">
                                            <Label Grid.Column="0" Text="{Binding ProduitNom}" FontSize="13" TextColor="#333"/>
                                            <Label Grid.Column="1" Text="{Binding TotalQuantite, StringFormat='{0:N0}'}" FontSize="13" TextColor="#E65100" HorizontalTextAlignment="End"/>
                                            <Label Grid.Column="2" Text="{Binding TotalMontant, StringFormat='{0:N2}'}" FontSize="13" FontAttributes="Bold" TextColor="#333" HorizontalTextAlignment="End"/>
                                            <Label Grid.Column="3" Text="{Binding NombreAchats}" FontSize="13" TextColor="#999" HorizontalTextAlignment="End"/>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                                <BindableLayout.EmptyView>
                                    <Label Text="Aucun achat" TextColor="#999" Padding="20" HorizontalTextAlignment="Center"/>
                                </BindableLayout.EmptyView>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
