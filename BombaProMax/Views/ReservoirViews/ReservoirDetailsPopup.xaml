<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BombaProMax.Views.ReservoirViews.ReservoirDetailsPopup"
               Color="Transparent">

    <Border BackgroundColor="#F5F5F5" Padding="0" WidthRequest="700" HeightRequest="800" StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="12"/>
        </Border.StrokeShape>
        
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- ========================================= -->
            <!-- HEADER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="0" BackgroundColor="#336860" Padding="20,18" StrokeThickness="0">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                    <Border Grid.Column="0"
                            BackgroundColor="White"
                            WidthRequest="50"
                            HeightRequest="50"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="25"/>
                        </Border.StrokeShape>
                        <Label Text="🛢️" 
                               FontSize="24"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                        <Label x:Name="ReservoirNumeroLabel"
                               FontSize="20" 
                               FontAttributes="Bold"
                               TextColor="White"/>
                        <Label x:Name="ReservoirProduitLabel"
                               FontSize="12"
                               TextColor="#A5D6A7"/>
                        <Label x:Name="ReservoirIdLabel"
                               FontSize="10"
                               TextColor="#A5D6A7"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="2" 
                            Text="✕" 
                            BackgroundColor="#2E5D56" 
                            TextColor="White" 
                            FontSize="16" 
                            WidthRequest="36" 
                            HeightRequest="36" 
                            CornerRadius="18" 
                            Clicked="OnCloseClicked"/>
                </Grid>
            </Border>

            <!-- ========================================= -->
            <!-- CONTENT                                   -->
            <!-- ========================================= -->
            <ScrollView Grid.Row="1" Padding="20,15">
                <VerticalStackLayout Spacing="15">
                    
                    <!-- Statistics Cards Row -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                        <!-- Capacity Card -->
                        <Border Grid.Column="0" BackgroundColor="White" Padding="15" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Label Text="📊" FontSize="26" HorizontalOptions="Center"/>
                                <Label x:Name="CapaciteLabel"
                                       Text="0.00 L"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       TextColor="#1565C0"/>
                                <Label Text="Capacité Totale"
                                       FontSize="11"
                                       HorizontalOptions="Center"
                                       TextColor="#666"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Current Level Card -->
                        <Border Grid.Column="1" BackgroundColor="White" Padding="15" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Label Text="⛽" FontSize="26" HorizontalOptions="Center"/>
                                <Label x:Name="NiveauLabel"
                                       Text="0.00 L"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       TextColor="#2E7D32"/>
                                <Label Text="Niveau Actuel"
                                       FontSize="11"
                                       HorizontalOptions="Center"
                                       TextColor="#666"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Available Space Card -->
                        <Border Grid.Column="2" BackgroundColor="White" Padding="15" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Label Text="📈" FontSize="26" HorizontalOptions="Center"/>
                                <Label x:Name="EspaceDisponibleLabel"
                                       Text="0.00 L"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       TextColor="#E65100"/>
                                <Label Text="Espace Disponible"
                                       FontSize="11"
                                       HorizontalOptions="Center"
                                       TextColor="#666"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Percentage Bar Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                                <Label Text="💧" FontSize="18"/>
                                <Label Text="Niveau de Remplissage:"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#2C3E50"/>
                                <Label x:Name="PercentageLabel"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#336860"/>
                            </HorizontalStackLayout>
                            <ProgressBar x:Name="FuelProgressBar"
                                        HeightRequest="16"
                                        ProgressColor="#27AE60"
                                        BackgroundColor="#E0E0E0"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Details Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="ℹ️ INFORMATIONS DÉTAILLÉES" FontSize="11" FontAttributes="Bold" TextColor="#336860"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" 
                                  ColumnDefinitions="150,*"
                                  RowSpacing="10">
                                <Label Grid.Row="0" Grid.Column="0" Text="Numéro:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="0" Grid.Column="1" x:Name="NumeroDetailLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="1" Grid.Column="0" Text="Type Carburant:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="1" Grid.Column="1" x:Name="ProduitDetailLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="2" Grid.Column="0" Text="Capacité:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="2" Grid.Column="1" x:Name="CapaciteDetailLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="3" Grid.Column="0" Text="Niveau Actuel:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="3" Grid.Column="1" x:Name="NiveauDetailLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="4" Grid.Column="0" Text="Espace Disponible:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="4" Grid.Column="1" x:Name="EspaceDetailLabel" FontSize="12" TextColor="#333"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Related Records Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="🔗 ENREGISTREMENTS LIÉS" FontSize="11" FontAttributes="Bold" TextColor="#336860"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <Grid RowDefinitions="Auto,Auto,Auto" 
                                  ColumnDefinitions="150,*"
                                  RowSpacing="10">
                                <Label Grid.Row="0" Grid.Column="0" Text="Pompes:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="0" Grid.Column="1" x:Name="PompesCountLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="1" Grid.Column="0" Text="Allocations:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="1" Grid.Column="1" x:Name="AllocationsCountLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="2" Grid.Column="0" Text="Jaugeages:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="2" Grid.Column="1" x:Name="JaugeagesCountLabel" FontSize="12" TextColor="#333"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Audit Info Card -->
                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="📅 INFORMATIONS D'AUDIT" FontSize="11" FontAttributes="Bold" TextColor="#336860"/>
                            <BoxView Color="#E0E0E0" HeightRequest="1"/>
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" 
                                  ColumnDefinitions="150,*"
                                  RowSpacing="10">
                                <Label Grid.Row="0" Grid.Column="0" Text="Créé le:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="0" Grid.Column="1" x:Name="DateCreationLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="1" Grid.Column="0" Text="Ajouté par:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="1" Grid.Column="1" x:Name="AjouteParLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="2" Grid.Column="0" Text="Modifié le:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="2" Grid.Column="1" x:Name="DateModificationLabel" FontSize="12" TextColor="#333"/>
                                <Label Grid.Row="3" Grid.Column="0" Text="Modifié par:" FontSize="12" FontAttributes="Bold" TextColor="#666"/>
                                <Label Grid.Row="3" Grid.Column="1" x:Name="ModifieParLabel" FontSize="12" TextColor="#333"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ========================================= -->
            <!-- FOOTER                                    -->
            <!-- ========================================= -->
            <Border Grid.Row="2" BackgroundColor="White" Padding="20,15" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,-2" Radius="6" Opacity="0.06"/>
                </Border.Shadow>
                <Button Text="✓ Fermer" 
                        BackgroundColor="#336860" 
                        TextColor="White" 
                        Padding="30,12" 
                        CornerRadius="8"
                        FontAttributes="Bold"
                        HorizontalOptions="End"
                        Clicked="OnCloseClicked"/>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>
