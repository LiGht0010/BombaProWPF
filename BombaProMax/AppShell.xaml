<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BombaProMax.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:BombaProMax"
    xmlns:views="clr-namespace:BombaProMax.Views"
    xmlns:user="clr-namespace:BombaProMax.Views.User"
    xmlns:fournisseur="clr-namespace:BombaProMax.Views.FournisseurViews"
    xmlns:client="clr-namespace:BombaProMax.Views.ClientViews"
    xmlns:produit="clr-namespace:BombaProMax.Views.ProduitViews"
    xmlns:chauffeur="clr-namespace:BombaProMax.Views.ChauffeurViews"
    xmlns:camion="clr-namespace:BombaProMax.Views.CamionViews"
    xmlns:citerne="clr-namespace:BombaProMax.Views.CiterneViews"
    xmlns:Employe="clr-namespace:BombaProMax.Views.EmployeViews"
    xmlns:Reservoir="clr-namespace:BombaProMax.Views.ReservoirViews"
    xmlns:Pompe="clr-namespace:BombaProMax.Views.PompeViews"
    xmlns:achat="clr-namespace:BombaProMax.Views.AchatViews"
    xmlns:venteLub="clr-namespace:BombaProMax.Views.VenteLubEtArticles"
    xmlns:depense="clr-namespace:BombaProMax.Views.DepenseViews"
    xmlns:facture="clr-namespace:BombaProMax.Views.FactureViews"
    xmlns:dashboard="clr-namespace:BombaProMax.Views.DashboardViews"
    xmlns:rapport="clr-namespace:BombaProMax.Views.RapportViews"
    xmlns:service="clr-namespace:BombaProMax.Views.ServiceViews"
    xmlns:venteService="clr-namespace:BombaProMax.Views.VenteServiceViews"
    xmlns:caisse="clr-namespace:BombaProMax.Views.CaisseViews"
    FlyoutBackgroundColor="#FFFFFF"
    BackgroundColor="#F8FAFC"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    FlyoutWidth="300"
    FlyoutBehavior="Flyout"
    Navigated="OnShellNavigated"
    Navigating="OnShellNavigating">

    <!-- Removed BackButtonBehavior -->

    <Shell.FlyoutHeaderTemplate>
        <DataTemplate>
            <Grid HeightRequest="180" Padding="24,32,24,24">
                <Grid.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Color="#1F4E45" Offset="0.0" />
                        <GradientStop Color="#2D6A5F" Offset="1.0" />
                    </LinearGradientBrush>
                </Grid.Background>
                <VerticalStackLayout VerticalOptions="Start" Spacing="12">
                    <!-- Logo Container - Semi-transparent white -->
                    <Border StrokeThickness="0.5"
                            Stroke="#FFFFFF"
                            BackgroundColor="#2D6A5F"
                            WidthRequest="56"
                            HeightRequest="56"
                            HorizontalOptions="Start">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <Label Text="BP" 
                               FontSize="22"
                               FontFamily="Sans-Serif"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center"/>
                    </Border>
                    <!-- App Title -->
                    <VerticalStackLayout Spacing="2">
                        <Label Text="BombaProMax" 
                               TextColor="White" 
                               FontSize="22" 
                               FontAttributes="Bold"/>
                        <Label Text="Gestion Station Service" 
                               TextColor="#80CBC4" 
                               FontSize="13"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Grid>
        </DataTemplate>
    </Shell.FlyoutHeaderTemplate>

    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid Padding="24,12" BackgroundColor="Transparent">
                <Label Text="{Binding Title}" 
                       TextColor="#334155"
                       FontSize="15"
                       VerticalOptions="Center"/>
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <Shell.MenuItemTemplate>
        <DataTemplate>
            <Frame  Margin="12,5"
                    Padding="40,20"
                    BackgroundColor="#F1F5F9"
                    BorderColor="#E2E8F0"
                    CornerRadius="30"
                    HasShadow="False">
                
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Text="{Binding Text}" 
                           TextColor="#475569"
                           FontSize="15"
                           FontAttributes="Bold"
                           VerticalOptions="Center"/>
                    <Ellipse Grid.Column="1"
                             WidthRequest="10"
                             HeightRequest="10"
                             Fill="#94A3B8"
                             VerticalOptions="Center"/>
                </Grid>

            </Frame>
        </DataTemplate>
    </Shell.MenuItemTemplate>

    <!-- Tenant Selection Page (Hidden from Flyout, shown first) -->
    <FlyoutItem FlyoutItemIsVisible="False">
        <ShellContent x:Name="TenantSelectionShellContent" Route="TenantSelectionPage"/>
    </FlyoutItem>

    <!-- Login Page (Hidden from Flyout) -->
    <FlyoutItem FlyoutItemIsVisible="False">
        <ShellContent x:Name="LoginShellContent" Route="LoginPage"/>
    </FlyoutItem>

    <!-- ════════════════════════════════════════════════════════════ -->
    <!-- OPÉRATIONS DE JOURNÉE -->
    <!-- ════════════════════════════════════════════════════════════ -->
    <MenuItem Text="Démarrer la journée" Clicked="OnStartJourneeClicked"/>

    <!-- ════════════════════════════════════════════════════════════ -->
    <!-- ADMINISTRATION GÉNÉRALE -->
    <!-- ════════════════════════════════════════════════════════════ -->
    <FlyoutItem Title="ADMINISTRATION GÉNÉRALE" FlyoutDisplayOptions="AsMultipleItems">
        <ShellContent x:Name="HomeShellContent" Title="Accueil" Route="HomePage"/>
        <ShellContent x:Name="DashboardShellContent" Title="Tableau de Bord" Route="DashboardPage"/>
        <ShellContent x:Name="RapportShellContent" Title="Rapports" Route="RapportPage"/>
        <ShellContent x:Name="UsersShellContent" Title="Utilisateurs" Route="User"/>
    </FlyoutItem>

    <!-- ════════════════════════════════════════════════════════════ -->
    <!-- ACTIVITÉ COMMERCIALE -->
    <!-- ════════════════════════════════════════════════════════════ -->
    <FlyoutItem Title="ACTIVITÉ COMMERCIALE" FlyoutDisplayOptions="AsMultipleItems">
        <ShellContent x:Name="ClientShellContent" Title="Clients" Route="ClientPage"/>
        <ShellContent x:Name="AchatShellContent" Title="Achats" Route="AchatPage"/>
        <ShellContent x:Name="PeriodeShellContent" Title="Périodes de Vente" Route="PeriodePage"/>
        <ShellContent x:Name="VenteLubShellContent" Title="Ventes Lub/Articles" Route="VenteLubrifiantsEtArticlesPage"/>
        <ShellContent x:Name="VenteServiceShellContent" Title="Ventes Services" Route="VenteServicePage"/>
        <ShellContent x:Name="DepenseShellContent" Title="Dépenses" Route="DepensePage"/>
        <ShellContent x:Name="CaisseShellContent" Title="Caisse" Route="CaissePage"/>
    </FlyoutItem>

    <!-- ════════════════════════════════════════════════════════════ -->
    <!-- INFRASTRUCTURE DE LA STATION -->
    <!-- ════════════════════════════════════════════════════════════ -->
    <FlyoutItem Title="INFRASTRUCTURE DE LA STATION" FlyoutDisplayOptions="AsMultipleItems">
        <ShellContent x:Name="ProductsShellContent" Title="Produits" Route="ProduitPage"/>
        <ShellContent x:Name="ReservoirShellContent" Title="Réservoirs" Route="ReservoirPage"/>
        <ShellContent x:Name="PompeShellContent" Title="Pompes" Route="PompePage"/>
        <ShellContent x:Name="JaugeageShellContent" Title="Jaugeage" Route="JaugeagePage"/>
        <ShellContent x:Name="ServiceShellContent" Title="Services" Route="ServicePage"/>
    </FlyoutItem>

    <!-- ════════════════════════════════════════════════════════════ -->
    <!-- GESTION DES RESSOURCES -->
    <!-- ════════════════════════════════════════════════════════════ -->
    <FlyoutItem Title="GESTION DES RESSOURCES" FlyoutDisplayOptions="AsMultipleItems">
        <ShellContent x:Name="FournisseurShellContent" Title="Fournisseurs &amp; Flotte" Route="FournisseurPage"/>
        <ShellContent x:Name="EmployeShellContent" Title="Employés" Route="EmployePage"/>
    </FlyoutItem>
</Shell>