<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BombaProMax.Styles.CaisseStyles">

    <!-- COLOR PALETTE -->
    <Color x:Key="CaisseNeuBg">#EEF1F5</Color>
    <Color x:Key="CaisseNeuCardBg">#F8FAFC</Color>
    <Color x:Key="CaisseNeuPrimary">#2E7D32</Color>
    <Color x:Key="CaisseNeuPrimaryLight">#4CAF50</Color>
    <Color x:Key="CaisseNeuPrimaryDark">#1B5E20</Color>
    <Color x:Key="CaisseNeuTextPrimary">#1F2937</Color>
    <Color x:Key="CaisseNeuTextSecondary">#6B7280</Color>
    <Color x:Key="CaisseNeuShadowLight">#FFFFFF</Color>
    <Color x:Key="CaisseNeuShadowDark">#C5CAD1</Color>
    <Color x:Key="CaisseNeuSuccess">#4CAF50</Color>
    <Color x:Key="CaisseNeuWarning">#FF9800</Color>
    <Color x:Key="CaisseNeuDanger">#E53935</Color>
    <Color x:Key="CaisseNeuInfo">#1976D2</Color>

    <!-- PAGE STYLES -->
    <Style x:Key="CaissePageStyle" TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{StaticResource CaisseNeuBg}"/>
    </Style>

    <Style x:Key="CaissePageScrollView" TargetType="ScrollView">
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="CaissePageMainStack" TargetType="VerticalStackLayout">
        <Setter Property="Padding" Value="24"/>
        <Setter Property="Spacing" Value="20"/>
    </Style>

    <Style x:Key="CaissePageHeaderStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="4"/>
    </Style>

    <Style x:Key="CaissePageTitleLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource CaisseNeuTextPrimary}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>

    <Style x:Key="CaissePageSubtitleLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource CaisseNeuTextSecondary}"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- STAT CARDS -->
    <Style x:Key="CaisseStatCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CaisseNeuCardBg}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="16"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CaisseBigStatCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CaisseNeuCardBg}"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="20"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CaisseStatIcon" TargetType="Label">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="CaisseStatNumber" TargetType="Label">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="CaisseBigStatNumber" TargetType="Label">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="CaisseStatLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource CaisseNeuTextSecondary}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <!-- TABLE STYLES -->
    <Style x:Key="CaisseTableCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CaisseNeuCardBg}"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="20"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CaisseTableContainer" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="0"/>
    </Style>

    <Style x:Key="CaisseTableHeaderGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="1.5*,1.5*,1.5*,1.5*,2*,1*"/>
        <Setter Property="ColumnSpacing" Value="8"/>
        <Setter Property="Padding" Value="20,16"/>
        <Setter Property="BackgroundColor" Value="{StaticResource CaisseNeuPrimary}"/>
    </Style>

    <Style x:Key="CaisseTableHeaderLabel" TargetType="Label">
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="CaisseTableHeaderLabelLeft" TargetType="Label">
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Start"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="CaisseTableRowGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="1.5*,1.5*,1.5*,1.5*,2*,1*"/>
        <Setter Property="ColumnSpacing" Value="8"/>
        <Setter Property="Padding" Value="20,14"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="MinimumHeightRequest" Value="60"/>
    </Style>

    <Style x:Key="CaisseRowDivider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="BackgroundColor" Value="#E5E7EB"/>
        <Setter Property="Margin" Value="20,0"/>
    </Style>

    <!-- DATA LABELS -->
    <Style x:Key="CaisseMontantLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource CaisseNeuSuccess}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="CaisseDateLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource CaisseNeuTextPrimary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="HorizontalTextAlignment" Value="Start"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="CaisseReferenceLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource CaisseNeuInfo}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Start"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="CaisseBanqueLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource CaisseNeuTextPrimary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="HorizontalTextAlignment" Value="Start"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="CaisseNotesLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource CaisseNeuTextSecondary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="LineBreakMode" Value="TailTruncation"/>
        <Setter Property="MaxLines" Value="2"/>
        <Setter Property="HorizontalTextAlignment" Value="Start"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <!-- BUTTONS -->
    <Style x:Key="CaisseAddButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource CaisseNeuPrimary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="CornerRadius" Value="12"/>
    </Style>

    <Style x:Key="CaisseFilterButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource CaisseNeuPrimaryLight}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <Style x:Key="CaisseResetButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="#E5E7EB"/>
        <Setter Property="TextColor" Value="{StaticResource CaisseNeuTextSecondary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <Style x:Key="CaisseEditButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="#E3F2FD"/>
        <Setter Property="TextColor" Value="{StaticResource CaisseNeuInfo}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="MinimumWidthRequest" Value="40"/>
    </Style>

    <Style x:Key="CaisseDeleteButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="#FFEBEE"/>
        <Setter Property="TextColor" Value="{StaticResource CaisseNeuDanger}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="MinimumWidthRequest" Value="40"/>
    </Style>

    <Style x:Key="CaisseActionsCell" TargetType="HorizontalStackLayout">
        <Setter Property="Spacing" Value="8"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>

    <!-- FILTERS -->
    <Style x:Key="CaisseFilterLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource CaisseNeuTextSecondary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="CaisseFilterDatePicker" TargetType="DatePicker">
        <Setter Property="TextColor" Value="{StaticResource CaisseNeuTextPrimary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="MinimumWidthRequest" Value="130"/>
    </Style>

    <!-- EMPTY VIEW -->
    <Style x:Key="CaisseEmptyView" TargetType="VerticalStackLayout">
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="Padding" Value="40"/>
        <Setter Property="Spacing" Value="12"/>
    </Style>

    <Style x:Key="CaisseEmptyTitle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource CaisseNeuTextPrimary}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="CaisseEmptySubtitle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource CaisseNeuTextSecondary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="CaisseEmptyButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource CaisseNeuPrimary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="24,14"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Margin" Value="0,8,0,0"/>
    </Style>

    <!-- LOADING -->
    <Style x:Key="CaissePageLoadingIndicator" TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource CaisseNeuPrimary}"/>
        <Setter Property="HeightRequest" Value="50"/>
        <Setter Property="WidthRequest" Value="50"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>

</ResourceDictionary>
