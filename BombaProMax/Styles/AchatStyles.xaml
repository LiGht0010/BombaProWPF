<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BombaProMax.Styles.AchatStyles">

    <!-- ================================================================== -->
    <!-- LIGHT NEUMORPHIC DESIGN SYSTEM - ACHAT MODULE                      -->
    <!-- ================================================================== -->

    <!-- COLOR PALETTE -->
    <Color x:Key="AchatNeuSurface">#e8e8e8</Color>
    <Color x:Key="AchatNeuCardBg">#E8ECF1</Color>
    <Color x:Key="AchatNeuShadowDark">#C5CAD1</Color>
    <Color x:Key="AchatNeuShadowLight">#FFFFFF</Color>
    <Color x:Key="AchatNeuShadowDarkSoft">#D1D5DB</Color>
    <Color x:Key="AchatNeuPrimary">#4A8FBF</Color>
    <Color x:Key="AchatNeuDanger">#E16C6C</Color>
    <Color x:Key="AchatNeuSecondary">#8FA3B8</Color>
    <Color x:Key="AchatNeuSuccess">#5EAA8D</Color>
    <Color x:Key="AchatNeuWarning">#E8A84C</Color>
    <Color x:Key="AchatNeuTextPrimary">#2E2E2E</Color>
    <Color x:Key="AchatNeuTextSecondary">#5A6068</Color>
    <Color x:Key="AchatNeuTextMuted">#8B939E</Color>
    <Color x:Key="AchatNeuTextLight">#A8B0BA</Color>
    <Color x:Key="AchatNeuBorderLight">#E5E9EF</Color>
    <Color x:Key="AchatMBG">#f5f5f5</Color>

    <x:String x:Key="AchatTableColumns">1.2*,1*,1.5*,1.5*,1*,1.2*,3*</x:String>

    <!-- PAGE BASE STYLES -->
    <Style x:Key="AchatPageStyle" TargetType="ContentPage">
        <Setter Property="Title" Value="Achats"/>
        <Setter Property="Shell.NavBarIsVisible" Value="True"/>
        <Setter Property="BackgroundColor" Value="{StaticResource AchatMBG}"/>
    </Style>

    <Style x:Key="AchatPageScrollView" TargetType="ScrollView">
        <Setter Property="Padding" Value="28"/>
    </Style>

    <Style x:Key="AchatPageMainStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="24"/>
    </Style>

    <!-- HEADER SECTION -->
    <Style x:Key="AchatPageHeaderStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="6"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="AchatPageTitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextPrimary}"/>
    </Style>

    <Style x:Key="AchatPageSubtitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextMuted}"/>
    </Style>

    <!-- STAT CARDS -->
    <Style x:Key="AchatStatCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource AchatNeuSurface}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource AchatNeuShadowDark}" Offset="6,6" Radius="12" Opacity="0.25"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="AchatStatNumber" TargetType="Label">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuPrimary}"/>
    </Style>

    <Style x:Key="AchatStatLabel" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextMuted}"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.3"/>
    </Style>

    <!-- SEARCH CONTAINER -->
    <Style x:Key="AchatSearchContainer" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource AchatNeuSurface}"/>
        <Setter Property="Padding" Value="16,14"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource AchatNeuShadowDarkSoft}" Offset="2,2" Radius="6" Opacity="0.15"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="AchatSearchEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{StaticResource AchatNeuSurface}"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextPrimary}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource AchatNeuTextLight}"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- LOADING INDICATOR -->
    <Style x:Key="AchatPageLoadingIndicator" TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource AchatNeuPrimary}"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="HeightRequest" Value="50"/>
        <Setter Property="WidthRequest" Value="50"/>
    </Style>

    <!-- ADD BUTTON -->
    <Style x:Key="AchatAddButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AchatNeuPrimary}"/>
        <Setter Property="TextColor" Value="#FFFFFF"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HeightRequest" Value="46"/>
        <Setter Property="Padding" Value="24,0"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource AchatNeuPrimary}" Offset="0,4" Radius="10" Opacity="0.35"/></Setter.Value></Setter>
    </Style>

    <!-- TABLE CARD -->
    <Style x:Key="AchatTableCard" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="BackgroundColor" Value="{StaticResource AchatNeuSurface}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource AchatNeuShadowDark}" Offset="8,8" Radius="20" Opacity="0.28"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="AchatTableContainer" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="0"/>
    </Style>

    <!-- TABLE HEADER -->
    <Style x:Key="AchatTableHeaderGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="{StaticResource AchatTableColumns}"/>
        <Setter Property="ColumnSpacing" Value="12"/>
        <Setter Property="Padding" Value="28,18"/>
        <Setter Property="BackgroundColor" Value="{StaticResource AchatNeuPrimary}"/>
    </Style>

    <Style x:Key="AchatTableHeaderLabel" TargetType="Label">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuShadowLight}"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.8"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="AchatTableHeaderLabelLeft" TargetType="Label" BasedOn="{StaticResource AchatTableHeaderLabel}">
        <Setter Property="HorizontalTextAlignment" Value="Start"/>
    </Style>

    <Style x:Key="AchatTableDivider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="Color" Value="{StaticResource AchatNeuBorderLight}"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
    </Style>

    <Style x:Key="AchatTableCollectionView" TargetType="CollectionView">
        <Setter Property="SelectionMode" Value="None"/>
    </Style>

    <!-- TABLE ROW -->
    <Style x:Key="AchatTableRowGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="{StaticResource AchatTableColumns}"/>
        <Setter Property="ColumnSpacing" Value="12"/>
        <Setter Property="Padding" Value="28,18"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="MinimumHeightRequest" Value="76"/>
    </Style>

    <!-- CELL STYLES -->
    <Style x:Key="AchatNumberCell" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource AchatNeuCardBg}"/>
        <Setter Property="HeightRequest" Value="32"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="16"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource AchatNeuShadowDarkSoft}" Offset="1,1" Radius="3" Opacity="0.12"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="AchatNumberLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource AchatNeuPrimary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="AchatDateCell" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextSecondary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="AchatFournisseurCell" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Start"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
        <Setter Property="LineBreakMode" Value="TailTruncation"/>
        <Setter Property="MaxLines" Value="1"/>
    </Style>

    <Style x:Key="AchatProduitCell" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextSecondary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="HorizontalTextAlignment" Value="Start"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
        <Setter Property="LineBreakMode" Value="TailTruncation"/>
        <Setter Property="MaxLines" Value="1"/>
    </Style>

    <Style x:Key="AchatQuantiteCell" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource AchatNeuSuccess}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="AchatCoutCell" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource AchatNeuWarning}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="AchatActionsCell" TargetType="HorizontalStackLayout">
        <Setter Property="Spacing" Value="10"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
    </Style>

    <!-- ACTION BUTTONS -->
    <Style x:Key="AchatDetailsButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AchatNeuSecondary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="MinimumWidthRequest" Value="70"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource AchatNeuSecondary}" Offset="0,3" Radius="6" Opacity="0.25"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="AchatAllocationButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AchatNeuPrimary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="MinimumWidthRequest" Value="80"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource AchatNeuPrimary}" Offset="0,3" Radius="6" Opacity="0.3"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="AchatModifierButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AchatNeuSuccess}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="MinimumWidthRequest" Value="75"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource AchatNeuSuccess}" Offset="0,3" Radius="6" Opacity="0.3"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="AchatSupprimerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AchatNeuSurface}"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuDanger}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="MinimumWidthRequest" Value="80"/>
        <Setter Property="BorderWidth" Value="1.5"/>
        <Setter Property="BorderColor" Value="{StaticResource AchatNeuDanger}"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource AchatNeuShadowDark}" Offset="2,2" Radius="4" Opacity="0.12"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="AchatRowDivider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="Color" Value="{StaticResource AchatNeuBorderLight}"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
        <Setter Property="Margin" Value="28,0"/>
        <Setter Property="Opacity" Value="0.7"/>
    </Style>

    <!-- EMPTY VIEW -->
    <Style x:Key="AchatEmptyView" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="16"/>
        <Setter Property="Padding" Value="60,80"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>

    <Style x:Key="AchatEmptyTitle" TargetType="Label">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextPrimary}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="AchatEmptySubtitle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextMuted}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="MaximumWidthRequest" Value="320"/>
    </Style>

    <Style x:Key="AchatEmptyButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AchatNeuPrimary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="28,14"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Margin" Value="0,12,0,0"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource AchatNeuPrimary}" Offset="0,4" Radius="10" Opacity="0.35"/></Setter.Value></Setter>
    </Style>

    <!-- POPUP STYLES -->
    <Style x:Key="AchatPopupBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource AchatNeuSurface}"/>
        <Setter Property="Padding" Value="32"/>
        <Setter Property="WidthRequest" Value="650"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="24"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="#000000" Offset="0,12" Radius="40" Opacity="0.18"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="AchatPopupTitle" TargetType="Label">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextPrimary}"/>
    </Style>

    <Style x:Key="AchatPopupCloseButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AchatNeuCardBg}"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextMuted}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="WidthRequest" Value="36"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="CornerRadius" Value="18"/>
    </Style>

    <Style x:Key="AchatPopupDivider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="Color" Value="{StaticResource AchatNeuBorderLight}"/>
    </Style>

    <Style x:Key="AchatPopupFieldLabel" TargetType="Label">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextMuted}"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.5"/>
    </Style>

    <Style x:Key="AchatPopupFieldLabelSmall" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextSecondary}"/>
    </Style>

    <Style x:Key="AchatPopupEntry" TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextPrimary}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource AchatNeuTextLight}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
    </Style>

    <Style x:Key="AchatPopupTotalBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="#E8F5ED"/>
        <Setter Property="Padding" Value="15,12"/>
        <Setter Property="StrokeThickness" Value="2"/>
        <Setter Property="Stroke" Value="{StaticResource AchatNeuSuccess}"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="10"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="AchatPopupTotalLabel" TargetType="Label">
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuSuccess}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="AchatPopupTotalValue" TargetType="Label">
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuSuccess}"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="AchatPopupSectionBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="#E8F1F8"/>
        <Setter Property="Padding" Value="15"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="12"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="AchatPopupSectionTitle" TargetType="Label">
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuPrimary}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Margin" Value="0,0,0,5"/>
    </Style>

    <Style x:Key="AchatPopupWarningBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="#FDF4E8"/>
        <Setter Property="Padding" Value="15"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="12"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="AchatPopupWarningTitle" TargetType="Label">
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuWarning}"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style x:Key="AchatPopupWarningSubtitle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextMuted}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="AchatPopupCancelButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AchatNeuCardBg}"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextSecondary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="HeightRequest" Value="48"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource AchatNeuShadowDark}" Offset="3,3" Radius="6" Opacity="0.15"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="AchatPopupCreateButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AchatNeuSuccess}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="HeightRequest" Value="48"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource AchatNeuSuccess}" Offset="0,4" Radius="10" Opacity="0.35"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="AchatPopupSaveButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AchatNeuPrimary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="HeightRequest" Value="48"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource AchatNeuPrimary}" Offset="0,4" Radius="10" Opacity="0.35"/></Setter.Value></Setter>
    </Style>

    <!-- ================================================================== -->
    <!-- ALLOCATION POPUP STYLES                                            -->
    <!-- ================================================================== -->

    <Style x:Key="AchatAllocationPopupBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource AchatNeuSurface}"/>
        <Setter Property="Padding" Value="28"/>
        <Setter Property="WidthRequest" Value="750"/>
        <Setter Property="MaximumHeightRequest" Value="700"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="24"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="#000000" Offset="0,12" Radius="40" Opacity="0.18"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="AchatAllocationInfoBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource AchatNeuCardBg}"/>
        <Setter Property="Padding" Value="20,16"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="14"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="AchatAllocationInfoLabel" TargetType="Label">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextMuted}"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.5"/>
    </Style>

    <Style x:Key="AchatAllocationInfoValue" TargetType="Label">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextPrimary}"/>
    </Style>

    <Style x:Key="AchatAllocationInfoValueHighlight" TargetType="Label">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuPrimary}"/>
    </Style>

    <Style x:Key="AchatAllocationSectionTitle" TargetType="Label">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextSecondary}"/>
        <Setter Property="Margin" Value="0,5,0,10"/>
    </Style>

    <Style x:Key="AchatAllocationReservoirCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="White"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="Stroke" Value="{StaticResource AchatNeuBorderLight}"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="12"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource AchatNeuShadowDarkSoft}" Offset="2,2" Radius="6" Opacity="0.1"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="AchatAllocationReservoirNumero" TargetType="Label">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextPrimary}"/>
    </Style>

    <Style x:Key="AchatAllocationReservoirProduit" TargetType="Label">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="TextColor" Value="{StaticResource AchatNeuTextSecondary}"/>
    </Style>

    <Style x:Key="AchatAllocationReservoirLevel" TargetType="Label">
