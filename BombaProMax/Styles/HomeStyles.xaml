<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BombaProMax.Styles.HomeStyles">

    <!-- ================================================================== -->
    <!-- LIGHT NEUMORPHIC DESIGN SYSTEM - HOME MODULE                       -->
    <!-- ================================================================== -->

    <!-- COLOR PALETTE -->
    <Color x:Key="HomeNeuSurface">#e8e8e8</Color>
    <Color x:Key="HomeNeuCardBg">#E8ECF1</Color>
    <Color x:Key="HomeNeuShadowDark">#C5CAD1</Color>
    <Color x:Key="HomeNeuShadowLight">#FFFFFF</Color>
    <Color x:Key="HomeNeuShadowDarkSoft">#D1D5DB</Color>
    <Color x:Key="HomeNeuPrimary">#667eea</Color>
    <Color x:Key="HomeNeuPrimaryDark">#764ba2</Color>
    <Color x:Key="HomeNeuSecondary">#6B8DD6</Color>
    <Color x:Key="HomeNeuDanger">#E16C6C</Color>
    <Color x:Key="HomeNeuSuccess">#5EAA8D</Color>
    <Color x:Key="HomeNeuWarning">#E8A84C</Color>
    <Color x:Key="HomeNeuTextPrimary">#2E2E2E</Color>
    <Color x:Key="HomeNeuTextSecondary">#5A6068</Color>
    <Color x:Key="HomeNeuTextMuted">#8B939E</Color>
    <Color x:Key="HomeNeuTextLight">#A8B0BA</Color>
    <Color x:Key="HomeNeuBorderLight">#E5E9EF</Color>
    <Color x:Key="HomeMBG">#f5f5f5</Color>
    
    <!-- Stat Card Colors -->
    <Color x:Key="HomeStatEmploye">#2E7D32</Color>
    <Color x:Key="HomeStatEmployeBg">#E8F5E9</Color>
    <Color x:Key="HomeStatFournisseur">#E65100</Color>
    <Color x:Key="HomeStatFournisseurBg">#FFF3E0</Color>
    <Color x:Key="HomeStatProduit">#1565C0</Color>
    <Color x:Key="HomeStatProduitBg">#E3F2FD</Color>
    <Color x:Key="HomeStatPompe">#C2185B</Color>
    <Color x:Key="HomeStatPompeBg">#FCE4EC</Color>
    <Color x:Key="HomeStatClient">#3949AB</Color>
    <Color x:Key="HomeStatClientBg">#E8EAF6</Color>
    <Color x:Key="HomeStatDepense">#C62828</Color>
    <Color x:Key="HomeStatDepenseBg">#FFEBEE</Color>

    <!-- ================================================================== -->
    <!-- PAGE BASE STYLES                                                   -->
    <!-- ================================================================== -->

    <Style x:Key="HomePageStyle" TargetType="ContentPage">
        <Setter Property="Title" Value="Accueil"/>
        <Setter Property="Shell.NavBarIsVisible" Value="True"/>
        <Setter Property="BackgroundColor" Value="{StaticResource HomeMBG}"/>
    </Style>

    <Style x:Key="HomePageScrollView" TargetType="ScrollView">
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="HomePageMainStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="20"/>
        <Setter Property="Padding" Value="28"/>
    </Style>

    <!-- ================================================================== -->
    <!-- HEADER BANNER                                                      -->
    <!-- ================================================================== -->

    <Style x:Key="HomeHeaderBanner" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="Padding" Value="25"/>
        <Setter Property="Margin" Value="0,10,0,0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="HomeHeaderStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="8"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
    </Style>

    <Style x:Key="HomeHeaderTitleStack" TargetType="HorizontalStackLayout">
        <Setter Property="Spacing" Value="10"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
    </Style>

    <Style x:Key="HomeHeaderIcon" TargetType="Label">
        <Setter Property="FontSize" Value="28"/>
    </Style>

    <Style x:Key="HomeHeaderTitle" TargetType="Label">
        <Setter Property="FontSize" Value="26"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="White"/>
    </Style>

    <Style x:Key="HomeHeaderSubtitle" TargetType="Label">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="#E0E0FF"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
    </Style>

    <Style x:Key="HomeHeaderStatus" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="#C0C0E0"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="Margin" Value="0,5,0,0"/>
    </Style>

    <!-- ================================================================== -->
    <!-- STATISTICS CARDS                                                   -->
    <!-- ================================================================== -->

    <Style x:Key="HomeStatsGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="*,*,*"/>
        <Setter Property="RowDefinitions" Value="Auto,Auto"/>
        <Setter Property="ColumnSpacing" Value="12"/>
        <Setter Property="RowSpacing" Value="12"/>
    </Style>

    <Style x:Key="HomeStatCardBase" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource HomeNeuShadowDark}" Offset="6,6" Radius="12" Opacity="0.25"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="HomeStatCardEmploye" TargetType="Border" BasedOn="{StaticResource HomeStatCardBase}">
        <Setter Property="BackgroundColor" Value="{StaticResource HomeStatEmploye}"/>
    </Style>

    <Style x:Key="HomeStatCardFournisseur" TargetType="Border" BasedOn="{StaticResource HomeStatCardBase}">
        <Setter Property="BackgroundColor" Value="{StaticResource HomeStatFournisseur}"/>
    </Style>

    <Style x:Key="HomeStatCardProduit" TargetType="Border" BasedOn="{StaticResource HomeStatCardBase}">
        <Setter Property="BackgroundColor" Value="{StaticResource HomeStatProduit}"/>
    </Style>

    <Style x:Key="HomeStatCardPompe" TargetType="Border" BasedOn="{StaticResource HomeStatCardBase}">
        <Setter Property="BackgroundColor" Value="{StaticResource HomeStatPompe}"/>
    </Style>

    <Style x:Key="HomeStatCardClient" TargetType="Border" BasedOn="{StaticResource HomeStatCardBase}">
        <Setter Property="BackgroundColor" Value="{StaticResource HomeStatClient}"/>
    </Style>

    <Style x:Key="HomeStatCardDepense" TargetType="Border" BasedOn="{StaticResource HomeStatCardBase}">
        <Setter Property="BackgroundColor" Value="{StaticResource HomeStatDepense}"/>
    </Style>

    <Style x:Key="HomeStatCardStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="8"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
    </Style>

    <Style x:Key="HomeStatNumber" TargetType="Label">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="TextColor" Value="White"/>
    </Style>

    <Style x:Key="HomeStatLabel" TargetType="Label">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.3"/>
        <Setter Property="Opacity" Value="0.9"/>
    </Style>

    <!-- ================================================================== -->
    <!-- QUICK ACTIONS SECTION                                              -->
    <!-- ================================================================== -->

    <Style x:Key="HomeActionsSection" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="12"/>
        <Setter Property="Margin" Value="0,10,0,0"/>
    </Style>

    <Style x:Key="HomeActionsTitleStack" TargetType="HorizontalStackLayout">
        <Setter Property="Spacing" Value="8"/>
    </Style>

    <Style x:Key="HomeActionsTitleIcon" TargetType="Label">
        <Setter Property="FontSize" Value="20"/>
    </Style>

    <Style x:Key="HomeActionsTitle" TargetType="Label">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource HomeNeuTextPrimary}"/>
    </Style>

    <Style x:Key="HomeActionsGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="*,*,*"/>
        <Setter Property="ColumnSpacing" Value="10"/>
    </Style>

    <Style x:Key="HomeActionCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource HomeNeuSurface}"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource HomeNeuShadowDarkSoft}" Offset="4,4" Radius="8" Opacity="0.18"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="HomeActionCardStack" TargetType="HorizontalStackLayout">
        <Setter Property="Spacing" Value="10"/>
    </Style>

    <Style x:Key="HomeActionIcon" TargetType="Label">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>

    <Style x:Key="HomeActionTextStack" TargetType="VerticalStackLayout">
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>

    <Style x:Key="HomeActionTitle" TargetType="Label">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource HomeNeuTextPrimary}"/>
    </Style>

    <Style x:Key="HomeActionSubtitle" TargetType="Label">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="TextColor" Value="{StaticResource HomeNeuTextMuted}"/>
    </Style>

    <!-- ================================================================== -->
    <!-- BOTTOM CARDS SECTION                                               -->
    <!-- ================================================================== -->

    <Style x:Key="HomeBottomCardsGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="*,*,*"/>
        <Setter Property="ColumnSpacing" Value="12"/>
        <Setter Property="Margin" Value="0,10,0,20"/>
    </Style>

    <Style x:Key="HomeBottomCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource HomeNeuSurface}"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="Padding" Value="15"/>
        <Setter Property="HeightRequest" Value="150"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource HomeNeuShadowDark}" Offset="6,6" Radius="12" Opacity="0.25"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="HomeBottomCardStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="10"/>
    </Style>

    <Style x:Key="HomeBottomCardTitleStack" TargetType="HorizontalStackLayout">
        <Setter Property="Spacing" Value="8"/>
    </Style>

    <Style x:Key="HomeBottomCardIcon" TargetType="Label">
        <Setter Property="FontSize" Value="18"/>
    </Style>

    <Style x:Key="HomeBottomCardTitle" TargetType="Label">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource HomeNeuTextPrimary}"/>
    </Style>

    <Style x:Key="HomeBottomCardContent" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="{StaticResource HomeNeuTextMuted}"/>
        <Setter Property="VerticalOptions" Value="CenterAndExpand"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
    </Style>

    <Style x:Key="HomeBottomCardLinkBorder" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="6"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="HomeBottomCardLinkBorderAchats" TargetType="Border" BasedOn="{StaticResource HomeBottomCardLinkBorder}">
        <Setter Property="BackgroundColor" Value="{StaticResource HomeStatProduitBg}"/>
    </Style>

    <Style x:Key="HomeBottomCardLinkBorderPeriodes" TargetType="Border" BasedOn="{StaticResource HomeBottomCardLinkBorder}">
        <Setter Property="BackgroundColor" Value="{StaticResource HomeStatEmployeBg}"/>
    </Style>

    <Style x:Key="HomeBottomCardLinkLabel" TargetType="Label">
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style x:Key="HomeBottomCardLinkLabelAchats" TargetType="Label" BasedOn="{StaticResource HomeBottomCardLinkLabel}">
        <Setter Property="TextColor" Value="{StaticResource HomeStatProduit}"/>
    </Style>

    <Style x:Key="HomeBottomCardLinkLabelPeriodes" TargetType="Label" BasedOn="{StaticResource HomeBottomCardLinkLabel}">
        <Setter Property="TextColor" Value="{StaticResource HomeStatEmploye}"/>
    </Style>

    <!-- Alerts Section -->
    <Style x:Key="HomeAlertsStack" TargetType="VerticalStackLayout">
        <Setter Property="VerticalOptions" Value="CenterAndExpand"/>
        <Setter Property="Spacing" Value="5"/>
    </Style>

    <Style x:Key="HomeAlertsStatusStack" TargetType="HorizontalStackLayout">
        <Setter Property="Spacing" Value="8"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
    </Style>

    <Style x:Key="HomeAlertsStatusIcon" TargetType="Label">
        <Setter Property="FontSize" Value="16"/>
    </Style>

    <Style x:Key="HomeAlertsStatusText" TargetType="Label">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource HomeStatEmploye}"/>
    </Style>

    <Style x:Key="HomeAlertsSubtext" TargetType="Label">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="TextColor" Value="{StaticResource HomeNeuTextMuted}"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
    </Style>

</ResourceDictionary>