<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BombaProMax.Styles.ClientStyles">

    <!-- ================================================================== -->
    <!-- LIGHT NEUMORPHIC DESIGN SYSTEM - CLIENT MODULE                     -->
    <!-- ================================================================== -->

    <!-- COLOR PALETTE -->
    <Color x:Key="ClientNeuSurface">#e8e8e8</Color>
    <Color x:Key="ClientNeuCardBg">#E8ECF1</Color>
    <Color x:Key="ClientNeuShadowDark">#C5CAD1</Color>
    <Color x:Key="ClientNeuShadowLight">#FFFFFF</Color>
    <Color x:Key="ClientNeuShadowDarkSoft">#D1D5DB</Color>
    <Color x:Key="ClientNeuPrimary">#4A8FBF</Color>
    <Color x:Key="ClientNeuDanger">#E16C6C</Color>
    <Color x:Key="ClientNeuSecondary">#8FA3B8</Color>
    <Color x:Key="ClientNeuSuccess">#5EAA8D</Color>
    <Color x:Key="ClientNeuWarning">#E8A84C</Color>
    <Color x:Key="ClientNeuTextPrimary">#E8ECF1</Color>
    <Color x:Key="ClientNeuTextSecondary">#5A6068</Color>
    <Color x:Key="ClientNeuTextMuted">#8B939E</Color>
    <Color x:Key="ClientNeuTextLight">#A8B0BA</Color>
    <Color x:Key="ClientNeuBorderLight">#E5E9EF</Color>
    <Color x:Key="GREY">#3c3c3c</Color>

    <Color x:Key="ClientMBG">#f5f5f5</Color>
    
    <!-- Additional Colors for Credit Management -->
    <Color x:Key="ClientCreditOrange">#FF9800</Color>
    <Color x:Key="ClientCreditOrangeBg">#FFF3E0</Color>
    <Color x:Key="ClientCreditOrangeText">#E65100</Color>
    <Color x:Key="ClientCreditGreen">#4CAF50</Color>
    <Color x:Key="ClientCreditGreenBg">#E8F5E9</Color>
    <Color x:Key="ClientCreditGreenText">#2E7D32</Color>
    <Color x:Key="ClientCreditRed">#F44336</Color>
    <Color x:Key="ClientCreditRedBg">#FFEBEE</Color>
    <Color x:Key="ClientCreditRedText">#C62828</Color>
    <Color x:Key="ClientCreditBlue">#2196F3</Color>
    <Color x:Key="ClientCreditBlueBg">#E3F2FD</Color>
    <Color x:Key="ClientCreditBlueText">#1565C0</Color>
    <Color x:Key="ClientCreditPurple">#9C27B0</Color>
    <Color x:Key="ClientCreditPurpleBg">#F3E5F5</Color>
    <Color x:Key="ClientCreditPurpleText">#7B1FA2</Color>
    <Color x:Key="ClientCreditTableHeader">#ECEFF1</Color>
    <Color x:Key="ClientCreditTableHeaderText">#37474F</Color>
    <Color x:Key="ClientCreditTabInactive">#E0E0E0</Color>
    <Color x:Key="ClientCreditTabInactiveText">#666666</Color>

    <!-- Replace star-based column definitions with more explicit sizing -->
    <!-- This prevents WinUI 3 Release mode layout calculation issues -->
    <x:String x:Key="ClientTableColumns">100,180,130,150,Auto</x:String>
    <x:String x:Key="CreditTransactionColumns">80,140,150,60,120,80,130</x:String>
    <x:String x:Key="CreditReglementColumns">80,120,120,150,120,120</x:String>

    <!-- ================================================================== -->
    <!-- CLIENT PAGE STYLES                                                 -->
    <!-- ================================================================== -->

    <!-- PAGE BASE STYLES -->
    <Style x:Key="ClientPageStyle" TargetType="ContentPage">
        <Setter Property="Title" Value="Clients"/>
        <Setter Property="Shell.NavBarIsVisible" Value="True"/>
        <Setter Property="BackgroundColor" Value="{StaticResource ClientMBG}"/>
    </Style>

    <Style x:Key="ClientPageScrollView" TargetType="ScrollView">
        <Setter Property="Padding" Value="28"/>
    </Style>

    <Style x:Key="ClientPageMainStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="24"/>
    </Style>

    <!-- HEADER SECTION -->
    <Style x:Key="ClientPageHeaderStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="6"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="ClientPageTitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource GREY}"/>
    </Style>

    <Style x:Key="ClientPageSubtitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource ClientNeuTextMuted}"/>
    </Style>

    <!-- STAT CARDS -->
    <Style x:Key="ClientStatCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuSurface}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource ClientNeuShadowDark}" Offset="6,6" Radius="12" Opacity="0.25"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="ClientStatNumber" TargetType="Label">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource ClientNeuPrimary}"/>
    </Style>

    <Style x:Key="ClientStatLabel" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="{StaticResource ClientNeuTextMuted}"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.3"/>
    </Style>

    <!-- SEARCH CONTAINER -->
    <Style x:Key="ClientSearchContainer" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuSurface}"/>
        <Setter Property="Padding" Value="16,14"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource ClientNeuShadowDarkSoft}" Offset="2,2" Radius="6" Opacity="0.15"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="ClientSearchEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuSurface}"/>
        <Setter Property="TextColor" Value="{StaticResource ClientNeuTextPrimary}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource ClientNeuTextLight}"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- LOADING INDICATOR -->
    <Style x:Key="ClientPageLoadingIndicator" TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource ClientNeuPrimary}"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="HeightRequest" Value="50"/>
        <Setter Property="WidthRequest" Value="50"/>
    </Style>

    <!-- ADD BUTTON -->
    <Style x:Key="ClientAddButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuPrimary}"/>
        <Setter Property="TextColor" Value="#FFFFFF"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HeightRequest" Value="46"/>
        <Setter Property="Padding" Value="24,0"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource ClientNeuPrimary}" Offset="0,4" Radius="10" Opacity="0.35"/></Setter.Value></Setter>
    </Style>

    <!-- TABLE CARD -->
    <Style x:Key="ClientTableCard" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuSurface}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource ClientNeuShadowDark}" Offset="8,8" Radius="20" Opacity="0.28"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="ClientTableContainer" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="0"/>
    </Style>

    <!-- TABLE HEADER - Force explicit font family -->
    <Style x:Key="ClientTableHeaderGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="{StaticResource ClientTableColumns}"/>
        <Setter Property="ColumnSpacing" Value="12"/>
        <Setter Property="Padding" Value="28,18"/>
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuPrimary}"/>
    </Style>

    <Style x:Key="ClientTableHeaderLabel" TargetType="Label">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource ClientNeuShadowLight}"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.8"/>
        <Setter Property="HorizontalTextAlignment" Value="Start"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
        <!-- CRITICAL: Force font for consistent rendering -->
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontAutoScalingEnabled" Value="False"/>
    </Style>

    <Style x:Key="ClientTableHeaderLabelLeft" TargetType="Label" BasedOn="{StaticResource ClientTableHeaderLabel}">
        <Setter Property="HorizontalTextAlignment" Value="Start"/>
    </Style>

    <Style x:Key="ClientTableDivider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="Color" Value="{StaticResource ClientNeuBorderLight}"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
    </Style>

    <Style x:Key="ClientTableCollectionView" TargetType="CollectionView">
        <Setter Property="SelectionMode" Value="None"/>
    </Style>

    <!-- TABLE ROW - Force explicit font family -->
    <Style x:Key="ClientTableRowGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="{StaticResource ClientTableColumns}"/>
        <Setter Property="ColumnSpacing" Value="12"/>
        <Setter Property="Padding" Value="28,18"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="MinimumHeightRequest" Value="76"/>
    </Style>

    <!-- CELL STYLES -->
    <Style x:Key="ClientNumberCell" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuCardBg}"/>
        <Setter Property="HeightRequest" Value="32"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="16"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource ClientNeuShadowDarkSoft}" Offset="1,1" Radius="3" Opacity="0.12"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="ClientNumberLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource ClientNeuPrimary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ClientNameCell" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource GREY}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Start"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
        <Setter Property="LineBreakMode" Value="TailTruncation"/>
        <Setter Property="MaxLines" Value="1"/>
    </Style>

    <Style x:Key="ClientContactCell" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource ClientNeuTextSecondary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
        <Setter Property="LineBreakMode" Value="TailTruncation"/>
        <Setter Property="MaxLines" Value="1"/>
    </Style>

    <Style x:Key="ClientCompanyCell" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource ClientNeuTextSecondary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="HorizontalTextAlignment" Value="Start"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
        <Setter Property="LineBreakMode" Value="TailTruncation"/>
        <Setter Property="MaxLines" Value="1"/>
    </Style>

    <Style x:Key="ClientActionsCell" TargetType="HorizontalStackLayout">
        <Setter Property="Spacing" Value="10"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
    </Style>

    <!-- ACTION BUTTONS -->
    <Style x:Key="ClientDetailsButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuSecondary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="MinimumWidthRequest" Value="70"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource ClientNeuSecondary}" Offset="0,3" Radius="6" Opacity="0.25"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="ClientCreditButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuWarning}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="MinimumWidthRequest" Value="70"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource ClientNeuWarning}" Offset="0,3" Radius="6" Opacity="0.3"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="ClientModifierButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuPrimary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="MinimumWidthRequest" Value="75"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource ClientNeuPrimary}" Offset="0,3" Radius="6" Opacity="0.3"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="ClientSupprimerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuSurface}"/>
        <Setter Property="TextColor" Value="{StaticResource ClientNeuDanger}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="MinimumWidthRequest" Value="80"/>
        <Setter Property="BorderWidth" Value="1.5"/>
        <Setter Property="BorderColor" Value="{StaticResource ClientNeuDanger}"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource ClientNeuShadowDark}" Offset="2,2" Radius="4" Opacity="0.12"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="ClientRowDivider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="Color" Value="{StaticResource ClientNeuBorderLight}"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
        <Setter Property="Margin" Value="28,0"/>
        <Setter Property="Opacity" Value="0.7"/>
    </Style>

    <!-- EMPTY VIEW -->
    <Style x:Key="ClientEmptyView" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="16"/>
        <Setter Property="Padding" Value="60,80"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>

    <Style x:Key="ClientEmptyTitle" TargetType="Label">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="TextColor" Value="{StaticResource ClientNeuTextPrimary}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ClientEmptySubtitle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource ClientNeuTextMuted}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="MaximumWidthRequest" Value="320"/>
    </Style>

    <Style x:Key="ClientEmptyButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuPrimary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="28,14"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Margin" Value="0,12,0,0"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource ClientNeuPrimary}" Offset="0,4" Radius="10" Opacity="0.35"/></Setter.Value></Setter>
    </Style>

    <!-- ================================================================== -->
    <!-- CREDIT MANAGEMENT PAGE STYLES - NEUMORPHIC MATCHING CLIENT PAGE    -->
    <!-- ================================================================== -->

    <!-- Credit Page Style - Same as Client Page -->
    <Style x:Key="CreditPageStyle" TargetType="ContentPage">
        <Setter Property="Title" Value="Gestion du Crédit Client"/>
        <Setter Property="Shell.NavBarIsVisible" Value="True"/>
        <Setter Property="BackgroundColor" Value="{StaticResource ClientMBG}"/>
    </Style>

    <Style x:Key="CreditPageScrollView" TargetType="ScrollView">
        <Setter Property="Padding" Value="28"/>
    </Style>

    <Style x:Key="CreditPageMainStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="24"/>
    </Style>

    <!-- Credit Header - Matching Client Page Header -->
    <Style x:Key="CreditHeaderGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="Auto,*,Auto"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style x:Key="CreditBackButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuSecondary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HeightRequest" Value="46"/>
        <Setter Property="Padding" Value="24,0"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource ClientNeuSecondary}" Offset="0,4" Radius="10" Opacity="0.35"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="CreditHeaderStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="6"/>
        <Setter Property="Margin" Value="20,0"/>
    </Style>

    <Style x:Key="CreditTitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource GREY}"/>
    </Style>

    <Style x:Key="CreditSubtitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource ClientNeuTextMuted}"/>
    </Style>

    <Style x:Key="CreditRefreshButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuPrimary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HeightRequest" Value="46"/>
        <Setter Property="Padding" Value="24,0"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource ClientNeuPrimary}" Offset="0,4" Radius="10" Opacity="0.35"/></Setter.Value></Setter>
    </Style>

    <!-- Client Selector Card - Neumorphic Style -->
    <Style x:Key="CreditClientSelectorCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuSurface}"/>
        <Setter Property="Padding" Value="16,14"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource ClientNeuShadowDark}" Offset="6,6" Radius="12" Opacity="0.25"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="CreditClientSelectorGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="Auto,*"/>
        <Setter Property="ColumnSpacing" Value="12"/>
    </Style>

    <Style x:Key="CreditClientIconLabel" TargetType="Label">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>

    <Style x:Key="CreditClientSelectorStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="5"/>
    </Style>

    <Style x:Key="CreditClientSelectorLabel" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="{StaticResource ClientNeuTextMuted}"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.3"/>
    </Style>

    <Style x:Key="CreditClientPicker" TargetType="Picker">
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuSurface}"/>
        <Setter Property="TextColor" Value="{StaticResource GREY}"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- Loading Indicator - Same as Client Page -->
    <Style x:Key="CreditLoadingIndicator" TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource ClientNeuPrimary}"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="HeightRequest" Value="50"/>
        <Setter Property="WidthRequest" Value="50"/>
    </Style>

    <!-- Bilan Cards Grid - Stats Row like Client Page -->
    <Style x:Key="CreditBilanGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="*,*,*,*,*"/>
        <Setter Property="ColumnSpacing" Value="16"/>
    </Style>

    <!-- Bilan Cards - Neumorphic Stat Card Style -->
    <Style x:Key="CreditBilanCardBase" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuSurface}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource ClientNeuShadowDark}" Offset="6,6" Radius="12" Opacity="0.25"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="CreditBilanCardOrange" TargetType="Border" BasedOn="{StaticResource CreditBilanCardBase}"/>
    <Style x:Key="CreditBilanCardGreen" TargetType="Border" BasedOn="{StaticResource CreditBilanCardBase}"/>
    <Style x:Key="CreditBilanCardRed" TargetType="Border" BasedOn="{StaticResource CreditBilanCardBase}"/>
    <Style x:Key="CreditBilanCardBlue" TargetType="Border" BasedOn="{StaticResource CreditBilanCardBase}"/>
    <Style x:Key="CreditBilanCardPurple" TargetType="Border" BasedOn="{StaticResource CreditBilanCardBase}"/>

    <Style x:Key="CreditBilanStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="4"/>
    </Style>

    <Style x:Key="CreditBilanIcon" TargetType="Label">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="HorizontalOptions" Value="Start"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="CreditBilanValue" TargetType="Label">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>

    <Style x:Key="CreditBilanValueOrange" TargetType="Label" BasedOn="{StaticResource CreditBilanValue}">
        <Setter Property="TextColor" Value="{StaticResource ClientNeuWarning}"/>
    </Style>

    <Style x:Key="CreditBilanValueGreen" TargetType="Label" BasedOn="{StaticResource CreditBilanValue}">
        <Setter Property="TextColor" Value="{StaticResource ClientNeuSuccess}"/>
    </Style>

    <Style x:Key="CreditBilanValueRed" TargetType="Label" BasedOn="{StaticResource CreditBilanValue}">
        <Setter Property="TextColor" Value="{StaticResource ClientNeuDanger}"/>
    </Style>

    <Style x:Key="CreditBilanValueBlue" TargetType="Label" BasedOn="{StaticResource CreditBilanValue}">
        <Setter Property="TextColor" Value="{StaticResource ClientNeuPrimary}"/>
    </Style>

    <Style x:Key="CreditBilanValuePurple" TargetType="Label" BasedOn="{StaticResource CreditBilanValue}">
        <Setter Property="TextColor" Value="{StaticResource ClientNeuSecondary}"/>
    </Style>

    <Style x:Key="CreditBilanLabel" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="{StaticResource ClientNeuTextMuted}"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.3"/>
    </Style>

    <!-- Tabs Card - Neumorphic Table Card Style -->
    <Style x:Key="CreditTabsCard" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuSurface}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource ClientNeuShadowDark}" Offset="8,8" Radius="20" Opacity="0.28"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="CreditTabsHeaderGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="*,*"/>
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuPrimary}"/>
    </Style>

    <Style x:Key="CreditTabButtonActive" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource ClientNeuPrimary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
