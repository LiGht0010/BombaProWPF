<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BombaProMax.Styles.PompeStyles">

    <!-- ================================================================== -->
    <!-- LIGHT NEUMORPHIC DESIGN SYSTEM - POMPE MODULE                      -->
    <!-- ================================================================== -->

    <!-- COLOR PALETTE -->
    <Color x:Key="PompeNeuSurface">#e8e8e8</Color>
    <Color x:Key="PompeNeuCardBg">#E8ECF1</Color>
    <Color x:Key="PompeNeuShadowDark">#C5CAD1</Color>
    <Color x:Key="PompeNeuShadowLight">#FFFFFF</Color>
    <Color x:Key="PompeNeuShadowDarkSoft">#D1D5DB</Color>
    <Color x:Key="PompeNeuPrimary">#4A8FBF</Color>
    <Color x:Key="PompeNeuDanger">#E16C6C</Color>
    <Color x:Key="PompeNeuSecondary">#8FA3B8</Color>
    <Color x:Key="PompeNeuSuccess">#5EAA8D</Color>
    <Color x:Key="PompeNeuWarning">#E8A84C</Color>
    <Color x:Key="PompeNeuTextPrimary">#2E2E2E</Color>
    <Color x:Key="PompeNeuTextSecondary">#5A6068</Color>
    <Color x:Key="PompeNeuTextMuted">#8B939E</Color>
    <Color x:Key="PompeNeuTextLight">#A8B0BA</Color>
    <Color x:Key="PompeNeuBorderLight">#E5E9EF</Color>
    <Color x:Key="PompeMBG">#f5f5f5</Color>

    <x:String x:Key="PompeTableColumns">0.6*,1*,1.2*,1.3*,1.3*,2.6*</x:String>

    <!-- PAGE BASE STYLES -->
    <Style x:Key="PompePageStyle" TargetType="ContentPage">
        <Setter Property="Title" Value="Pompes"/>
        <Setter Property="Shell.NavBarIsVisible" Value="True"/>
        <Setter Property="BackgroundColor" Value="{StaticResource PompeMBG}"/>
    </Style>

    <Style x:Key="PompePageScrollView" TargetType="ScrollView">
        <Setter Property="Padding" Value="28"/>
    </Style>

    <Style x:Key="PompePageMainStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="24"/>
    </Style>

    <!-- HEADER SECTION -->
    <Style x:Key="PompePageHeaderStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="6"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="PompePageTitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource PompeNeuTextPrimary}"/>
    </Style>

    <Style x:Key="PompePageSubtitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource PompeNeuTextMuted}"/>
    </Style>

    <!-- STAT CARDS -->
    <Style x:Key="PompeStatCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuSurface}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PompeNeuShadowDark}" Offset="6,6" Radius="12" Opacity="0.25"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PompeStatNumber" TargetType="Label">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource PompeNeuPrimary}"/>
    </Style>

    <Style x:Key="PompeStatLabel" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="{StaticResource PompeNeuTextMuted}"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.3"/>
    </Style>

    <!-- SEARCH CONTAINER -->
    <Style x:Key="PompeSearchContainer" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuSurface}"/>
        <Setter Property="Padding" Value="16,14"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PompeNeuShadowDarkSoft}" Offset="2,2" Radius="6" Opacity="0.15"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PompeSearchEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuSurface}"/>
        <Setter Property="TextColor" Value="{StaticResource PompeNeuTextPrimary}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource PompeNeuTextLight}"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- LOADING INDICATOR -->
    <Style x:Key="PompePageLoadingIndicator" TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource PompeNeuPrimary}"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="HeightRequest" Value="50"/>
        <Setter Property="WidthRequest" Value="50"/>
    </Style>

    <!-- ADD BUTTON -->
    <Style x:Key="PompeAddButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuPrimary}"/>
        <Setter Property="TextColor" Value="#FFFFFF"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HeightRequest" Value="46"/>
        <Setter Property="Padding" Value="24,0"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PompeNeuPrimary}" Offset="0,4" Radius="10" Opacity="0.35"/></Setter.Value></Setter>
    </Style>

    <!-- TABLE CARD -->
    <Style x:Key="PompeTableCard" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuSurface}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PompeNeuShadowDark}" Offset="8,8" Radius="20" Opacity="0.28"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PompeTableContainer" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="0"/>
    </Style>

    <!-- TABLE HEADER -->
    <Style x:Key="PompeTableHeaderGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="{StaticResource PompeTableColumns}"/>
        <Setter Property="ColumnSpacing" Value="12"/>
        <Setter Property="Padding" Value="28,18"/>
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuPrimary}"/>
    </Style>

    <Style x:Key="PompeTableHeaderLabel" TargetType="Label">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource PompeNeuShadowLight}"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.8"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PompeTableDivider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="Color" Value="{StaticResource PompeNeuBorderLight}"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
    </Style>

    <Style x:Key="PompeTableCollectionView" TargetType="CollectionView">
        <Setter Property="SelectionMode" Value="None"/>
    </Style>

    <!-- TABLE ROW -->
    <Style x:Key="PompeTableRowGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="{StaticResource PompeTableColumns}"/>
        <Setter Property="ColumnSpacing" Value="12"/>
        <Setter Property="Padding" Value="28,18"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="MinimumHeightRequest" Value="76"/>
    </Style>

    <!-- CELL STYLES -->
    <Style x:Key="PompeIdCell" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuCardBg}"/>
        <Setter Property="HeightRequest" Value="32"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="16"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PompeNeuShadowDarkSoft}" Offset="1,1" Radius="3" Opacity="0.12"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PompeIdLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource PompeNeuPrimary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <!-- Numero Badge - Neumorphic -->
    <Style x:Key="PompeNumeroBadge" TargetType="Border">
        <Setter Property="BackgroundColor" Value="#E8F5ED"/>
        <Setter Property="HeightRequest" Value="32"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="16"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PompeNeuShadowDarkSoft}" Offset="1,1" Radius="3" Opacity="0.12"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PompeNumeroLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource PompeNeuSuccess}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <!-- Status Badge - Neumorphic -->
    <Style x:Key="PompeStatutBadge" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuSuccess}"/>
        <Setter Property="HeightRequest" Value="32"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="16"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PompeNeuShadowDarkSoft}" Offset="1,1" Radius="3" Opacity="0.12"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PompeStatutLabel" TargetType="Label">
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PompeReservoirLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource PompeNeuTextSecondary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
        <Setter Property="LineBreakMode" Value="TailTruncation"/>
        <Setter Property="MaxLines" Value="1"/>
    </Style>

    <Style x:Key="PompeMetersLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource PompeNeuTextSecondary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PompeActionsCell" TargetType="HorizontalStackLayout">
        <Setter Property="Spacing" Value="10"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
    </Style>

    <!-- ACTION BUTTONS -->
    <Style x:Key="PompeDetailsButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuSecondary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="MinimumWidthRequest" Value="70"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PompeNeuSecondary}" Offset="0,3" Radius="6" Opacity="0.25"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PompeModifierButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuPrimary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="MinimumWidthRequest" Value="75"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PompeNeuPrimary}" Offset="0,3" Radius="6" Opacity="0.3"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PompeSupprimerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuSurface}"/>
        <Setter Property="TextColor" Value="{StaticResource PompeNeuDanger}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="MinimumWidthRequest" Value="80"/>
        <Setter Property="BorderWidth" Value="1.5"/>
        <Setter Property="BorderColor" Value="{StaticResource PompeNeuDanger}"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PompeNeuShadowDark}" Offset="2,2" Radius="4" Opacity="0.12"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PompeRowDivider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="Color" Value="{StaticResource PompeNeuBorderLight}"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
        <Setter Property="Margin" Value="28,0"/>
        <Setter Property="Opacity" Value="0.7"/>
    </Style>

    <!-- EMPTY VIEW -->
    <Style x:Key="PompeEmptyView" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="16"/>
        <Setter Property="Padding" Value="60,80"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>

    <Style x:Key="PompeEmptyTitle" TargetType="Label">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="TextColor" Value="{StaticResource PompeNeuTextPrimary}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PompeEmptySubtitle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource PompeNeuTextMuted}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="MaximumWidthRequest" Value="320"/>
    </Style>

    <Style x:Key="PompeEmptyButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuPrimary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="28,14"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Margin" Value="0,12,0,0"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PompeNeuPrimary}" Offset="0,4" Radius="10" Opacity="0.35"/></Setter.Value></Setter>
    </Style>

    <!-- POPUP STYLES -->
    <Style x:Key="PompePopupContainer" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuSurface}"/>
        <Setter Property="Padding" Value="32"/>
        <Setter Property="WidthRequest" Value="650"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="24"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="#000000" Offset="0,12" Radius="40" Opacity="0.18"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PompePopupTitle" TargetType="Label">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource PompeNeuTextPrimary}"/>
    </Style>

    <Style x:Key="PompePopupCloseButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuCardBg}"/>
        <Setter Property="TextColor" Value="{StaticResource PompeNeuTextMuted}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="WidthRequest" Value="36"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="CornerRadius" Value="18"/>
    </Style>

    <Style x:Key="PompePopupSectionCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuCardBg}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="14"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PompeNeuShadowDarkSoft}" Offset="2,2" Radius="6" Opacity="0.12"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PompePopupSectionTitle" TargetType="Label">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource PompeNeuTextPrimary}"/>
    </Style>

    <Style x:Key="PompePopupFieldLabel" TargetType="Label">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource PompeNeuTextMuted}"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.5"/>
    </Style>

    <Style x:Key="PompeDetailsValueLabel" TargetType="Label">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="TextColor" Value="{StaticResource PompeNeuTextPrimary}"/>
        <Setter Property="Margin" Value="0,6,0,0"/>
    </Style>

    <Style x:Key="PompePopupInputContainer" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuSurface}"/>
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="Stroke" Value="{StaticResource PompeNeuBorderLight}"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="10"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PompePopupEntry" TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource PompeNeuTextPrimary}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource PompeNeuTextLight}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
    </Style>

    <Style x:Key="PompePopupPicker" TargetType="Picker">
        <Setter Property="TextColor" Value="{StaticResource PompeNeuTextPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="TitleColor" Value="{StaticResource PompeNeuTextMuted}"/>
    </Style>

    <Style x:Key="PompePopupErrorLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource PompeNeuDanger}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,12,0,0"/>
    </Style>

    <Style x:Key="PompePopupCancelButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuCardBg}"/>
        <Setter Property="TextColor" Value="{StaticResource PompeNeuTextSecondary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="HeightRequest" Value="48"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PompeNeuShadowDark}" Offset="3,3" Radius="6" Opacity="0.15"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PompePopupCreateButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuSuccess}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="HeightRequest" Value="48"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PompeNeuSuccess}" Offset="0,4" Radius="10" Opacity="0.35"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PompeDetailsCloseButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuPrimary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="40,12"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="HeightRequest" Value="48"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PompeNeuPrimary}" Offset="0,4" Radius="10" Opacity="0.35"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PompePopupDivider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="Color" Value="{StaticResource PompeNeuBorderLight}"/>
    </Style>

    <Style x:Key="PompeStatsCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource PompeNeuSurface}"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="12"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PompeNeuShadowDark}" Offset="4,4" Radius="8" Opacity="0.18"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PompeStatsNumber" TargetType="Label">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource PompeNeuPrimary}"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PompeStatsLabel" TargetType="Label">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="TextColor" Value="{StaticResource PompeNeuTextMuted}"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.3"/>
    </Style>

</ResourceDictionary>