    <x:String x:Key="VenteLubTableColumns">1.2*,1.8*,0.8*,1*,1*,1.2*,1*,1*,1*</x:String>

    <Style x:Key="VenteLubPageStyle" TargetType="ContentPage">
        <Setter Property="Title" Value="Ventes Lubrifiants"/>
        <Setter Property="Shell.NavBarIsVisible" Value="True"/>
        <Setter Property="BackgroundColor" Value="{StaticResource VenteLubMBG}"/>
    </Style>

    <Style x:Key="VenteLubPageScrollView" TargetType="ScrollView">
        <Setter Property="Padding" Value="28"/>
    </Style>

    <Style x:Key="VenteLubPageMainStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="24"/>
    </Style>

    <Style x:Key="VenteLubPageHeaderStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="6"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="VenteLubPageTitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource VenteLubNeuTextPrimary}"/>
    </Style>

    <Style x:Key="VenteLubPageSubtitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource VenteLubNeuTextMuted}"/>
    </Style>

    <Style x:Key="VenteLubStatCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource VenteLubNeuSurface}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
        <Setter Property="StrokeShape">
            <Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value>
        </Setter>
        <Setter Property="Shadow">
            <Setter.Value><Shadow Brush="{StaticResource VenteLubNeuShadowDark}" Offset="6,6" Radius="12" Opacity="0.25"/></Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="VenteLubStatNumber" TargetType="Label">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource VenteLubNeuPrimary}"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="VenteLubStatLabel" TargetType="Label">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="TextColor" Value="{StaticResource VenteLubNeuTextMuted}"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.3"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="VenteLubStatIcon" TargetType="Label">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style x:Key="VenteLubFilterContainer" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource VenteLubNeuSurface}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape">
            <Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value>
        </Setter>
        <Setter Property="Shadow">
            <Setter.Value><Shadow Brush="{StaticResource VenteLubNeuShadowDarkSoft}" Offset="2,2" Radius="6" Opacity="0.15"/></Setter.Value>
