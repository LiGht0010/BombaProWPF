        <Setter Property="Color" Value="{StaticResource VenteLubNeuPrimary}"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="HeightRequest" Value="50"/>
        <Setter Property="WidthRequest" Value="50"/>
    </Style>

    <Style x:Key="VenteLubAddButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource VenteLubNeuSuccess}"/>
        <Setter Property="TextColor" Value="#FFFFFF"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HeightRequest" Value="46"/>
        <Setter Property="Padding" Value="24,0"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Shadow">
            <Setter.Value><Shadow Brush="{StaticResource VenteLubNeuSuccess}" Offset="0,4" Radius="10" Opacity="0.35"/></Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="VenteLubTableCard" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="BackgroundColor" Value="{StaticResource VenteLubNeuSurface}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="StrokeShape">
            <Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value>
