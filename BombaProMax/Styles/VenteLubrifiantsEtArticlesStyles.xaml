        <Setter Property="Shadow">
            <Setter.Value><Shadow Brush="{StaticResource VenteLubNeuShadowDark}" Offset="8,8" Radius="20" Opacity="0.28"/></Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="VenteLubTableContainer" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="0"/>
