    <Style x:Key="VenteLubActionsCell" TargetType="HorizontalStackLayout">
        <Setter Property="Spacing" Value="6"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
    </Style>

    <Style x:Key="VenteLubEditButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource VenteLubNeuInfo}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="HeightRequest" Value="32"/>
        <Setter Property="MinimumWidthRequest" Value="40"/>
        <Setter Property="Shadow">
            <Setter.Value><Shadow Brush="{StaticResource VenteLubNeuInfo}" Offset="0,2" Radius="4" Opacity="0.25"/></Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="VenteLubDeleteButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource VenteLubNeuDanger}"/>
