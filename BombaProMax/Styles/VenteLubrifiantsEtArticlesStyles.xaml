    <Style x:Key="VenteLubFilterButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource VenteLubNeuInfo}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Shadow">
            <Setter.Value><Shadow Brush="{StaticResource VenteLubNeuInfo}" Offset="0,3" Radius="6" Opacity="0.3"/></Setter.Value>
        </Setter>
    </Style>

