    <Style x:Key="VenteLubFilterDatePicker" TargetType="DatePicker">
        <Setter Property="BackgroundColor" Value="{StaticResource VenteLubNeuCardBg}"/>
        <Setter Property="TextColor" Value="{StaticResource VenteLubNeuTextPrimary}"/>
