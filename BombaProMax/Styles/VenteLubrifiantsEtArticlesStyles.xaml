    <!-- COLOR PALETTE - Oil/Lubricant Theme (Orange/Amber) -->
    <Color x:Key="VenteLubNeuSurface">#e8e8e8</Color>
    <Color x:Key="VenteLubNeuCardBg">#E8ECF1</Color>
    <Color x:Key="VenteLubNeuShadowDark">#C5CAD1</Color>
    <Color x:Key="VenteLubNeuShadowLight">#FFFFFF</Color>
    <Color x:Key="VenteLubNeuShadowDarkSoft">#D1D5DB</Color>
    <Color x:Key="VenteLubNeuPrimary">#E65100</Color>
    <Color x:Key="VenteLubNeuDanger">#E16C6C</Color>
    <Color x:Key="VenteLubNeuSecondary">#8FA3B8</Color>
    <Color x:Key="VenteLubNeuSuccess">#2E7D32</Color>
    <Color x:Key="VenteLubNeuWarning">#F57C00</Color>
    <Color x:Key="VenteLubNeuInfo">#1976D2</Color>
    <Color x:Key="VenteLubNeuPurple">#7B1FA2</Color>
    <Color x:Key="VenteLubNeuTeal">#00796B</Color>
    <Color x:Key="VenteLubNeuTextPrimary">#2E2E2E</Color>
    <Color x:Key="VenteLubNeuTextSecondary">#5A6068</Color>
    <Color x:Key="VenteLubNeuTextMuted">#8B939E</Color>
    <Color x:Key="VenteLubNeuTextLight">#A8B0BA</Color>
    <Color x:Key="VenteLubNeuBorderLight">#E5E9EF</Color>
