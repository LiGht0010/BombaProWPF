<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BombaProMax.Styles.Dividers">

    <!-- Colors needed for dividers -->
    <Color x:Key="NeumorphicDivider">#CBD5E0</Color>

    <!-- Table Header Divider -->
    <Style x:Key="TableHeaderDivider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="2"/>
        <Setter Property="Color" Value="{StaticResource NeumorphicDivider}"/>
        <Setter Property="Margin" Value="0,0,0,15"/>
    </Style>

    <!-- Table Row Divider -->
    <Style x:Key="TableRowDivider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="Color" Value="{StaticResource NeumorphicDivider}"/>
        <Setter Property="Margin" Value="0,15,0,0"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
    </Style>

</ResourceDictionary>