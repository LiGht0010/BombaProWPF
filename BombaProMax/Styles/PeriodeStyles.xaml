<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    x:Class="BombaProMax.Styles.PeriodeStyles">

    <!-- COLOR PALETTE -->
    <Color x:Key="PeriodeNeuSurface">#e8e8e8</Color>
    <Color x:Key="PeriodeNeuCardBg">#E8ECF1</Color>
    <Color x:Key="PeriodeNeuShadowDark">#C5CAD1</Color>
    <Color x:Key="PeriodeNeuShadowLight">#FFFFFF</Color>
    <Color x:Key="PeriodeNeuShadowDarkSoft">#D1D5DB</Color>
    <Color x:Key="PeriodeNeuPrimary">#1976D2</Color>
    <Color x:Key="PeriodeNeuDanger">#E16C6C</Color>
    <Color x:Key="PeriodeNeuSecondary">#8FA3B8</Color>
    <Color x:Key="PeriodeNeuSuccess">#5EAA8D</Color>
    <Color x:Key="PeriodeNeuWarning">#E8A84C</Color>
    <Color x:Key="PeriodeNeuTextPrimary">#2E2E2E</Color>
    <Color x:Key="PeriodeNeuTextSecondary">#5A6068</Color>
    <Color x:Key="PeriodeNeuTextMuted">#8B939E</Color>
    <Color x:Key="PeriodeNeuTextLight">#A8B0BA</Color>
    <Color x:Key="PeriodeNeuBorderLight">#E5E9EF</Color>
    <Color x:Key="PeriodeMBG">#f5f5f5</Color>

    <x:String x:Key="PeriodeTableColumns">1.2*,1.2*,1.5*,1*,1*,2*</x:String>

    <!-- PAGE BASE STYLES -->
    <Style x:Key="PeriodePageStyle" TargetType="ContentPage">
        <Setter Property="Title" Value="Periodes"/>
        <Setter Property="Shell.NavBarIsVisible" Value="True"/>
        <Setter Property="BackgroundColor" Value="{StaticResource PeriodeMBG}"/>
    </Style>

    <Style x:Key="PeriodePageScrollView" TargetType="ScrollView">
        <Setter Property="Padding" Value="28"/>
    </Style>

    <Style x:Key="PeriodePageMainStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="24"/>
    </Style>

    <!-- HEADER SECTION -->
    <Style x:Key="PeriodePageHeaderStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="6"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="PeriodePageTitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuTextPrimary}"/>
    </Style>

    <Style x:Key="PeriodePageSubtitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuTextMuted}"/>
    </Style>

    <!-- STAT CARDS -->
    <Style x:Key="PeriodeStatCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource PeriodeNeuSurface}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PeriodeNeuShadowDark}" Offset="6,6" Radius="12" Opacity="0.25"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PeriodeStatNumber" TargetType="Label">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuPrimary}"/>
    </Style>

    <Style x:Key="PeriodeStatLabel" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuTextMuted}"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.3"/>
    </Style>

    <!-- FILTER CONTAINER -->
    <Style x:Key="PeriodeFilterContainer" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource PeriodeNeuSurface}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PeriodeNeuShadowDarkSoft}" Offset="2,2" Radius="6" Opacity="0.15"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PeriodeFilterLabel" TargetType="Label">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuTextMuted}"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="Margin" Value="4,0,0,6"/>
    </Style>

    <Style x:Key="PeriodeFilterInputBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource PeriodeNeuCardBg}"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="8"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PeriodeNeuShadowDarkSoft}" Offset="2,2" Radius="4" Opacity="0.12"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PeriodeFilterDatePicker" TargetType="DatePicker">
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuTextSecondary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
    </Style>

    <Style x:Key="PeriodeFilterPicker" TargetType="Picker">
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuTextSecondary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="TitleColor" Value="{StaticResource PeriodeNeuTextMuted}"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
    </Style>

    <Style x:Key="PeriodeFilterEntry" TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuTextPrimary}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource PeriodeNeuTextLight}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
    </Style>

    <Style x:Key="PeriodeFilterButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PeriodeNeuPrimary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PeriodeNeuPrimary}" Offset="0,3" Radius="6" Opacity="0.3"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PeriodeResetButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PeriodeNeuSecondary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PeriodeNeuSecondary}" Offset="0,3" Radius="6" Opacity="0.25"/></Setter.Value></Setter>
    </Style>

    <!-- LOADING INDICATOR -->
    <Style x:Key="PeriodePageLoadingIndicator" TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource PeriodeNeuPrimary}"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="HeightRequest" Value="50"/>
        <Setter Property="WidthRequest" Value="50"/>
    </Style>

    <!-- ADD BUTTON -->
    <Style x:Key="PeriodeAddButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PeriodeNeuPrimary}"/>
        <Setter Property="TextColor" Value="#FFFFFF"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HeightRequest" Value="46"/>
        <Setter Property="Padding" Value="24,0"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PeriodeNeuPrimary}" Offset="0,4" Radius="10" Opacity="0.35"/></Setter.Value></Setter>
    </Style>

    <!-- TABLE CARD -->
    <Style x:Key="PeriodeTableCard" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="BackgroundColor" Value="{StaticResource PeriodeNeuSurface}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PeriodeNeuShadowDark}" Offset="8,8" Radius="20" Opacity="0.28"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PeriodeTableContainer" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="0"/>
    </Style>

    <!-- TABLE HEADER -->
    <Style x:Key="PeriodeTableHeaderGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="{StaticResource PeriodeTableColumns}"/>
        <Setter Property="ColumnSpacing" Value="12"/>
        <Setter Property="Padding" Value="28,18"/>
        <Setter Property="BackgroundColor" Value="{StaticResource PeriodeNeuPrimary}"/>
    </Style>

    <Style x:Key="PeriodeTableHeaderLabel" TargetType="Label">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuShadowLight}"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.8"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PeriodeTableHeaderLabelLeft" TargetType="Label" BasedOn="{StaticResource PeriodeTableHeaderLabel}">
        <Setter Property="HorizontalTextAlignment" Value="Start"/>
    </Style>

    <!-- TABLE ROW -->
    <Style x:Key="PeriodeTableRowGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="{StaticResource PeriodeTableColumns}"/>
        <Setter Property="ColumnSpacing" Value="12"/>
        <Setter Property="Padding" Value="28,18"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="MinimumHeightRequest" Value="76"/>
    </Style>

    <!-- CELL STYLES -->
    <Style x:Key="PeriodeDateCell" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuTextPrimary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PeriodeTimeCell" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuTextSecondary}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PeriodeEmployeCell" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuTextPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Start"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
        <Setter Property="LineBreakMode" Value="TailTruncation"/>
        <Setter Property="MaxLines" Value="1"/>
    </Style>

    <Style x:Key="PeriodeTPECell" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuPrimary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PeriodeEspecesCell" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuSuccess}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PeriodeActionsCell" TargetType="HorizontalStackLayout">
        <Setter Property="Spacing" Value="10"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
    </Style>

    <!-- ACTION BUTTONS -->
    <Style x:Key="PeriodeDetailsButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PeriodeNeuSecondary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="MinimumWidthRequest" Value="80"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PeriodeNeuSecondary}" Offset="0,3" Radius="6" Opacity="0.25"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PeriodeModifierButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PeriodeNeuSuccess}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="MinimumWidthRequest" Value="80"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PeriodeNeuSuccess}" Offset="0,3" Radius="6" Opacity="0.3"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PeriodeSupprimerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PeriodeNeuSurface}"/>
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuDanger}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="MinimumWidthRequest" Value="90"/>
        <Setter Property="BorderWidth" Value="1.5"/>
        <Setter Property="BorderColor" Value="{StaticResource PeriodeNeuDanger}"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PeriodeNeuShadowDark}" Offset="2,2" Radius="4" Opacity="0.12"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PeriodeRowDivider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="Color" Value="{StaticResource PeriodeNeuBorderLight}"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
        <Setter Property="Margin" Value="28,0"/>
        <Setter Property="Opacity" Value="0.7"/>
    </Style>

    <!-- EMPTY VIEW -->
    <Style x:Key="PeriodeEmptyView" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="16"/>
        <Setter Property="Padding" Value="60,80"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>

    <Style x:Key="PeriodeEmptyTitle" TargetType="Label">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuTextPrimary}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PeriodeEmptySubtitle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuTextMuted}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="MaximumWidthRequest" Value="320"/>
    </Style>

    <Style x:Key="PeriodeEmptyButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PeriodeNeuPrimary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="28,14"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Margin" Value="0,12,0,0"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PeriodeNeuPrimary}" Offset="0,4" Radius="10" Opacity="0.35"/></Setter.Value></Setter>
    </Style>

    <!-- POPUP STYLES -->
    <Style x:Key="PeriodePopupBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource PeriodeNeuSurface}"/>
        <Setter Property="Padding" Value="32"/>
        <Setter Property="WidthRequest" Value="650"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="24"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="#000000" Offset="0,12" Radius="40" Opacity="0.18"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PeriodePopupTitle" TargetType="Label">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuTextPrimary}"/>
    </Style>

    <Style x:Key="PeriodePopupCloseButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PeriodeNeuCardBg}"/>
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuTextMuted}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="WidthRequest" Value="36"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="CornerRadius" Value="18"/>
    </Style>

    <Style x:Key="PeriodePopupDivider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="Color" Value="{StaticResource PeriodeNeuBorderLight}"/>
    </Style>

    <Style x:Key="PeriodePopupFieldLabel" TargetType="Label">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuTextMuted}"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.5"/>
    </Style>

    <Style x:Key="PeriodePopupEntry" TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuTextPrimary}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource PeriodeNeuTextLight}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
    </Style>

    <Style x:Key="PeriodePopupSectionBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="#E8F1F8"/>
        <Setter Property="Padding" Value="15"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="12"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PeriodePopupSectionTitle" TargetType="Label">
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuPrimary}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Margin" Value="0,0,0,5"/>
    </Style>

    <Style x:Key="PeriodePopupCancelButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PeriodeNeuCardBg}"/>
        <Setter Property="TextColor" Value="{StaticResource PeriodeNeuTextSecondary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="HeightRequest" Value="48"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PeriodeNeuShadowDark}" Offset="3,3" Radius="6" Opacity="0.15"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PeriodePopupCreateButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PeriodeNeuSuccess}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="HeightRequest" Value="48"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PeriodeNeuSuccess}" Offset="0,4" Radius="10" Opacity="0.35"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="PeriodePopupSaveButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PeriodeNeuPrimary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="HeightRequest" Value="48"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource PeriodeNeuPrimary}" Offset="0,4" Radius="10" Opacity="0.35"/></Setter.Value></Setter>
    </Style>

</ResourceDictionary>