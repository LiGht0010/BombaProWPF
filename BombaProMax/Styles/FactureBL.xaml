<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BombaProMax.Styles.FactureBL">

    <!-- ================================================================== -->
    <!-- LIGHT NEUMORPHIC DESIGN SYSTEM - FACTURE & BL MODULE               -->
    <!-- ================================================================== -->

    <!-- COLOR PALETTE -->
    <Color x:Key="FBLNeuSurface">#e8e8e8</Color>
    <Color x:Key="FBLNeuCardBg">#E8ECF1</Color>
    <Color x:Key="FBLNeuShadowDark">#C5CAD1</Color>
    <Color x:Key="FBLNeuShadowLight">#FFFFFF</Color>
    <Color x:Key="FBLNeuShadowDarkSoft">#D1D5DB</Color>
    <Color x:Key="FBLNeuPrimary">#4A8FBF</Color>
    <Color x:Key="FBLNeuDanger">#E16C6C</Color>
    <Color x:Key="FBLNeuSecondary">#8FA3B8</Color>
    <Color x:Key="FBLNeuSuccess">#5EAA8D</Color>
    <Color x:Key="FBLNeuWarning">#E8A84C</Color>
    <Color x:Key="FBLNeuTextPrimary">#2E2E2E</Color>
    <Color x:Key="FBLNeuTextSecondary">#5A6068</Color>
    <Color x:Key="FBLNeuTextMuted">#8B939E</Color>
    <Color x:Key="FBLNeuTextLight">#A8B0BA</Color>
    <Color x:Key="FBLNeuBorderLight">#E5E9EF</Color>
    <Color x:Key="FBLMBG">#f5f5f5</Color>

    <!-- Additional Colors for Facture/BL Management -->
    <Color x:Key="FBLFactureGreen">#4CAF50</Color>
    <Color x:Key="FBLFactureGreenBg">#E8F5E9</Color>
    <Color x:Key="FBLFactureGreenText">#2E7D32</Color>
    <Color x:Key="FBLFactureOrange">#FF9800</Color>
    <Color x:Key="FBLFactureOrangeBg">#FFF3E0</Color>
    <Color x:Key="FBLFactureOrangeText">#E65100</Color>
    <Color x:Key="FBLBLBlue">#2196F3</Color>
    <Color x:Key="FBLBLBlueBg">#E3F2FD</Color>
    <Color x:Key="FBLBLBlueText">#1565C0</Color>
    <Color x:Key="FBLBLPurple">#9C27B0</Color>
    <Color x:Key="FBLBLPurpleBg">#F3E5F5</Color>
    <Color x:Key="FBLBLPurpleText">#7B1FA2</Color>

    <!-- Column Definitions - Factures (6 columns: checkbox, date, numero, client, montant, actions) -->
    <x:String x:Key="FBLFactureColumns">0.5*,1*,1.4*,1.5*,1.2*,1.3*</x:String>
    <!-- Column Definitions - BL (7 columns: checkbox, date, numero, client, montant, statut, actions) -->
    <x:String x:Key="FBLBLColumns">0.5*,1*,1.4*,1.5*,1.2*,0.8*,1.3*</x:String>

    <!-- ================================================================== -->
    <!-- PAGE STYLES                                                        -->
    <!-- ================================================================== -->

    <Style x:Key="FBLPageStyle" TargetType="ContentPage">
        <Setter Property="Title" Value="Factures et Bons de Livraison"/>
        <Setter Property="Shell.NavBarIsVisible" Value="True"/>
        <Setter Property="BackgroundColor" Value="{StaticResource FBLMBG}"/>
    </Style>

    <Style x:Key="FBLPageScrollView" TargetType="ScrollView">
        <Setter Property="Padding" Value="28"/>
    </Style>

    <Style x:Key="FBLPageMainStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="24"/>
    </Style>

    <!-- ================================================================== -->
    <!-- HEADER STYLES                                                      -->
    <!-- ================================================================== -->

    <Style x:Key="FBLHeaderGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="*,Auto"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style x:Key="FBLHeaderStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="6"/>
    </Style>

    <Style x:Key="FBLTitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource FBLNeuTextPrimary}"/>
    </Style>

    <Style x:Key="FBLSubtitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource FBLNeuTextMuted}"/>
    </Style>

    <Style x:Key="FBLRefreshButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource FBLNeuPrimary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HeightRequest" Value="46"/>
        <Setter Property="Padding" Value="24,0"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource FBLNeuPrimary}" Offset="0,4" Radius="10" Opacity="0.35"/></Setter.Value></Setter>
    </Style>

    <!-- ================================================================== -->
    <!-- SEARCH AND FILTER SECTION                                          -->
    <!-- ================================================================== -->

    <Style x:Key="FBLSearchFilterCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource FBLNeuSurface}"/>
        <Setter Property="Padding" Value="16,14"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource FBLNeuShadowDark}" Offset="6,6" Radius="12" Opacity="0.25"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="FBLSearchFilterGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="Auto,*,Auto"/>
        <Setter Property="ColumnSpacing" Value="12"/>
    </Style>

    <Style x:Key="FBLSearchIconLabel" TargetType="Label">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>

    <Style x:Key="FBLSearchEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{StaticResource FBLNeuSurface}"/>
        <Setter Property="TextColor" Value="{StaticResource FBLNeuTextPrimary}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource FBLNeuTextLight}"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style x:Key="FBLClientSelectorStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="5"/>
    </Style>

    <Style x:Key="FBLClientSelectorLabel" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="{StaticResource FBLNeuTextSecondary}"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.3"/>
    </Style>

    <Style x:Key="FBLClientPicker" TargetType="Picker">
        <Setter Property="BackgroundColor" Value="{StaticResource FBLNeuSurface}"/>
        <Setter Property="TextColor" Value="{StaticResource FBLNeuTextPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- ================================================================== -->
    <!-- LOADING INDICATOR                                                  -->
    <!-- ================================================================== -->

    <Style x:Key="FBLLoadingIndicator" TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource FBLNeuPrimary}"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="HeightRequest" Value="50"/>
        <Setter Property="WidthRequest" Value="50"/>
    </Style>

    <!-- ================================================================== -->
    <!-- STATISTICS CARDS                                                   -->
    <!-- ================================================================== -->

    <Style x:Key="FBLStatsGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="*,*,*,*"/>
        <Setter Property="ColumnSpacing" Value="16"/>
    </Style>

    <Style x:Key="FBLStatCardBase" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource FBLNeuSurface}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource FBLNeuShadowDark}" Offset="6,6" Radius="12" Opacity="0.25"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="FBLStatStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="4"/>
    </Style>

    <Style x:Key="FBLStatValueBase" TargetType="Label">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>

    <Style x:Key="FBLStatValuePrimary" TargetType="Label" BasedOn="{StaticResource FBLStatValueBase}">
        <Setter Property="TextColor" Value="{StaticResource FBLNeuPrimary}"/>
    </Style>

    <Style x:Key="FBLStatValueGreen" TargetType="Label" BasedOn="{StaticResource FBLStatValueBase}">
        <Setter Property="TextColor" Value="{StaticResource FBLNeuSuccess}"/>
    </Style>

    <Style x:Key="FBLStatValueOrange" TargetType="Label" BasedOn="{StaticResource FBLStatValueBase}">
        <Setter Property="TextColor" Value="{StaticResource FBLNeuWarning}"/>
    </Style>

    <Style x:Key="FBLStatValueBlue" TargetType="Label" BasedOn="{StaticResource FBLStatValueBase}">
        <Setter Property="TextColor" Value="{StaticResource FBLBLBlue}"/>
    </Style>

    <Style x:Key="FBLStatLabel" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="{StaticResource FBLNeuTextMuted}"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.3"/>
    </Style>

    <!-- ================================================================== -->
    <!-- TABS CARD - NEUMORPHIC TABLE CARD                                  -->
    <!-- ================================================================== -->

    <Style x:Key="FBLTabsCard" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="BackgroundColor" Value="{StaticResource FBLNeuSurface}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="2"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource FBLNeuShadowDark}" Offset="8,8" Radius="20" Opacity="0.28"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="FBLTabsContainer" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="0"/>
    </Style>

    <Style x:Key="FBLTabsHeaderGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="*,*"/>
        <Setter Property="BackgroundColor" Value="{StaticResource FBLNeuPrimary}"/>
    </Style>

    <Style x:Key="FBLTabButtonActive" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource FBLNeuPrimary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.8"/>
        <Setter Property="Padding" Value="18"/>
    </Style>

    <Style x:Key="FBLTabButtonInactive" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource FBLNeuSecondary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.8"/>
        <Setter Property="Padding" Value="18"/>
        <Setter Property="Opacity" Value="0.8"/>
    </Style>

    <!-- ================================================================== -->
    <!-- TAB CONTENT                                                        -->
    <!-- ================================================================== -->

    <Style x:Key="FBLTabContent" TargetType="VerticalStackLayout">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Spacing" Value="0"/>
    </Style>

    <!-- Filter Buttons Row -->
    <Style x:Key="FBLFilterButtonsStack" TargetType="HorizontalStackLayout">
        <Setter Property="HorizontalOptions" Value="Start"/>
        <Setter Property="Padding" Value="28,18"/>
        <Setter Property="Spacing" Value="10"/>
    </Style>

    <Style x:Key="FBLFilterButtonActive" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource FBLNeuPrimary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource FBLNeuPrimary}" Offset="0,2" Radius="4" Opacity="0.3"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="FBLFilterButtonInactive" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource FBLNeuCardBg}"/>
        <Setter Property="TextColor" Value="{StaticResource FBLNeuTextSecondary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource FBLNeuShadowDarkSoft}" Offset="1,1" Radius="3" Opacity="0.12"/></Setter.Value></Setter>
    </Style>

    <!-- ================================================================== -->
    <!-- FACTURE TABLE STYLES                                               -->
    <!-- ================================================================== -->

    <Style x:Key="FBLFactureHeaderGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="{StaticResource FBLFactureColumns}"/>
        <Setter Property="ColumnSpacing" Value="12"/>
        <Setter Property="Padding" Value="28,18"/>
        <Setter Property="BackgroundColor" Value="{StaticResource FBLNeuCardBg}"/>
    </Style>

    <Style x:Key="FBLTableHeaderLabel" TargetType="Label">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource FBLNeuTextSecondary}"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="CharacterSpacing" Value="0.8"/>
        <Setter Property="HorizontalTextAlignment" Value="Start"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="FBLTableHeaderLabelCenter" TargetType="Label" BasedOn="{StaticResource FBLTableHeaderLabel}">
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="FBLTableHeaderLabelEnd" TargetType="Label" BasedOn="{StaticResource FBLTableHeaderLabel}">
        <Setter Property="HorizontalTextAlignment" Value="End"/>
    </Style>

    <Style x:Key="FBLCollectionView" TargetType="CollectionView">
        <Setter Property="SelectionMode" Value="None"/>
    </Style>

    <Style x:Key="FBLFactureRowGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="{StaticResource FBLFactureColumns}"/>
        <Setter Property="ColumnSpacing" Value="12"/>
        <Setter Property="Padding" Value="28,18"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="MinimumHeightRequest" Value="60"/>
    </Style>

    <Style x:Key="FBLTableCellText" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource FBLNeuTextPrimary}"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Start"/>
        <Setter Property="HorizontalTextAlignment" Value="Start"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style x:Key="FBLTableCellTextMuted" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource FBLNeuTextSecondary}"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Start"/>
        <Setter Property="HorizontalTextAlignment" Value="Start"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style x:Key="FBLTableCellTextCenter" TargetType="Label" BasedOn="{StaticResource FBLTableCellText}">
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
    </Style>

    <Style x:Key="FBLTableCellAmountGreen" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource FBLNeuSuccess}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="End"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style x:Key="FBLTableCellAmountBlue" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource FBLBLBlue}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="End"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- Number Pill Style -->
    <Style x:Key="FBLNumberCell" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource FBLNeuCardBg}"/>
        <Setter Property="HeightRequest" Value="32"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="HorizontalOptions" Value="Start"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="16"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource FBLNeuShadowDarkSoft}" Offset="1,1" Radius="3" Opacity="0.12"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="FBLNumberLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource FBLNeuPrimary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <!-- Status Badge -->
    <Style x:Key="FBLStatusBadge" TargetType="Border">
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="HeightRequest" Value="32"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="16"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource FBLNeuShadowDarkSoft}" Offset="1,1" Radius="3" Opacity="0.12"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="FBLStatusBadgeLabel" TargetType="Label">
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <!-- ================================================================== -->
    <!-- BON LIVRAISON TABLE STYLES                                         -->
    <!-- ================================================================== -->

    <Style x:Key="FBLBLHeaderGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="{StaticResource FBLBLColumns}"/>
        <Setter Property="ColumnSpacing" Value="12"/>
        <Setter Property="Padding" Value="28,18"/>
        <Setter Property="BackgroundColor" Value="{StaticResource FBLNeuCardBg}"/>
    </Style>

    <Style x:Key="FBLBLRowGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="{StaticResource FBLBLColumns}"/>
        <Setter Property="ColumnSpacing" Value="12"/>
        <Setter Property="Padding" Value="28,18"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="MinimumHeightRequest" Value="60"/>
    </Style>

    <!-- ================================================================== -->
    <!-- ACTION BUTTONS                                                     -->
    <!-- ================================================================== -->

    <Style x:Key="FBLRowActionsStack" TargetType="HorizontalStackLayout">
        <Setter Property="Spacing" Value="10"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
    </Style>

    <Style x:Key="FBLDetailsButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource FBLNeuSecondary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="MinimumWidthRequest" Value="70"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource FBLNeuSecondary}" Offset="0,3" Radius="6" Opacity="0.25"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="FBLPayButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource FBLNeuSuccess}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="MinimumWidthRequest" Value="60"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource FBLNeuSuccess}" Offset="0,3" Radius="6" Opacity="0.3"/></Setter.Value></Setter>
    </Style>

    <Style x:Key="FBLDeleteButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource FBLNeuSurface}"/>
        <Setter Property="TextColor" Value="{StaticResource FBLNeuDanger}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="MinimumWidthRequest" Value="50"/>
        <Setter Property="BorderWidth" Value="1.5"/>
        <Setter Property="BorderColor" Value="{StaticResource FBLNeuDanger}"/>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource FBLNeuShadowDark}" Offset="2,2" Radius="4" Opacity="0.12"/></Setter.Value></Setter>
    </Style>

    <!-- Row Divider -->
    <Style x:Key="FBLRowDivider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="Color" Value="{StaticResource FBLNeuBorderLight}"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
        <Setter Property="Margin" Value="28,0"/>
        <Setter Property="Opacity" Value="0.7"/>
    </Style>

    <!-- ================================================================== -->
    <!-- EMPTY VIEW                                                         -->
    <!-- ================================================================== -->

    <Style x:Key="FBLEmptyView" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="16"/>
        <Setter Property="Padding" Value="60,80"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>

    <Style x:Key="FBLEmptyTitle" TargetType="Label">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="TextColor" Value="{StaticResource FBLNeuTextPrimary}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="FBLEmptySubtitle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource FBLNeuTextMuted}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="MaximumWidthRequest" Value="320"/>
    </Style>

    <!-- ================================================================== -->
    <!-- ROW BORDER (for selectable rows)                                   -->
    <!-- ================================================================== -->

    <Style x:Key="FBLRowBorder" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="0"/></Setter.Value></Setter>
    </Style>

    <!-- ================================================================== -->
    <!-- SUMMARY BAR (for selection summary and merge buttons)              -->
    <!-- ================================================================== -->

    <Style x:Key="FBLSummaryBar" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource FBLNeuCardBg}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="Margin" Value="0,8,0,0"/>
        <Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="8"/></Setter.Value></Setter>
        <Setter Property="Shadow"><Setter.Value><Shadow Brush="{StaticResource FBLNeuShadowDark}" Offset="0,-2" Radius="8" Opacity="0.15"/></Setter.Value></Setter>
    </Style>

    <!-- Aliases for FBL to match existing converters -->
    <Color x:Key="FBLTextPrimary">#2E2E2E</Color>
    <Color x:Key="FBLTextMuted">#8B939E</Color>

</ResourceDictionary>