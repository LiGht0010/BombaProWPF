<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    x:Class="BombaProMax.Styles.RapportStyles">

    <!-- COLOR PALETTE -->
    <Color x:Key="RapportBg">#F5F5F5</Color>
    <Color x:Key="RapportCardBg">White</Color>
    <Color x:Key="RapportHeaderBlue">#1976D2</Color>
    <Color x:Key="RapportHeaderBlueLight">#B3E5FC</Color>
    <Color x:Key="RapportHeaderBlueDark">#1565C0</Color>
    <Color x:Key="RapportGreen">#2E7D32</Color>
    <Color x:Key="RapportOrange">#E65100</Color>
    <Color x:Key="RapportRed">#C62828</Color>
    <Color x:Key="RapportTextPrimary">#333333</Color>
    <Color x:Key="RapportTextSecondary">#666666</Color>
    <Color x:Key="RapportTextMuted">#999999</Color>
    <Color x:Key="RapportBorder">#E0E0E0</Color>

    <!-- PAGE STYLES -->
    <Style x:Key="RapportPageStyle" TargetType="ContentPage">
        <Setter Property="Title" Value="Rapports"/>
        <Setter Property="BackgroundColor" Value="{StaticResource RapportBg}"/>
    </Style>

    <Style x:Key="RapportPageScrollView" TargetType="ScrollView">
        <Setter Property="Padding" Value="25,20"/>
    </Style>

    <Style x:Key="RapportPageMainStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="20"/>
    </Style>

    <!-- HEADER STYLES -->
    <Style x:Key="RapportHeaderBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource RapportHeaderBlue}"/>
        <Setter Property="Padding" Value="25,18"/>
        <Setter Property="StrokeThickness" Value="0"/>
    </Style>

    <Style x:Key="RapportHeaderTitle" TargetType="Label">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="White"/>
    </Style>

    <Style x:Key="RapportHeaderSubtitle" TargetType="Label">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="TextColor" Value="{StaticResource RapportHeaderBlueLight}"/>
    </Style>

    <!-- FILTER SECTION -->
    <Style x:Key="RapportFilterCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource RapportCardBg}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="StrokeThickness" Value="0"/>
    </Style>

    <Style x:Key="RapportFilterLabel" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="{StaticResource RapportTextSecondary}"/>
    </Style>

    <Style x:Key="RapportFilterButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource RapportHeaderBlue}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style x:Key="RapportPrintButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource RapportGreen}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <!-- SECTION CARD -->
    <Style x:Key="RapportSectionCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource RapportCardBg}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="StrokeThickness" Value="0"/>
    </Style>

    <Style x:Key="RapportSectionTitle" TargetType="Label">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource RapportTextPrimary}"/>
    </Style>

    <!-- SUMMARY STYLES -->
    <Style x:Key="RapportSummaryLabel" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="{StaticResource RapportTextSecondary}"/>
    </Style>

    <Style x:Key="RapportSummaryValue" TargetType="Label">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource RapportTextPrimary}"/>
    </Style>

    <!-- TABLE STYLES -->
    <Style x:Key="RapportTableHeaderLabel" TargetType="Label">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource RapportTextSecondary}"/>
    </Style>

    <Style x:Key="RapportTableCellLabel" TargetType="Label">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="TextColor" Value="{StaticResource RapportTextPrimary}"/>
    </Style>

    <!-- LOADING -->
    <Style x:Key="RapportLoadingIndicator" TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource RapportHeaderBlue}"/>
        <Setter Property="HeightRequest" Value="50"/>
        <Setter Property="WidthRequest" Value="50"/>
    </Style>

    <Style x:Key="RapportEmptyLabel" TargetType="Label">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource RapportTextMuted}"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="Padding" Value="40"/>
    </Style>

</ResourceDictionary>
