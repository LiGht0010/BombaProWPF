    <Style x:Key="UserNameLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource UserNeuTextPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
