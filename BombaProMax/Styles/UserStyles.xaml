    <!-- COLOR PALETTE -->
    <Color x:Key="UserNeuSurface">#e8e8e8</Color>
    <Color x:Key="UserNeuCardBg">#E8ECF1</Color>
    <Color x:Key="UserNeuShadowDark">#C5CAD1</Color>
    <Color x:Key="UserNeuShadowLight">#FFFFFF</Color>
    <Color x:Key="UserNeuShadowDarkSoft">#D1D5DB</Color>
    <Color x:Key="UserNeuPrimary">#4A8FBF</Color>
    <Color x:Key="UserNeuDanger">#E16C6C</Color>
