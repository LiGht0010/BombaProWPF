        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="Color" Value="{StaticResource UserNeuBorderLight}"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
    </Style>

    <Style x:Key="UserTableCollectionView" TargetType="CollectionView">
        <Setter Property="SelectionMode" Value="None"/>
